---
import PropertyCard from './PropertyCard.astro';
import type { Property } from '../lib/tokko';

interface Props {
  properties: Property[];
  currentPage: number;
  totalPages: number;
}

const { properties, currentPage, totalPages } = Astro.props;

const url = Astro.url;
const view = url.searchParams.get('view') || 'grid';

// Generate clean query URL relative path
const canonicalUrl = Astro.url;
function getPageLink(pageNumber: number | string) {
  const newUrl = new URL(canonicalUrl);
  newUrl.searchParams.set('page', pageNumber.toString());
  return newUrl.pathname + newUrl.search;
}

// Generate truncated page list
function getVisiblePages(current: number, total: number) {
  const pages: (number | string)[] = [];
  if (total <= 5) {
    for (let i = 1; i <= total; i++) pages.push(i);
  } else {
    // Always show page 1
    pages.push(1);
    
    // Show left ellipsis if current page is far from beginning
    if (current > 3) {
      pages.push('...');
    }
    
    // Middle range pages
    const start = Math.max(2, current - 1);
    const end = Math.min(total - 1, current + 1);
    
    // If we are close to the start or end, adjust range to show 3 numbers in the middle
    let adjustedStart = start;
    let adjustedEnd = end;
    
    if (current <= 3) {
      adjustedEnd = 4;
    } else if (current >= total - 2) {
      adjustedStart = total - 3;
    }
    
    for (let i = Math.max(2, adjustedStart); i <= Math.min(total - 1, adjustedEnd); i++) {
      pages.push(i);
    }
    
    // Show right ellipsis if current page is far from end
    if (current < total - 2) {
      pages.push('...');
    }
    
    // Always show last page
    pages.push(total);
  }
  return pages;
}

const pageNumbers = getVisiblePages(currentPage, totalPages);
---

<div class:list={["space-y-12 w-full", view === 'list' && "list-view-active"]} id="property-grid-outer">
    {properties.length === 0 ? (
        <div class="text-center py-20 bg-pure-white border border-outline-variant/30 rounded-lg shadow-sm w-full flex flex-col items-center justify-center p-6">
            <span class="material-symbols-outlined text-[64px] text-secondary/40 mb-4">search_off</span>
            <h3 class="font-headline-md text-headline-md text-primary mb-2">Sin Resultados</h3>
            <p class="font-body-md text-secondary mb-6">No encontramos propiedades que coincidan con tus filtros.</p>
            <a 
              href="/search-results/" 
              class="bg-primary text-pure-white hover:bg-neutral-800 hover:text-pure-white px-6 py-3 rounded-full transition-all duration-300 font-sans text-xs font-bold uppercase tracking-wider shadow-md hover:scale-[1.02] active:scale-[0.98]"
            >
              Limpiar todos los filtros
            </a>
        </div>
    ) : (
        <div 
          id="property-grid-container" 
          class:list={[
            "grid w-full transition-all duration-350",
            view === 'list' ? "grid-cols-1 gap-6" : "grid-cols-1 md:grid-cols-2 gap-8"
          ]}
        >
            {properties.map((prop) => (
                <PropertyCard property={prop} />
            ))}
        </div>
    )}

    <!-- Server-Side Pagination Links with Page Numbers -->
    {totalPages > 1 && (
        <div class="flex justify-center items-center gap-4 pt-8 border-t border-outline-variant/10 w-full select-none">
            {currentPage > 1 ? (
                <a 
                  href={getPageLink(currentPage - 1)} 
                  class="flex items-center justify-center w-10 h-10 rounded-full border border-outline-variant/50 text-primary hover:bg-primary hover:text-pure-white transition-all active:scale-95 shadow-sm"
                  aria-label="Página anterior"
                >
                    <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                </a>
            ) : (
                <button 
                  disabled 
                  class="flex items-center justify-center w-10 h-10 rounded-full border border-outline-variant/30 text-secondary/40 cursor-not-allowed opacity-50 shadow-sm"
                  aria-label="Página anterior"
                >
                    <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                </button>
            )}

            <!-- Numbered Links -->
            <div class="flex items-center gap-2">
                {pageNumbers.map((num) => {
                    if (num === '...') {
                        return (
                            <span class="flex items-center justify-center w-10 h-10 text-secondary/60 font-sans text-xs font-semibold select-none">
                                ...
                            </span>
                        );
                    }
                    const isActive = num === currentPage;
                    return isActive ? (
                        <span class="flex items-center justify-center w-10 h-10 rounded-full bg-primary text-pure-white font-sans text-xs font-bold shadow-sm select-none">
                            {num}
                        </span>
                    ) : (
                        <a 
                          href={getPageLink(num)} 
                          class="flex items-center justify-center w-10 h-10 rounded-full border border-outline-variant/50 text-primary hover:bg-primary hover:text-pure-white font-sans text-xs font-semibold transition-all active:scale-95 shadow-sm"
                        >
                            {num}
                        </a>
                    );
                })}
            </div>

            {currentPage < totalPages ? (
                <a 
                  href={getPageLink(currentPage + 1)} 
                  class="flex items-center justify-center w-10 h-10 rounded-full border border-outline-variant/50 text-primary hover:bg-primary hover:text-pure-white transition-all active:scale-95 shadow-sm"
                  aria-label="Página siguiente"
                >
                    <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                </a>
            ) : (
                <button 
                  disabled 
                  class="flex items-center justify-center w-10 h-10 rounded-full border border-outline-variant/30 text-secondary/40 cursor-not-allowed opacity-50 shadow-sm"
                  aria-label="Página siguiente"
                >
                    <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                </button>
            )}
        </div>
    )}
</div>
