---
import PropertyCard from './PropertyCard.astro';
import type { Property } from '../lib/tokko';

interface Props {
  properties: Property[];
  currentPage: number;
  totalPages: number;
}

const { properties, currentPage, totalPages } = Astro.props;

const url = Astro.url;
const view = url.searchParams.get('view') || 'grid';

// Generate clean query URL relative path
const canonicalUrl = Astro.url;
function getPageLink(pageNumber: number) {
  const newUrl = new URL(canonicalUrl);
  newUrl.searchParams.set('page', pageNumber.toString());
  return newUrl.pathname + newUrl.search;
}
const pageNumbers = Array.from({ length: totalPages }, (_, i) => i + 1);
---

<div class:list={["space-y-12 w-full", view === 'list' && "list-view-active"]} id="property-grid-outer">
    {properties.length === 0 ? (
        <div class="text-center py-20 bg-pure-white border border-outline-variant/30 rounded-lg shadow-sm w-full flex flex-col items-center justify-center p-6">
            <span class="material-symbols-outlined text-[64px] text-secondary/40 mb-4">search_off</span>
            <h3 class="font-headline-md text-headline-md text-primary mb-2">Sin Resultados</h3>
            <p class="font-body-md text-secondary mb-6">No encontramos propiedades que coincidan con tus filtros.</p>
            <a 
              href="/search-results/" 
              class="bg-primary text-pure-white hover:bg-refined-gold hover:text-primary px-6 py-3 rounded-full transition-all duration-300 font-sans text-xs font-bold uppercase tracking-wider shadow-md hover:scale-[1.02] active:scale-[0.98]"
            >
              Limpiar todos los filtros
            </a>
        </div>
    ) : (
        <div 
          id="property-grid-container" 
          class:list={[
            "grid w-full transition-all duration-350",
            view === 'list' ? "grid-cols-1 gap-6" : "grid-cols-1 md:grid-cols-2 gap-8"
          ]}
        >
            {properties.map((prop) => (
                <PropertyCard property={prop} />
            ))}
        </div>
    )}

    <!-- Server-Side Pagination Links with Page Numbers -->
    {totalPages > 1 && (
        <div class="flex justify-center items-center gap-4 pt-8 border-t border-outline-variant/10 w-full select-none">
            {currentPage > 1 ? (
                <a 
                  href={getPageLink(currentPage - 1)} 
                  class="flex items-center justify-center w-10 h-10 rounded-full border border-outline-variant/50 text-primary hover:bg-[#C5A880] hover:text-pure-white transition-all active:scale-95 shadow-sm"
                  aria-label="Página anterior"
                >
                    <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                </a>
            ) : (
                <button 
                  disabled 
                  class="flex items-center justify-center w-10 h-10 rounded-full border border-outline-variant/30 text-secondary/40 cursor-not-allowed opacity-50 shadow-sm"
                  aria-label="Página anterior"
                >
                    <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                </button>
            )}

            <!-- Numbered Links -->
            <div class="flex items-center gap-2">
                {pageNumbers.map((num) => {
                    const isActive = num === currentPage;
                    return isActive ? (
                        <span class="flex items-center justify-center w-10 h-10 rounded-full bg-primary text-pure-white font-sans text-xs font-bold shadow-sm select-none">
                            {num}
                        </span>
                    ) : (
                        <a 
                          href={getPageLink(num)} 
                          class="flex items-center justify-center w-10 h-10 rounded-full border border-outline-variant/50 text-primary hover:bg-[#C5A880] hover:text-pure-white font-sans text-xs font-semibold transition-all active:scale-95 shadow-sm"
                        >
                            {num}
                        </a>
                    );
                })}
            </div>

            {currentPage < totalPages ? (
                <a 
                  href={getPageLink(currentPage + 1)} 
                  class="flex items-center justify-center w-10 h-10 rounded-full border border-outline-variant/50 text-primary hover:bg-[#C5A880] hover:text-pure-white transition-all active:scale-95 shadow-sm"
                  aria-label="Página siguiente"
                >
                    <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                </a>
            ) : (
                <button 
                  disabled 
                  class="flex items-center justify-center w-10 h-10 rounded-full border border-outline-variant/30 text-secondary/40 cursor-not-allowed opacity-50 shadow-sm"
                  aria-label="Página siguiente"
                >
                    <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                </button>
            )}
        </div>
    )}
</div>
