---
interface Props {
  isDarkHero?: boolean;
}

const { isDarkHero = false } = Astro.props;
---

<nav 
  id="topNav" 
  class:list={[
    "fixed top-0 w-full z-50 transition-all duration-300",
    isDarkHero 
      ? "bg-transparent py-6 text-pure-white" 
      : "bg-surface/90 backdrop-blur-nav py-4 text-primary shadow-md"
  ]}
>
    <div class="flex justify-between items-center px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
        <a href="/" class="flex items-center gap-4">
            <img 
              id="logo-img" 
              alt="MUV Propiedades Icon" 
              class:list={[
                "h-8 w-auto object-contain transition-all duration-300",
                isDarkHero ? "brightness-0 invert" : "brightness-0"
              ]}
              src="/assets/iso_muv.png"
              width="32"
              height="32"
            />
        </a>
        <div class="hidden md:flex items-center space-x-3 lg:space-x-5 xl:space-x-7">
            <a class="font-sans text-[15px] font-[500] normal-case hover:opacity-75 transition-opacity nav-underline-anim" href="/search-results/?operation_id=1">Venta</a>
            <a class="font-sans text-[15px] font-[500] normal-case hover:opacity-75 transition-opacity nav-underline-anim" href="/search-results/?operation_id=2">Alquiler</a>
            <a class="font-sans text-[15px] font-[500] normal-case hover:opacity-75 transition-opacity nav-underline-anim" href="/emprendimientos/">Emprendimientos</a>
            <a class="font-sans text-[15px] font-[500] normal-case hover:opacity-75 transition-opacity nav-underline-anim" href="/tasaciones/">Tasaciones</a>
            <a class="font-sans text-[15px] font-[500] normal-case hover:opacity-75 transition-opacity nav-underline-anim" href="/quienes-somos/">Quienes Somos</a>
            <a class="font-sans text-[15px] font-[500] normal-case hover:opacity-75 transition-opacity nav-underline-anim" href="/contacto/">Contacto</a>
            <a 
              href="tel:1122862000" 
              class="flex items-center gap-1.5 font-sans text-[15px] font-[500] normal-case hover:opacity-75 transition-opacity ml-2"
            >
                <span class="material-symbols-outlined text-[20px]">phone_in_talk</span>
                <span>1122862000</span>
            </a>
        </div>
        <div class="md:hidden">
            <button 
              type="button"
              id="menu-toggle"
              aria-label="Abrir menú de navegación"
              class:list={[
                "material-symbols-outlined cursor-pointer border-0 bg-transparent outline-none flex items-center justify-center",
                isDarkHero ? "text-pure-white" : "text-primary"
              ]}
            >
              menu
            </button>
        </div>
    </div>
</nav>

<!-- Mobile Navigation Drawer -->
<div id="mobile-menu" class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm transition-opacity duration-300 opacity-0 pointer-events-none flex justify-end">
    <div class="w-72 sm:w-80 h-full bg-pure-white p-8 flex flex-col justify-between shadow-2xl transition-transform duration-300 transform translate-x-full relative">
        <div>
            <!-- Header Section inside Drawer -->
            <div class="flex justify-between items-center pb-6 border-b border-outline-variant/20 mb-8">
                <img 
                  src="/assets/iso_muv.png" 
                  alt="MUV Isotype" 
                  class="h-8 w-auto object-contain brightness-0"
                  width="32"
                  height="32"
                />
                <button 
                  type="button"
                  id="menu-close" 
                  class="w-10 h-10 rounded-full flex items-center justify-center hover:bg-surface-container active:scale-95 transition-all text-primary cursor-pointer border-0 bg-transparent outline-none"
                  aria-label="Cerrar menú de navegación"
                >
                    <span class="material-symbols-outlined text-[24px]">close</span>
                </button>
            </div>
            
            <!-- Navigation Links -->
            <nav class="space-y-1 flex flex-col">
                <a 
                  class="group flex justify-between items-center py-3 px-4 rounded-xl text-secondary hover:text-primary hover:bg-surface transition-all duration-300 font-sans text-sm font-medium" 
                  href="/search-results/?operation_id=1"
                >
                    <span>Venta</span>
                    <span class="material-symbols-outlined text-[18px] text-outline/40 group-hover:text-primary group-hover:translate-x-0.5 transition-all duration-300">chevron_right</span>
                </a>
                <a 
                  class="group flex justify-between items-center py-3 px-4 rounded-xl text-secondary hover:text-primary hover:bg-surface transition-all duration-300 font-sans text-sm font-medium" 
                  href="/search-results/?operation_id=2"
                >
                    <span>Alquiler</span>
                    <span class="material-symbols-outlined text-[18px] text-outline/40 group-hover:text-primary group-hover:translate-x-0.5 transition-all duration-300">chevron_right</span>
                </a>
                <a 
                  class="group flex justify-between items-center py-3 px-4 rounded-xl text-secondary hover:text-primary hover:bg-surface transition-all duration-300 font-sans text-sm font-medium" 
                  href="/emprendimientos/"
                >
                    <span>Emprendimientos</span>
                    <span class="material-symbols-outlined text-[18px] text-outline/40 group-hover:text-primary group-hover:translate-x-0.5 transition-all duration-300">chevron_right</span>
                </a>
                <a 
                  class="group flex justify-between items-center py-3 px-4 rounded-xl text-secondary hover:text-primary hover:bg-surface transition-all duration-300 font-sans text-sm font-medium" 
                  href="/tasaciones/"
                >
                    <span>Tasaciones</span>
                    <span class="material-symbols-outlined text-[18px] text-outline/40 group-hover:text-primary group-hover:translate-x-0.5 transition-all duration-300">chevron_right</span>
                </a>
                <a 
                  class="group flex justify-between items-center py-3 px-4 rounded-xl text-secondary hover:text-primary hover:bg-surface transition-all duration-300 font-sans text-sm font-medium" 
                  href="/quienes-somos/"
                >
                    <span>Quiénes Somos</span>
                    <span class="material-symbols-outlined text-[18px] text-outline/40 group-hover:text-primary group-hover:translate-x-0.5 transition-all duration-300">chevron_right</span>
                </a>
                <a 
                  class="group flex justify-between items-center py-3 px-4 rounded-xl text-secondary hover:text-primary hover:bg-surface transition-all duration-300 font-sans text-sm font-medium" 
                  href="/contacto/"
                >
                    <span>Contacto</span>
                    <span class="material-symbols-outlined text-[18px] text-outline/40 group-hover:text-primary group-hover:translate-x-0.5 transition-all duration-300">chevron_right</span>
                </a>
            </nav>
        </div>
        
        <!-- Footer of the Drawer -->
        <div class="space-y-6 pt-6 border-t border-outline-variant/10">
            <a 
              href="tel:1122862000" 
              class="bg-primary text-pure-white px-6 py-3.5 rounded-full text-center font-sans font-bold text-xs uppercase tracking-wider flex items-center justify-center gap-2 hover:bg-black/90 hover:scale-[1.02] active:scale-[0.98] transition-all shadow-md cursor-pointer border-0 outline-none"
            >
                <span class="material-symbols-outlined text-[18px]">phone_in_talk</span>
                <span>1122862000</span>
            </a>
            
            <div class="flex flex-col items-center gap-3">
                <a href="mailto:info@muvpropiedades.com" class="text-xs text-secondary hover:text-primary transition-colors font-sans font-medium">info@muvpropiedades.com</a>
                <div class="flex gap-4 items-center">
                    <a href="https://www.facebook.com/muvprop" target="_blank" rel="noopener noreferrer" class="text-secondary hover:text-primary transition-colors" aria-label="Seguinos en Facebook (abre en nueva pestaña)">
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
                            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                        </svg>
                    </a>
                    <a href="https://www.instagram.com/muvprop" target="_blank" rel="noopener noreferrer" class="text-secondary hover:text-primary transition-colors" aria-label="Seguinos en Instagram (abre en nueva pestaña)">
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
                            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script is:inline define:vars={{ isDarkHero }}>
  // Scroll navbar animations
  if (isDarkHero) {
    const logoImg = document.getElementById('logo-img');
    if (logoImg) {
      if (window.scrollY > 50) {
        logoImg.classList.add('brightness-0');
        logoImg.classList.remove('invert');
      } else {
        logoImg.classList.add('brightness-0', 'invert');
      }
    }

    window.addEventListener('scroll', () => {
        const topNav = document.getElementById('topNav');
        const logoImg = document.getElementById('logo-img');
        const menuToggle = document.getElementById('menu-toggle');
        if (!topNav || !logoImg) return;
        
        if (window.scrollY > 50) {
            topNav.classList.add('bg-surface/90', 'backdrop-blur-nav', 'py-4', 'text-primary', 'shadow-md');
            topNav.classList.remove('bg-transparent', 'py-6', 'text-pure-white');
            logoImg.classList.add('brightness-0');
            logoImg.classList.remove('invert');
            if (menuToggle) {
              menuToggle.classList.remove('text-pure-white');
              menuToggle.classList.add('text-primary');
            }
        } else {
            topNav.classList.add('bg-transparent', 'py-6', 'text-pure-white');
            topNav.classList.remove('bg-surface/90', 'backdrop-blur-nav', 'py-4', 'text-primary', 'shadow-md');
            logoImg.classList.add('brightness-0', 'invert');
            if (menuToggle) {
              menuToggle.classList.remove('text-primary');
              menuToggle.classList.add('text-pure-white');
            }
        }
    });
  }

  // Mobile menu interactions
  const menuToggle = document.getElementById('menu-toggle');
  const menuClose = document.getElementById('menu-close');
  const mobileMenu = document.getElementById('mobile-menu');

  if (menuToggle && mobileMenu) {
    const drawerPanel = mobileMenu.querySelector('.transform');
    menuToggle.addEventListener('click', () => {
      mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
      mobileMenu.classList.add('opacity-100', 'pointer-events-auto');
      if (drawerPanel) {
        drawerPanel.classList.remove('translate-x-full');
        drawerPanel.classList.add('translate-x-0');
      }
    });
  }

  if (menuClose && mobileMenu) {
    const drawerPanel = mobileMenu.querySelector('.transform');
    const closeMenu = () => {
      if (drawerPanel) {
        drawerPanel.classList.remove('translate-x-0');
        drawerPanel.classList.add('translate-x-full');
      }
      setTimeout(() => {
        mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');
        mobileMenu.classList.add('opacity-0', 'pointer-events-none');
      }, 300); // match duration of transition
    };

    menuClose.addEventListener('click', closeMenu);
    mobileMenu.addEventListener('click', (e) => {
      if (e.target === mobileMenu) {
        closeMenu();
      }
    });
  }
</script>
