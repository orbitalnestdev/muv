---
import CountryPhoneSelector from './CountryPhoneSelector.astro';

interface Props {
  propertyId?: number;
  propertyTitle?: string;
  isDevelopment?: boolean;
}

const { propertyId, propertyTitle, isDevelopment = false } = Astro.props;

// Construct WhatsApp url
const waPhone = isDevelopment ? "5491155796447" : "5491122862000";
const waText = propertyTitle 
  ? `Hola! Estoy interesado en la propiedad: ${propertyTitle}${propertyId ? ` (ID: ${propertyId})` : ''}. Me gustaría coordinar una visita.` 
  : "Hola! Quisiera realizar una consulta sobre una propiedad.";
const waUrl = `https://wa.me/${waPhone}?text=${encodeURIComponent(waText)}`;
---

<div class="bg-pure-white p-6 border border-outline-variant/30 rounded-lg shadow-sm w-full sticky top-28 font-sans select-none">
    <!-- Agent Profile Header -->
    <div class="flex items-center gap-4 mb-6 text-left">
        <div class="w-14 h-14 bg-black rounded-lg flex items-center justify-center shadow-sm border border-outline-variant/20 overflow-hidden p-2.5">
            <img 
              src="/assets/iso_muv.png" 
              alt="MUV" 
              class="w-full h-full object-contain brightness-0 invert"
            />
        </div>
        <div class="space-y-1">
            <h4 class="font-headline text-[15px] font-bold text-primary leading-tight">MUV Propiedades</h4>
            <p class="text-[11px] text-secondary font-medium">Agencia inmobiliaria en Buenos Aires</p>
            <!-- 5 Gold Stars Rating -->
            <div class="flex gap-0.5 text-primary">
                <span class="material-symbols-outlined text-[14px] fill-[1]" style="font-variation-settings: 'FILL' 1">star</span>
                <span class="material-symbols-outlined text-[14px] fill-[1]" style="font-variation-settings: 'FILL' 1">star</span>
                <span class="material-symbols-outlined text-[14px] fill-[1]" style="font-variation-settings: 'FILL' 1">star</span>
                <span class="material-symbols-outlined text-[14px] fill-[1]" style="font-variation-settings: 'FILL' 1">star</span>
                <span class="material-symbols-outlined text-[14px] fill-[1]" style="font-variation-settings: 'FILL' 1">star</span>
            </div>
        </div>
    </div>

    <!-- Inquiry Form -->
    <form id="lead-form" class="space-y-5 text-left" data-property-id={propertyId}>
        <!-- Status Notification Box -->
        <div id="form-status" class="hidden p-4 rounded text-xs font-semibold select-none"></div>

        <!-- Name Input -->
        <div class="space-y-1">
            <label for="lead-name" class="text-secondary font-bold text-[9px] uppercase tracking-widest block">Nombre Completo</label>
            <input 
              type="text" 
              id="lead-name" 
              required 
              placeholder="Ingresa tu nombre"
              class="w-full bg-transparent border-0 border-b border-[#E5E2E1] focus:border-primary focus:ring-0 px-0 py-2 text-[13.5px] text-primary placeholder:text-outline/40 focus:outline-none"
            />
        </div>

        <!-- Email Input -->
        <div class="space-y-1">
            <label for="lead-email" class="text-secondary font-bold text-[9px] uppercase tracking-widest block">Email</label>
            <input 
              type="email" 
              id="lead-email" 
              required 
              placeholder="tu@email.com"
              class="w-full bg-transparent border-0 border-b border-[#E5E2E1] focus:border-primary focus:ring-0 px-0 py-2 text-[13.5px] text-primary placeholder:text-outline/40 focus:outline-none"
            />
        </div>

        <!-- Phone Input (required by Tokko CRM backend api) -->
        <div class="space-y-1">
            <label for="lead-phone" class="text-secondary font-bold text-[9px] uppercase tracking-widest block">Teléfono / WhatsApp</label>
            <CountryPhoneSelector 
              phoneId="lead-phone" 
              countryId="country-code" 
              placeholder="Teléfono" 
              required={true}
              containerClass="border-b border-[#E5E2E1] focus-within:border-primary transition-all duration-300"
              inputClass="pl-2.5 pb-2 pt-1 text-[13.5px]"
            />
        </div>

        <!-- Message/Comment -->
        <div class="space-y-1">
            <label for="lead-message" class="text-secondary font-bold text-[9px] uppercase tracking-widest block">Mensaje</label>
            <textarea 
              id="lead-message" 
              rows="3" 
              placeholder="Estoy interesado en esta propiedad..."
              class="w-full bg-transparent border-0 border-b border-[#E5E2E1] focus:border-primary focus:ring-0 px-0 py-2 text-[13.5px] text-primary placeholder:text-outline/40 focus:outline-none resize-none"
            >Estoy interesado en esta propiedad...</textarea>
        </div>

        <!-- Sticky Form Buttons Stack -->
        <div class="space-y-3 pt-3">
            <!-- Submit (Consultar por esta Propiedad) -->
            <button 
              type="submit" 
              id="btn-submit-lead"
              class="w-full bg-primary text-pure-white py-4 rounded-xl font-sans text-sm font-semibold uppercase tracking-wider hover:bg-black/90 hover:shadow-lg transition-all duration-300 active:scale-[0.98] flex items-center justify-center gap-2 shadow-md cursor-pointer"
            >
                <span class="material-symbols-outlined text-[18px]">mail</span>
                <span>Consultar por esta Propiedad</span>
            </button>

            <!-- WhatsApp Link -->
            <a 
              href={waUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="w-full bg-[#25D366] text-pure-white py-4 rounded-xl font-sans text-sm font-semibold uppercase tracking-wider hover:bg-[#22c35e] hover:shadow-lg transition-all duration-300 active:scale-[0.98] flex items-center justify-center gap-2.5 text-center shadow-[0_4px_12px_rgba(37,211,102,0.2)] border-0 cursor-pointer"
            >
              <!-- Official WhatsApp Icon -->
              <svg class="w-4 h-4 text-pure-white fill-current" viewBox="0 0 24 24">
                <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.458L0 24zm6.224-3.826l.446.265c1.504.893 3.179 1.363 4.901 1.364h.005c5.485 0 9.948-4.463 9.952-9.953.002-2.66-.1032-5.158-2.92-6.977a9.181 9.181 0 00-6.98-2.92c-5.491 0-9.954 4.465-9.959 9.956-.002 1.777.464 3.51 1.349 5.042l.295.513-.996 3.636 3.72-.975zm11.187-5.328c-.287-.144-1.702-.84-1.965-.936-.264-.096-.456-.144-.648.144-.192.288-.744.936-.912 1.128-.168.192-.336.216-.624.072-1.359-.68-2.335-1.113-3.238-2.667-.238-.41.238-.38.68-.763.108-.093.216-.216.324-.324.108-.108.144-.18.216-.324.072-.144.036-.264-.018-.372-.054-.108-.456-1.104-.624-1.512-.164-.396-.344-.344-.472-.352l-.4-.008c-.264 0-.696.096-.984.408-.288.312-1.104 1.08-1.104 2.64 0 1.56 1.128 3.072 1.284 3.288.156.216 2.22 3.392 5.378 4.756.752.325 1.339.519 1.796.665.756.24 1.444.207 1.988.126.607-.09 1.702-.696 1.944-1.368.24-.672.24-1.248.168-1.368-.072-.12-.264-.216-.552-.36z" />
              </svg>
              <span>Contactar por WhatsApp</span>
            </a>


        </div>
    </form>

    <!-- Guardar / Compartir / Imprimir actions -->
    <div class="border-t border-outline-variant/10 mt-6 pt-5 flex flex-wrap justify-center sm:justify-between items-center gap-3 text-slate-blue/80 text-[11px] font-semibold tracking-wider font-sans select-none">
        <!-- Guardar -->
        <button 
          id="btn-lead-save" 
          class="flex items-center gap-1.5 hover:text-primary transition-colors cursor-pointer focus:outline-none"
        >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
            </svg>
            <span>Guardar</span>
        </button>

        <!-- Compartir -->
        <button 
          id="btn-lead-share" 
          class="flex items-center gap-1.5 hover:text-primary transition-colors cursor-pointer focus:outline-none"
        >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="18" cy="5" r="3" />
              <circle cx="6" cy="12" r="3" />
              <circle cx="18" cy="19" r="3" />
              <path d="M8.59 13.51l6.83 3.98M15.41 6.51l-6.82 3.98" />
            </svg>
            <span>Compartir</span>
        </button>

        <!-- Imprimir -->
        <button 
          id="btn-lead-print" 
          class="flex items-center gap-1.5 hover:text-primary transition-colors cursor-pointer focus:outline-none"
          onclick="window.print()"
        >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
              <path d="M6 14h12v8H6z" />
            </svg>
            <span>Imprimir</span>
        </button>
    </div>
</div>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement;
  const statusBox = document.getElementById('form-status');
  const submitBtn = document.getElementById('btn-submit-lead') as HTMLButtonElement;

  if (form && statusBox && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Clear previous states
      statusBox.className = 'hidden p-4 rounded text-xs font-semibold select-none';
      statusBox.innerHTML = '';
      
      const name = (document.getElementById('lead-name') as HTMLInputElement).value;
      const email = (document.getElementById('lead-email') as HTMLInputElement).value;
      const countryCode = (form.querySelector('#country-code') as HTMLSelectElement).value;
      const phoneVal = (document.getElementById('lead-phone') as HTMLInputElement).value;
      const text = (document.getElementById('lead-message') as HTMLTextAreaElement).value;
      const propertyId = form.dataset.propertyId ? Number(form.dataset.propertyId) : undefined;

      // 1. Audit and validate phone number
      let digits = phoneVal.replace(/\D/g, '');
      
      // Strip country code if manually input
      if (digits.startsWith(countryCode)) {
        digits = digits.substring(countryCode.length);
      }
      // Strip leading 0
      if (digits.startsWith('0')) {
        digits = digits.substring(1);
      }

      if (countryCode === '54') {
        // Mobile '15' prefix handling (e.g. 11 15... or 341 15...)
        if (digits.substring(2, 4) === '15') {
          digits = digits.substring(0, 2) + digits.substring(4);
        } else if (digits.substring(3, 5) === '15') {
          digits = digits.substring(0, 3) + digits.substring(5);
        } else if (digits.substring(4, 6) === '15') {
          digits = digits.substring(0, 4) + digits.substring(6);
        }

        // Error if they only typed 15 followed by a number without area code
        if (digits.startsWith('15')) {
          statusBox.classList.remove('hidden');
          statusBox.classList.add('bg-red-100', 'text-red-800');
          statusBox.innerHTML = '<span class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">error</span>Por favor, incluya el código de área (ej: 11 para Buenos Aires) en lugar del prefijo 15.</span>';
          return;
        }

        // Argentine numbers must be exactly 10 digits (or 11 if starting with mobile prefix '9')
        if (digits.length !== 10 && !(digits.length === 11 && digits.startsWith('9'))) {
          statusBox.classList.remove('hidden');
          statusBox.classList.add('bg-red-100', 'text-red-800');
          statusBox.innerHTML = '<span class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">error</span>El teléfono debe incluir código de área y tener 10 dígitos (ej: 11 2345 6789).</span>';
          return;
        }
      } else {
        // General international number format validation (6 to 14 digits)
        if (digits.length < 6 || digits.length > 14) {
          statusBox.classList.remove('hidden');
          statusBox.classList.add('bg-red-100', 'text-red-800');
          statusBox.innerHTML = '<span class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">error</span>Por favor ingrese un número de teléfono válido.</span>';
          return;
        }
      }

      const phone = `+${countryCode} ${digits}`;

      // Toggle pending state
      const originalBtnText = submitBtn.innerHTML;
      submitBtn.innerHTML = 'Enviando...';
      submitBtn.disabled = true;
      submitBtn.classList.add('opacity-70', 'cursor-not-allowed');

      try {
        const response = await fetch('/api/lead', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ name, email, phone, text, propertyId })
        });

        const result = await response.json();

        if (!response.ok) {
          throw new Error(result.error || 'Hubo un error al procesar el contacto.');
        }

        // Show Success
        statusBox.classList.remove('hidden');
        statusBox.classList.add('bg-green-100', 'text-green-800');
        statusBox.innerHTML = '<span class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">check_circle</span>Consulta enviada con éxito.</span>';
        form.reset();
      } catch (err: any) {
        // Show Error
        statusBox.classList.remove('hidden');
        statusBox.classList.add('bg-red-100', 'text-red-800');
        statusBox.innerHTML = `<span class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">error</span>${err.message || 'Error de conexión.'}</span>`;
      } finally {
        // Restore button state
        submitBtn.innerHTML = originalBtnText;
        submitBtn.disabled = false;
        submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
      }
    });
  }

  // Favorite button local storage state
  const saveBtn = document.getElementById('btn-lead-save');
  const propertyId = form?.dataset.propertyId;
  if (saveBtn && propertyId) {
    const favKey = `muv_fav_${propertyId}`;
    let isSaved = localStorage.getItem(favKey) === 'true';
    const heartSvg = saveBtn.querySelector('svg');
    const updateSaveIcon = () => {
      if (heartSvg) {
        heartSvg.setAttribute('fill', isSaved ? '#ba1a1a' : 'none');
        heartSvg.setAttribute('stroke', isSaved ? '#ba1a1a' : 'currentColor');
      }
    };
    updateSaveIcon();

    saveBtn.addEventListener('click', (e) => {
      e.preventDefault();
      isSaved = !isSaved;
      localStorage.setItem(favKey, isSaved ? 'true' : 'false');
      updateSaveIcon();
    });
  }

  // Share action link alert copy
  const shareBtn = document.getElementById('btn-lead-share');
  if (shareBtn) {
    shareBtn.addEventListener('click', (e) => {
      e.preventDefault();
      navigator.clipboard.writeText(window.location.href);
      alert('¡Enlace de propiedad copiado al portapapeles!');
    });
  }
</script>
