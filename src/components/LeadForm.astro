---
interface Props {
  propertyId?: number;
  propertyTitle?: string;
}

const { propertyId, propertyTitle } = Astro.props;

// Construct WhatsApp url
const waText = propertyTitle 
  ? `Hola! Estoy interesado en la propiedad: ${propertyTitle} (ID: ${propertyId}). Me gustaría coordinar una visita.` 
  : "Hola! Quisiera realizar una consulta sobre una propiedad.";
const waUrl = `https://wa.me/5491122862000?text=${encodeURIComponent(waText)}`;
---

<div class="bg-pure-white p-6 border border-outline-variant/30 rounded-lg shadow-sm w-full sticky top-28 font-sans select-none">
    <!-- Agent Profile Header -->
    <div class="flex items-center gap-4 mb-6 text-left">
        <div class="w-14 h-14 bg-black rounded-lg flex items-center justify-center shadow-sm border border-outline-variant/20 overflow-hidden p-2.5">
            <img 
              src="/assets/iso_muv.png" 
              alt="MUV" 
              class="w-full h-full object-contain brightness-0 invert"
            />
        </div>
        <div class="space-y-1">
            <h4 class="font-headline text-[15px] font-bold text-primary leading-tight">MUV Propiedades</h4>
            <p class="text-[11px] text-secondary font-medium">Real Estate Premium</p>
            <!-- 5 Gold Stars Rating -->
            <div class="flex gap-0.5 text-refined-gold">
                <span class="material-symbols-outlined text-[14px] fill-[1]" style="font-variation-settings: 'FILL' 1">star</span>
                <span class="material-symbols-outlined text-[14px] fill-[1]" style="font-variation-settings: 'FILL' 1">star</span>
                <span class="material-symbols-outlined text-[14px] fill-[1]" style="font-variation-settings: 'FILL' 1">star</span>
                <span class="material-symbols-outlined text-[14px] fill-[1]" style="font-variation-settings: 'FILL' 1">star</span>
                <span class="material-symbols-outlined text-[14px] fill-[1]" style="font-variation-settings: 'FILL' 1">star</span>
            </div>
        </div>
    </div>

    <!-- Inquiry Form -->
    <form id="lead-form" class="space-y-5 text-left" data-property-id={propertyId}>
        <!-- Status Notification Box -->
        <div id="form-status" class="hidden p-4 rounded text-xs font-semibold select-none"></div>

        <!-- Name Input -->
        <div class="space-y-1">
            <label for="lead-name" class="text-secondary font-bold text-[9px] uppercase tracking-widest block">Nombre Completo</label>
            <input 
              type="text" 
              id="lead-name" 
              required 
              placeholder="Ingresa tu nombre"
              class="w-full bg-transparent border-0 border-b border-[#E5E2E1] focus:border-refined-gold focus:ring-0 px-0 py-2 text-[13.5px] text-primary placeholder:text-outline/40 focus:outline-none"
            />
        </div>

        <!-- Email Input -->
        <div class="space-y-1">
            <label for="lead-email" class="text-secondary font-bold text-[9px] uppercase tracking-widest block">Email</label>
            <input 
              type="email" 
              id="lead-email" 
              required 
              placeholder="tu@email.com"
              class="w-full bg-transparent border-0 border-b border-[#E5E2E1] focus:border-refined-gold focus:ring-0 px-0 py-2 text-[13.5px] text-primary placeholder:text-outline/40 focus:outline-none"
            />
        </div>

        <!-- Phone Input (required by Tokko CRM backend api) -->
        <div class="space-y-1">
            <label for="lead-phone" class="text-secondary font-bold text-[9px] uppercase tracking-widest block">Teléfono / WhatsApp</label>
            <input 
              type="tel" 
              id="lead-phone" 
              required 
              placeholder="Ingresa tu teléfono"
              class="w-full bg-transparent border-0 border-b border-[#E5E2E1] focus:border-refined-gold focus:ring-0 px-0 py-2 text-[13.5px] text-primary placeholder:text-outline/40 focus:outline-none"
            />
        </div>

        <!-- Message/Comment -->
        <div class="space-y-1">
            <label for="lead-message" class="text-secondary font-bold text-[9px] uppercase tracking-widest block">Mensaje</label>
            <textarea 
              id="lead-message" 
              rows="3" 
              placeholder="Estoy interesado en esta propiedad..."
              class="w-full bg-transparent border-0 border-b border-[#E5E2E1] focus:border-refined-gold focus:ring-0 px-0 py-2 text-[13.5px] text-primary placeholder:text-outline/40 focus:outline-none resize-none"
            >Estoy interesado en esta propiedad...</textarea>
        </div>

        <!-- Sticky Form Buttons Stack -->
        <div class="space-y-2.5 pt-3">
            <!-- Submit (Agendar Visita) -->
            <button 
              type="submit" 
              id="btn-submit-lead"
              class="w-full bg-primary text-pure-white py-3.5 rounded font-headline text-xs font-bold uppercase tracking-wider hover:bg-black/90 transition-all duration-300 active:scale-[0.98] flex items-center justify-center gap-2 shadow-sm cursor-pointer"
            >
                <span>Agendar Visita</span>
            </button>

            <!-- WhatsApp Link -->
            <a 
              href={waUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="w-full border border-black/85 text-primary py-3 rounded font-headline text-xs font-bold uppercase tracking-wider hover:bg-slate-50 transition-all duration-300 active:scale-[0.98] flex items-center justify-center gap-2 text-center"
            >
              <!-- WhatsApp Mini Icon -->
              <svg class="w-4 h-4 fill-current text-primary" viewBox="0 0 24 24">
                <path d="M12.031 2C6.18 2 1.437 6.743 1.437 12.594c0 1.87.487 3.692 1.411 5.302L1.05 23.364l5.642-1.481c1.547.844 3.28 1.288 5.333 1.288 5.857 0 10.605-4.744 10.605-10.594C22.63 6.743 17.887 2 12.03 2zm.006 1.62c4.981 0 9.017 4.037 9.017 9.018 0 4.981-4.037 9.018-9.017 9.018-1.748 0-3.385-.502-4.782-1.365l-.342-.206-3.541.93.945-3.454-.226-.36A8.97 8.97 0 0 1 3.06 12.64c0-4.982 4.035-9.02 9.017-9.02zm-2.485 3.535c-.173 0-.361.02-.524.082-.162.062-.35.158-.512.314-.388.38-.85.882-.85 1.834 0 1.096.797 2.148.91 2.302.112.152 1.54 2.383 3.75 3.321 2.21.937 2.21.624 2.612.585.4-.04 1.294-.528 1.477-1.036.183-.508.183-.942.128-1.036-.055-.094-.203-.151-.43-.264-.225-.113-1.294-.638-1.49-.711-.198-.073-.341-.11-.489.112-.147.222-.574.71-.703.856-.13.147-.26.166-.489.053-.228-.113-.965-.355-1.838-1.134-.68-.606-1.139-1.353-1.272-1.583-.134-.227-.014-.35.099-.462.102-.102.228-.264.341-.397.113-.13.15-.222.226-.372.076-.147.037-.28-.019-.393-.056-.113-.489-1.178-.67-1.616-.18-.426-.36-.368-.492-.375z" />
              </svg>
              <span>WhatsApp</span>
            </a>

            <!-- Solicitar Tasacion -->
            <a 
              href="/contacto"
              class="w-full border border-black/85 text-primary py-3 rounded font-headline text-xs font-bold uppercase tracking-wider hover:bg-slate-50 transition-all duration-300 active:scale-[0.98] flex items-center justify-center gap-2 text-center"
            >
              <span>Solicitar Tasación</span>
            </a>
        </div>
    </form>

    <!-- Guardar / Compartir / Imprimir actions -->
    <div class="border-t border-outline-variant/10 mt-6 pt-5 flex justify-between items-center gap-3 text-slate-blue/80 text-[11px] font-semibold tracking-wider font-sans select-none">
        <!-- Guardar -->
        <button 
          id="btn-lead-save" 
          class="flex items-center gap-1.5 hover:text-primary transition-colors cursor-pointer focus:outline-none"
        >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
            </svg>
            <span>Guardar</span>
        </button>

        <!-- Compartir -->
        <button 
          id="btn-lead-share" 
          class="flex items-center gap-1.5 hover:text-primary transition-colors cursor-pointer focus:outline-none"
        >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="18" cy="5" r="3" />
              <circle cx="6" cy="12" r="3" />
              <circle cx="18" cy="19" r="3" />
              <path d="M8.59 13.51l6.83 3.98M15.41 6.51l-6.82 3.98" />
            </svg>
            <span>Compartir</span>
        </button>

        <!-- Imprimir -->
        <button 
          id="btn-lead-print" 
          class="flex items-center gap-1.5 hover:text-primary transition-colors cursor-pointer focus:outline-none"
          onclick="window.print()"
        >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
              <path d="M6 14h12v8H6z" />
            </svg>
            <span>Imprimir</span>
        </button>
    </div>
</div>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement;
  const statusBox = document.getElementById('form-status');
  const submitBtn = document.getElementById('btn-submit-lead') as HTMLButtonElement;

  if (form && statusBox && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Clear previous states
      statusBox.className = 'hidden p-4 rounded text-xs font-semibold select-none';
      statusBox.innerHTML = '';
      
      const name = (document.getElementById('lead-name') as HTMLInputElement).value;
      const email = (document.getElementById('lead-email') as HTMLInputElement).value;
      const phone = (document.getElementById('lead-phone') as HTMLInputElement).value;
      const text = (document.getElementById('lead-message') as HTMLTextAreaElement).value;
      const propertyId = form.dataset.propertyId ? Number(form.dataset.propertyId) : undefined;

      // Toggle pending state
      const originalBtnText = submitBtn.innerHTML;
      submitBtn.innerHTML = 'Enviando...';
      submitBtn.disabled = true;
      submitBtn.classList.add('opacity-70', 'cursor-not-allowed');

      try {
        const response = await fetch('/api/lead', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ name, email, phone, text, propertyId })
        });

        const result = await response.json();

        if (!response.ok) {
          throw new Error(result.error || 'Hubo un error al procesar el contacto.');
        }

        // Show Success
        statusBox.classList.remove('hidden');
        statusBox.classList.add('bg-green-100', 'text-green-800');
        statusBox.innerHTML = '<span class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">check_circle</span>Consulta enviada con éxito.</span>';
        form.reset();
      } catch (err: any) {
        // Show Error
        statusBox.classList.remove('hidden');
        statusBox.classList.add('bg-red-100', 'text-red-800');
        statusBox.innerHTML = `<span class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">error</span>${err.message || 'Error de conexión.'}</span>`;
      } finally {
        // Restore button state
        submitBtn.innerHTML = originalBtnText;
        submitBtn.disabled = false;
        submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
      }
    });
  }

  // Favorite button local storage state
  const saveBtn = document.getElementById('btn-lead-save');
  const propertyId = form?.dataset.propertyId;
  if (saveBtn && propertyId) {
    const favKey = `muv_fav_${propertyId}`;
    let isSaved = localStorage.getItem(favKey) === 'true';
    const heartSvg = saveBtn.querySelector('svg');
    const updateSaveIcon = () => {
      if (heartSvg) {
        heartSvg.setAttribute('fill', isSaved ? '#ba1a1a' : 'none');
        heartSvg.setAttribute('stroke', isSaved ? '#ba1a1a' : 'currentColor');
      }
    };
    updateSaveIcon();

    saveBtn.addEventListener('click', (e) => {
      e.preventDefault();
      isSaved = !isSaved;
      localStorage.setItem(favKey, isSaved ? 'true' : 'false');
      updateSaveIcon();
    });
  }

  // Share action link alert copy
  const shareBtn = document.getElementById('btn-lead-share');
  if (shareBtn) {
    shareBtn.addEventListener('click', (e) => {
      e.preventDefault();
      navigator.clipboard.writeText(window.location.href);
      alert('¡Enlace de propiedad copiado al portapapeles!');
    });
  }
</script>
