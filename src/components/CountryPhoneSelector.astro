---
import { countries } from '../lib/countries';

interface Props {
  phoneId?: string;
  countryId?: string;
  placeholder?: string;
  required?: boolean;
  inputClass?: string;
  containerClass?: string;
}

const {
  phoneId = "phone",
  countryId = "country-code",
  placeholder = "Teléfono",
  required = true,
  inputClass = "",
  containerClass = ""
} = Astro.props;
---

<div class={`phone-selector-container relative flex items-center ${containerClass}`}>
  <!-- Trigger Button displaying selected flag -->
  <button type="button" class="country-btn flex items-center gap-1.5 focus:outline-none cursor-pointer pl-1 shrink-0 h-full">
    <img class="selected-flag w-5 h-auto rounded-sm border border-outline-variant/20" src="https://flagcdn.com/w20/ar.png" alt="AR" width="20" height="15" />
    <span class="text-[8px] text-primary/50 select-none">▼</span>
  </button>

  <!-- Vertical separator line -->
  <div class="h-4.5 w-px bg-outline-variant/30 mx-2 shrink-0"></div>

  <!-- Hidden input to store selected dial code (default: 54) -->
  <input type="hidden" id={countryId} class="country-hidden-input" value="54" />

  <!-- Visible telephone text input -->
  <input 
    type="tel" 
    id={phoneId} 
    required={required} 
    placeholder={placeholder} 
    class={`phone-visible-input w-full bg-transparent border-0 focus:ring-0 text-sm p-0 focus:outline-none ${inputClass}`} 
  />

  <!-- Dropdown Country Picker Panel -->
  <div class="country-dropdown absolute left-0 top-full mt-2 w-64 max-h-60 overflow-y-auto bg-pure-white border border-outline-variant/30 rounded-xl shadow-2xl z-50 hidden select-none">
    <!-- Search Box -->
    <div class="p-2 border-b border-outline-variant/10 sticky top-0 bg-pure-white z-10">
      <input 
        type="text" 
        class="country-search-input w-full px-3 py-1.5 text-xs border border-outline-variant/30 rounded-full focus:outline-none focus:border-primary bg-transparent text-primary" 
        placeholder="Buscar país..." 
      />
    </div>
    <!-- Option List -->
    <div class="country-options py-1">
      {countries.map((c) => (
        <button 
          type="button" 
          class="country-option w-full flex items-center justify-between px-4 py-2 hover:bg-neutral-100 text-left text-xs text-primary transition-colors cursor-pointer border-0 bg-transparent focus:outline-none"
          data-dial={c.dial}
          data-code={c.code}
          data-name={c.name.toLowerCase()}
        >
          <span class="flex items-center gap-2.5">
            <img class="w-4.5 h-auto rounded-sm shrink-0 border border-outline-variant/10" src={`https://flagcdn.com/w20/${c.code}.png`} alt={c.name} loading="lazy" width="20" height="15" />
            <span class="truncate max-w-[140px] text-primary">{c.name}</span>
          </span>
          <span class="text-secondary font-medium shrink-0">+{c.dial}</span>
        </button>
      ))}
    </div>
  </div>
</div>

<script>
  function initPhoneSelectors() {
    document.querySelectorAll('.phone-selector-container').forEach((container) => {
      // Avoid duplicate event listener binding
      if (container.getAttribute('data-phone-initialized') === 'true') return;
      container.setAttribute('data-phone-initialized', 'true');

      const triggerBtn = container.querySelector('.country-btn') as HTMLButtonElement;
      const dropdown = container.querySelector('.country-dropdown') as HTMLDivElement;
      const searchInput = container.querySelector('.country-search-input') as HTMLInputElement;
      const hiddenInput = container.querySelector('.country-hidden-input') as HTMLInputElement;
      const selectedFlag = container.querySelector('.selected-flag') as HTMLImageElement;
      const options = container.querySelectorAll('.country-option') as NodeListOf<HTMLButtonElement>;

      if (!triggerBtn || !dropdown || !searchInput || !hiddenInput || !selectedFlag) return;

      // Toggle dropdown
      triggerBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isHidden = dropdown.classList.contains('hidden');
        
        // Close other dropdowns first
        document.querySelectorAll('.country-dropdown').forEach((d) => d.classList.add('hidden'));
        
        if (isHidden) {
          dropdown.classList.remove('hidden');
          searchInput.value = '';
          searchInput.focus();
          
          // Reset option visibility
          options.forEach((opt) => opt.classList.remove('hidden'));
        }
      });

      // Search filtering
      searchInput.addEventListener('input', () => {
        const query = searchInput.value.toLowerCase().trim();
        options.forEach((opt) => {
          const name = opt.dataset.name || '';
          const dial = opt.dataset.dial || '';
          if (name.includes(query) || dial.includes(query)) {
            opt.classList.remove('hidden');
          } else {
            opt.classList.add('hidden');
          }
        });
      });

      // Select country
      options.forEach((opt) => {
        opt.addEventListener('click', (e) => {
          e.stopPropagation();
          const dial = opt.dataset.dial || '54';
          const code = opt.dataset.code || 'ar';
          
          hiddenInput.value = dial;
          selectedFlag.src = `https://flagcdn.com/w20/${code}.png`;
          selectedFlag.alt = code.toUpperCase();
          
          dropdown.classList.add('hidden');
        });
      });

      // Close on click outside
      document.addEventListener('click', () => {
        dropdown.classList.add('hidden');
      });

      // Prevent closing dropdown when clicking inside search input or dropdown panel
      dropdown.addEventListener('click', (e) => {
        e.stopPropagation();
      });
    });
  }

  // Initialize on page load
  initPhoneSelectors();
  // Support Astro View Transitions
  document.addEventListener('astro:page-load', initPhoneSelectors);
</script>
