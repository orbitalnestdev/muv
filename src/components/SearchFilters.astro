---
const url = Astro.url;

const barrioMap: Record<string, string> = {
  'belgrano': 'Belgrano',
  'palermo': 'Palermo',
  'palermo-hollywood': 'Palermo Hollywood',
  'palermo-soho': 'Palermo Soho',
  'palermo-chico': 'Palermo Chico',
  'palermo-nuevo': 'Palermo Nuevo',
  'recoleta': 'Recoleta',
  'puerto-madero': 'Puerto Madero',
  'villa-urquiza': 'Villa Urquiza',
  'colegiales': 'Colegiales',
  'nunez': 'Nuñez',
  'villa-crespo': 'Villa Crespo',
  'flores': 'Flores',
  'san-telmo': 'San Telmo',
  'botanico': 'Botanico',
  'once': 'Once',
  'microcentro': 'Microcentro'
};

const pathSlug = url.pathname.replace(/^\/|\/$/g, '').replace(/^city\//, '');
const pathBarrio = barrioMap[pathSlug] || '';
const isBarrioPage = !!pathBarrio;

const actionPath = isBarrioPage ? url.pathname : '/search-results/';
const operationId = url.searchParams.get('operation_id') || '';
const propertyTypeId = url.searchParams.get('property_type_id') || '';

const currency = url.searchParams.get('currency') || 'USD';

// Define dynamic ranges based on operation type, currency, and specialized neighborhood settings
const isRent = operationId === '2';
const isArs = currency === 'ARS';

let defaultMin = isRent ? (isArs ? '5000' : '200') : (isArs ? '500000' : '50000');
let defaultMax = isRent ? (isArs ? '250000' : '5000') : (isArs ? '50000000' : '2000000');

// Specialized neighborhood price slider configurations
if (pathSlug === 'puerto-madero') {
  defaultMin = isRent ? (isArs ? '20000' : '500') : (isArs ? '2000000' : '150000');
  defaultMax = isRent ? (isArs ? '1000000' : '15000') : (isArs ? '200000000' : '5000000');
} else if (pathSlug === 'recoleta' || pathSlug === 'palermo') {
  defaultMin = isRent ? (isArs ? '10000' : '300') : (isArs ? '1000000' : '80000');
  defaultMax = isRent ? (isArs ? '600000' : '8000') : (isArs ? '100000000' : '3000000');
}

const sliderStep = isRent ? (isArs ? '5000' : '100') : (isArs ? '100000' : '25000');

const priceMin = url.searchParams.get('price_min') || '';
const priceMax = url.searchParams.get('price_max') || '';
const rooms = url.searchParams.get('rooms') || '';
const bedrooms = url.searchParams.get('bedrooms') || '';
const bathrooms = url.searchParams.get('bathrooms') || '';
const garage = url.searchParams.get('garage') || '';
const surfaceMin = url.searchParams.get('surface_min') || '';
const surfaceMax = url.searchParams.get('surface_max') || '';
const query = url.searchParams.get('q') || '';
const location = url.searchParams.get('location') || '';
const activeAmenities = url.searchParams.getAll('amenities') || [];
const view = url.searchParams.get('view') || '';

// Key amenities specialized by neighborhood
let amenitiesList = [
  'Piscina',
  'Parrilla',
  'Cochera',
  'Seguridad',
  'Gimnasio',
  'SUM',
  'Balcón',
  'Apto Profesional'
];

if (pathSlug === 'puerto-madero') {
  amenitiesList = ['Piscina', 'Gimnasio', 'Seguridad 24hs', 'Cochera', 'SUM', 'Sauna', 'Solarium', 'Vista al Río'];
} else if (pathSlug === 'palermo') {
  amenitiesList = ['Balcón', 'Parrilla', 'Terraza', 'Apto Profesional', 'Piscina', 'Luminoso', 'Solarium', 'Cochera'];
} else if (pathSlug === 'recoleta') {
  amenitiesList = ['Baulera', 'Cochera', 'Seguridad', 'Balcón', 'Terraza', 'Calefacción', 'Ascensor', 'Apto Profesional'];
}

const norm = (str: string) => str.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();
const normLoc = (location || pathBarrio) ? norm(location || pathBarrio) : '';
const isSelectedLocation = (val: string) => norm(val) === normLoc;
---

<form method="GET" action={actionPath} class="space-y-6 w-full" id="filters-form">
    {view && <input type="hidden" name="view" id="val-view" value={view} />}
    <!-- 1. Tipo de Operación -->
    <div class="space-y-2">
        <label class="font-sans text-[11px] font-[500] text-secondary/80 uppercase tracking-widest block">Tipo de Operación</label>
        <div class="grid grid-cols-3 gap-2">
            <button 
              type="button" 
              data-val="" 
              class:list={[
                "btn-op py-2 px-3 border rounded font-sans text-[11px] font-[400] uppercase tracking-wider text-center transition-all duration-200 cursor-pointer",
                operationId === '' 
                  ? "bg-primary text-pure-white border-primary font-[500]" 
                  : "bg-pure-white text-secondary border-outline-variant/50 hover:border-primary"
              ]}
            >
                Todos
            </button>
            <button 
              type="button" 
              data-val="1" 
              class:list={[
                "btn-op py-2 px-3 border rounded font-sans text-[11px] font-[400] uppercase tracking-wider text-center transition-all duration-200 cursor-pointer",
                operationId === '1' 
                  ? "bg-primary text-pure-white border-primary font-[500]" 
                  : "bg-pure-white text-secondary border-outline-variant/50 hover:border-primary"
              ]}
            >
                Venta
            </button>
            <button 
              type="button" 
              data-val="2" 
              class:list={[
                "btn-op py-2 px-3 border rounded font-sans text-[11px] font-[400] uppercase tracking-wider text-center transition-all duration-200 cursor-pointer",
                operationId === '2' 
                  ? "bg-primary text-pure-white border-primary font-[500]" 
                  : "bg-pure-white text-secondary border-outline-variant/50 hover:border-primary"
              ]}
            >
                Alquiler
            </button>
        </div>
        <input type="hidden" name="operation_id" id="val-operation-id" value={operationId} />
    </div>

    <!-- 2. Ubicación / Barrio -->
    <div class="space-y-2">
        <label for="select-location" class="font-sans text-[11px] font-[500] text-secondary/80 uppercase tracking-widest block">Ubicación / Barrio</label>
        <div class="relative">
            <select 
              name="location" 
              id="select-location"
              class="w-full bg-[#f3f4f5] border border-outline-variant/30 px-4 py-3 rounded text-sm text-primary focus:ring-1 focus:ring-primary focus:outline-none appearance-none !bg-none cursor-pointer pr-10 font-[300]"
            >
                <option value="">Todos los barrios</option>
                <option value="Belgrano" selected={isSelectedLocation('Belgrano')}>Belgrano</option>
                <option value="Colegiales" selected={isSelectedLocation('Colegiales')}>Colegiales</option>
                <option value="Flores" selected={isSelectedLocation('Flores')}>Flores</option>
                <option value="Microcentro" selected={isSelectedLocation('Microcentro')}>Microcentro</option>
                <option value="Nuñez" selected={isSelectedLocation('Nuñez')}>Núñez</option>
                <option value="Once" selected={isSelectedLocation('Once')}>Once</option>
                <option value="Palermo" selected={isSelectedLocation('Palermo')}>Palermo</option>
                <option value="Palermo Hollywood" selected={isSelectedLocation('Palermo Hollywood')}>Palermo Hollywood</option>
                <option value="Palermo Soho" selected={isSelectedLocation('Palermo Soho')}>Palermo Soho</option>
                <option value="Palermo Chico" selected={isSelectedLocation('Palermo Chico')}>Palermo Chico</option>
                <option value="Palermo Nuevo" selected={isSelectedLocation('Palermo Nuevo')}>Palermo Nuevo</option>
                <option value="Puerto Madero" selected={isSelectedLocation('Puerto Madero')}>Puerto Madero</option>
                <option value="Recoleta" selected={isSelectedLocation('Recoleta')}>Recoleta</option>
                <option value="San Telmo" selected={isSelectedLocation('San Telmo')}>San Telmo</option>
                <option value="Villa Crespo" selected={isSelectedLocation('Villa Crespo')}>Villa Crespo</option>
                <option value="Villa Urquiza" selected={isSelectedLocation('Villa Urquiza')}>Villa Urquiza</option>
            </select>
            <span class="material-symbols-outlined text-[18px] text-primary absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none">unfold_more</span>
        </div>
    </div>

    <!-- 3. Tipo de Propiedad -->
    <div class="space-y-2">
        <label for="select-prop-type" class="font-sans text-[11px] font-[500] text-secondary/80 uppercase tracking-widest block">Tipo de Propiedad</label>
        <div class="relative">
            <select 
              name="property_type_id" 
              id="select-prop-type"
              class="w-full bg-[#f3f4f5] border border-outline-variant/30 px-4 py-3 rounded text-sm text-primary focus:ring-1 focus:ring-primary focus:outline-none appearance-none !bg-none cursor-pointer pr-10 font-[300]"
            >
                <option value="">Todos los tipos</option>
                <option value="2" selected={propertyTypeId === '2'}>Departamento</option>
                <option value="3" selected={propertyTypeId === '3'}>Casa</option>
                <option value="4" selected={propertyTypeId === '4'}>PH</option>
                <option value="7" selected={propertyTypeId === '7'}>Local</option>
            </select>
            <span class="material-symbols-outlined text-[18px] text-primary absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none">unfold_more</span>
        </div>
    </div>

    <!-- 4. Rango de Precio (Slick Double Slider + Manual Sincronizados) -->
    <div class="space-y-3">
        <!-- Moneda Toggle -->
        <div class="space-y-1.5 select-none">
            <label class="font-sans text-[11px] font-[500] text-secondary/80 uppercase tracking-widest block">Moneda</label>
            <div class="grid grid-cols-2 gap-2">
                <button 
                  type="button" 
                  data-val="USD" 
                  class:list={[
                    "btn-currency py-1.5 px-3 border rounded text-[11px] font-[400] uppercase tracking-wider text-center transition-all duration-200 cursor-pointer",
                    currency === 'ARS' 
                      ? "bg-pure-white text-secondary border-outline-variant/50 hover:border-primary" 
                      : "bg-primary text-pure-white border-primary font-[500]"
                  ]}
                >
                    USD
                </button>
                <button 
                  type="button" 
                  data-val="ARS" 
                  class:list={[
                    "btn-currency py-1.5 px-3 border rounded text-[11px] font-[400] uppercase tracking-wider text-center transition-all duration-200 cursor-pointer",
                    currency === 'ARS' 
                      ? "bg-primary text-pure-white border-primary font-[500]" 
                      : "bg-pure-white text-secondary border-outline-variant/50 hover:border-primary"
                  ]}
                >
                    ARS
                </button>
            </div>
            <input type="hidden" name="currency" id="val-currency" value={currency} />
        </div>

        <div class="flex justify-between items-center pt-1.5">
            <label class="font-sans text-[11px] font-[500] text-secondary/80 uppercase tracking-widest">Presupuesto</label>
            <span class="text-xs font-[400] text-secondary/90 font-sans" id="price-range-label">
                {priceMin || priceMax 
                  ? `${currency} ${new Intl.NumberFormat('es-AR').format(Number(priceMin || defaultMin))} - ${currency} ${new Intl.NumberFormat('es-AR').format(Number(priceMax || defaultMax))}` 
                  : 'Cualquier precio'
                }
            </span>
        </div>
        
        <!-- Double Slider Track -->
        <div class="relative w-full h-6 flex items-center select-none slider-wrapper pt-1">
            <div class="absolute w-full h-[5px] bg-[#e2e8f0] rounded pointer-events-none"></div>
            <div id="slider-track" class="absolute h-[5px] bg-primary rounded pointer-events-none" style="left: 0%; right: 0%;"></div>
            
            <input 
              type="range" 
              id="slider-min" 
              min={defaultMin} 
              max={defaultMax} 
              step={sliderStep} 
              value={priceMin || defaultMin} 
              class="absolute w-full pointer-events-auto appearance-none bg-transparent h-2 outline-none cursor-pointer" 
              style="z-index: 2;"
              aria-label="Precio mínimo"
            />
            <input 
              type="range" 
              id="slider-max" 
              min={defaultMin} 
              max={defaultMax} 
              step={sliderStep} 
              value={priceMax || defaultMax} 
              class="absolute w-full pointer-events-auto appearance-none bg-transparent h-2 outline-none cursor-pointer" 
              style="z-index: 2;"
              aria-label="Precio máximo"
            />
        </div>
        
        <!-- Manual numeric inputs styled nicely -->
        <div class="grid grid-cols-2 gap-3 pt-1">
            <div class="space-y-1">
                <span class="text-[9px] font-[400] text-secondary/60 uppercase tracking-wider block">Mínimo</span>
                <div class="relative flex items-center">
                    <span class="absolute left-3 text-xs text-[#858383] font-semibold font-sans">
                        {currency === 'ARS' ? '$' : 'U$S'}
                    </span>
                    <input 
                      type="number" 
                      id="input-price-min" 
                      placeholder="Mínimo" 
                      value={priceMin}
                      class="w-full bg-[#f3f4f5] border border-outline-variant/30 pl-11 pr-3 py-2 rounded text-xs text-primary focus:ring-1 focus:ring-primary focus:outline-none font-[300] font-sans"
                    />
                </div>
            </div>
            <div class="space-y-1">
                <span class="text-[9px] font-[400] text-secondary/60 uppercase tracking-wider block">Máximo</span>
                <div class="relative flex items-center">
                    <span class="absolute left-3 text-xs text-[#858383] font-semibold font-sans">
                        {currency === 'ARS' ? '$' : 'U$S'}
                    </span>
                    <input 
                      type="number" 
                      id="input-price-max" 
                      placeholder="Máximo" 
                      value={priceMax}
                      class="w-full bg-[#f3f4f5] border border-outline-variant/30 pl-11 pr-3 py-2 rounded text-xs text-primary focus:ring-1 focus:ring-primary focus:outline-none font-[300] font-sans"
                    />
                </div>
            </div>
        </div>

        <input type="hidden" name="price_min" id="val-price-min" value={priceMin} />
        <input type="hidden" name="price_max" id="val-price-max" value={priceMax} />
    </div>

    <!-- 5. Ambientes (Rooms) & Dormitorios (Bedrooms) -->
    <div class="grid grid-cols-2 gap-4">
        <!-- Ambientes -->
        <div class="space-y-2">
            <label class="font-sans text-[11px] font-[500] text-secondary/80 uppercase tracking-widest block">Ambientes</label>
            <div class="grid grid-cols-5 gap-1">
                {['', '1', '2', '3', '4'].map((num) => (
                    <button 
                      type="button" 
                      data-val={num} 
                      class:list={[
                        "btn-rooms py-2 border rounded text-xs font-[400] text-center transition-all duration-200 cursor-pointer",
                        rooms === num 
                          ? "bg-primary text-pure-white border-primary font-[500]" 
                          : "bg-pure-white text-secondary border-outline-variant/50 hover:border-primary"
                      ]}
                    >
                        {num === '' ? 'T' : num === '4' ? '4+' : num}
                    </button>
                ))}
            </div>
            <input type="hidden" name="rooms" id="val-rooms" value={rooms} />
        </div>

        <!-- Dormitorios -->
        <div class="space-y-2">
            <label class="font-sans text-[11px] font-[500] text-secondary/80 uppercase tracking-widest block">Dormitorios</label>
            <div class="grid grid-cols-5 gap-1">
                {['', '1', '2', '3', '4'].map((num) => (
                    <button 
                      type="button" 
                      data-val={num} 
                      class:list={[
                        "btn-bedrooms py-2 border rounded text-xs font-[400] text-center transition-all duration-200 cursor-pointer",
                        bedrooms === num 
                          ? "bg-primary text-pure-white border-primary font-[500]" 
                          : "bg-pure-white text-secondary border-outline-variant/50 hover:border-primary"
                      ]}
                    >
                        {num === '' ? 'T' : num === '4' ? '4+' : num}
                    </button>
                ))}
            </div>
            <input type="hidden" name="bedrooms" id="val-bedrooms" value={bedrooms} />
        </div>
    </div>

    <!-- Baños (Bathrooms) & Cocheras (Garages) -->
    <div class="grid grid-cols-2 gap-4">
        <!-- Baños -->
        <div class="space-y-2">
            <label class="font-sans text-[11px] font-[500] text-secondary/80 uppercase tracking-widest block">Baños</label>
            <div class="grid grid-cols-5 gap-1">
                {['', '1', '2', '3', '4'].map((num) => (
                    <button 
                      type="button" 
                      data-val={num} 
                      class:list={[
                        "btn-bathrooms py-2 border rounded text-xs font-[400] text-center transition-all duration-200 cursor-pointer",
                        bathrooms === num 
                          ? "bg-primary text-pure-white border-primary font-[500]" 
                          : "bg-pure-white text-secondary border-outline-variant/50 hover:border-primary"
                      ]}
                    >
                        {num === '' ? 'T' : num === '4' ? '4+' : num}
                    </button>
                ))}
            </div>
            <input type="hidden" name="bathrooms" id="val-bathrooms" value={bathrooms} />
        </div>

        <!-- Cocheras -->
        <div class="space-y-2">
            <label class="font-sans text-[11px] font-[500] text-secondary/80 uppercase tracking-widest block">Cocheras</label>
            <div class="grid grid-cols-5 gap-1">
                {['', '1', '2', '3', '4'].map((num) => (
                    <button 
                      type="button" 
                      data-val={num} 
                      class:list={[
                        "btn-garage py-2 border rounded text-xs font-[400] text-center transition-all duration-200 cursor-pointer",
                        garage === num 
                          ? "bg-primary text-pure-white border-primary font-[500]" 
                          : "bg-pure-white text-secondary border-outline-variant/50 hover:border-primary"
                      ]}
                    >
                        {num === '' ? 'T' : num === '4' ? '4+' : num}
                    </button>
                ))}
            </div>
            <input type="hidden" name="garage" id="val-garage" value={garage} />
        </div>
    </div>

    <!-- Superficie (m²) -->
    <div class="space-y-2">
        <label class="font-sans text-[11px] font-[500] text-secondary/80 uppercase tracking-widest block">Superficie (m²)</label>
        <div class="grid grid-cols-2 gap-3">
            <div class="space-y-1">
                <span class="text-[9px] font-[400] text-secondary/60 uppercase tracking-wider block">Mínima</span>
                <div class="relative flex items-center">
                    <input 
                      type="number" 
                      name="surface_min" 
                      id="input-surface-min" 
                      placeholder="Mínima" 
                      value={surfaceMin}
                      class="w-full bg-[#f3f4f5] border border-outline-variant/30 px-3 py-2 rounded text-xs text-primary focus:ring-1 focus:ring-primary focus:outline-none font-[300] font-sans"
                    />
                </div>
            </div>
            <div class="space-y-1">
                <span class="text-[9px] font-[400] text-secondary/60 uppercase tracking-wider block">Máxima</span>
                <div class="relative flex items-center">
                    <input 
                      type="number" 
                      name="surface_max" 
                      id="input-surface-max" 
                      placeholder="Máxima" 
                      value={surfaceMax}
                      class="w-full bg-[#f3f4f5] border border-outline-variant/30 px-3 py-2 rounded text-xs text-primary focus:ring-1 focus:ring-primary focus:outline-none font-[300] font-sans"
                    />
                </div>
            </div>
        </div>
    </div>

    <!-- 6. Características (Amenities Checklist) -->
    <div class="space-y-3 pt-2">
        <label class="font-sans text-[11px] font-[500] text-secondary/80 uppercase tracking-widest block">Características</label>
        <div class="grid grid-cols-2 gap-3 text-xs text-secondary/80">
            {amenitiesList.map((item) => {
              const isChecked = activeAmenities.includes(item);
              return (
                <label class="flex items-center gap-2.5 cursor-pointer hover:text-primary transition-all select-none">
                    <input 
                      type="checkbox" 
                      name="amenities" 
                      value={item} 
                      checked={isChecked}
                      class="filter-checkbox border-outline-variant/50 text-primary focus:ring-primary rounded w-4 h-4 transition-all"
                    />
                    <span class="font-[300] font-sans">{item}</span>
                </label>
              );
            })}
        </div>
    </div>

    <!-- Search keyword (lower priority search bar inside sidebar) -->
    <div class="space-y-2 pt-2 border-t border-outline-variant/10">
        <label for="input-keyword" class="font-sans text-[11px] font-[500] text-secondary/80 uppercase tracking-widest block">Palabras clave adicionales</label>
        <div class="relative">
            <input 
              type="text" 
              name="q" 
              id="input-keyword" 
              placeholder="Ej. balcón, cochera, vista..." 
              value={query}
              class="w-full bg-[#f3f4f5] border border-outline-variant/30 px-4 py-3 rounded text-sm text-primary placeholder-[#747878] focus:ring-1 focus:ring-primary focus:outline-none font-[300]"
            />
            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-secondary/60">search</span>
        </div>
    </div>

    <!-- Actions -->
    <div class="pt-4 border-t border-outline-variant/20 grid grid-cols-2 gap-4">
        <button 
          type="button" 
          id="btn-clear" 
          class="border border-outline-variant/50 text-secondary py-3 rounded font-sans text-xs font-[400] uppercase tracking-wider text-center hover:bg-surface-container transition-colors active:scale-95 cursor-pointer"
        >
            Limpiar
        </button>
        <button 
          type="submit" 
          class="bg-primary text-pure-white py-3 rounded font-sans text-xs font-[500] uppercase tracking-wider text-center hover:bg-primary/95 transition-colors active:scale-95 cursor-pointer"
        >
            Buscar
        </button>
    </div>
</form>

<script>
  let submitTimeout: any = null;
  const submitForm = () => {
    if (submitTimeout) clearTimeout(submitTimeout);
    
    const gridOuter = document.getElementById('property-grid-outer');
    if (gridOuter) {
      gridOuter.style.opacity = '0.5';
      gridOuter.style.pointerEvents = 'none';
    }
    
    submitTimeout = setTimeout(() => {
      const form = document.getElementById('filters-form') as HTMLFormElement | null;
      if (form) form.submit();
    }, 600);
  };

  // Operation selectors
  document.querySelectorAll('.btn-op').forEach((btn: any) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.btn-op').forEach((b: any) => {
        b.classList.remove('bg-primary', 'text-pure-white', 'border-primary');
        b.classList.add('bg-pure-white', 'text-slate-blue', 'border-outline-variant/50');
      });
      btn.classList.add('bg-primary', 'text-pure-white', 'border-primary');
      btn.classList.remove('bg-pure-white', 'text-slate-blue', 'border-outline-variant/50');
      
      const valInput = document.getElementById('val-operation-id') as HTMLInputElement;
      if (valInput) {
        valInput.value = btn.dataset.val || '';
        submitForm();
      }
    });
  });

  // Selectors auto-submit
  const propTypeSelect = document.getElementById('select-prop-type') as HTMLSelectElement | null;
  if (propTypeSelect) {
    propTypeSelect.addEventListener('change', submitForm);
  }

  const locationSelect = document.getElementById('select-location') as HTMLSelectElement | null;
  if (locationSelect) {
    locationSelect.addEventListener('change', () => {
      const barrioSlugs = ['belgrano', 'palermo', 'recoleta', 'puerto-madero', 'villa-urquiza', 'colegiales', 'nunez'];
      const isBarrioPage = barrioSlugs.some(slug => window.location.pathname.replace(/^\/|\/$/g, '') === slug);
      if (isBarrioPage) {
        const form = document.getElementById('filters-form') as HTMLFormElement | null;
        if (form) {
          form.action = '/search-results/';
        }
      }
      submitForm();
    });
  }

  // Checkboxes auto-submit
  document.querySelectorAll('.filter-checkbox').forEach((checkbox: any) => {
    checkbox.addEventListener('change', submitForm);
  });

  // Rooms selectors
  document.querySelectorAll('.btn-rooms').forEach((btn: any) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.btn-rooms').forEach((b: any) => {
        b.classList.remove('bg-primary', 'text-pure-white', 'border-primary');
        b.classList.add('bg-pure-white', 'text-slate-blue', 'border-outline-variant/50');
      });
      btn.classList.add('bg-primary', 'text-pure-white', 'border-primary');
      btn.classList.remove('bg-pure-white', 'text-slate-blue', 'border-outline-variant/50');
      
      const valInput = document.getElementById('val-rooms') as HTMLInputElement;
      if (valInput) {
        valInput.value = btn.dataset.val || '';
        submitForm();
      }
    });
  });

  // Bedrooms selectors
  document.querySelectorAll('.btn-bedrooms').forEach((btn: any) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.btn-bedrooms').forEach((b: any) => {
        b.classList.remove('bg-primary', 'text-pure-white', 'border-primary');
        b.classList.add('bg-pure-white', 'text-slate-blue', 'border-outline-variant/50');
      });
      btn.classList.add('bg-primary', 'text-pure-white', 'border-primary');
      btn.classList.remove('bg-pure-white', 'text-slate-blue', 'border-outline-variant/50');
      
      const valInput = document.getElementById('val-bedrooms') as HTMLInputElement;
      if (valInput) {
        valInput.value = btn.dataset.val || '';
        submitForm();
      }
    });
  });

  // Bathrooms selectors
  document.querySelectorAll('.btn-bathrooms').forEach((btn: any) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.btn-bathrooms').forEach((b: any) => {
        b.classList.remove('bg-primary', 'text-pure-white', 'border-primary');
        b.classList.add('bg-pure-white', 'text-slate-blue', 'border-outline-variant/50');
      });
      btn.classList.add('bg-primary', 'text-pure-white', 'border-primary');
      btn.classList.remove('bg-pure-white', 'text-slate-blue', 'border-outline-variant/50');
      
      const valInput = document.getElementById('val-bathrooms') as HTMLInputElement;
      if (valInput) {
        valInput.value = btn.dataset.val || '';
        submitForm();
      }
    });
  });

  // Garage selectors
  document.querySelectorAll('.btn-garage').forEach((btn: any) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.btn-garage').forEach((b: any) => {
        b.classList.remove('bg-primary', 'text-pure-white', 'border-primary');
        b.classList.add('bg-pure-white', 'text-slate-blue', 'border-outline-variant/50');
      });
      btn.classList.add('bg-primary', 'text-pure-white', 'border-primary');
      btn.classList.remove('bg-pure-white', 'text-slate-blue', 'border-outline-variant/50');
      
      const valInput = document.getElementById('val-garage') as HTMLInputElement;
      if (valInput) {
        valInput.value = btn.dataset.val || '';
        submitForm();
      }
    });
  });

  // Surface inputs change event
  const inputSurfMin = document.getElementById('input-surface-min') as HTMLInputElement | null;
  const inputSurfMax = document.getElementById('input-surface-max') as HTMLInputElement | null;
  if (inputSurfMin) {
    inputSurfMin.addEventListener('change', submitForm);
  }
  if (inputSurfMax) {
    inputSurfMax.addEventListener('change', submitForm);
  }

  // Price Double Slider & Manual Inputs Sincronización
  const sliderMin = document.getElementById('slider-min') as HTMLInputElement | null;
  const sliderMax = document.getElementById('slider-max') as HTMLInputElement | null;
  const inputMin = document.getElementById('input-price-min') as HTMLInputElement | null;
  const inputMax = document.getElementById('input-price-max') as HTMLInputElement | null;
  const track = document.getElementById('slider-track');
  const label = document.getElementById('price-range-label');
  const minValHidden = document.getElementById('val-price-min') as HTMLInputElement | null;
  const maxValHidden = document.getElementById('val-price-max') as HTMLInputElement | null;
  const wrapper = document.querySelector('.slider-wrapper');

  if (sliderMin && sliderMax && track && label && minValHidden && maxValHidden && inputMin && inputMax) {
    let hasMin = !!minValHidden.value;
    let hasMax = !!maxValHidden.value;

    const updateSliderFromControls = (minVal: number, maxVal: number, triggerSource: 'slider' | 'input', isUserAction = false) => {
      const minGap = parseInt(sliderMin.step) || 25000;
      
      if (maxVal - minVal < minGap) {
        if (triggerSource === 'slider') {
          // If slider was adjusted, respect boundaries and push the other slider
          // to maintain gap
        } else {
          // If numerical input was adjusted, clamp values
          minVal = maxVal - minGap;
        }
      }

      // Constrain within min/max bounds
      const minLimit = parseInt(sliderMin.min) || 200;
      const maxLimit = parseInt(sliderMax.max) || 2500000;
      minVal = Math.max(minLimit, Math.min(maxLimit, minVal));
      maxVal = Math.max(minLimit, Math.min(maxLimit, maxVal));

      if (triggerSource === 'input') {
        sliderMin.value = minVal.toString();
        sliderMax.value = maxVal.toString();
        hasMin = true;
        hasMax = true;
      } else {
        if (isUserAction || hasMin) {
          inputMin.value = minVal.toString();
          hasMin = true;
        }
        if (isUserAction || hasMax) {
          inputMax.value = maxVal.toString();
          hasMax = true;
        }
      }

      const minPercent = ((minVal - parseInt(sliderMin.min)) / (parseInt(sliderMin.max) - parseInt(sliderMin.min))) * 100;
      const maxPercent = ((maxVal - parseInt(sliderMax.min)) / (parseInt(sliderMax.max) - parseInt(sliderMax.min))) * 100;

      track.style.left = minPercent + '%';
      track.style.right = (100 - maxPercent) + '%';

      const curr = (document.getElementById('val-currency') as HTMLInputElement)?.value || 'USD';
      if (hasMin || hasMax) {
        label.textContent = `${curr} ${new Intl.NumberFormat('es-AR').format(minVal)} - ${curr} ${new Intl.NumberFormat('es-AR').format(maxVal)}`;
        minValHidden.value = minVal.toString();
        maxValHidden.value = maxVal.toString();
      } else {
        label.textContent = 'Cualquier precio';
        minValHidden.value = '';
        maxValHidden.value = '';
      }
    };

    // Slider inputs
    const handleSliderInput = function(this: any) {
      let minVal = parseInt(sliderMin.value);
      let maxVal = parseInt(sliderMax.value);
      const minGap = parseInt(sliderMin.step) || 25000;

      if (maxVal - minVal < minGap) {
        if (this === sliderMin) {
          sliderMin.value = (maxVal - minGap).toString();
          minVal = maxVal - minGap;
        } else {
          sliderMax.value = (minVal + minGap).toString();
          maxVal = minVal + minGap;
        }
      }

      updateSliderFromControls(minVal, maxVal, 'slider', true);
    };

    sliderMin.addEventListener('input', handleSliderInput);
    sliderMax.addEventListener('input', handleSliderInput);
    sliderMin.addEventListener('change', submitForm);
    sliderMax.addEventListener('change', submitForm);

    // Manual inputs change event (fires when leaving input or hitting enter)
    const handleManualInputChange = () => {
      const minLimit = parseInt(sliderMin.min) || 200;
      const maxLimit = parseInt(sliderMax.max) || 2500000;
      let minVal = parseInt(inputMin.value) || minLimit;
      let maxVal = parseInt(inputMax.value) || maxLimit;
      
      if (minVal > maxVal) {
        const temp = minVal;
        minVal = maxVal;
        maxVal = temp;
      }
      
      updateSliderFromControls(minVal, maxVal, 'input', true);
      submitForm();
    };

    inputMin.addEventListener('change', handleManualInputChange);
    inputMax.addEventListener('change', handleManualInputChange);

    // Z-index resolution wrapper hover helper
    if (wrapper) {
      wrapper.addEventListener('mousemove', (e: any) => {
        const rect = wrapper.getBoundingClientRect();
        const percent = (e.clientX - rect.left) / rect.width;
        const min = parseFloat(sliderMin.min);
        const max = parseFloat(sliderMin.max);
        const hoverVal = min + percent * (max - min);

        const distMin = Math.abs(hoverVal - parseFloat(sliderMin.value));
        const distMax = Math.abs(hoverVal - parseFloat(sliderMax.value));

        if (distMin < distMax) {
          sliderMin.style.zIndex = '3';
          sliderMax.style.zIndex = '2';
        } else {
          sliderMin.style.zIndex = '2';
          sliderMax.style.zIndex = '3';
        }
      });
    }
    
    // Sync UI on start
    updateSliderFromControls(parseInt(sliderMin.value), parseInt(sliderMax.value), 'slider', false);
  }

  // Clear button logic
  const clearBtn = document.getElementById('btn-clear');
  if (clearBtn) {
    clearBtn.addEventListener('click', () => {
      const valView = (document.getElementById('val-view') as HTMLInputElement | null)?.value || '';
      window.location.href = '/search-results/' + (valView ? `?view=${valView}` : '');
    });
  }

  // Currency selectors
  document.querySelectorAll('.btn-currency').forEach((btn: any) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.btn-currency').forEach((b: any) => {
        b.classList.remove('bg-primary', 'text-pure-white', 'border-primary');
        b.classList.add('bg-pure-white', 'text-slate-blue', 'border-outline-variant/50');
      });
      btn.classList.add('bg-primary', 'text-pure-white', 'border-primary');
      btn.classList.remove('bg-pure-white', 'text-slate-blue', 'border-outline-variant/50');
      
      const valInput = document.getElementById('val-currency') as HTMLInputElement;
      if (valInput) {
        valInput.value = btn.dataset.val || 'USD';
        
        // Dynamic slider range adjustments on currency toggle
        const isRent = (document.getElementById('val-operation-id') as HTMLInputElement)?.value === '2';
        const isArs = btn.dataset.val === 'ARS';
        
        const sliderMin = document.getElementById('slider-min') as HTMLInputElement | null;
        const sliderMax = document.getElementById('slider-max') as HTMLInputElement | null;
        if (sliderMin && sliderMax) {
          const defaultMinPrice = isRent ? (isArs ? '5000' : '200') : (isArs ? '500000' : '50000');
          const defaultMaxPrice = isRent ? (isArs ? '250000' : '5000') : (isArs ? '50000000' : '2000000');
          const stepVal = isRent ? (isArs ? '5000' : '100') : (isArs ? '100000' : '25000');

          sliderMin.min = defaultMinPrice;
          sliderMin.max = defaultMaxPrice;
          sliderMin.step = stepVal;
          sliderMax.min = defaultMinPrice;
          sliderMax.max = defaultMaxPrice;
          sliderMax.step = stepVal;
          
          sliderMin.value = defaultMinPrice;
          sliderMax.value = defaultMaxPrice;
        }

        submitForm();
      }
    });
  });
</script>

