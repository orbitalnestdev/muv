---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  isDarkHero?: boolean;
}

const { 
  title, 
  description = "MUV Propiedades | Especialistas en propiedades premium y emprendimientos exclusivos en las mejores zonas de Buenos Aires.", 
  isDarkHero = false 
} = Astro.props;
---

<!DOCTYPE html>
<html class="scroll-smooth" lang="es">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>{title}</title>
    <meta name="description" content={description}>
    
    <!-- Open Graph / SEO -->
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="website">
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
</head>
<body class="bg-background text-on-background font-body-md overflow-x-hidden relative">
    <!-- Premium Preloader -->
    <div id="preloader" class="fixed inset-0 bg-[#121212] z-[99999] flex items-center justify-center opacity-100" style="transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1);">
        <div class="relative flex flex-col items-center">
            <!-- Spinner and Logo Group -->
            <div class="relative w-28 h-28 flex items-center justify-center">
                <!-- Outer elegant spinning golden ring (Clockwise) -->
                <div class="absolute w-28 h-28 rounded-full border border-[#C5A059]/10 border-t-[#C5A059]/80 border-r-[#C5A059]/30 animate-spin-clockwise"></div>
                
                <!-- Inner elegant spinning golden ring (Counter-Clockwise) -->
                <div class="absolute w-22 h-22 rounded-full border border-dashed border-[#C5A059]/15 border-b-[#C5A059]/80 animate-spin-counter"></div>
                
                <!-- Inner isotype logo with pulse scaling & gold drop shadow glow -->
                <div class="animate-luxury-breathe relative z-10 flex items-center justify-center">
                    <img 
                      src="/assets/iso_muv.png" 
                      alt="MUV Preloader" 
                      class="w-10 h-10 object-contain brightness-0 invert"
                    />
                </div>
            </div>
        </div>
    </div>

    <!-- Header/Navbar -->
    <Header isDarkHero={isDarkHero} />
    
    <!-- Page Main Content Slot -->
    <slot />
    
    <!-- Footer -->
    <Footer />

    <script is:inline>
      (function() {
        const preloader = document.getElementById('preloader');
        if (preloader) {
          // Disable body scroll initially
          document.body.style.overflow = 'hidden';
          
          const minLoadingTime = 900; 
          const startTime = Date.now();
          
          const fadeOutPreloader = () => {
            const elapsedTime = Date.now() - startTime;
            const delay = Math.max(0, minLoadingTime - elapsedTime);
            
            setTimeout(() => {
              preloader.style.opacity = '0';
              preloader.style.pointerEvents = 'none';
              document.body.style.overflow = '';
              
              setTimeout(() => {
                preloader.remove();
              }, 700);
            }, delay);
          };
          
          if (document.readyState === 'complete') {
            fadeOutPreloader();
          } else {
            window.addEventListener('load', fadeOutPreloader);
            // Backup fallback timeout
            setTimeout(fadeOutPreloader, 4000);
          }
        }
      })();
    </script>
</body>
</html>

<style is:global>
  @keyframes spinClockwise {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes spinCounterClockwise {
    from { transform: rotate(360deg); }
    to { transform: rotate(0deg); }
  }
  @keyframes luxuryBreathe {
    0%, 100% {
      transform: scale(0.94);
      filter: drop-shadow(0 0 6px rgba(197, 160, 89, 0.15));
    }
    50% {
      transform: scale(1.06);
      filter: drop-shadow(0 0 20px rgba(197, 160, 89, 0.55));
    }
  }
  .animate-spin-clockwise {
    animation: spinClockwise 3.5s linear infinite;
  }
  .animate-spin-counter {
    animation: spinCounterClockwise 2.5s linear infinite;
  }
  .animate-luxury-breathe {
    animation: luxuryBreathe 2.5s ease-in-out infinite;
  }
</style>
