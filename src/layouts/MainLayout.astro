---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  isDarkHero?: boolean;
  ogImage?: string;
  robots?: string;
}

const { 
  title, 
  description = "MUV Propiedades | Especialistas en propiedades premium y emprendimientos exclusivos en las mejores zonas de Buenos Aires.", 
  isDarkHero = false,
  ogImage = "/assets/iso_muv.png",
  robots = "index, follow"
} = Astro.props;

// Compute clean canonical URL (excluding query parameters to avoid duplicate content penalties)
const canonicalUrl = new URL(Astro.url.pathname, "https://muvpropiedades.com").href;
const absoluteOgImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, "https://muvpropiedades.com").href;
---

<!DOCTYPE html>
<html class="scroll-smooth" lang="es">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>{title}</title>
    <meta name="description" content={description}>
    <meta name="robots" content={robots}>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/favicon.png?v=4" />
    <link rel="shortcut icon" href="/favicon.ico?v=4" />
    
    <!-- Open Graph / SEO -->
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="website">
    <meta property="og:url" content={canonicalUrl}>
    <meta property="og:image" content={absoluteOgImage}>
    
    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={absoluteOgImage}>
    
    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://wsrv.nl" />


    
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" as="style" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" />
    
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=ac_unit,add_circle,apartment,arrow_back,arrow_forward,arrow_outward,balcony,bathtub,bed,business,calendar_today,chair,check_circle,checkroom,chevron_left,chevron_right,close,construction,deck,desk,domain,error,expand_more,fitness_center,format_list_bulleted,foundation,fullscreen,grid_view,groups,home,image_not_supported,kitchen,layers,local_laundry_service,location_on,mail,map,meeting_room,menu,museum,open_in_new,outdoor_grill,pets,phone_in_talk,photo_library,pool,refresh,roofing,room_service,search,search_off,security,send,share,spa,sports_esports,square_foot,star,streetview,table_restaurant,table_rows,thermostat,tsunami,tune,unfold_more,videocam,view_cozy,view_list,visibility,wb_sunny,wc,yard&display=swap" as="style" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=ac_unit,add_circle,apartment,arrow_back,arrow_forward,arrow_outward,balcony,bathtub,bed,business,calendar_today,chair,check_circle,checkroom,chevron_left,chevron_right,close,construction,deck,desk,domain,error,expand_more,fitness_center,format_list_bulleted,foundation,fullscreen,grid_view,groups,home,image_not_supported,kitchen,layers,local_laundry_service,location_on,mail,map,meeting_room,menu,museum,open_in_new,outdoor_grill,pets,phone_in_talk,photo_library,pool,refresh,roofing,room_service,search,search_off,security,send,share,spa,sports_esports,square_foot,star,streetview,table_restaurant,table_rows,thermostat,tsunami,tune,unfold_more,videocam,view_cozy,view_list,visibility,wb_sunny,wc,yard&display=swap" />
    
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=ac_unit,add_circle,apartment,arrow_back,arrow_forward,arrow_outward,balcony,bathtub,bed,business,calendar_today,chair,check_circle,checkroom,chevron_left,chevron_right,close,construction,deck,desk,domain,error,expand_more,fitness_center,format_list_bulleted,foundation,fullscreen,grid_view,groups,home,image_not_supported,kitchen,layers,local_laundry_service,location_on,mail,map,meeting_room,menu,museum,open_in_new,outdoor_grill,pets,phone_in_talk,photo_library,pool,refresh,roofing,room_service,search,search_off,security,send,share,spa,sports_esports,square_foot,star,streetview,table_restaurant,table_rows,thermostat,tsunami,tune,unfold_more,videocam,view_cozy,view_list,visibility,wb_sunny,wc,yard&display=swap" rel="stylesheet" />
    </noscript>
    
    <!-- Custom Head Injection Slot -->
    <slot name="head" />
</head>
<body class="bg-background text-on-background font-body-md text-body-md overflow-x-hidden relative">
    <!-- Premium Preloader -->
    <div id="preloader" class="fixed inset-0 bg-[#121212] z-[99999] flex items-center justify-center opacity-100" style="transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1);">
        <div class="relative flex flex-col items-center">
            <!-- Spinner and Logo Group -->
            <div class="relative w-28 h-28 flex items-center justify-center">
                <!-- Static elegant background track ring -->
                <div class="absolute w-24 h-24 rounded-full border border-white/5"></div>
                
                <!-- Spinning elegant gold active ring segment -->
                <div class="absolute w-24 h-24 rounded-full border border-transparent border-t-[#e9c176]/80 animate-spin-elegant"></div>
                
                <!-- Glowing golden backdrop behind isotype (GPU-accelerated opacity pulse) -->
                <div class="absolute w-14 h-14 bg-[#e9c176]/15 rounded-full blur-md animate-glow-pulse"></div>
                
                <!-- Inner isotype logo with hardware-accelerated subtle scale pulse -->
                <div class="animate-logo-pulse relative z-10 flex items-center justify-center">
                    <img 
                      src="/assets/iso_muv_opt.webp" 
                      alt="MUV Preloader" 
                      class="w-10 h-10 object-contain brightness-0 invert"
                      width="40"
                      height="40"
                    />
                </div>
            </div>
        </div>
    </div>

    <!-- Header/Navbar -->
    <Header isDarkHero={isDarkHero} />
    
    <!-- Page Main Content Slot -->
    <slot />
    
    <!-- Footer -->
    <Footer />

    <!-- WhatsApp Floating Button -->
    <button 
      id="btn-global-whatsapp" 
      class="fixed bottom-6 right-6 z-50 bg-[#25D366] text-pure-white p-4 rounded-full shadow-lg hover:bg-[#20ba5a] hover:scale-105 active:scale-95 transition-all flex items-center justify-center cursor-pointer border-0 outline-none"
      aria-label="Contactar por WhatsApp"
    >
        <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24">
            <path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 001.333 4.982L2 22l5.233-1.371a9.994 9.994 0 004.78 1.218h.004c5.502 0 9.981-4.479 9.982-9.985A9.97 9.97 0 0012.012 2zm5.72 14.158c-.249.704-1.444 1.353-1.996 1.412-.5.053-1.15.084-3.355-.785-2.82-1.11-4.636-3.977-4.777-4.163-.14-.186-1.139-1.517-1.139-2.89 0-1.373.72-2.048 1.002-2.33.282-.282.61-.353.812-.353h.582c.186 0 .436-.07.68.517.25.597.854 2.083.928 2.235.074.152.124.33.023.533-.1.203-.152.33-.3.504-.15.172-.315.386-.45.517-.15.148-.306.31-.132.61.173.3.77 1.27 1.657 2.059.81.71 1.488.93 1.698 1.037.21.107.33.09.454-.052.124-.144.53-.618.67-.83.14-.21.282-.178.477-.107.195.07 1.24.585 1.455.693.215.108.358.162.41.25.05.09.05.518-.2.122zm0 0"/>
        </svg>
    </button>

    <!-- WhatsApp Modal Dialog -->
    <dialog id="whatsapp-dialog" closedby="any" class="fixed inset-0 m-auto max-w-sm w-[90%] h-fit bg-pure-white rounded-2xl shadow-2xl border border-outline-variant/30 overflow-hidden outline-none p-0 select-none z-[9999]" aria-labelledby="whatsapp-title">
        <div class="flex justify-between items-center px-6 py-4 bg-[#25D366] text-pure-white">
            <div class="flex items-center gap-2">
                <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
                    <path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 001.333 4.982L2 22l5.233-1.371a9.994 9.994 0 004.78 1.218h.004c5.502 0 9.981-4.479 9.982-9.985A9.97 9.97 0 0012.012 2zm5.72 14.158c-.249.704-1.444 1.353-1.996 1.412-.5.053-1.15.084-3.355-.785-2.82-1.11-4.636-3.977-4.777-4.163-.14-.186-1.139-1.517-1.139-2.89 0-1.373.72-2.048 1.002-2.33.282-.282.61-.353.812-.353h.582c.186 0 .436-.07.68.517.25.597.854 2.083.928 2.235.074.152.124.33.023.533-.1.203-.152.33-.3.504-.15.172-.315.386-.45.517-.15.148-.306.31-.132.61.173.3.77 1.27 1.657 2.059.81.71 1.488.93 1.698 1.037.21.107.33.09.454-.052.124-.144.53-.618.67-.83.14-.21.282-.178.477-.107.195.07 1.24.585 1.455.693.215.108.358.162.41.25.05.09.05.518-.2.122zm0 0"/>
                </svg>
                <h3 id="whatsapp-title" class="font-sans font-bold text-base">Iniciar conversación</h3>
            </div>
            <button type="button" id="whatsapp-close" class="text-pure-white hover:text-white/80 transition-colors cursor-pointer border-0 bg-transparent flex items-center justify-center outline-none" aria-label="Cerrar modal">
                <span class="material-symbols-outlined text-[22px]">close</span>
            </button>
        </div>
        <form id="whatsapp-form" class="p-6 space-y-4">
            <div class="space-y-1.5 text-left">
                <label for="whatsapp-user-name" class="block text-xs font-bold text-secondary uppercase tracking-wider font-sans">Por favor, ingresá tu nombre:</label>
                <input 
                  type="text" 
                  id="whatsapp-user-name" 
                  required 
                  placeholder="Tu nombre completo" 
                  class="w-full border border-outline-variant/35 bg-pure-white rounded-lg px-3 py-2.5 focus:ring-1 focus:ring-primary focus:border-primary outline-none text-sm text-primary placeholder:text-outline/40 font-sans"
                />
            </div>
            <button 
              type="submit" 
              class="w-full bg-[#25D366] text-pure-white hover:bg-[#20ba5a] py-3.5 rounded-lg font-sans text-xs font-bold uppercase tracking-wider transition-all duration-300 text-center shadow-md flex items-center justify-center gap-2 cursor-pointer border-0 outline-none hover:scale-[1.01] active:scale-[0.99]"
            >
                <span>Continuar a WhatsApp</span>
                <span class="material-symbols-outlined text-[16px]">send</span>
            </button>
        </form>
    </dialog>

    <script is:inline>
      (function() {
        const preloader = document.getElementById('preloader');
        if (preloader) {
          // Disable body scroll initially
          document.body.style.overflow = 'hidden';
          
          const minLoadingTime = 900; 
          const startTime = Date.now();
          
          const fadeOutPreloader = () => {
            const elapsedTime = Date.now() - startTime;
            const delay = Math.max(0, minLoadingTime - elapsedTime);
            
            setTimeout(() => {
              preloader.style.opacity = '0';
              preloader.style.pointerEvents = 'none';
              document.body.style.overflow = '';
              
              setTimeout(() => {
                preloader.remove();
              }, 700);
            }, delay);
          };
          
          if (document.readyState === 'interactive' || document.readyState === 'complete') {
            fadeOutPreloader();
          } else {
            window.addEventListener('DOMContentLoaded', fadeOutPreloader);
            // Backup fallback timeout
            setTimeout(fadeOutPreloader, 1500);
          }
        }
      })();

      // WhatsApp global click & submit script
      (function() {
        const btn = document.getElementById('btn-global-whatsapp');
        const dialog = document.getElementById('whatsapp-dialog');
        const closeBtn = document.getElementById('whatsapp-close');
        const form = document.getElementById('whatsapp-form');
        const nameInput = document.getElementById('whatsapp-user-name');

        if (!btn || !dialog) return;

        btn.addEventListener('click', () => {
          dialog.showModal();
          setTimeout(() => {
            if (nameInput) nameInput.focus();
          }, 100);
        });

        if (closeBtn) {
          closeBtn.addEventListener('click', () => {
            dialog.close();
          });
        }

        if (form) {
          form.addEventListener('submit', (e) => {
            e.preventDefault();
            const nameVal = nameInput ? nameInput.value.trim() : '';
            if (!nameVal) return;

            let text = `Hola! Soy ${nameVal}. Quisiera hacer una consulta sobre propiedades.`;
            const pageInfo = document.getElementById('whatsapp-page-info');
            let waPhone = '5491122862000';
            if (pageInfo) {
              const title = pageInfo.getAttribute('data-title') || '';
              const id = pageInfo.getAttribute('data-id') || '';
              const isDevelopment = pageInfo.getAttribute('data-is-development') === 'true';
              if (isDevelopment) {
                waPhone = '5491155796447';
              }
              text = `Hola, me interesa la propiedad ${title} (ID: ${id}) que vi en el sitio web. Mi nombre es ${nameVal}.`;
            }

            const waUrl = `https://wa.me/${waPhone}?text=${encodeURIComponent(text)}`;
            
            // Bypass popup blockers in mobile WebViews (Instagram, Facebook ads) and mobile browsers
            if (/Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent)) {
              window.location.href = waUrl;
            } else {
              window.open(waUrl, '_blank', 'noopener,noreferrer');
            }
            
            dialog.close();
            if (nameInput) nameInput.value = '';
          });
        }

        // Fallback for click outside (light-dismiss) on Safari or older browsers
        if (!('closedBy' in HTMLDialogElement.prototype)) {
          dialog.addEventListener('click', (event) => {
            if (event.target !== dialog) return;
            const rect = dialog.getBoundingClientRect();
            const isDialogContent = (
              rect.top <= event.clientY &&
              event.clientY <= rect.top + rect.height &&
              rect.left <= event.clientX &&
              event.clientX <= rect.left + rect.width
            );
            if (!isDialogContent) {
              dialog.close();
            }
          });
        }
      })();
    </script>
</body>
</html>

<style is:global>
  @keyframes spinElegant {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  @keyframes glowPulse {
    0%, 100% {
      opacity: 0.25;
      transform: scale(0.92);
    }
    50% {
      opacity: 0.8;
      transform: scale(1.15);
    }
  }
  @keyframes logoPulse {
    0%, 100% {
      transform: scale(0.96);
    }
    50% {
      transform: scale(1.04);
    }
  }
  .animate-spin-elegant {
    animation: spinElegant 1.5s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    will-change: transform;
  }
  .animate-glow-pulse {
    animation: glowPulse 2.5s ease-in-out infinite;
    will-change: opacity, transform;
  }
  .animate-logo-pulse {
    animation: logoPulse 2.5s ease-in-out infinite;
    will-change: transform;
  }

  /* dialog styling & animations */
  dialog::backdrop {
    background-color: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  
  dialog[open] {
    animation: dialogFadeIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  
  @keyframes dialogFadeIn {
    from { opacity: 0; transform: scale(0.95) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
</style>
