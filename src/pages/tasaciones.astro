---
import MainLayout from '../layouts/MainLayout.astro';
import CountryPhoneSelector from '../components/CountryPhoneSelector.astro';
---

<MainLayout 
  title="Tasaciones | MUV Propiedades" 
  description="Solicitá tu tasación rápida, precisa y profesional con MUV Propiedades. Valuamos tu inmueble con rigurosidad y el mejor conocimiento del mercado de real estate."
  isDarkHero={false}
>
  <main class="bg-pure-white">
    <!-- Hero Section: Header with M Isotype Watermark -->
    <section class="relative bg-black pt-44 pb-20 overflow-hidden flex items-center min-h-[260px]">
      <!-- Watermark M logo -->
      <div class="absolute right-0 top-20 h-[calc(100%-5rem)] w-1/2 opacity-20 pointer-events-none select-none">
        <img 
          src="/assets/iso_muv_opt.webp" 
          alt="Watermark" 
          class="absolute bottom-0 right-6 md:right-16 h-full w-auto object-contain brightness-0 invert"
          width="160"
          height="160"
        />
      </div>
      
      <div class="relative z-10 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto w-full text-left">
        <h1 class="font-display-lg text-3xl md:text-4xl text-pure-white leading-tight font-medium tracking-tight">
          Tasaciones rápidas y seguras
        </h1>
      </div>
    </section>

    <!-- Content Split Grid: Info vs Form -->
    <section class="py-16 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start text-left">
        
        <!-- Left Column: conocé el valor real -->
        <div class="md:col-span-7 space-y-6">
          <h2 class="font-sans font-[300] md:text-[35px] text-2xl text-primary tracking-tight leading-tight">
            Conocé el valor real de tu propiedad
          </h2>
          <div class="space-y-4 text-xs md:text-sm text-secondary leading-relaxed">
            <p>
              Entendemos que es fundamental contar con una tasación precisa y confiable al momento de vender. En MUV brindamos información clara y profesional para que puedas avanzar con seguridad, tanto en propiedades residenciales como comerciales.
            </p>
            <p>
              Cada tasación contempla los factores clave que definen el valor de un inmueble: ubicación, superficie, zonificación, estado general y valores comparativos de mercado.
            </p>
            <p>
              Nuestro equipo realiza una valoración real, competitiva y transparente.
            </p>
          </div>
        </div>

        <!-- Right Column: Inquiry Form -->
        <div class="md:col-span-5 space-y-6 bg-pure-white md:p-2">
          <h3 class="font-headline-lg text-sm md:text-base text-primary font-bold leading-snug">
            Contactanos y tasá tu propiedad con respaldo profesional.
          </h3>
          
          <!-- Inquiry Form -->
          <form id="tasacion-form" class="space-y-4">
            <!-- Status Notification Box -->
            <div id="form-status" class="hidden p-4 rounded-xl text-xs font-semibold select-none mb-4"></div>

            <!-- Input: Nombre -->
            <div>
              <input 
                type="text" 
                id="name"
                name="name"
                placeholder="Nombre" 
                required
                class="w-full px-6 py-3 border border-outline-variant/40 rounded-full focus:outline-none focus:border-primary text-sm bg-transparent transition-all duration-300"
              />
            </div>

            <!-- Input: Email -->
            <div>
              <input 
                type="email" 
                id="email"
                name="email"
                placeholder="Email" 
                required
                class="w-full px-6 py-3 border border-outline-variant/40 rounded-full focus:outline-none focus:border-primary text-sm bg-transparent transition-all duration-300"
              />
            </div>

            <!-- Input: Teléfono with country code selector -->
            <CountryPhoneSelector 
              phoneId="phone" 
              countryId="country-code" 
              placeholder="Teléfono" 
              required={true}
              containerClass="border border-outline-variant/40 rounded-full px-5 py-2.5 focus-within:border-primary transition-all duration-300"
              inputClass="pl-3.5"
            />

            <!-- Input: Mensaje -->
            <div>
              <textarea 
                id="message"
                name="message"
                placeholder="Mensaje" 
                rows="5"
                required
                class="w-full px-6 py-4 border border-outline-variant/40 rounded-3xl focus:outline-none focus:border-primary text-sm bg-transparent resize-none transition-all duration-300"
              ></textarea>
            </div>

            <!-- Submit Button -->
            <div class="pt-2">
              <button 
                type="submit" 
                class="bg-black text-pure-white hover:bg-black/90 px-10 py-3 rounded-full text-xs font-bold uppercase tracking-wider transition-all duration-300 active:scale-95 cursor-pointer"
              >
                Enviar
              </button>
            </div>
          </form>
        </div>

        <script>
          const form = document.getElementById('tasacion-form') as HTMLFormElement;
          const statusBox = document.getElementById('form-status');
          const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

          if (form && statusBox && submitBtn) {
            form.addEventListener('submit', async (e) => {
              e.preventDefault();

              // Clear previous states
              statusBox.className = 'hidden p-4 rounded-xl text-xs font-semibold select-none mb-4';
              statusBox.innerHTML = '';
              
              const name = (form.querySelector('#name') as HTMLInputElement).value;
              const email = (form.querySelector('#email') as HTMLInputElement).value;
              const countryCode = (form.querySelector('#country-code') as HTMLSelectElement).value;
              const phoneVal = (form.querySelector('#phone') as HTMLInputElement).value;
              const textVal = (form.querySelector('#message') as HTMLTextAreaElement).value;

              // 1. Audit and validate phone number
              let digits = phoneVal.replace(/\D/g, '');
              
              // Strip country code if manually input
              if (digits.startsWith(countryCode)) {
                digits = digits.substring(countryCode.length);
              }
              // Strip leading 0
              if (digits.startsWith('0')) {
                digits = digits.substring(1);
              }

              if (countryCode === '54') {
                // Mobile '15' prefix handling (e.g. 11 15... or 341 15...)
                if (digits.substring(2, 4) === '15') {
                  digits = digits.substring(0, 2) + digits.substring(4);
                } else if (digits.substring(3, 5) === '15') {
                  digits = digits.substring(0, 3) + digits.substring(5);
                } else if (digits.substring(4, 6) === '15') {
                  digits = digits.substring(0, 4) + digits.substring(6);
                }

                // Error if they only typed 15 followed by a number without area code
                if (digits.startsWith('15')) {
                  statusBox.classList.remove('hidden');
                  statusBox.classList.add('bg-red-100', 'text-red-800');
                  statusBox.innerHTML = '<span class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">error</span>Por favor, incluya el código de área (ej: 11 para Buenos Aires) en lugar del prefijo 15.</span>';
                  return;
                }

                // Argentine numbers must be exactly 10 digits (or 11 if starting with mobile prefix '9')
                if (digits.length !== 10 && !(digits.length === 11 && digits.startsWith('9'))) {
                  statusBox.classList.remove('hidden');
                  statusBox.classList.add('bg-red-100', 'text-red-800');
                  statusBox.innerHTML = '<span class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">error</span>El teléfono debe incluir código de área y tener 10 dígitos (ej: 11 2345 6789).</span>';
                  return;
                }
              } else {
                // General international number format validation (6 to 14 digits)
                if (digits.length < 6 || digits.length > 14) {
                  statusBox.classList.remove('hidden');
                  statusBox.classList.add('bg-red-100', 'text-red-800');
                  statusBox.innerHTML = '<span class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">error</span>Por favor ingrese un número de teléfono válido.</span>';
                  return;
                }
              }

              const phone = `+${countryCode} ${digits}`;
              const text = `[Pedido de Tasación]: ${textVal}`;

              // Toggle pending state
              const originalBtnText = submitBtn.innerHTML;
              submitBtn.innerHTML = 'Enviando...';
              submitBtn.disabled = true;
              submitBtn.classList.add('opacity-70', 'cursor-not-allowed');

              try {
                const response = await fetch('/api/lead', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/json'
                  },
                  body: JSON.stringify({ name, email, phone, text })
                });

                const result = await response.json();

                if (!response.ok) {
                  throw new Error(result.error || 'Hubo un error al procesar la tasación.');
                }

                // Show Success
                statusBox.classList.remove('hidden');
                statusBox.classList.add('bg-green-100', 'text-green-800');
                statusBox.innerHTML = '<span class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">check_circle</span>Pedido de tasación enviado con éxito. Nos contactaremos a la brevedad.</span>';
                form.reset();
              } catch (err: any) {
                // Show Error
                statusBox.classList.remove('hidden');
                statusBox.classList.add('bg-red-100', 'text-red-800');
                statusBox.innerHTML = `<span class="flex items-center gap-2"><span class="material-symbols-outlined text-[16px]">error</span>${err.message || 'Error de conexión.'}</span>`;
              } finally {
                // Restore button state
                submitBtn.innerHTML = originalBtnText;
                submitBtn.disabled = false;
                submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
              }
            });
          }
        </script>

      </div>
    </section>
  </main>
</MainLayout>
