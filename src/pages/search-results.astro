---
import MainLayout from '../layouts/MainLayout.astro';
import SearchFilters from '../components/SearchFilters.astro';
import PropertyGrid from '../components/PropertyGrid.astro';
import { getProperties } from '../lib/tokko';

// Extract query parameters from URL
const url = Astro.url;
const view = url.searchParams.get('view') || 'map'; // 'map' is default!

const q = url.searchParams.get('q') || '';
const location = url.searchParams.get('location') || '';
const operationId = url.searchParams.get('operation_id') || '';
const propertyTypeId = url.searchParams.get('property_type_id') || '';
const priceMin = url.searchParams.get('price_min') || '';
const priceMax = url.searchParams.get('price_max') || '';
const currency = url.searchParams.get('currency') || '';
const rooms = url.searchParams.get('rooms') || '';
const bedrooms = url.searchParams.get('bedrooms') || '';
const bathrooms = url.searchParams.get('bathrooms') || '';
const garage = url.searchParams.get('garage') || '';
const surfaceMin = url.searchParams.get('surface_min') || '';
const surfaceMax = url.searchParams.get('surface_max') || '';
const amenities = url.searchParams.getAll('amenities') || [];
const currentPage = Number(url.searchParams.get('page') || '1');

// Fetch all properties to get the complete list of unique neighborhoods for filters
const { properties: allPropertiesForBarrios } = await getProperties();
const allNeighborhoods = Array.from(new Set(allPropertiesForBarrios.map(p => p.location?.name?.trim()).filter(Boolean))).sort((a, b) => a.localeCompare(b, 'es'));

// Fetch properties
// For Map view we need all properties to filter client-side.
// We get the full list of properties.
const searchFilters = view === 'map' ? {} : {
  q,
  location,
  operation_id: operationId,
  property_type_id: propertyTypeId,
  price_min: priceMin,
  price_max: priceMax,
  currency,
  rooms,
  bedrooms,
  bathrooms,
  garage,
  surface_min: surfaceMin,
  surface_max: surfaceMax,
  amenities
};
const { properties, total } = await getProperties(searchFilters);

// Calculate pagination (for grid/list view)
const limit = 6; // items per page
const startIndex = (currentPage - 1) * limit;
const endIndex = startIndex + limit;
const paginatedProperties = properties.slice(startIndex, endIndex);
const totalPages = Math.ceil(properties.length / limit) || 1;

// Active chips labels helper (for grid/list view)
interface ActiveChip {
  key: string;
  value?: string;
  label: string;
}
const activeChips: ActiveChip[] = [];
if (q) activeChips.push({ key: 'q', label: `Búsqueda: "${q}"` });
if (location) activeChips.push({ key: 'location', label: `Barrio: ${location}` });
if (operationId === '1') activeChips.push({ key: 'operation_id', label: 'Venta' });
if (operationId === '2') activeChips.push({ key: 'operation_id', label: 'Alquiler' });
if (propertyTypeId === '2') activeChips.push({ key: 'property_type_id', label: 'Departamento' });
if (propertyTypeId === '3') activeChips.push({ key: 'property_type_id', label: 'Casa' });
if (propertyTypeId === '13') activeChips.push({ key: 'property_type_id', label: 'PH' });
if (propertyTypeId === '7') activeChips.push({ key: 'property_type_id', label: 'Local' });
if (propertyTypeId === '5') activeChips.push({ key: 'property_type_id', label: 'Oficina' });
if (propertyTypeId === '1') activeChips.push({ key: 'property_type_id', label: 'Terreno' });
const isRent = operationId === '2';
const defaultMinPrice = isRent ? '200' : '50000';
const defaultMaxPrice = isRent ? '5000' : '2000000';
const priceSymbol = currency === 'ARS' ? '$' : 'USD';

if (priceMin && priceMin !== defaultMinPrice) activeChips.push({ key: 'price_min', label: `Desde ${priceSymbol} ${new Intl.NumberFormat('es-AR').format(Number(priceMin))}` });
if (priceMax && priceMax !== defaultMaxPrice) activeChips.push({ key: 'price_max', label: `Hasta ${priceSymbol} ${new Intl.NumberFormat('es-AR').format(Number(priceMax))}` });
if (url.searchParams.has('currency')) activeChips.push({ key: 'currency', label: `Moneda: ${currency}` });
if (rooms) activeChips.push({ key: 'rooms', label: `${rooms} Ambientes` });
if (bedrooms) activeChips.push({ key: 'bedrooms', label: `${bedrooms} Dormitorios` });
if (bathrooms) activeChips.push({ key: 'bathrooms', label: `${bathrooms} Baños` });
if (garage) activeChips.push({ key: 'garage', label: `${garage} Cocheras` });
if (surfaceMin) activeChips.push({ key: 'surface_min', label: `Sup. Mín: ${surfaceMin} m²` });
if (surfaceMax) activeChips.push({ key: 'surface_max', label: `Sup. Máx: ${surfaceMax} m²` });

if (Array.isArray(amenities)) {
  amenities.forEach(am => {
    activeChips.push({ key: 'amenities', value: am, label: am });
  });
}

// Dynamic Title and SEO Title Helper
let pageTitle = 'Propiedades Residenciales';
let seoTitle = 'Propiedades Residenciales | MUV Propiedades';

if (operationId === '1') {
  pageTitle = 'Propiedades en Venta';
  seoTitle = 'Propiedades en Venta | MUV Propiedades';
} else if (operationId === '2') {
  pageTitle = 'Propiedades en Alquiler';
  seoTitle = 'Propiedades en Alquiler | MUV Propiedades';
}

if (location) {
  pageTitle += ` en ${location}`;
  seoTitle = `${pageTitle} | MUV Propiedades`;
}

let seoDescription = "Buscador de propiedades de MUV Propiedades. Encontrá departamentos, casas y oficinas de categoría en las zonas más exclusivas de Buenos Aires.";
if (operationId === '1') {
  seoDescription = "Encontrá las mejores propiedades en venta en Buenos Aires. Departamentos, casas y desarrollos de categoría con MUV Propiedades.";
} else if (operationId === '2') {
  seoDescription = "Explorá las mejores propiedades en alquiler en Buenos Aires. Departamentos y oficinas premium en alquiler con MUV Propiedades.";
}

if (location) {
  seoDescription += ` Disponibles en ${location} y zonas de influencia.`;
}

// Generate URL preserving other params but changing view
function getLayoutUrl(newView: string) {
  const newUrl = new URL(url);
  newUrl.searchParams.set('view', newView);
  return newUrl.pathname + newUrl.search;
}
---

<MainLayout title={seoTitle} description={seoDescription} isDarkHero={false}>
  {view === 'grid' || view === 'list' ? (
    <!-- GRID & LIST LAYOUT -->
    <main class="pt-32 min-h-[70vh] bg-surface">
        <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto space-y-8 pb-24 font-sans">
            
            <!-- Page Banner Header -->
            <div class="text-left space-y-2">
                <h1 class="font-sans font-[300] md:text-[35px] text-2xl text-primary leading-tight tracking-tight">{pageTitle}</h1>
                <div class="w-12 h-[3px] bg-[#121212]"></div>
            </div>

            <!-- Main Split Layout -->
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter items-start">
                
                <!-- Desktop Sidebar Filters -->
                <aside class="hidden lg:block lg:col-span-3 bg-pure-white p-6 border border-outline-variant/30 rounded-lg shadow-sm sticky top-28">
                    <h2 class="font-headline-md text-sm text-primary font-bold mb-4 uppercase tracking-wider">Filtros de búsqueda</h2>
                    <SearchFilters />
                </aside>

                <!-- Mobile Sticky Filter Button Trigger -->
                <div class="lg:hidden sticky top-[72px] z-30 flex justify-between items-center bg-pure-white/95 backdrop-blur-md p-4 border border-outline-variant/30 rounded shadow-sm w-full select-none">
                    <span class="text-xs font-semibold text-secondary uppercase">{total} propiedades encontradas</span>
                    <button 
                      id="btn-mobile-filters" 
                      class="bg-primary text-pure-white px-4 py-2 rounded text-xs font-bold uppercase tracking-wider flex items-center gap-2 active:scale-95 transition-all cursor-pointer"
                    >
                        <span class="material-symbols-outlined text-[16px]">tune</span>
                        <span>Filtros</span>
                    </button>
                </div>

                <!-- Properties List Column -->
                <div class="lg:col-span-9 space-y-6">
                    
                    <!-- Search summary, layout toggle and active chips row -->
                    <div class="flex flex-col gap-4 w-full">
                        <div class="flex items-center justify-between w-full">
                            <div class="hidden lg:block text-xs font-semibold text-secondary uppercase">
                                {total} propiedades encontradas
                            </div>
                            <!-- Layout Switcher Toggle (Grid vs List vs Map) -->
                            <div class="flex items-center gap-1 bg-surface-container-low border border-outline-variant/30 rounded-lg p-0.5 select-none">
                                <button 
                                  type="button" 
                                  id="btn-layout-grid" 
                                  class:list={[
                                    "w-8 h-8 rounded-md flex items-center justify-center transition-all",
                                    view === 'list' ? "text-secondary hover:text-primary" : "bg-primary text-pure-white"
                                  ]}
                                  aria-label="Vista cuadrícula"
                                >
                                    <span class="material-symbols-outlined text-[18px]">grid_view</span>
                                </button>
                                <button 
                                  type="button" 
                                  id="btn-layout-list" 
                                  class:list={[
                                    "w-8 h-8 rounded-md flex items-center justify-center transition-all",
                                    view === 'list' ? "bg-primary text-pure-white" : "text-secondary hover:text-primary"
                                  ]}
                                  aria-label="Vista lista"
                                >
                                    <span class="material-symbols-outlined text-[18px]">format_list_bulleted</span>
                                </button>
                                <a 
                                  href={getLayoutUrl('map')} 
                                  id="btn-layout-map" 
                                  class="w-8 h-8 rounded-md flex items-center justify-center transition-all text-secondary hover:text-primary" 
                                  aria-label="Vista mapa"
                                >
                                    <span class="material-symbols-outlined text-[18px]">map</span>
                                </a>
                            </div>
                        </div>
                        
                        <!-- Active filters tags -->
                        {activeChips.length > 0 && (
                            <div class="flex flex-wrap gap-2 items-center">
                                <span class="text-[10px] uppercase font-bold text-secondary tracking-wider">Filtros:</span>
                                {activeChips.map((chip) => (
                                    <button 
                                      class="chip-remove bg-surface-container-high text-primary px-3 py-1.5 rounded-xl text-xs font-semibold flex items-center gap-1 hover:bg-[#C5A880] hover:text-pure-white transition-colors"
                                      data-key={chip.key}
                                      data-value={chip.value || ''}
                                    >
                                        <span>{chip.label}</span>
                                        <span class="material-symbols-outlined text-[14px]">close</span>
                                    </button>
                                ))}
                            </div>
                        )}
                    </div>

                    <!-- Property Cards Grid -->
                    <PropertyGrid 
                      properties={paginatedProperties} 
                      currentPage={currentPage} 
                      totalPages={totalPages} 
                    />
                </div>
            </div>
        </div>
    </main>

    <!-- Mobile Drawer Modal for Filters -->
    <div id="mobile-drawer" class="fixed inset-0 z-[60] bg-black/50 backdrop-blur-sm hidden select-none">
        <div class="fixed top-0 right-0 bottom-0 w-80 bg-pure-white p-6 flex flex-col space-y-6 shadow-2xl overflow-y-auto">
            <div class="flex justify-between items-center pb-4 border-b border-outline-variant/30">
                <span class="font-headline-md text-sm text-primary font-bold uppercase">Filtrar búsqueda</span>
                <span class="material-symbols-outlined cursor-pointer text-primary" id="btn-close-drawer">close</span>
            </div>
            <SearchFilters />
        </div>
    </div>
  ) : (
    <!-- MAP SPLIT LAYOUT (Default) -->
    <!-- Leaflet CSS and JS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

    <main id="map-page-main" class="min-h-screen pt-[72px] bg-surface flex flex-col lg:flex-row mobile-list-active font-sans">
      
      <!-- Left Column: Map -->
      <section id="map-section" class="w-full lg:w-1/2 lg:sticky lg:top-[72px] lg:h-[calc(100vh-72px)] h-[35vh] relative shrink-0">
        <!-- Map Loader Overlay -->
        <div id="map-loader" class="absolute inset-0 bg-pure-white z-[2000] flex flex-col items-center justify-center transition-opacity duration-500">
          <div class="w-10 h-10 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
          <p class="mt-4 font-sans text-xs font-bold uppercase tracking-widest text-primary">Cargando mapa interactivo...</p>
        </div>
        <div id="map" class="w-full h-full"></div>

        <!-- Search in this area button -->
        <button 
          id="btn-search-here" 
          class="absolute top-20 left-1/2 -translate-x-1/2 z-[1000] bg-pure-white text-primary border border-outline-variant/50 px-4 py-2 rounded-full text-xs font-bold uppercase tracking-wider shadow-md hover:bg-surface transition-all active:scale-95 hidden items-center gap-1.5 cursor-pointer font-sans"
        >
          <span class="material-symbols-outlined text-[16px] text-primary select-none pointer-events-none">refresh</span>
          Buscar en esta zona
        </button>

        <!-- Map Floating Overlays -->
        <!-- Top Row Controls -->
        <div class="absolute top-4 right-4 z-[1000] flex items-center gap-2 select-none pointer-events-auto">
          <!-- Map Type Select -->
          <div class="relative bg-[#121212]/85 border border-white/20 text-pure-white rounded pl-2.5 pr-8 py-1.5 flex items-center gap-1.5 text-xs font-semibold cursor-pointer shadow-md">
            <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
            </svg>
            <select id="map-layer-select" class="bg-transparent outline-none cursor-pointer text-pure-white font-bold uppercase tracking-wider text-[10px] appearance-none !bg-none border-0 p-0 focus:ring-0">
              <option value="calle" class="text-primary bg-pure-white font-bold">Calle</option>
              <option value="satelite" class="text-primary bg-pure-white font-bold">Satélite</option>
              <option value="terreno" class="text-primary bg-pure-white font-bold">Terreno</option>
            </select>
            <span class="material-symbols-outlined text-[14px] text-white/80 absolute right-2 pointer-events-none">expand_more</span>
          </div>

          <!-- Navigation Buttons -->
          <button id="btn-prev-marker" class="bg-[#121212]/85 border border-white/20 text-pure-white text-[10px] font-bold uppercase tracking-wider px-3 py-2 rounded flex items-center gap-1 hover:bg-[#C5A059] transition-all shadow-md active:scale-95">
            <span class="material-symbols-outlined text-[14px]">chevron_left</span>
            Anterior
          </button>
          <button id="btn-next-marker" class="bg-[#121212]/85 border border-white/20 text-pure-white text-[10px] font-bold uppercase tracking-wider px-3 py-2 rounded flex items-center gap-1 hover:bg-[#C5A059] transition-all shadow-md active:scale-95">
            Siguiente
            <span class="material-symbols-outlined text-[14px]">chevron_right</span>
          </button>
        </div>

        <!-- Bottom Row Info -->
        <div id="map-listings-counter" class="absolute bottom-4 left-4 z-[1000] bg-[#121212]/85 text-pure-white text-[9px] font-bold uppercase tracking-wider px-3.5 py-2 rounded shadow-md border border-white/10 select-none pointer-events-none">
          Mostrando 0 de 0 propiedades
        </div>

        <!-- Fullscreen Toggle Button -->
        <button id="btn-fullscreen-map" class="absolute bottom-4 right-4 z-[1000] bg-[#121212]/85 border border-white/10 text-pure-white text-[9.5px] font-bold uppercase tracking-widest px-4 py-2.5 rounded shadow-md flex items-center gap-1.5 hover:bg-[#C5A059] transition-all pointer-events-auto active:scale-95">
          <span class="material-symbols-outlined text-[14px]">fullscreen</span>
          Pantalla Completa
        </button>
      </section>

      <!-- Right Column: Sidebar Filters & Horizontal Properties List -->
      <section id="list-section" class="w-full lg:w-1/2 flex flex-col bg-surface border-t lg:border-t-0 lg:border-l border-outline-variant/30 shrink-0">
        
        <!-- Top Filters Container with horizontal pills -->
        <div class="bg-pure-white border-b border-outline-variant/30 px-5 py-4 shrink-0 z-20 shadow-sm relative select-none">
          
          <!-- Row 0: Title and Layout Switcher -->
          <div class="flex items-center justify-between mb-4 pb-2 border-b border-outline-variant/15 font-sans">
            <h1 id="map-page-title" class="font-sans text-xs md:text-sm font-bold text-primary tracking-wider uppercase">
              Mapa de Propiedades
            </h1>
            <div class="flex items-center gap-1 bg-surface-container-low border border-outline-variant/30 rounded-lg p-0.5 select-none">
                <a 
                  href={getLayoutUrl('grid')} 
                  id="btn-map-layout-grid" 
                  class="w-8 h-8 rounded-md flex items-center justify-center transition-all text-secondary hover:text-primary" 
                  aria-label="Vista cuadrícula"
                >
                    <span class="material-symbols-outlined text-[18px]">grid_view</span>
                </a>
                <a 
                  href={getLayoutUrl('list')} 
                  id="btn-map-layout-list" 
                  class="w-8 h-8 rounded-md flex items-center justify-center transition-all text-secondary hover:text-primary" 
                  aria-label="Vista lista"
                >
                    <span class="material-symbols-outlined text-[18px]">format_list_bulleted</span>
                </a>
                <button 
                  type="button" 
                  class="w-8 h-8 rounded-md flex items-center justify-center transition-all bg-primary text-pure-white cursor-default" 
                  aria-label="Vista mapa"
                >
                    <span class="material-symbols-outlined text-[18px]">map</span>
                </button>
            </div>
          </div>

          <!-- Row 1: Keyword Search Bar with Ajax -->
          <div class="relative flex items-center mb-4">
            <span class="material-symbols-outlined text-secondary/50 absolute left-4 pointer-events-none">search</span>
            <input 
              type="text" 
              id="filter-keyword" 
              placeholder="Buscar por dirección, título o descripción..." 
              class="w-full pl-11 pr-10 py-2.5 text-sm rounded-xl border border-outline-variant/40 focus:border-primary focus:outline-none bg-surface/30 font-sans transition-all duration-300" 
            />
            <button 
              type="button" 
              id="btn-clear-keyword" 
              class="absolute right-4 text-secondary/40 hover:text-secondary hidden"
              aria-label="Limpiar búsqueda"
            >
              <span class="material-symbols-outlined text-[18px]">close</span>
            </button>
          </div>

          <!-- Row 2: Filter Pills Row -->
          <div class="flex flex-wrap items-center gap-2 relative" id="filter-pills-row">
            
            <!-- Pill: Operación -->
            <div class="static sm:relative filter-pill-wrapper">
              <button type="button" class="filter-pill flex items-center gap-1.5 px-4 py-2 rounded-full border border-outline-variant/50 text-xs font-semibold text-secondary bg-pure-white hover:border-primary transition-all duration-200" data-dropdown="dropdown-operation">
                <span id="pill-label-operation">Operación</span>
                <span class="material-symbols-outlined text-[16px] text-primary">expand_more</span>
              </button>
              <div id="dropdown-operation" class="filter-dropdown absolute top-full left-0 right-0 mx-auto sm:mx-0 sm:right-auto mt-2 w-[calc(100vw-40px)] sm:w-48 bg-pure-white border border-outline-variant/30 rounded-lg shadow-lg z-50 hidden p-2 space-y-0.5 animate-fade-in">
                <button type="button" class="btn-select-op w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="">Cualquiera</button>
                <button type="button" class="btn-select-op w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="1">Venta</button>
                <button type="button" class="btn-select-op w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="2">Alquiler</button>
              </div>
            </div>

            <!-- Pill: Barrio -->
            <div class="static sm:relative filter-pill-wrapper">
              <button type="button" class="filter-pill flex items-center gap-1.5 px-4 py-2 rounded-full border border-outline-variant/50 text-xs font-semibold text-secondary bg-pure-white hover:border-primary transition-all duration-200" data-dropdown="dropdown-barrio">
                <span id="pill-label-barrio">Barrio</span>
                <span class="material-symbols-outlined text-[16px] text-primary">expand_more</span>
              </button>
              <div id="dropdown-barrio" class="filter-dropdown absolute top-full left-0 right-0 mx-auto sm:mx-0 sm:right-auto mt-2 w-[calc(100vw-40px)] sm:w-64 bg-pure-white border border-outline-variant/30 rounded-lg shadow-lg z-50 hidden p-3 space-y-3 animate-fade-in">
                <div class="max-h-60 overflow-y-auto space-y-2 scrollbar-thin" id="barrio-options-container" data-all-barrios={JSON.stringify(allNeighborhoods)}>
                </div>
                <div class="border-t border-outline-variant/20 pt-2 flex justify-between items-center">
                  <button type="button" class="btn-clear-barrio text-[10px] font-bold text-secondary hover:text-primary transition-colors">Limpiar</button>
                  <button type="button" class="btn-apply-barrio bg-primary text-pure-white text-[10px] font-bold uppercase tracking-wider px-3 py-1.5 rounded-lg transition-all hover:bg-[#121212] hover:text-pure-white active:scale-95">Aplicar</button>
                </div>
              </div>
            </div>

            <!-- Pill: Propiedad -->
            <div class="static sm:relative filter-pill-wrapper">
              <button type="button" class="filter-pill flex items-center gap-1.5 px-4 py-2 rounded-full border border-outline-variant/50 text-xs font-semibold text-secondary bg-pure-white hover:border-primary transition-all duration-200" data-dropdown="dropdown-type">
                <span id="pill-label-type">Propiedad</span>
                <span class="material-symbols-outlined text-[16px] text-primary">expand_more</span>
              </button>
              <div id="dropdown-type" class="filter-dropdown absolute top-full left-0 right-0 mx-auto sm:mx-0 sm:right-auto mt-2 w-[calc(100vw-40px)] sm:w-56 bg-pure-white border border-outline-variant/30 rounded-lg shadow-lg z-50 hidden p-3 space-y-3 animate-fade-in">
                <div class="space-y-2">
                  <label class="flex items-center gap-2.5 cursor-pointer text-xs font-semibold text-secondary hover:text-primary">
                    <input type="checkbox" class="filter-type-chk rounded border-outline-variant/50 text-primary focus:ring-primary w-4 h-4" data-name="Departamento" value="2">
                    <span>Departamento</span>
                  </label>
                  <label class="flex items-center gap-2.5 cursor-pointer text-xs font-semibold text-secondary hover:text-primary">
                    <input type="checkbox" class="filter-type-chk rounded border-outline-variant/50 text-primary focus:ring-primary w-4 h-4" data-name="Casa" value="3">
                    <span>Casa</span>
                  </label>
                  <label class="flex items-center gap-2.5 cursor-pointer text-xs font-semibold text-secondary hover:text-primary">
                    <input type="checkbox" class="filter-type-chk rounded border-outline-variant/50 text-primary focus:ring-primary w-4 h-4" data-name="PH" value="13">
                    <span>PH</span>
                  </label>
                  <label class="flex items-center gap-2.5 cursor-pointer text-xs font-semibold text-secondary hover:text-primary">
                    <input type="checkbox" class="filter-type-chk rounded border-outline-variant/50 text-primary focus:ring-primary w-4 h-4" data-name="Local" value="7">
                    <span>Local</span>
                  </label>
                  <label class="flex items-center gap-2.5 cursor-pointer text-xs font-semibold text-secondary hover:text-primary">
                    <input type="checkbox" class="filter-type-chk rounded border-outline-variant/50 text-primary focus:ring-primary w-4 h-4" data-name="Oficina" value="5">
                    <span>Oficina</span>
                  </label>
                  <label class="flex items-center gap-2.5 cursor-pointer text-xs font-semibold text-secondary hover:text-primary">
