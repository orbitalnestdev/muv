          `;
        });

        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = html;
        while (tempDiv.firstChild) {
          listContainer.appendChild(tempDiv.firstChild);
        }
        displayedPropertiesCount = end;
        attachCardListeners();
      }

      function attachCardListeners() {
        document.querySelectorAll('.property-row-card').forEach((card: any) => {
          let photos: string[] = [];
          try { photos = JSON.parse(card.dataset.photos || '[]'); } catch(e) {}
          let currentIdx = 0;

          const imgElement = card.querySelector('.row-carousel-img') as HTMLImageElement;
          const prevBtn = card.querySelector('.row-btn-prev');
          const nextBtn = card.querySelector('.row-btn-next');
          const zoomBtn = card.querySelector('.row-zoom-btn');

          if (imgElement && photos.length > 0) {
            const getOptimizedSrc = (src: string) => src;
            if (prevBtn) {
              prevBtn.addEventListener('click', (e: Event) => {
                e.preventDefault(); e.stopPropagation();
                currentIdx = (currentIdx - 1 + photos.length) % photos.length;
                imgElement.src = getOptimizedSrc(photos[currentIdx]);
              });
            }
            if (nextBtn) {
              nextBtn.addEventListener('click', (e: Event) => {
                e.preventDefault(); e.stopPropagation();
                currentIdx = (currentIdx + 1) % photos.length;
                imgElement.src = getOptimizedSrc(photos[currentIdx]);
              });
            }
          }

          if (zoomBtn) {
            zoomBtn.addEventListener('click', (e: Event) => {
              e.preventDefault(); e.stopPropagation();
              window.location.href = `/property/${card.dataset.id}/`;
            });
          }

          card.addEventListener('click', (e: Event) => {
            const target = e.target as HTMLElement;
            if (target.closest('a') || target.closest('button')) return;

            const propertyId = parseInt(card.dataset.id);
            const lat = parseFloat(card.dataset.lat);
            const lng = parseFloat(card.dataset.lng);

            if (!isNaN(lat) && !isNaN(lng) && map) {
              map.setView([lat, lng], 17);
              const matchedMarker = activeMarkers.find(marker => marker.propertyIds && marker.propertyIds.includes(propertyId));
              if (matchedMarker) {
                matchedMarker.openPopup();
                currentMarkerIndex = activeMarkers.indexOf(matchedMarker);
              }
            }
          });

          let hoverTimeout: any = null;
          card.addEventListener('mouseenter', () => {
            if (hoverTimeout) clearTimeout(hoverTimeout);
            hoverTimeout = setTimeout(() => {
              const propertyId = parseInt(card.dataset.id);
              const matchedMarker = activeMarkers.find(marker => marker.propertyIds && marker.propertyIds.includes(propertyId));
              if (matchedMarker && map) {
                matchedMarker.openPopup();
                matchedMarker.getElement()?.classList.add('marker-highlight');
              }
            }, 150);
          });

          card.addEventListener('mouseleave', () => {
            if (hoverTimeout) clearTimeout(hoverTimeout);
            const propertyId = parseInt(card.dataset.id);
            const matchedMarker = activeMarkers.find(marker => marker.propertyIds && marker.propertyIds.includes(propertyId));
            matchedMarker?.getElement()?.classList.remove('marker-highlight');
          });
        });
      }

      function navigateMarkers(direction: 'next' | 'prev') {
        if (activeMarkers.length === 0 || !map) return;
        if (direction === 'next') {
          currentMarkerIndex = (currentMarkerIndex + 1) % activeMarkers.length;
        } else {
          currentMarkerIndex = (currentMarkerIndex - 1 + activeMarkers.length) % activeMarkers.length;
        }
        const marker = activeMarkers[currentMarkerIndex];
        map.setView(marker.getLatLng(), 17);
        marker.openPopup();

        const propertyId = marker.propertyIds[0];
        const cardEl = document.querySelector(`.property-row-card[data-id="${propertyId}"]`);
        if (cardEl) {
          cardEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          cardEl.classList.add('bg-primary/10');
          setTimeout(() => cardEl.classList.remove('bg-primary/10'), 1500);
        }
      }

      function initDoubleSlider() {
        sliderMin = document.getElementById('slider-min') as HTMLInputElement;
        sliderMax = document.getElementById('slider-max') as HTMLInputElement;
        const track = document.getElementById('slider-track');
        const label = document.getElementById('price-range-label');
        const wrapper = document.querySelector('.slider-wrapper');

        if (!sliderMin || !sliderMax || !track || !label) return;

        function updateSlider(this: any) {
          if (!sliderMin || !sliderMax) return;
          let minVal = parseInt(sliderMin.value);
          let maxVal = parseInt(sliderMax.value);
          const isRent = filterState.operation === '2';
          const minGap = isRent ? 100 : 50000;

          if (maxVal - minVal < minGap) {
            if (this === sliderMin) {
              sliderMin.value = (maxVal - minGap).toString();
              minVal = maxVal - minGap;
            } else {
              sliderMax.value = (minVal + minGap).toString();
              maxVal = minVal + minGap;
            }
          }

          const minPercent = ((minVal - parseInt(sliderMin.min)) / (parseInt(sliderMin.max) - parseInt(sliderMin.min))) * 100;
          const maxPercent = ((maxVal - parseInt(sliderMax.min)) / (parseInt(sliderMax.max) - parseInt(sliderMax.min))) * 100;

          track.style.left = minPercent + '%';
          track.style.right = (100 - maxPercent) + '%';

          const symbol = filterState.currency === 'ARS' ? '$' : 'USD';
          const maxLimit = parseInt(sliderMax.max);
          const isMaxLimit = maxVal >= maxLimit;
          const maxText = isMaxLimit ? 'Sin límite' : `${symbol} ${new Intl.NumberFormat('es-AR').format(maxVal)}`;
          label.textContent = `${symbol} ${new Intl.NumberFormat('es-AR').format(minVal)} - ${maxText}`;
          filterState.priceMin = minVal;
          filterState.priceMax = maxVal;
        }

        sliderMin.addEventListener('input', () => {
          hasUserFilteredPrice = true;
          updateSlider.call(sliderMin);
        });
        sliderMax.addEventListener('input', () => {
          hasUserFilteredPrice = true;
          updateSlider.call(sliderMax);
        });
        sliderMin.addEventListener('change', () => {
          hasUserFilteredPrice = true;
          filterAndRender();
        });
        sliderMax.addEventListener('change', () => {
          hasUserFilteredPrice = true;
          filterAndRender();
        });

        if (wrapper) {
          wrapper.addEventListener('mousemove', (e: any) => {
            const rect = wrapper.getBoundingClientRect();
            const percent = (e.clientX - rect.left) / rect.width;
            const min = parseFloat(sliderMin.min);
            const max = parseFloat(sliderMin.max);
            const hoverVal = min + percent * (max - min);

            const distMin = Math.abs(hoverVal - parseFloat(sliderMin.value));
            const distMax = Math.abs(hoverVal - parseFloat(sliderMax.value));

            if (distMin < distMax) {
              sliderMin.style.zIndex = '3';
              sliderMax.style.zIndex = '2';
            } else {
              sliderMin.style.zIndex = '2';
              sliderMax.style.zIndex = '3';
            }
          });
        }
        
        updateSlider.call(sliderMin);
      }

      function adjustPriceSliderRange() {
        const sliderMin = document.getElementById('slider-min') as HTMLInputElement;
        const sliderMax = document.getElementById('slider-max') as HTMLInputElement;
        if (!sliderMin || !sliderMax) return;
        
        const isRent = filterState.operation === '2';
        const isArs = filterState.currency === 'ARS';
        
        const defaultMin = isRent ? (isArs ? '5000' : '200') : (isArs ? '500000' : '50000');
        const defaultMax = isRent ? (isArs ? '250000' : '5000') : (isArs ? '50000000' : '2000000');
        const sliderStep = isRent ? (isArs ? '5000' : '100') : (isArs ? '100000' : '25000');

        sliderMin.min = defaultMin;
        sliderMin.max = defaultMax;
        sliderMin.step = sliderStep;
        sliderMax.min = defaultMin;
        sliderMax.max = defaultMax;
        sliderMax.step = sliderStep;

        sliderMin.value = defaultMin;
        sliderMax.value = defaultMax;

        sliderMin.dispatchEvent(new Event('input'));
      }

      function initLayerSelect() {
        const select = document.getElementById('map-layer-select') as HTMLSelectElement;
        if (!select || !map) return;
        select.addEventListener('change', () => {
          const selected = select.value as keyof typeof layers;
          if (currentTileLayer) map.removeLayer(currentTileLayer);
          currentTileLayer = L.tileLayer(layers[selected], { attribution: layersAttribution[selected] }).addTo(map);
        });
      }

      function initFullscreen() {
        const btn = document.getElementById('btn-fullscreen-map');
        const mapEl = document.getElementById('map');
        if (!btn || !mapEl) return;
        btn.addEventListener('click', () => {
          if (!document.fullscreenElement) {
            mapEl.requestFullscreen().then(() => {
              setTimeout(() => map.invalidateSize(), 200);
            }).catch(err => { console.error(err); });
          } else {
            document.exitFullscreen();
          }
        });
        document.addEventListener('fullscreenchange', () => {
          if (map) setTimeout(() => map.invalidateSize(), 200);
        });
      }

      function initBarriosDropdown() {
        const barrioContainer = document.getElementById('barrio-options-container');
        if (!barrioContainer) return;
        
        const sortedBarrios = JSON.parse(barrioContainer.dataset.allBarrios || '[]');
        let html = '';
        sortedBarrios.forEach(b => {
          html += `
            <label class="flex items-center gap-2.5 cursor-pointer text-xs font-semibold text-secondary hover:text-primary">
              <input type="checkbox" class="filter-barrio-chk rounded border-outline-variant/50 text-primary focus:ring-primary w-4 h-4" value="${b.toLowerCase()}" data-name="${b}">
              <span>${b}</span>
            </label>
          `;
        });
        barrioContainer.innerHTML = html;
      }

      function initDynamicTags() {
        const tagsContainer = document.getElementById('dynamic-tags-container');
        if (!tagsContainer) return;

        const allTags = new Set<string>();
        rawProperties.forEach((p: any) => {
          if (p.tags) {
            p.tags.forEach((t: any) => {
              if (t.name) allTags.add(t.name.trim());
            });
          }
        });

        const blacklistPattern = /(unidad|disponible|available|unit|water|electricity|gas|pavement|sewage|paved|access|intercom|phone|internet|wifi|cable|lighting)/i;
        const filteredTags = Array.from(allTags).filter(tag => !blacklistPattern.test(tag));
        
        const mappedTags = filteredTags.map(tag => {
          const lowerTag = tag.toLowerCase();
          const translation = tagTranslations[lowerTag] || { label: tag, icon: 'tag' };
          return { raw: tag, lower: lowerTag, label: translation.label, icon: translation.icon };
        }).sort((a, b) => a.label.localeCompare(b, 'es'));

        let html = '';
        mappedTags.forEach(item => {
          html += `
            <button type="button" class="btn-more-toggle flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-outline-variant/50 text-[10px] font-semibold text-secondary bg-pure-white transition-all hover:border-primary" data-key="${item.lower}">
              <span class="material-symbols-outlined text-[14px]">${item.icon}</span>
              <span>${item.label}</span>
            </button>
          `;
        });
        tagsContainer.innerHTML = html;
      }

      function attachDynamicTagListeners() {
        const btnMoreToggles = document.querySelectorAll('.btn-more-toggle');
        btnMoreToggles.forEach((btn: any) => {
          btn.addEventListener('click', () => {
            const key = btn.getAttribute('data-key') || '';
            const idx = filterState.moreToggles.indexOf(key);
            if (idx > -1) {
              filterState.moreToggles.splice(idx, 1);
              btn.classList.remove('bg-[#C5A059]/10', 'border-[#C5A059]', 'text-[#121212]', 'font-bold');
              btn.classList.add('bg-pure-white', 'border-outline-variant/50', 'text-secondary');
            } else {
              filterState.moreToggles.push(key);
              btn.classList.add('bg-[#C5A059]/10', 'border-[#C5A059]', 'text-[#121212]', 'font-bold');
              btn.classList.remove('bg-pure-white', 'border-outline-variant/50', 'text-secondary');
            }
          });
        });
      }

      function updatePillLabels() {
        const opLabel = document.getElementById('pill-label-operation');
        if (opLabel) {
          opLabel.textContent = filterState.operation === '' ? 'Operación' : (filterState.operation === '1' ? 'Venta' : 'Alquiler');
        }

        const barrioLabel = document.getElementById('pill-label-barrio');
        if (barrioLabel) {
          if (filterState.barrios.length === 0) {
            barrioLabel.textContent = 'Barrio';
          } else if (filterState.barrios.length === 1) {
            const chk = document.querySelector(`.filter-barrio-chk[value="${filterState.barrios[0]}"]`) as HTMLInputElement;
            barrioLabel.textContent = chk ? chk.dataset.name : filterState.barrios[0];
          } else {
            barrioLabel.textContent = `${filterState.barrios.length} Barrios`;
          }
        }

        const typeLabel = document.getElementById('pill-label-type');
        if (typeLabel) {
          if (filterState.types.length === 0) {
            typeLabel.textContent = 'Propiedad';
          } else if (filterState.types.length === 1) {
            const chk = document.querySelector(`.filter-type-chk[value="${filterState.types[0]}"]`) as HTMLInputElement;
            typeLabel.textContent = chk ? chk.dataset.name : '1 Tipo';
          } else {
            typeLabel.textContent = `${filterState.types.length} Tipos`;
          }
        }
      }

      function updateSearchLinks() {
        // Build query string matching active filterState
        const params = new URLSearchParams();
        if (filterState.keyword) params.set('q', filterState.keyword);
        if (filterState.operation) params.set('operation_id', filterState.operation);
        if (filterState.currency) params.set('currency', filterState.currency);
        
        if (hasUserFilteredPrice) {
          params.set('price_min', filterState.priceMin.toString());
          const maxLimit = sliderMax ? parseInt(sliderMax.max) : (filterState.currency === 'ARS' ? 50000000 : 2000000);
          if (filterState.priceMax < maxLimit) {
            params.set('price_max', filterState.priceMax.toString());
          }
        }

        if (filterState.rooms) params.set('rooms', filterState.rooms);
        if (filterState.bedrooms) params.set('bedrooms', filterState.bedrooms);
        if (filterState.bathrooms) params.set('bathrooms', filterState.bathrooms);
        if (filterState.garage) params.set('garage', filterState.garage);
        if (filterState.surfaceMin !== null) params.set('surface_min', filterState.surfaceMin.toString());
        if (filterState.surfaceMax !== null) params.set('surface_max', filterState.surfaceMax.toString());
        
        filterState.types.forEach(t => params.append('property_type_id', t));
        filterState.barrios.forEach(b => {
          const chk = document.querySelector(`.filter-barrio-chk[value="${b}"]`) as HTMLInputElement;
          if (chk && chk.dataset.name) {
            params.append('location', chk.dataset.name);
          }
        });
        filterState.moreToggles.forEach(tag => params.append('amenities', tag));

        const queryStr = params.toString() ? '?' + params.toString() : '';
        const gridLink = document.getElementById('btn-map-layout-grid') as HTMLAnchorElement | null;
        const listLink = document.getElementById('btn-map-layout-list') as HTMLAnchorElement | null;

        if (gridLink) gridLink.href = '/search-results/?view=grid' + (queryStr ? '&' + params.toString() : '');
        if (listLink) listLink.href = '/search-results/?view=list' + (queryStr ? '&' + params.toString() : '');

        // Sync browser address bar URL in map view in real-time
        const currentUrl = new URL(window.location.href);
        const view = currentUrl.searchParams.get('view') || 'map';
        params.set('view', view);
        window.history.replaceState({}, '', currentUrl.pathname + '?' + params.toString());
      }

      // Initialize all triggers
      initMap();
      initLayerSelect();
      initFullscreen();
      initBarriosDropdown();
      initDynamicTags();
      attachDynamicTagListeners();
      initDoubleSlider();

        // Preset filters from URL params inside map filters
        const qParam = urlParams.get('q');
        if (qParam) {
          filterState.keyword = qParam;
          const input = document.getElementById('filter-keyword') as HTMLInputElement;
          if (input) {
            input.value = qParam;
            document.getElementById('btn-clear-keyword')?.classList.remove('hidden');
          }
        }

        const opParam = urlParams.get('operation_id');
        if (opParam) {
          filterState.operation = opParam;
          const btn = document.querySelector(`.btn-select-op[data-val="${opParam}"]`);
          if (btn) btn.classList.add('bg-primary/10', 'text-primary');
        }

        const currencyParam = urlParams.get('currency');
        if (currencyParam) {
          filterState.currency = currencyParam;
          document.querySelectorAll('.btn-currency-toggle').forEach(b => {
            b.classList.remove('bg-primary', 'text-pure-white', 'border-primary');
            b.classList.add('bg-pure-white', 'text-secondary', 'border-outline-variant/50');
          });
          const btn = document.querySelector(`.btn-currency-toggle[data-val="${currencyParam}"]`);
          if (btn) {
            btn.classList.add('bg-primary', 'text-pure-white', 'border-primary');
            btn.classList.remove('bg-pure-white', 'text-secondary', 'border-outline-variant/50');
          }
        }

        const locParams = urlParams.getAll('location');
        if (locParams.length > 0) {
          const clientNormalize = (str: string) => str.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();
          locParams.forEach(loc => {
            const normalizedLoc = clientNormalize(loc);
            const chk = Array.from(document.querySelectorAll('.filter-barrio-chk')).find((c: any) => 
              clientNormalize(c.dataset.name || '') === normalizedLoc || 
              clientNormalize(c.value || '') === normalizedLoc
            ) as HTMLInputElement | undefined;
            if (chk) {
              chk.checked = true;
              filterState.barrios.push(chk.value);
            }
          });
        }

        const typeParams = urlParams.getAll('property_type_id');
        if (typeParams.length > 0) {
          typeParams.forEach(type => {
            const chk = document.querySelector(`.filter-type-chk[value="${type}"]`) as HTMLInputElement;
            if (chk) {
              chk.checked = true;
              filterState.types.push(type);
            }
          });
        }

        // Adjust price slider range based on parsed currency and operation type
        adjustPriceSliderRange();

        const priceMinParam = urlParams.get('price_min');
        if (priceMinParam) {
          filterState.priceMin = parseInt(priceMinParam);
          if (sliderMin) sliderMin.value = priceMinParam;
          hasUserFilteredPrice = true;
        }

        const priceMaxParam = urlParams.get('price_max');
        if (priceMaxParam) {
          filterState.priceMax = parseInt(priceMaxParam);
          if (sliderMax) sliderMax.value = priceMaxParam;
          hasUserFilteredPrice = true;
        }

        if (priceMinParam || priceMaxParam) {
          sliderMin?.dispatchEvent(new Event('input'));
        }

        const roomsParam = urlParams.get('rooms');
        if (roomsParam) {
          filterState.rooms = roomsParam;
          const btn = document.querySelector(`.btn-select-rooms[data-val="${roomsParam}"]`);
          if (btn) btn.classList.add('bg-primary/10', 'text-primary');
        }

        const bedroomsParam = urlParams.get('bedrooms');
        if (bedroomsParam) {
          filterState.bedrooms = bedroomsParam;
          const btn = document.querySelector(`.btn-select-bedrooms[data-val="${bedroomsParam}"]`);
          if (btn) btn.classList.add('bg-primary/10', 'text-primary');
        }

        const bathroomsParam = urlParams.get('bathrooms');
        if (bathroomsParam) {
          filterState.bathrooms = bathroomsParam;
          const btn = document.querySelector(`.btn-select-bathrooms[data-val="${bathroomsParam}"]`);
          if (btn) btn.classList.add('bg-primary/10', 'text-primary');
        }

        const garageParam = urlParams.get('garage');
        if (garageParam) {
          filterState.garage = garageParam;
          const btn = document.querySelector(`.btn-select-garage[data-val="${garageParam}"]`);
          if (btn) btn.classList.add('bg-primary/10', 'text-primary');
        }

        const surfaceMinParam = urlParams.get('surface_min');
        if (surfaceMinParam) {
          filterState.surfaceMin = parseInt(surfaceMinParam);
          const input = document.getElementById('filter-surface-min') as HTMLInputElement;
          if (input) input.value = surfaceMinParam;
        }

        const surfaceMaxParam = urlParams.get('surface_max');
        if (surfaceMaxParam) {
          filterState.surfaceMax = parseInt(surfaceMaxParam);
          const input = document.getElementById('filter-surface-max') as HTMLInputElement;
          if (input) input.value = surfaceMaxParam;
        }

        const amenitiesParams = urlParams.getAll('amenities');
        if (amenitiesParams.length > 0) {
          amenitiesParams.forEach(am => {
            filterState.moreToggles.push(am.toLowerCase());
            const btn = document.querySelector(`.btn-more-toggle[data-key="${am.toLowerCase()}"]`);
            if (btn) btn.classList.add('bg-[#C5A059]/10', 'border-[#C5A059]', 'text-[#121212]', 'font-bold');
          });
        }

        // Run rendering
        filterAndRender();

        // Setup drop-down togglers
        document.querySelectorAll('.filter-pill').forEach((pill: any) => {
          pill.addEventListener('click', (e: Event) => {
            e.stopPropagation();
            const targetId = pill.dataset.dropdown;
            document.querySelectorAll('.filter-dropdown').forEach((d: any) => {
              if (d.id !== targetId) d.classList.add('hidden');
            });
            const drop = document.getElementById(targetId);
            if (drop) drop.classList.toggle('hidden');
          });
        });

        // Hide dropdowns when clicking outside
        document.addEventListener('click', () => {
          document.querySelectorAll('.filter-dropdown').forEach((d: any) => d.classList.add('hidden'));
        });

        document.querySelectorAll('.filter-dropdown').forEach((d: any) => {
          d.addEventListener('click', (e: Event) => e.stopPropagation());
        });

        // Dropdown actions listeners
        // Keyword Search Bar
        const kwInput = document.getElementById('filter-keyword') as HTMLInputElement | null;
        const clearKeywordBtn = document.getElementById('btn-clear-keyword');
        if (kwInput) {
          let kwTimeout: any = null;
          kwInput.addEventListener('input', () => {
            if (kwTimeout) clearTimeout(kwTimeout);
            if (kwInput.value.trim()) clearKeywordBtn?.classList.remove('hidden');
            else clearKeywordBtn?.classList.add('hidden');

            kwTimeout = setTimeout(() => {
              filterState.keyword = kwInput.value.trim();
              filterAndRender();
            }, 450);
          });
        }

        if (clearKeywordBtn && kwInput) {
          clearKeywordBtn.addEventListener('click', () => {
            kwInput.value = '';
            filterState.keyword = '';
            clearKeywordBtn.classList.add('hidden');
            filterAndRender();
          });
        }

        // Operation click
        document.querySelectorAll('.btn-select-op').forEach((b: any) => {
          b.addEventListener('click', () => {
            document.querySelectorAll('.btn-select-op').forEach(btn => btn.classList.remove('bg-primary/10', 'text-primary'));
            if (b.dataset.val !== '') b.classList.add('bg-primary/10', 'text-primary');
            filterState.operation = b.dataset.val;
            adjustPriceSliderRange();
            filterAndRender();
            document.getElementById('dropdown-operation')?.classList.add('hidden');
          });
        });

        // Currency Toggle
        document.querySelectorAll('.btn-currency-toggle').forEach((b: any) => {
          b.addEventListener('click', () => {
            document.querySelectorAll('.btn-currency-toggle').forEach(btn => {
              btn.classList.remove('bg-primary', 'text-pure-white', 'border-primary');
              btn.classList.add('bg-pure-white', 'text-secondary', 'border-outline-variant/50');
            });
            
            b.classList.add('bg-primary', 'text-pure-white', 'border-primary');
            b.classList.remove('bg-pure-white', 'text-secondary', 'border-outline-variant/50');
            filterState.currency = b.dataset.val || '';
            
            adjustPriceSliderRange();
            filterAndRender();
          });
        });

        // Price manual apply
        document.querySelector('.btn-apply-price')?.addEventListener('click', () => {
          filterAndRender();
          document.getElementById('dropdown-price')?.classList.add('hidden');
        });

        // Rooms select
        document.querySelectorAll('.btn-select-rooms').forEach((b: any) => {
          b.addEventListener('click', () => {
            document.querySelectorAll('.btn-select-rooms').forEach(btn => btn.classList.remove('bg-primary/10', 'text-primary'));
            if (b.dataset.val !== '') b.classList.add('bg-primary/10', 'text-primary');
            filterState.rooms = b.dataset.val;
            filterAndRender();
            document.getElementById('dropdown-rooms')?.classList.add('hidden');
          });
        });

        // Bedrooms select
        document.querySelectorAll('.btn-select-bedrooms').forEach((b: any) => {
          b.addEventListener('click', () => {
            document.querySelectorAll('.btn-select-bedrooms').forEach(btn => btn.classList.remove('bg-primary/10', 'text-primary'));
            if (b.dataset.val !== '') b.classList.add('bg-primary/10', 'text-primary');
            filterState.bedrooms = b.dataset.val;
            filterAndRender();
            document.getElementById('dropdown-bedrooms')?.classList.add('hidden');
          });
        });

        // Bathrooms select
        document.querySelectorAll('.btn-select-bathrooms').forEach((b: any) => {
          b.addEventListener('click', () => {
            document.querySelectorAll('.btn-select-bathrooms').forEach(btn => btn.classList.remove('bg-primary/10', 'text-primary'));
            if (b.dataset.val !== '') b.classList.add('bg-primary/10', 'text-primary');
            filterState.bathrooms = b.dataset.val;
            filterAndRender();
            document.getElementById('dropdown-bathrooms')?.classList.add('hidden');
          });
        });

        // Garage select
        document.querySelectorAll('.btn-select-garage').forEach((b: any) => {
          b.addEventListener('click', () => {
            document.querySelectorAll('.btn-select-garage').forEach(btn => btn.classList.remove('bg-primary/10', 'text-primary'));
            if (b.dataset.val !== '') b.classList.add('bg-primary/10', 'text-primary');
            filterState.garage = b.dataset.val;
            filterAndRender();
            document.getElementById('dropdown-garage')?.classList.add('hidden');
          });
        });

        // Surface inputs
        const surfaceMinInput = document.getElementById('filter-surface-min') as HTMLInputElement | null;
        const surfaceMaxInput = document.getElementById('filter-surface-max') as HTMLInputElement | null;
        
        // Barrio apply / clear
        document.querySelector('.btn-apply-barrio')?.addEventListener('click', () => {
          filterState.barrios = [];
          document.querySelectorAll('.filter-barrio-chk:checked').forEach((chk: any) => {
            filterState.barrios.push(chk.value);
          });
          filterAndRender();
          document.getElementById('dropdown-barrio')?.classList.add('hidden');
        });

        document.querySelector('.btn-clear-barrio')?.addEventListener('click', () => {
          document.querySelectorAll('.filter-barrio-chk').forEach((chk: any) => chk.checked = false);
          filterState.barrios = [];
          filterAndRender();
        });

        // Property Type apply / clear
        document.querySelector('.btn-apply-type')?.addEventListener('click', () => {
          filterState.types = [];
          document.querySelectorAll('.filter-type-chk:checked').forEach((chk: any) => {
            filterState.types.push(chk.value);
          });
          filterAndRender();
          document.getElementById('dropdown-type')?.classList.add('hidden');
        });

        document.querySelector('.btn-clear-type')?.addEventListener('click', () => {
          document.querySelectorAll('.filter-type-chk').forEach((chk: any) => chk.checked = false);
          filterState.types = [];
          filterAndRender();
        });

        // More Filters apply / clear
        document.getElementById('btn-apply-more')?.addEventListener('click', () => {
          if (surfaceMinInput) {
            filterState.surfaceMin = surfaceMinInput.value.trim() ? parseFloat(surfaceMinInput.value) : null;
          }
          if (surfaceMaxInput) {
            filterState.surfaceMax = surfaceMaxInput.value.trim() ? parseFloat(surfaceMaxInput.value) : null;
          }
          filterAndRender();
          document.getElementById('dropdown-more')?.classList.add('hidden');
        });

        document.getElementById('btn-clear-more')?.addEventListener('click', () => {
          if (surfaceMinInput) surfaceMinInput.value = '';
          if (surfaceMaxInput) surfaceMaxInput.value = '';
          filterState.surfaceMin = null;
          filterState.surfaceMax = null;
          filterState.moreToggles = [];
          document.querySelectorAll('.btn-more-toggle').forEach((btn: any) => {
            btn.classList.remove('bg-[#C5A059]/10', 'border-[#C5A059]', 'text-[#121212]', 'font-bold');
            btn.classList.add('bg-pure-white', 'border-outline-variant/50', 'text-secondary');
          });
          filterAndRender();
        });

        // General reset filters
        document.getElementById('btn-clear-search')?.addEventListener('click', () => {
          filterState.keyword = '';
          if (kwInput) kwInput.value = '';
          clearKeywordBtn?.classList.add('hidden');

          filterState.operation = '';
          document.querySelectorAll('.btn-select-op').forEach(b => b.classList.remove('bg-primary/10', 'text-primary'));

          filterState.barrios = [];
          document.querySelectorAll('.filter-barrio-chk').forEach((chk: any) => { chk.checked = false; });

          filterState.types = [];
          document.querySelectorAll('.filter-type-chk').forEach((chk: any) => { chk.checked = false; });

          filterState.currency = '';
          hasUserFilteredPrice = false;
          document.querySelectorAll('.btn-currency-toggle').forEach(b => {
            b.classList.remove('bg-primary', 'text-pure-white', 'border-primary');
            b.classList.add('bg-pure-white', 'text-secondary', 'border-outline-variant/50');
          });

          if (sliderMin && sliderMax) {
            sliderMin.value = '200';
            sliderMax.value = '2500000';
          }
          adjustPriceSliderRange();

          filterState.rooms = '';
          document.querySelectorAll('.btn-select-rooms').forEach(b => b.classList.remove('bg-primary/10', 'text-primary'));

          filterState.bedrooms = '';
          document.querySelectorAll('.btn-select-bedrooms').forEach(b => b.classList.remove('bg-primary/10', 'text-primary'));

          filterState.bathrooms = '';
          document.querySelectorAll('.btn-select-bathrooms').forEach(b => b.classList.remove('bg-primary/10', 'text-primary'));

          filterState.garage = '';
          document.querySelectorAll('.btn-select-garage').forEach(b => b.classList.remove('bg-primary/10', 'text-primary'));

          filterState.surfaceMin = null;
          filterState.surfaceMax = null;
          if (surfaceMinInput) surfaceMinInput.value = '';
          if (surfaceMaxInput) surfaceMaxInput.value = '';

          filterState.moreToggles = [];
          document.querySelectorAll('.btn-more-toggle').forEach((btn: any) => {
            btn.classList.remove('bg-[#C5A059]/10', 'border-[#C5A059]', 'text-[#121212]', 'font-bold');
            btn.classList.add('bg-pure-white', 'border-outline-variant/50', 'text-secondary');
          });

          filterState.mapBounds = null;
          const searchHereBtn = document.getElementById('btn-search-here');
          if (searchHereBtn) {
            searchHereBtn.classList.add('hidden');
            searchHereBtn.classList.remove('flex');
          }

          filterAndRender();
        });

        // Prev / Next marker floating buttons
        document.getElementById('btn-prev-marker')?.addEventListener('click', () => navigateMarkers('prev'));
        document.getElementById('btn-next-marker')?.addEventListener('click', () => navigateMarkers('next'));
    }

    // Navigation and toggling elements for Mobile view in Map Layout
    const toggleBtn = document.getElementById('btn-mobile-view-toggle');
    const mainContainer = document.getElementById('map-page-main');
    const toggleIcon = document.getElementById('toggle-view-icon');
    const toggleText = document.getElementById('toggle-view-text');
    if (toggleBtn && mainContainer && toggleIcon && toggleText) {
      toggleBtn.addEventListener('click', () => {
        if (mainContainer.classList.contains('mobile-list-active')) {
          mainContainer.classList.remove('mobile-list-active');
          mainContainer.classList.add('mobile-map-active');
          toggleIcon.textContent = 'list';
          toggleText.textContent = 'Ver Lista';
          if (map) setTimeout(() => map.invalidateSize(), 150);
        } else {
          mainContainer.classList.remove('mobile-map-active');
          mainContainer.classList.add('mobile-list-active');
          toggleIcon.textContent = 'map';
          toggleText.textContent = 'Ver Mapa';
        }
      });
    }

    window.addEventListener('resize', () => { if (map) map.invalidateSize(); });
    window.addEventListener('scroll', () => {
      if ((window.innerHeight + window.scrollY) >= (document.documentElement.scrollHeight - 200)) {
        loadNextBatch();
      }
    });
  }
</script>
