              <button id="btn-no-results-reset" class="bg-primary text-pure-white text-xs font-bold uppercase tracking-wider px-6 py-2.5 rounded-xl transition-all duration-200 hover:bg-[#C5A880] active:scale-95 shadow-sm font-sans">Restablecer Filtros</button>
            </div>
          `;
          document.getElementById('btn-no-results-reset')?.addEventListener('click', () => {
            document.getElementById('btn-clear-search')?.click();
