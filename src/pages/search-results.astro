<!-- Double Range Slider & Page Custom Animations -->
<style is:global>
  /* Hide footer on map view to avoid double scrollbar and allow full height */
  body:has(#map-page-main) footer {
    display: none !important;
  }

  .slider-wrapper input[type="range"] {
    -webkit-appearance: none;
    appearance: none;
    pointer-events: none;
  }
  .slider-wrapper input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    height: 16px;
    width: 16px;
    border-radius: 50%;
    background: #ffffff;
    border: 2px solid #C5A880;
    pointer-events: auto;
    cursor: pointer;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
    margin-top: -1.5px;
  }
  .slider-wrapper input[type="range"]::-moz-range-thumb {
    height: 14px;
    width: 14px;
    border-radius: 50%;
    background: #ffffff;
    border: 2px solid #C5A880;
    pointer-events: auto;
    cursor: pointer;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
  }

  /* Custom Row Card animations */
  .property-row-card {
    animation: rowCardFadeIn 0.35s ease-out forwards;
  }
  @keyframes rowCardFadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Leaflet marker hover highlights and bounce animations */
  .marker-highlight .leaflet-pin-container {
    animation: markerBounce 0.45s ease infinite alternate;
  }
  @keyframes markerBounce {
    from { transform: translateY(0); }
    to { transform: translateY(-8px); }
  }

  /* Custom Leaflet Popup Overrides */
  .leaflet-popup-content-wrapper {
    padding: 0 !important;
    overflow: hidden !important;
    border-radius: 8px !important;
    box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.1) !important;
  }
  .leaflet-popup-content {
    margin: 0 !important;
    width: 280px !important;
  }
  .leaflet-popup-tip {
    background: #ffffff !important;
  }

  /* Filter pills arrow rotation */
  .filter-pill span.material-symbols-outlined {
    transition: transform 0.2s ease;
  }
  
  /* Hide scrollbar */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .scrollbar-thin::-webkit-scrollbar {
    width: 6px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.15);
    border-radius: 3px;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb:hover {
    background: rgba(0, 0, 0, 0.3);
  }

  /* Mobile Split toggling states with transitions */
  @media (max-width: 1023px) {
    .mobile-map-active #map-section {
      display: block !important;
      height: calc(100vh - 72px) !important;
      width: 100% !important;
      animation: mobileFadeIn 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .mobile-map-active #list-section {
      display: none !important;
    }
    
    .mobile-list-active #map-section {
      display: none !important;
    }
    .mobile-list-active #list-section {
      display: flex !important;
      width: 100% !important;
      animation: mobileFadeIn 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
  }

  @keyframes mobileFadeIn {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  declare const L: any;

  // Initialize Layout from view param or localStorage
  const urlParams = new URLSearchParams(window.location.search);
  const currentView = urlParams.get('view') || 'map';

  if (currentView === 'grid' || currentView === 'list') {
    // -------------------------------------------------------------
    // GRID & LIST VIEW CLIENT LOGIC
    // -------------------------------------------------------------
    const gridBtn = document.getElementById('btn-layout-grid');
    const listBtn = document.getElementById('btn-layout-list');
    const gridContainer = document.getElementById('property-grid-container');
    const gridOuter = document.getElementById('property-grid-outer');

    const setViewLayout = (layout: 'grid' | 'list') => {
      if (!gridContainer || !gridOuter || !gridBtn || !listBtn) return;
      
      // Update hidden form view parameter to preserve state on filter submit
      const viewInput = document.getElementById('val-view') as HTMLInputElement | null;
      if (viewInput) viewInput.value = layout;

      // Update URL search parameters without reloading the page
      const currentUrl = new URL(window.location.href);
      currentUrl.searchParams.set('view', layout);
      window.history.replaceState({}, '', currentUrl.pathname + currentUrl.search);
      
      if (layout === 'list') {
        gridContainer.classList.remove('grid-cols-1', 'md:grid-cols-2', 'gap-8');
        gridContainer.classList.add('grid-cols-1', 'gap-6');
        gridOuter.classList.add('list-view-active');
        
        listBtn.classList.remove('text-secondary', 'hover:text-primary');
        listBtn.classList.add('bg-primary', 'text-pure-white');
        gridBtn.classList.remove('bg-primary', 'text-pure-white');
        gridBtn.classList.add('text-secondary', 'hover:text-primary');
        
        localStorage.setItem('muv-search-layout', 'list');
      } else {
        gridContainer.classList.add('grid-cols-1', 'md:grid-cols-2', 'gap-8');
        gridContainer.classList.remove('grid-cols-1', 'gap-6');
        gridOuter.classList.remove('list-view-active');
        
        gridBtn.classList.remove('text-secondary', 'hover:text-primary');
        gridBtn.classList.add('bg-primary', 'text-pure-white');
        listBtn.classList.remove('bg-primary', 'text-pure-white');
        listBtn.classList.add('text-secondary', 'hover:text-primary');
        
        localStorage.setItem('muv-search-layout', 'grid');
      }
    };

    if (gridBtn && listBtn) {
      gridBtn.addEventListener('click', () => setViewLayout('grid'));
      listBtn.addEventListener('click', () => setViewLayout('list'));
      
      const savedLayout = localStorage.getItem('muv-search-layout') as 'grid' | 'list' | null;
      if (savedLayout) {
        setViewLayout(savedLayout);
      } else if (currentView === 'list') {
        setViewLayout('list');
      } else {
        setViewLayout('grid');
      }
    }

    // Mobile drawer filters
    const openBtn = document.getElementById('btn-mobile-filters');
    const closeBtn = document.getElementById('btn-close-drawer');
    const drawer = document.getElementById('mobile-drawer');

    if (openBtn && drawer) {
      openBtn.addEventListener('click', () => {
        drawer.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      });
    }

    if (closeBtn && drawer) {
      closeBtn.addEventListener('click', () => {
        drawer.classList.add('hidden');
        document.body.style.overflow = '';
      });
      drawer.addEventListener('click', (e) => {
        if (e.target === drawer) {
          drawer.classList.add('hidden');
          document.body.style.overflow = '';
        }
      });
    }

    // Active chips removal
    document.querySelectorAll('.chip-remove').forEach((chip: any) => {
      chip.addEventListener('click', () => {
        const key = chip.dataset.key;
        const val = chip.dataset.value;
        const url = new URL(window.location.href);
        
        if (key === 'amenities' && val) {
          const currentAms = url.searchParams.getAll('amenities');
          url.searchParams.delete('amenities');
          currentAms.forEach(am => {
            if (am !== val) {
              url.searchParams.append('amenities', am);
            }
          });
        } else {
          url.searchParams.delete(key);
        }
        
        url.searchParams.set('page', '1');
