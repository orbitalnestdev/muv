      function createPinHTML(typeId: number, count: number = 1) {
        const pinColor = '#35baf6'; // Sky blue pin color matching Google Maps reference
        const iconColor = '#2D3748'; // Dark charcoal/black icon color
        let path = '';
        
        // House and tree icon for residential (Departamento, Casa, PH)
        if (typeId === 2 || typeId === 3 || typeId === 4) {
          path = `
            <path d="M9.5,15.5 L14,11 L18.5,15.5 L17,15.5 L17,21.5 L11,21.5 L11,15.5 Z" fill="${iconColor}" />
            <rect x="18.5" y="17.5" width="1.2" height="4" fill="${iconColor}" />
            <circle cx="19.1" cy="15.2" r="2.2" fill="${iconColor}" />
          `;
        } else if (typeId === 8) {
          // Oficina (Briefcase)
          path = `<path d="M19,14h-1.5v-1c0-.5-.4-1-1-1h-1c-.5 0-1 .4-1 1v1H13c-.5 0-1 .4-1 1v5c0 .5.4 1 1 1h6c.5 0 1-.4 1-1v-5c0-.5-.4-1-1-1zm-4-1h2v1h-2v-1z" fill="${iconColor}" />`;
        } else if (typeId === 7) {
          // Local (Storefront)
          path = `<path d="M10,12.5v1l1,3v5h10v-5l1-3v-1H10zm3.5,8h-2v-3h2v3zm4,0h-2v-3h2v3zm3.5-4h-9l-.5-2h10l-.5 2z" fill="${iconColor}" />`;
        } else {
          // Default: House and tree icon
          path = `
            <path d="M9.5,15.5 L14,11 L18.5,15.5 L17,15.5 L17,21.5 L11,21.5 L11,15.5 Z" fill="${iconColor}" />
            <rect x="18.5" y="17.5" width="1.2" height="4" fill="${iconColor}" />
            <circle cx="19.1" cy="15.2" r="2.2" fill="${iconColor}" />
          `;
        }

        return `
          <div class="relative w-8 h-10 select-none pointer-events-none leaflet-pin-container">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="38" viewBox="0 0 32 38">
              <defs>
                <filter id="pin-shadow" x="-20%" y="-20%" width="140%" height="140%">
                  <feDropShadow dx="0" dy="2" stdDeviation="1.5" flood-color="#000000" flood-opacity="0.35"/>
                </filter>
              </defs>
              <g filter="url(#pin-shadow)">
                <!-- Teardrop Pin Shape (Sky Blue Pin) -->
                <path d="M16 4 C9.4 4 4 9.4 4 16 c0 10 12 22 12 22 s12-12 12-22 c0-6.6-5.4-12-12-12 z" fill="${pinColor}" stroke="#FFFFFF" stroke-width="1.8" />
                <!-- White circle in the center -->
                <circle cx="16" cy="16" r="7.5" fill="#FFFFFF" />
                <!-- Icon inside the white circle -->
                ${path}
              </g>
            </svg>
            ${count > 1 ? `
              <div class="absolute -top-1.5 -right-1.5 bg-[#121212] text-white border border-white text-[9px] font-bold rounded-full w-[18.5px] h-[18.5px] flex items-center justify-center shadow-md z-10 leading-none">
                ${count}
              </div>
            ` : ''}
          </div>
        `.trim();
      }

      function initMap() {
        if (!document.getElementById('map')) return;
        if (typeof L === 'undefined') {
          setTimeout(initMap, 100);
          return;
        }
        const defaultCoords = [-34.580, -58.420];
        const defaultZoom = 14;
        map = L.map('map', { 
          zoomControl: false, 
          attributionControl: true,
          scrollWheelZoom: false // UX Improvement: disable scroll wheel hijacking on desktop
        }).setView(defaultCoords, defaultZoom);
        currentTileLayer = L.tileLayer(layers.calle, { attribution: layersAttribution.calle }).addTo(map);
        L.control.zoom({ position: 'bottomright' }).addTo(map);

        const loader = document.getElementById('map-loader');
        if (loader) {
          loader.style.opacity = '0';
          setTimeout(() => { loader.style.display = 'none'; }, 500);
        }

        // "Buscar en esta zona" (Search in this area) event listeners
        map.on('dragend zoomend', () => {
          const searchHereBtn = document.getElementById('btn-search-here');
          if (searchHereBtn) {
            searchHereBtn.classList.remove('hidden');
            searchHereBtn.classList.add('flex');
          }
        });

        const searchHereBtn = document.getElementById('btn-search-here');
        if (searchHereBtn) {
          searchHereBtn.addEventListener('click', () => {
            if (map) {
              filterState.mapBounds = map.getBounds();
              filterAndRender(true);
            }
            searchHereBtn.classList.add('hidden');
            searchHereBtn.classList.remove('flex');
          });
        }

        setTimeout(() => { map.invalidateSize(); }, 150);
        filterAndRender();
      }

      function getFilteredProperties() {
        return rawProperties.filter((p: any) => {
          if (filterState.mapBounds) {
            const lat = parseFloat(p.geo_lat);
            const lng = parseFloat(p.geo_long);
            if (isNaN(lat) || isNaN(lng) || !filterState.mapBounds.contains(L.latLng(lat, lng))) {
              return false;
            }
          }
          if (filterState.keyword) {
            const clientNormalize = (str: string) => (str || '').toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();
            const kw = clientNormalize(filterState.keyword);
            const titleMatch = clientNormalize(p.publication_title).includes(kw);
            const descMatch = clientNormalize(p.description).includes(kw);
            const addrMatch = clientNormalize(p.address).includes(kw);
            const locationMatch = p.location?.name && clientNormalize(p.location.name).includes(kw);
            if (!titleMatch && !descMatch && !addrMatch && !locationMatch) return false;
          }

          if (filterState.operation) {
            const opId = parseInt(filterState.operation);
            if (!p.operations?.some((op: any) => op.operation_id === opId)) return false;
          }

          if (filterState.barrios.length > 0) {
            const propBarrio = p.location?.name?.toLowerCase().trim();
            if (!propBarrio || !filterState.barrios.some(b => propBarrio.includes(b))) return false;
          }

          if (filterState.types.length > 0) {
            if (!filterState.types.includes(p.type?.id?.toString())) return false;
          }

          if (filterState.rooms) {
            const roomsVal = parseInt(filterState.rooms);
            if (roomsVal === 4) {
              if ((p.room_amount || 0) < 4) return false;
            } else if (p.room_amount !== roomsVal) {
              return false;
            }
          }

          if (filterState.bedrooms) {
            const bedsVal = parseInt(filterState.bedrooms);
            if (bedsVal === 4) {
              if ((p.suite_amount || 0) < 4) return false;
            } else if (p.suite_amount !== bedsVal) {
              return false;
            }
          }

          if (filterState.bathrooms) {
            const bathVal = parseInt(filterState.bathrooms);
            const totalBaths = (p.bathroom_amount || 0) + (p.toilet_amount || 0);
            if (bathVal === 4) {
              if (totalBaths < 4) return false;
            } else if (totalBaths !== bathVal) {
              return false;
            }
          }

          if (filterState.garage) {
            const garageVal = parseInt(filterState.garage);
            if (garageVal === 4) {
              if ((p.parking_lot_amount || 0) < 4) return false;
            } else if (p.parking_lot_amount !== garageVal) {
              return false;
            }
          }

          if (filterState.surfaceMin !== null || filterState.surfaceMax !== null) {
            const totalSurf = parseFloat(p.total_surface || p.covered_surface || p.surface || '0');
            if (filterState.surfaceMin !== null && totalSurf < filterState.surfaceMin) return false;
            if (filterState.surfaceMax !== null && totalSurf > filterState.surfaceMax) return false;
          }

          const opId = filterState.operation ? parseInt(filterState.operation) : null;
          const currFilter = filterState.currency;
          let priceObj = null;
          
          if (p.operations) {
            const matchedOps = p.operations.filter((op: any) => !opId || op.operation_id === opId);
            for (const op of matchedOps) {
              if (op.prices) {
                const foundPrice = op.prices.find((pr: any) => !currFilter || pr.currency === currFilter);
                if (foundPrice) {
                  priceObj = foundPrice;
                  break;
                }
              }
            }
            if (!priceObj && matchedOps.length > 0 && matchedOps[0].prices) {
              priceObj = matchedOps[0].prices[0];
            }
          }

          if (priceObj) {
            if (filterState.currency && priceObj.currency !== filterState.currency) return false;
            
            if (hasUserFilteredPrice) {
              if (priceObj.price < filterState.priceMin) return false;
              
              const maxLimit = sliderMax ? parseInt(sliderMax.max) : (filterState.currency === 'ARS' ? 50000000 : 2000000);
              if (filterState.priceMax < maxLimit && priceObj.price > filterState.priceMax) return false;
            }
          } else {
            if (hasUserFilteredPrice && filterState.priceMin > 200) return false;
          }

          if (filterState.moreToggles.length > 0) {
            const propTags = (p.tags || []).map((t: any) => t.name.toLowerCase());
            const age = p.age !== undefined && p.age !== null ? parseInt(p.age) : null;
            for (const toggle of filterState.moreToggles) {
              let matched = false;
              if (toggle === 'apto-credito') {
                matched = propTags.some(t => t.includes('crédito') || t.includes('credito') || t.includes('financed') || t.includes('credit'));
              } else if (toggle === 'apto-profesional') {
                matched = propTags.some(t => t.includes('profesional') || t.includes('professional') || t.includes('work able') || t.includes('office'));
              } else if (toggle === 'a-estrenar') {
                matched = (age === 0) || propTags.some(t => t.includes('estrenar') || t.includes('nuevo') || t.includes('brand new') || t.includes('under construction'));
              } else if (toggle === 'hasta-5-anos') {
                matched = (age !== null && age <= 5) || propTags.some(t => t.includes('5 años') || t.includes('5 years') || t.includes('recent') || t.includes('reciente'));
              } else if (toggle === 'hasta-10-anos') {
                matched = (age !== null && age <= 10) || propTags.some(t => t.includes('10 años') || t.includes('10 years'));
              } else if (toggle === 'hasta-20-anos') {
                matched = (age !== null && age <= 20) || propTags.some(t => t.includes('20 años') || t.includes('20 years'));
              } else if (toggle === 'mas-de-20-anos') {
                matched = (age !== null && age > 20) || propTags.some(t => t.includes('antiguo') || t.includes('old') || t.includes('classic') || t.includes('más de 20') || t.includes('more than 20'));
              } else {
                matched = propTags.some(t => t === toggle || t.includes(toggle));
              }
              if (!matched) return false;
            }
          }

          return true;
        });
      }

      function filterAndRender(keepMapBounds = false) {
        if (!keepMapBounds) {
          filterState.mapBounds = null;
          const searchHereBtn = document.getElementById('btn-search-here');
          if (searchHereBtn) {
            searchHereBtn.classList.add('hidden');
            searchHereBtn.classList.remove('flex');
          }
        }
        updatePillLabels();
        const filtered = getFilteredProperties();

        if (map) {
          activeMarkers.forEach(marker => map.removeLayer(marker));
          activeMarkers = [];
          currentMarkerIndex = -1;

          const groups: { [key: string]: any[] } = {};
          filtered.forEach((p: any) => {
          const lat = parseFloat(p.geo_lat);
          const lng = parseFloat(p.geo_long);
          if (!isNaN(lat) && !isNaN(lng)) {
            const key = `${lat.toFixed(5)},${lng.toFixed(5)}`;
            if (!groups[key]) groups[key] = [];
            groups[key].push(p);
          }
        });

        const bounds = L.latLngBounds([]);
        let hasCoords = false;
        let sumLat = 0;
        let sumLng = 0;
        let coordCount = 0;

        Object.keys(groups).forEach(key => {
          const groupProps = groups[key];
          const count = groupProps.length;
          const firstProp = groupProps[0];
          const lat = parseFloat(firstProp.geo_lat);
          const lng = parseFloat(firstProp.geo_long);

          if (!isNaN(lat) && !isNaN(lng)) {
            const pinHtml = createPinHTML(firstProp.type?.id, count);
            const customIcon = L.divIcon({
              html: pinHtml,
              className: 'custom-map-marker',
              iconSize: [32, 40],
              iconAnchor: [16, 40],
              popupAnchor: [0, -35]
            });

            let popupContent = '';
            if (count === 1) {
              const p = firstProp;
              const op = p.operations?.[0];
              const price = op?.prices?.[0];
              const priceStr = price ? `${price.currency}${new Intl.NumberFormat('es-AR', { maximumFractionDigits: 0 }).format(price.price)}` : 'Consultar';
              const thumb = p.photos?.[0]?.thumb || p.photos?.[0]?.image || 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=300&q=80';
              let opTypeLabel = op ? op.operation_type.toUpperCase() : 'VENTA';
              if (opTypeLabel.includes('RENT') || opTypeLabel.includes('ALQ')) opTypeLabel = 'ALQUILER';

              const beds = p.suite_amount || 0;
              const rooms = p.room_amount || 0;
              const baths = (p.bathroom_amount || 0) + (p.toilet_amount || 0);
              const cocheras = p.parking_lot_amount || 0;
              const surfaceVal = p.total_surface || p.covered_surface || p.surface || '0';

              const specs = [];
              if (beds > 0) specs.push({ value: beds, icon: 'bed' });
              if (rooms > 0) specs.push({ value: rooms, icon: 'door' });
              if (baths > 0) specs.push({ value: baths, icon: 'bath' });
              if (cocheras > 0) specs.push({ value: cocheras, icon: 'car' });
              if (parseFloat(surfaceVal) > 0) specs.push({ value: parseFloat(surfaceVal).toFixed(0), icon: 'ruler' });

              const popupSpecsHtml = specs.map(spec => {
                let iconSvg = '';
                if (spec.icon === 'door') {
                  iconSvg = `<svg class="w-[14px] h-[14px] text-[#191c1d]/90 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="14" height="18" rx="1" /><circle cx="8" cy="12" r="0.75" fill="currentColor" /></svg>`;
                } else if (spec.icon === 'bed') {
                  iconSvg = `<svg class="w-[14px] h-[14px] text-[#191c1d]/90 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v6" /><path d="M3 10V6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v4" /><path d="M12 4v6" /><path d="M5 14h14" /></svg>`;
                } else if (spec.icon === 'bath') {
                  iconSvg = `<svg class="w-[14px] h-[14px] text-[#191c1d]/90 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20v-9a4 4 0 0 1 4-4h7" /><path d="M14 7h3l1 3H13z" fill="currentColor" fill-opacity="0.15" /><path d="M14 12v2M15.5 12v3M17 12v2" /></svg>`;
                } else if (spec.icon === 'car') {
                  iconSvg = `<svg class="w-[14px] h-[14px] text-[#191c1d]/90 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M6 14 L8 9h8l2 5" /><rect x="4" y="14" width="16" height="5" rx="1" /><circle cx="7" cy="16.5" r="0.75" fill="currentColor" /><circle cx="17" cy="16.5" r="0.75" fill="currentColor" /><path d="M6 19v2M18 19v2" /></svg>`;
                } else if (spec.icon === 'ruler') {
                  iconSvg = `<svg class="w-[14px] h-[14px] text-[#191c1d]/90 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M5 5v14h14z" /><path d="M8 8v8h8z" /><path d="M8 19v-1M11 19v-1M14 19v-1M17 19v-1" /></svg>`;
                }
                return `<div class="flex items-center gap-1 shrink-0">${iconSvg}<span class="text-[11px] font-semibold text-[#191c1d]">${spec.value}${spec.icon === 'ruler' ? ' m²' : ''}</span></div>`;
              }).join('');

              popupContent = `
                <div class="font-body-md select-none">
                  <div class="relative w-full h-[130px] overflow-hidden bg-gray-100 rounded-t-md">
                    <img src="${thumb}" class="w-full h-full object-cover" width="200" height="130" alt="" />
                    <div class="absolute top-2.5 left-2.5 flex gap-1.5 select-none items-center">
                      <span class="bg-[#121212]/85 text-pure-white border border-white/20 px-2 py-1 text-[10px] font-sans font-[300] leading-[10px] tracking-wider uppercase rounded-md">${opTypeLabel}</span>
                      <span class="bg-[#121212]/85 text-pure-white border border-white/20 px-2 py-1 text-[10px] font-sans font-[300] leading-[10px] tracking-wider uppercase rounded-md">DISPONIBLE</span>
                    </div>
                  </div>
                  <div class="p-4 bg-pure-white rounded-b-md text-left space-y-2">
                    <span class="text-sm font-bold text-primary block leading-none select-text">${priceStr}</span>
                    <span class="text-[11px] text-secondary font-medium block leading-tight truncate select-text">${p.address || p.publication_title}</span>
                    <span class="text-[9px] text-[#888888] font-bold block uppercase tracking-wider select-text">${(p.location?.name || '').toUpperCase()}</span>
                    <div class="border-t border-outline-variant/15 pt-2 flex flex-wrap items-center gap-3 text-[#191c1d] select-none leading-none">
                      ${popupSpecsHtml}
                    </div>
                    <a href="/property/${p.id}/" class="mt-3 block w-full bg-black hover:bg-[#121212] text-pure-white hover:text-pure-white text-center text-[9px] font-bold uppercase tracking-widest py-2 rounded transition-colors duration-200 font-sans">VER DETALLES</a>
                  </div>
                </div>
              `;
            } else {
              const itemsHtml = groupProps.map((p: any) => {
                const op = p.operations?.[0];
                const price = op?.prices?.[0];
                const priceStr = price ? `${price.currency}${new Intl.NumberFormat('es-AR', { maximumFractionDigits: 0 }).format(price.price)}` : 'Consultar';
                const thumb = p.photos?.[0]?.thumb || p.photos?.[0]?.image || 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=300&q=80';
                return `
                  <div class="flex items-center gap-3 p-2 hover:bg-surface rounded-lg transition-colors border border-outline-variant/10">
                    <img src="${thumb}" class="w-12 h-12 object-cover rounded-md flex-shrink-0" width="48" height="48" />
                    <div class="min-w-0 flex-grow text-left font-sans">
                      <div class="text-[10px] font-bold text-[#888888] uppercase tracking-wider leading-none">${p.type?.name || 'Propiedad'}</div>
                      <div class="text-[11px] font-semibold text-secondary truncate mt-0.5 leading-tight">${p.address || p.publication_title}</div>
                      <div class="text-xs font-bold text-primary mt-1 leading-none">${priceStr}</div>
                    </div>
                    <a href="/property/${p.id}/" class="bg-black text-pure-white text-[9px] font-bold uppercase px-2.5 py-1.5 rounded hover:bg-[#121212] hover:text-pure-white transition-colors flex-shrink-0 font-sans">Ver</a>
                  </div>
                `;
              }).join('');

              popupContent = `
                <div class="font-body-md p-3 bg-pure-white rounded-md text-left space-y-3 w-[280px]">
                  <div class="text-[9px] font-bold text-[#888888] uppercase tracking-widest leading-none border-b border-outline-variant/20 pb-2">
                    ${count} Propiedades en esta ubicación
                  </div>
                  <div class="space-y-2 max-h-[200px] overflow-y-auto pr-1 scrollbar-thin">
                    ${itemsHtml}
                  </div>
                </div>
              `;
            }

            const marker = L.marker([lat, lng], { icon: customIcon }).bindPopup(popupContent).addTo(map);
            marker.propertyIds = groupProps.map(p => p.id);
            activeMarkers.push(marker);

            bounds.extend([lat, lng]);
            hasCoords = true;

            sumLat += lat * count;
            sumLng += lng * count;
            coordCount += count;
          }
        });

        if (!keepMapBounds && hasCoords && activeMarkers.length > 0) {
          const avgLat = sumLat / coordCount;
          const avgLng = sumLng / coordCount;
          const centroid = L.latLng(avgLat, avgLng);

          const targetZoom = Math.max(13, Math.min(16, map.getBoundsZoom(bounds)));
          map.setView(centroid, targetZoom);
        }
        }

        allFilteredProperties = filtered;
        displayedPropertiesCount = 0;
        const listContainer = document.getElementById('properties-list');
        if (listContainer) {
          listContainer.innerHTML = '';
          listContainer.scrollTop = 0;
        }
        loadNextBatch();

        const counterEl = document.getElementById('map-listings-counter');
        if (counterEl) {
          counterEl.textContent = `Mostrando ${filtered.length} de ${rawProperties.length} propiedades`;
        }

        const isFiltered = filterState.keyword || filterState.operation || filterState.types.length > 0 ||
                           filterState.rooms || filterState.bedrooms || filterState.bathrooms || filterState.garage ||
                           filterState.surfaceMin !== null || filterState.surfaceMax !== null ||
                           filterState.moreToggles.length > 0 || filterState.barrios.length > 0 ||
                           filterState.priceMin > 200 || filterState.priceMax < 2500000;
        
        const clearBtn = document.getElementById('btn-clear-search');
        if (clearBtn) {
          if (isFiltered) clearBtn.classList.remove('hidden');
          else clearBtn.classList.add('hidden');
        }
        updateSearchLinks();
      }

      function loadNextBatch() {
        const listContainer = document.getElementById('properties-list');
        if (!listContainer) return;

        if (allFilteredProperties.length === 0) {
          listContainer.innerHTML = `
            <div class="flex flex-col items-center justify-center py-20 text-center space-y-4 font-sans">
              <span class="material-symbols-outlined text-[48px] text-secondary/40">search_off</span>
              <div class="space-y-1">
                <p class="font-headline-md text-base text-secondary font-bold">No encontramos ningún resultado</p>
