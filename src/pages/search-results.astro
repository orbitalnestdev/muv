          let opTypeLabel = op ? op.operation_type.toUpperCase() : 'VENTA';
          if (opTypeLabel.includes('RENT') || opTypeLabel.includes('ALQ')) opTypeLabel = 'ALQUILER';

          const beds = p.suite_amount || 0;
          const rooms = p.room_amount || 0;
          const baths = (p.bathroom_amount || 0) + (p.toilet_amount || 0);
          const cocheras = p.parking_lot_amount || 0;
          const surfaceVal = p.total_surface || p.covered_surface || p.surface || '0';

          const photos = p.photos || [];
          const imageList = photos.length > 0 ? photos.map((ph: any) => ph.image) : ['https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=500&q=80'];
          const optimizedSrc = imageList[0];

          const specs = [];
          if (beds > 0) specs.push({ value: beds, label: beds === 1 ? 'Dormitorio' : 'Dormitorios', icon: 'bed' });
          if (rooms > 0) specs.push({ value: rooms, label: rooms === 1 ? 'Ambiente' : 'Ambientes', icon: 'door' });
          if (baths > 0) specs.push({ value: baths, label: baths === 1 ? 'Baño' : 'Baños', icon: 'bath' });
          if (cocheras > 0) specs.push({ value: cocheras, label: cocheras === 1 ? 'Garage' : 'Garages', icon: 'car' });
          if (parseFloat(surfaceVal) > 0) specs.push({ value: Math.round(parseFloat(surfaceVal)), label: 'm²', icon: 'ruler' });

          const specsHtml = specs.map((spec, index) => {
            let iconSvg = '';
            if (spec.icon === 'door') {
              iconSvg = `<svg class="w-[16px] h-[16px] text-[#191c1d]/90 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.0" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="14" height="18" rx="1" /><circle cx="8" cy="12" r="0.75" fill="currentColor" /></svg>`;
            } else if (spec.icon === 'bed') {
              iconSvg = `<svg class="w-[16px] h-[16px] text-[#191c1d]/90 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.0" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v6" /><path d="M3 10V6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v4" /><path d="M12 4v6" /><path d="M5 14h14" /></svg>`;
            } else if (spec.icon === 'bath') {
              iconSvg = `<svg class="w-[16px] h-[16px] text-[#191c1d]/90 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.0" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20v-9a4 4 0 0 1 4-4h7" /><path d="M14 7h3l1 3H13z" fill="currentColor" fill-opacity="0.15" /><path d="M14 12v2M15.5 12v3M17 12v2" /></svg>`;
            } else if (spec.icon === 'car') {
              iconSvg = `<svg class="w-[16px] h-[16px] text-[#191c1d]/90 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.0" stroke-linecap="round" stroke-linejoin="round"><path d="M6 14 L8 9h8l2 5" /><rect x="4" y="14" width="16" height="5" rx="1" /><circle cx="7" cy="16.5" r="0.75" fill="currentColor" /><circle cx="17" cy="16.5" r="0.75" fill="currentColor" /><path d="M6 19v2M18 19v2" /></svg>`;
            } else if (spec.icon === 'ruler') {
              iconSvg = `<svg class="w-[16px] h-[16px] text-[#191c1d]/90 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.0" stroke-linecap="round" stroke-linejoin="round"><path d="M5 5v14h14z" /><path d="M8 8v8h8z" /><path d="M8 19v-1M11 19v-1M14 19v-1M17 19v-1" /></svg>`;
            }

            const isLast = index === specs.length - 1;
            const paddingClass = index === 0 ? 'pr-3.5' : isLast ? 'pl-3.5' : 'px-3.5';
            const borderClass = isLast ? '' : 'border-r border-outline-variant/25';
            return `
              <div class="${paddingClass} ${borderClass} flex flex-col items-start shrink-0 font-sans">
                <div class="flex items-center gap-1.5 font-normal text-[16px] text-primary">
                  <span>${spec.value}</span>
                  ${iconSvg}
                </div>
                <span class="text-[10.5px] text-[#747878] font-[300] mt-0.5 block leading-normal">${spec.label}</span>
              </div>
            `;
          }).join('');

          html += `
            <div class="property-row-card flex flex-col sm:flex-row bg-pure-white rounded-lg border border-outline-variant/30 overflow-hidden hover:shadow-md transition-all duration-300 relative group h-auto sm:h-[196px]" data-id="${p.id}" data-photos='${JSON.stringify(imageList)}' data-lat="${p.geo_lat || ''}" data-lng="${p.geo_long || ''}">
              <div class="relative w-full sm:w-[240px] h-[160px] sm:h-full overflow-hidden shrink-0 bg-gray-100 select-none">
                <div class="absolute top-3.5 left-3.5 z-10 select-none pointer-events-none opacity-40">
                  <div class="text-[12px] font-bold text-pure-white uppercase tracking-[0.2em] leading-none">MUV</div>
                </div>
                ${imageList.length > 1 ? `
                  <button class="row-carousel-btn row-btn-prev absolute left-2 top-1/2 -translate-y-1/2 z-10 w-8 h-8 flex items-center justify-center text-white/75 hover:text-white hover:scale-110 transition-all opacity-0 group-hover:opacity-100" aria-label="Anterior">
                    <span class="material-symbols-outlined text-[28px] font-light">chevron_left</span>
                  </button>
                  <button class="row-carousel-btn row-btn-next absolute right-2 top-1/2 -translate-y-1/2 z-10 w-8 h-8 flex items-center justify-center text-white/75 hover:text-white hover:scale-110 transition-all opacity-0 group-hover:opacity-100" aria-label="Siguiente">
                    <span class="material-symbols-outlined text-[28px] font-light">chevron_right</span>
                  </button>
                ` : ''}
                <div class="absolute bottom-2.5 right-2.5 z-10 flex items-center gap-1.5">
                  <button class="row-zoom-btn w-7 h-7 bg-[#121212]/60 hover:bg-primary border border-white/10 rounded flex items-center justify-center text-white transition-all opacity-0 group-hover:opacity-100 active:scale-95 pointer-events-auto" aria-label="Zoom">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
                    </svg>
                  </button>
                  <button class="row-save-btn w-7 h-7 bg-[#121212]/60 hover:bg-primary border border-white/10 rounded flex items-center justify-center text-white transition-all opacity-0 group-hover:opacity-100 active:scale-95 pointer-events-auto" aria-label="Guardar">
                    <span class="material-symbols-outlined text-[16px]">add_circle</span>
                  </button>
                </div>
                <a href="/property/${p.id}/" class="block w-full h-full">
                  <img src="${optimizedSrc}" class="row-carousel-img w-full h-full object-cover group-hover:scale-103 transition-transform duration-500" loading="lazy" width="240" height="160" alt="${p.publication_title}" />
                </a>
              </div>
              <div class="flex flex-col justify-between p-4 flex-grow text-left relative min-w-0 font-sans">
                <div class="flex justify-between items-center w-full">
                  <div class="flex gap-1.5 select-none items-center">
                    <span class="bg-[#4A4A4A] text-pure-white px-2.5 py-1 text-[10px] font-sans font-[300] leading-[10px] tracking-wider uppercase rounded-md">${opTypeLabel}</span>
                    <span class="bg-[#4A4A4A] text-pure-white px-2.5 py-1 text-[10px] font-sans font-[300] leading-[10px] tracking-wider uppercase rounded-md">DISPONIBLE</span>
                  </div>
                  <span class="font-sans text-[16px] font-bold text-[#191c1d] leading-none shrink-0 select-text">${priceText}</span>
                </div>
                <h3 class="font-sans text-[16px] font-medium text-[#191c1d] leading-tight truncate mt-2 max-w-full">
                  <a href="/property/${p.id}/" class="hover:text-primary transition-colors">${p.address || p.publication_title}</a>
                </h3>
                <div class="flex items-center gap-1 text-[#888888] text-[12px] font-medium mt-1 select-text">
                  <svg class="w-3.5 h-3.5 text-[#888888] flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" />
                  </svg>
                  <span>${p.location?.name || ''}</span>
                </div>
                <span class="font-sans text-[10px] font-bold text-[#191c1d] uppercase tracking-widest block mt-2">${p.type?.name ? p.type.name.toUpperCase() : 'DEPARTAMENTO'}</span>
                <div class="border-t border-outline-variant/15 pt-3.5 pb-1.5 mt-3 flex items-center text-[#191c1d] select-none overflow-x-auto whitespace-nowrap scrollbar-hide">
                  ${specsHtml}
