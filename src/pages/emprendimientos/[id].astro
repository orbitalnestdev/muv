---
import MainLayout from '../../layouts/MainLayout.astro';
import { getDevelopmentById, getPropertiesByDevelopmentId } from '../../lib/tokko';

const { id } = Astro.params;

// Fetch development data at request-time (SSR)
const development = await getDevelopmentById(Number(id));

// Handle missing development state
if (!development) {
  return Astro.redirect('/emprendimientos/');
}

// Fetch properties (units) associated with this development
const units = await getPropertiesByDevelopmentId(Number(id));

const {
  name,
  description,
  construction_status,
  location,
  photos = []
} = development;

const statusText = construction_status || "PREMIUM";
const addressText = location?.name || "Buenos Aires";
const fullLocationText = location?.full_location ? location.full_location.split('|').slice(-2).join(', ') : '';
---

<MainLayout 
  title={`${name} | Emprendimientos | MUV Propiedades`} 
  description={`${name} - Desarrollo exclusivo en ${addressText}. ${description.substring(0, 150)}...`}
  isDarkHero={false}
>
    <main class="pt-24 min-h-[70vh] bg-surface select-none">
        
        <!-- Breadcrumbs -->
        <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-6">
            <nav class="flex items-center space-x-2 text-label-sm font-label-sm text-secondary text-left">
                <a class="hover:text-primary transition-colors" href="/">Inicio</a>
                <span class="material-symbols-outlined text-[14px]">chevron_right</span>
                <a class="hover:text-primary transition-colors" href="/emprendimientos/">Emprendimientos</a>
                <span class="material-symbols-outlined text-[14px]">chevron_right</span>
                <span class="text-on-surface truncate max-w-[150px] md:max-w-xs">{name}</span>
            </nav>
        </div>

        <!-- 3-Image Gallery Grid -->
        <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-8">
            {photos.length >= 3 ? (
                <div class="grid grid-cols-1 md:grid-cols-3 gap-3 h-[45vh] md:h-[60vh] overflow-hidden select-none">
                    <!-- Left large image (2/3 width) -->
                    <div class="md:col-span-2 h-full overflow-hidden rounded-xl border border-outline-variant/20 shadow-sm relative group">
                        <img class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-103" src={photos[0].image} alt={`${name} principal`} />
                    </div>
                    <!-- Right two smaller stacked images (1/3 width) -->
                    <div class="hidden md:flex flex-col gap-3 h-full">
                        <div class="h-1/2 overflow-hidden rounded-xl border border-outline-variant/20 shadow-sm relative group">
                            <img class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-103" src={photos[1].image} alt={`${name} detalle 1`} />
                        </div>
                        <div class="h-1/2 overflow-hidden rounded-xl border border-outline-variant/20 shadow-sm relative group">
                            <img class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-103" src={photos[2].image} alt={`${name} detalle 2`} />
                        </div>
                    </div>
                </div>
            ) : photos.length === 2 ? (
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3 h-[45vh] md:h-[60vh] overflow-hidden select-none">
                    <div class="h-full overflow-hidden rounded-xl border border-outline-variant/20 shadow-sm relative group">
                        <img class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-103" src={photos[0].image} alt={`${name} 1`} />
                    </div>
                    <div class="h-full overflow-hidden rounded-xl border border-outline-variant/20 shadow-sm relative group">
                        <img class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-103" src={photos[1].image} alt={`${name} 2`} />
                    </div>
                </div>
            ) : (
                <div class="w-full h-[45vh] md:h-[60vh] overflow-hidden rounded-xl border border-outline-variant/20 shadow-sm relative group select-none">
                    <img 
                      class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-103" 
                      src={photos.length > 0 ? photos[0].image : "https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?auto=format&fit=crop&w=1600&q=80"} 
                      alt={name} 
                    />
                </div>
            )}
        </div>

        <!-- Title and Badges Block -->
        <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-6 text-left space-y-3">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <div class="space-y-1.5">
                    <h1 class="font-display-lg text-3xl md:text-5xl text-primary font-bold tracking-tight">
                        {name}
                    </h1>
                    <div class="flex items-center gap-2 text-slate-blue text-sm font-medium">
                        <span class="material-symbols-outlined text-[18px]">location_on</span>
                        <span>{addressText}</span>
                        {fullLocationText && <span class="text-secondary/50">|</span>}
                        {fullLocationText && <span class="text-secondary text-xs uppercase font-semibold">{fullLocationText}</span>}
                    </div>
                </div>
                <div>
                    <span class="inline-block px-4 py-1.5 bg-refined-gold text-pure-white font-label-sm text-xs font-bold uppercase tracking-widest rounded-lg shadow-sm">
                        {statusText}
                    </span>
                </div>
            </div>
        </div>

        <!-- Project Overview Section -->
        <section class="py-24 bg-surface-container-lowest text-left">
            <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop grid grid-cols-1 lg:grid-cols-12 gap-gutter">
                <div class="lg:col-span-8 space-y-6">
                    <h2 class="font-headline-lg text-2xl md:text-3xl text-primary border-l-4 border-refined-gold pl-6 font-semibold">Detalles del Emprendimiento</h2>
                    <div class="space-y-6 text-slate-blue font-body-lg leading-relaxed text-sm md:text-base whitespace-pre-line">
                        {description}
                    </div>
                    
                    <div class="mt-12 grid grid-cols-2 md:grid-cols-4 gap-8 pt-8 border-t border-outline-variant/30">
                        <div>
                            <span class="block text-refined-gold font-headline-md text-2xl font-bold mb-1">12</span>
                            <span class="font-label-sm text-xs text-on-surface-variant uppercase tracking-tighter font-semibold">Pisos</span>
                        </div>
                        <div>
                            <span class="block text-refined-gold font-headline-md text-2xl font-bold mb-1">{units.length || 'S/D'}</span>
                            <span class="font-label-sm text-xs text-on-surface-variant uppercase tracking-tighter font-semibold">Unidades</span>
                        </div>
                        <div>
                            <span class="block text-refined-gold font-headline-md text-2xl font-bold mb-1 font-bold">2026</span>
                            <span class="font-label-sm text-xs text-on-surface-variant uppercase tracking-tighter font-semibold">Entrega</span>
                        </div>
                        <div>
                            <span class="block text-refined-gold font-headline-md text-2xl font-bold mb-1">980m²</span>
                            <span class="font-label-sm text-xs text-on-surface-variant uppercase tracking-tighter font-semibold">Amenities</span>
                        </div>
                    </div>
                </div>
                
                <div class="lg:col-span-4 bg-off-white p-8 border border-outline-variant/30 flex flex-col justify-between h-fit rounded-lg shadow-sm">
                    <div>
                        <h3 class="font-headline-md text-lg text-primary font-bold mb-4">Ubicación</h3>
                        <div class="w-full h-48 bg-surface-container-high mb-6 overflow-hidden rounded relative border border-outline-variant/20 shadow-inner">
                            <iframe 
                                class="w-full h-full border-0 grayscale hover:grayscale-0 transition-all duration-700" 
                                src={`https://maps.google.com/maps?q=${encodeURIComponent(addressText)}&t=&z=15&ie=UTF8&iwloc=&output=embed`} 
                                allowfullscreen 
                                loading="lazy"
                                title={`Mapa de ${name}`}>
                            </iframe>
                        </div>
                        <p class="text-slate-blue font-body-md mb-2 font-medium">{addressText}</p>
                        <p class="text-on-surface-variant font-label-sm text-xs uppercase font-semibold">{fullLocationText}</p>
                    </div>
                    <button id="btn-download-brochure" class="mt-8 w-full border border-primary py-3.5 rounded font-label-lg text-label-lg text-primary hover:bg-primary hover:text-pure-white transition-all duration-300 font-bold uppercase tracking-wider">
                        DESCARGAR BROCHURE
                    </button>
                </div>
            </div>
        </section>

        <!-- Available Units (Properties Table) -->
        <section class="py-24 bg-off-white">
            <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
                <div class="flex flex-col sm:flex-row justify-between sm:items-end mb-12 gap-4 text-left">
                    <div>
                        <h2 class="font-headline-lg text-2xl md:text-3xl text-primary font-bold">Unidades Disponibles</h2>
                        <p class="text-secondary text-sm mt-1">Haga clic en una unidad para ver detalles completos.</p>
                    </div>
                    <div class="flex flex-wrap gap-4">
                        <select id="filter-rooms" class="border border-outline-variant rounded px-4 py-2 text-xs font-semibold text-slate-blue bg-white focus:ring-1 focus:ring-refined-gold outline-none">
                            <option value="">Todos los ambientes</option>
                            <option value="1">1 Ambiente</option>
                            <option value="2">2 Ambientes</option>
                            <option value="3">3 Ambientes</option>
                            <option value="4">4+ Ambientes</option>
                        </select>
                        <select id="sort-price" class="border border-outline-variant rounded px-4 py-2 text-xs font-semibold text-slate-blue bg-white focus:ring-1 focus:ring-refined-gold outline-none">
                            <option value="asc">Precio: Menor a Mayor</option>
                            <option value="desc">Precio: Mayor a Menor</option>
                        </select>
                    </div>
                </div>
                
                <div class="overflow-x-auto bg-pure-white rounded-lg border border-outline-variant/30 shadow-sm">
                    <table class="w-full border-collapse text-left">
                        <thead>
                            <tr class="border-b border-outline-variant text-left bg-surface-container-low/30">
                                <th class="p-6 font-sans text-xs text-primary font-bold uppercase tracking-wider">Dirección</th>
                                <th class="p-6 font-sans text-xs text-primary font-bold uppercase tracking-wider">Ambientes</th>
                                <th class="p-6 font-sans text-xs text-primary font-bold uppercase tracking-wider">Dormitorios</th>
                                <th class="p-6 font-sans text-xs text-primary font-bold uppercase tracking-wider">Superficie Cubierta</th>
                                <th class="p-6 font-sans text-xs text-primary font-bold uppercase tracking-wider">Superficie Total</th>
                                <th class="p-6 font-sans text-xs text-primary font-bold uppercase tracking-wider">Cochera</th>
                                <th class="p-6 font-sans text-xs text-primary font-bold uppercase tracking-wider">Venta</th>
                                <th class="p-6 font-sans text-xs text-primary font-bold uppercase tracking-wider">Alquiler</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant/30 font-medium" id="units-table-body">
                            {units.length === 0 ? (
                                <tr>
                                    <td colspan="8" class="p-8 text-center text-secondary font-medium">No hay unidades disponibles en este momento.</td>
                                </tr>
                            ) : (
                                units.map(u => {
                                    const ventaOp = u.operations?.find(op => op.operation_type.toLowerCase() === 'venta');
                                    const ventaPrice = ventaOp?.prices?.[0];
                                    const ventaVal = ventaPrice?.price || 0;
                                    const ventaText = ventaVal > 0 
                                      ? `${ventaPrice.currency || 'USD'} ${new Intl.NumberFormat('es-AR', { maximumFractionDigits: 0 }).format(ventaVal)}` 
                                      : '-';

                                    const alquilerOp = u.operations?.find(op => op.operation_type.toLowerCase() === 'alquiler');
                                    const alquilerPrice = alquilerOp?.prices?.[0];
                                    const alquilerVal = alquilerPrice?.price || 0;
                                    const alquilerText = alquilerVal > 0 
                                      ? `${alquilerPrice.currency || 'USD'} ${new Intl.NumberFormat('es-AR', { maximumFractionDigits: 0 }).format(alquilerVal)}` 
                                      : '-';

                                    const rooms = u.room_amount || 1;
                                    const bedrooms = u.suite_amount || 0;
                                    const coveredSize = u.covered_surface ? `${Number(u.covered_surface).toFixed(2)} m²` : '-';
                                    const totalSize = u.total_surface ? `${Number(u.total_surface).toFixed(2)} m²` : '-';
                                    const hasParking = u.parking_lot_amount && u.parking_lot_amount > 0 ? 'Sí' : 'No';

                                    const sortPriceVal = ventaVal > 0 ? ventaVal : alquilerVal;

                                    return (
                                        <tr 
                                          class="unit-row hover:bg-surface-container-lowest transition-colors duration-200 cursor-pointer"
                                          data-id={u.id}
                                          data-price={sortPriceVal}
                                          data-rooms={rooms}
                                        >
                                            <td class="p-6 font-sans text-sm text-slate-blue">{u.address ? `${u.address} ${u.reference_code || u.id}` : `${name.split(' - ')[0]} ${u.reference_code || u.id}`}</td>
                                            <td class="p-6 font-sans text-sm text-slate-blue">{rooms}</td>
                                            <td class="p-6 font-sans text-sm text-slate-blue">{bedrooms}</td>
                                            <td class="p-6 font-sans text-sm text-slate-blue">{coveredSize}</td>
                                            <td class="p-6 font-sans text-sm text-slate-blue">{totalSize}</td>
                                            <td class="p-6 font-sans text-sm text-slate-blue">{hasParking}</td>
                                            <td class="p-6 font-sans text-sm text-slate-blue">{ventaText}</td>
                                            <td class="p-6 font-sans text-sm text-slate-blue">{alquilerText}</td>
                                        </tr>
                                    );
                                })
                            )}
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <!-- Project Photos Gallery -->
        <section class="py-24 bg-surface-container-low">
            <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop text-left">
                <h2 class="font-headline-lg text-2xl md:text-3xl text-primary font-bold mb-12">Detalles del Proyecto</h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8" id="dev-photos-grid">
                    {photos.length > 0 ? (
                        photos.map(p => (
                            <div class="aspect-[4/5] overflow-hidden rounded bg-surface-container border border-outline-variant/20 relative group shadow-sm">
                                <img 
                                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" 
                                  src={p.image} 
                                  loading="lazy" 
                                  alt={`Foto de ${name}`} 
                                  width="600" 
                                  height="750" 
                                />
                            </div>
                        ))
                    ) : (
                        <div class="col-span-3 text-center py-12 text-secondary text-sm font-medium">Detalles visuales adicionales no disponibles.</div>
                    )}
                </div>
            </div>
        </section>
    </main>
</MainLayout>

<script is:inline define:vars={{ units, name }}>
  // Redirect unit row clicks to individual property page
  document.querySelectorAll('.unit-row').forEach(row => {
    row.addEventListener('click', (e) => {
      if (e.target.closest('a')) return;
      const id = row.getAttribute('data-id');
      if (id) {
        window.location.href = `/property/${id}/`;
      }
    });
  });

  // Table filtering and sorting
  const filterRooms = document.getElementById('filter-rooms');
  const sortPrice = document.getElementById('sort-price');
  const tableBody = document.getElementById('units-table-body');

  function filterAndSortTable() {
    if (!tableBody) return;
    const roomVal = filterRooms?.value || '';
    const sortVal = sortPrice?.value || 'asc';
    const rows = Array.from(tableBody.querySelectorAll('.unit-row'));

    rows.forEach(row => {
      const rooms = row.getAttribute('data-rooms') || '';
      const matchRooms = !roomVal || rooms === roomVal || (roomVal === '4' && parseInt(rooms) >= 4);

      if (matchRooms) {
        row.classList.remove('hidden');
      } else {
        row.classList.add('hidden');
      }
    });

    const sorted = rows.sort((a, b) => {
      const priceA = parseFloat(a.getAttribute('data-price') || '0');
      const priceB = parseFloat(b.getAttribute('data-price') || '0');
      return sortVal === 'asc' ? priceA - priceB : priceB - priceA;
    });

    sorted.forEach(row => tableBody.appendChild(row));
  }

  filterRooms?.addEventListener('change', filterAndSortTable);
  sortPrice?.addEventListener('change', filterAndSortTable);

  // Download brochure mock interaction
  const brochureBtn = document.getElementById('btn-download-brochure');
  brochureBtn?.addEventListener('click', () => {
    alert(`Brochure digital de ${name} enviado a su correo electrónico.`);
  });
</script>
