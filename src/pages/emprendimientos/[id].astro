---
import MainLayout from '../../layouts/MainLayout.astro';
import Gallery from '../../components/Gallery.astro';
import LeadForm from '../../components/LeadForm.astro';
import { getDevelopmentById, getPropertiesByDevelopmentId, getDevelopments } from '../../lib/tokko';

const { id } = Astro.params;

// Fetch development data at request-time (SSR)
const development = await getDevelopmentById(Number(id));

// Handle missing development state
if (!development) {
  return Astro.redirect('/emprendimientos/');
}

// Fetch properties (units) associated with this development
const rawUnits = await getPropertiesByDevelopmentId(Number(id));
const units = [...rawUnits].sort((a, b) => (b.room_amount || 0) - (a.room_amount || 0));

const {
  name,
  publication_title,
  description,
  construction_status,
  location,
  photos = [],
  address,
  construction_date
} = development;

const mainTitle = name;

const statusText = construction_status || "PREMIUM";
const addressText = address || location?.name || "Buenos Aires";
const fullLocationText = location?.full_location ? location.full_location.split('|').slice(-2).join(', ') : '';

function formatDeliveryDate(dateStr: string | null | undefined): string {
  if (!dateStr) return '';
  const parts = dateStr.split('-');
  if (parts.length < 2) return '';
  const year = parts[0];
  const monthNum = parseInt(parts[1], 10);
  const months = [
    'Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio',
    'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'
  ];
  const monthName = months[monthNum - 1] || '';
  return monthName ? `${monthName} ${year}` : year;
}

const deliveryDateText = formatDeliveryDate(construction_date);

function getUnitName(u: any): string {
  if (u.real_address && u.real_address.trim()) {
    return u.real_address.replace(/\s+/g, ' ').trim();
  }
  if (u.address && u.address.trim()) {
    return u.address.replace(/\s+/g, ' ').trim();
  }
  return u.publication_title || `Unidad ${u.id}`;
}

const photosList = photos.length > 0 ? photos.map(p => p.image) : [];

// Calculate minimum price from units
const ventaPrices = units
  .map(u => u.operations?.find(op => op.operation_type.toLowerCase() === 'venta')?.prices?.[0])
  .filter(p => p && p.price > 0);

const minPrice = ventaPrices.length > 0 
  ? Math.min(...ventaPrices.map(p => p.price))
  : 0;

const minPriceCurrency = ventaPrices.length > 0
  ? (ventaPrices[0].currency || 'USD')
  : 'USD';

const priceText = minPrice > 0
  ? `Desde ${minPriceCurrency} ${new Intl.NumberFormat('es-AR', { maximumFractionDigits: 0 }).format(minPrice)}`
  : 'Consultar';

// Fetch other developments for bottom section
const { developments: allDevs } = await getDevelopments();
const otherDevelopments = allDevs
  .filter(d => d.id !== Number(id))
  .slice(0, 2);

// Mapped unique amenities from units or default fallbacks
const defaultAmenities = [
  { name: 'Piscina' },
  { name: 'Gimnasio' },
  { name: 'SUM' },
  { name: 'Parrilla' },
  { name: 'Seguridad 24hs' },
  { name: 'Solarium' },
  { name: 'Cocheras' },
  { name: 'Laundry' }
];

const tagTranslations: Record<string, string> = {
  // Services
  'water': 'Agua Corriente',
  'sewer': 'Cloaca',
  'gas': 'Gas Natural',
  'electricity': 'Electricidad',
  'internet': 'Internet',
  'cable tv': 'Cable',
  'phone line': 'Línea Telefónica',
  'pavement': 'Pavimento',
  'security': 'Seguridad',
  'security 24hs': 'Seguridad 24hs',
  '24 hour security': 'Seguridad 24hs',
  'access control': 'Control de Acceso',
  
  // Amenities / Spaces / Characteristics
  'pool': 'Piscina',
  'swimming pool': 'Piscina',
  'outdoor swiming pool': 'Piscina',
  'gym': 'Gimnasio',
  'gymnasium': 'Gimnasio',
  'barbecue': 'Parrilla',
  'grill': 'Parrilla',
  'barbecue area': 'Parrilla',
  'communal bbq area': 'Parrilla',
  'individual grill in the apartment': 'Parrilla Individual',
  'quincho': 'Quincho',
  'sum': 'SUM',
  'balcony': 'Balcón',
  'professional use': 'Apto Profesional',
  'apto profesional': 'Apto Profesional',
  'work able': 'Apto Profesional',
  'solarium': 'Solarium',
  'solarium area': 'Solarium',
  'laundry': 'Laundry',
  'laundry room': 'Laundry',
  'playground': 'Juegos Infantiles',
  'green space': 'Espacio Verde',
  'green areas': 'Áreas Verdes',
  'terrace': 'Terraza',
  'parking': 'Cochera',
  'garage': 'Cochera',
  'cocheras': 'Cocheras',
  'air conditioning': 'Aire Acondicionado',
  'air conditioner': 'Aire Acondicionado',
  'individual air conditioner': 'Aire Acondicionado',
  'heating': 'Calefacción',
  'central heating': 'Calefacción Central',
  'elevator': 'Ascensor',
  'sauna': 'Sauna',
  'jacuzzi': 'Jacuzzi',
  'spa': 'Spa',
  'storage': 'Baulera',
  'locker room': 'Vestuario',
  'disabled access': 'Acceso Discapacitados',
  'kitchen': 'Cocina',
  'cocina': 'Cocina',
  'office': 'Oficina',
  'basement': 'Sótano',
  'toilet': 'Toilette',
  'toilette': 'Toilette',
  'playroom': 'Playroom',
  'play room': 'Playroom',
  'game room': 'Sala de Juegos',
  'living room': 'Living',
  'dining room': 'Comedor',
  'suite': 'Dormitorio en Suite',
  'dressing room': 'Vestidor',
  'desk': 'Escritorio',
  'patio': 'Patio',
  'garden': 'Jardín',
  'yard': 'Patio/Jardín',
  'attic': 'Altillo',
  'service quarters': 'Dependencia de Servicio',
  'hall': 'Hall',
  'gallery': 'Galería',
  'backyard': 'Jardín Trasero',
  'view': 'Vista',
  'river view': 'Vista al Río',
  'luminous': 'Luminoso',
  'category': 'Categoría',
  'pets allowed': 'Acepta Mascotas',
  'professional use / commercial': 'Apto Profesional / Comercial'
};

const translateTag = (name: string): string => {
  if (!name) return '';
  const key = name.trim().toLowerCase();
  return tagTranslations[key] || name;
};

const allTagsMap = new Map();
units.forEach(u => {
  u.tags?.forEach(tag => {
    const translated = translateTag(tag.name);
    allTagsMap.set(tag.id || tag.name, translated);
  });
});
const uniqueTags = Array.from(allTagsMap.values()).map(name => ({ name }));

const serviceKeywords = ['agua', 'luz', 'gas', 'cloaca', 'internet', 'electricidad', 'pavimento', 'desague', 'telefono', 'cable', 'corriente', 'servicio'];
const serviciosTags = uniqueTags.filter(tag => 
  serviceKeywords.some(keyword => tag.name.toLowerCase().includes(keyword))
);
const amenitiesTags = uniqueTags.filter(tag => 
  !serviceKeywords.some(keyword => tag.name.toLowerCase().includes(keyword))
);

const defaultServices = [
  { name: 'Agua Corriente' },
  { name: 'Cloaca' },
  { name: 'Gas Natural' },
  { name: 'Internet' },
  { name: 'Electricidad' },
  { name: 'Pavimento' }
];

const finalServicios = uniqueTags.length > 0 ? serviciosTags : defaultServices;
const finalAmenities = uniqueTags.length > 0 ? amenitiesTags : defaultAmenities;

// JSON-LD structured data for Real Estate Listing (Developments) SEO
const schemaJsonLd = {
  "@context": "https://schema.org",
  "@type": "RealEstateListing",
  "name": mainTitle,
  "description": description,
  "datePosted": new Date().toISOString(),
  "offers": minPrice > 0 ? {
    "@type": "Offer",
    "price": minPrice,
    "priceCurrency": minPriceCurrency,
    "availability": "https://schema.org/InStock"
  } : undefined,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": addressText,
    "addressLocality": location?.name || "Buenos Aires",
    "addressCountry": "AR"
  }
};
---

<MainLayout 
  title={`${mainTitle} | Emprendimientos | MUV Propiedades`} 
  description={`${mainTitle} - Desarrollo exclusivo en ${addressText}. ${description.substring(0, 150)}...`}
  isDarkHero={false}
>
    <!-- Inject Development Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaJsonLd)} slot="head" />

    <main class="pt-24 min-h-[70vh] bg-surface select-none pb-24">
        
        <!-- Breadcrumbs & Share/Fav Bar -->
        <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
            <div class="flex justify-between items-center py-3 border-b border-outline-variant/15 mb-4">
                <nav class="flex items-center text-[12px] text-secondary text-left font-sans font-[300] tracking-wide select-none">
                    <a class="hover:text-primary transition-colors flex items-center" href="/">
                        <span class="material-symbols-outlined text-[16px] mr-1">home</span>
                        Home
                    </a>
                    <span class="text-secondary/40 mx-2">&gt;</span>
                    <a class="hover:text-primary transition-colors" href="/emprendimientos/">Edificio</a>
                    <span class="text-secondary/40 mx-2">&gt;</span>
                    <span class="text-primary truncate max-w-[180px] sm:max-w-[360px] md:max-w-[500px]">{mainTitle}</span>
                </nav>
                <div class="flex gap-2">
                    <button id="btn-share" class="w-10 h-10 border border-outline-variant/35 rounded-full flex items-center justify-center text-primary hover:bg-primary hover:text-pure-white hover:border-primary transition-all duration-300 shadow-sm bg-pure-white cursor-pointer" title="Compartir emprendimiento">
                        <span class="material-symbols-outlined text-[20px]">share</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Title, Badges & Status/Price Header -->
        <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-5">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4 text-left font-sans">
                <div class="space-y-2">
                    <h1 class="font-sans font-[300] md:text-[36px] text-2xl text-primary leading-tight tracking-tight">
                        {mainTitle}
                    </h1>
                    
                    <div class="flex flex-wrap items-center gap-2 pt-1 select-none">
                        <span class="bg-[#7CB342] text-pure-white px-3 py-1 text-[9px] font-bold tracking-widest uppercase rounded-full">
                            {statusText}
                        </span>
                        <span class="bg-[#545F72] text-pure-white px-3 py-1 text-[9px] font-bold tracking-widest uppercase rounded-full">
                            EMPRENDIMIENTO
                        </span>
                        {deliveryDateText && (
                            <span class="bg-black/60 text-pure-white border border-white/25 px-3 py-1 text-[9px] font-bold tracking-widest uppercase rounded-full">
                                Entrega {deliveryDateText}
                            </span>
                        )}
                    </div>
                </div>
                
                <div class="text-left md:text-right shrink-0 pt-2 md:pt-0">
                    <span class="font-headline text-3xl md:text-4xl font-bold text-primary block leading-none">{priceText}</span>
                    {minPrice > 0 && (
                        <span class="text-xs font-semibold text-secondary/80 tracking-wide font-sans mt-2 block">Precio de referencia</span>
                    )}
                </div>
            </div>
        </div>

        <!-- High-Quality Image Gallery Grid (Mockup 3-photo grid inside Gallery component) -->
        <section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-6 select-none">
            <Gallery photos={photosList} title={mainTitle} />
        </section>

        <!-- Horizontal Specs Bar -->
        <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-12">
            <div class="bg-pure-white border border-outline-variant/30 rounded-xl shadow-sm flex flex-wrap justify-center items-center gap-x-6 md:gap-x-12 gap-y-4 py-6 px-4 select-none font-sans font-[300]">
                <!-- Item 1: Tipo de Ficha -->
                <div class="flex flex-col items-center justify-center min-w-[100px]">
                    <span class="material-symbols-outlined text-primary text-[24px] mb-1 select-none pointer-events-none">domain</span>
                    <span class="text-sm text-primary mt-1 whitespace-nowrap">Emprendimiento</span>
                </div>
                
                <!-- Item 2: Estado de Obra -->
                <div class="h-8 w-[1px] bg-outline-variant/30 hidden sm:block"></div>
                <div class="flex flex-col items-center justify-center min-w-[100px]">
                    <span class="material-symbols-outlined text-primary text-[24px] mb-1 select-none pointer-events-none">construction</span>
                    <span class="text-sm text-primary mt-1 whitespace-nowrap">{statusText}</span>
                </div>
                
                <!-- Item 3: Cantidad de Unidades -->
                <div class="h-8 w-[1px] bg-outline-variant/30 hidden sm:block"></div>
                <div class="flex flex-col items-center justify-center min-w-[100px]">
                    <span class="material-symbols-outlined text-primary text-[24px] mb-1 select-none pointer-events-none">view_cozy</span>
                    <span class="text-sm text-primary mt-1 whitespace-nowrap">{units.length} {units.length === 1 ? 'unidad' : 'unidades'}</span>
                </div>
                
                <!-- Item 4: Pisos / Fecha de Entrega -->
                <div class="h-8 w-[1px] bg-outline-variant/30 hidden sm:block"></div>
                <div class="flex flex-col items-center justify-center min-w-[100px]">
                    {deliveryDateText ? (
                        <span class="material-symbols-outlined text-primary text-[24px] mb-1 select-none pointer-events-none">calendar_today</span>
                        <span class="text-sm text-primary mt-1 whitespace-nowrap">Entrega {deliveryDateText}</span>
                    ) : (
                        <span class="material-symbols-outlined text-primary text-[24px] mb-1 select-none pointer-events-none">layers</span>
                        <span class="text-sm text-primary mt-1 whitespace-nowrap">12 Pisos</span>
                    )}
                </div>
                
                <!-- Item 5: Amenities -->
                <div class="h-8 w-[1px] bg-outline-variant/30 hidden sm:block"></div>
                <div class="flex flex-col items-center justify-center min-w-[100px]">
                    <span class="material-symbols-outlined text-primary text-[24px] mb-1 select-none pointer-events-none">pool</span>
                    <span class="text-sm text-primary mt-1 whitespace-nowrap">980 m² Amenities</span>
                </div>
            </div>
        </div>

        <!-- Full-Width Stacked Sections -->
        <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop space-y-16">
            
            <!-- Description -->
            <section class="space-y-4 font-sans text-left">
                <h2 class="font-headline text-[20px] font-bold text-primary uppercase tracking-wider border-b border-outline-variant/10 pb-3">El Emprendimiento</h2>
                <p class="font-body text-[15px] text-[#545F72] leading-relaxed whitespace-pre-line">
                    {description}
                </p>
            </section>

            <!-- Ubicación -->
            <section class="space-y-6 font-sans text-left">
                <div class="flex justify-between items-center border-b border-outline-variant/10 pb-3">
                    <h2 class="font-headline text-[20px] font-bold text-primary uppercase tracking-wider">Ubicación</h2>
                    <a 
                      href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(addressText + (location?.name ? ', ' + location.name : '') + ', Buenos Aires')}`} 
                      target="_blank" 
                      rel="noopener noreferrer" 
                      class="bg-black text-pure-white hover:bg-[#C5A059] transition-colors px-6 py-2.5 rounded-full text-xs font-bold uppercase tracking-widest flex items-center gap-2 cursor-pointer"
                    >
                        <span class="material-symbols-outlined text-[16px]">map</span>
                        <span>Abrir en Google Maps</span>
                    </a>
                </div>

                <div class="relative w-full h-[400px] rounded-xl overflow-hidden border border-outline-variant/35 bg-surface-container shadow-sm mt-4">
                    <iframe 
                      class="w-full h-full border-0 brightness-[0.98] contrast-[1.02]" 
                      src={`https://maps.google.com/maps?q=${encodeURIComponent(addressText + (location?.name ? ', ' + location.name : '') + ', Buenos Aires')}&t=&z=14&ie=UTF8&iwloc=&output=embed`} 
                      loading="lazy" 
                      allowfullscreen
                    ></iframe>
                </div>
            </section>

            <!-- Unidades Disponibles (Table/Cards) -->
            <section class="space-y-6 font-sans text-left">
                <div class="flex flex-col md:flex-row justify-between md:items-center border-b border-outline-variant/10 pb-3 gap-4">
                    <h2 class="font-headline text-[20px] font-bold text-primary uppercase tracking-wider">Unidades Disponibles</h2>
                    <div class="flex flex-wrap items-center gap-4 select-none">
                        <!-- View Toggle -->
                        <div class="flex items-center bg-surface-container-low/40 border border-outline-variant/20 p-1 rounded-lg">
                          <button id="view-cards-btn" class="flex items-center gap-1 px-3 py-1.5 text-xs font-medium uppercase tracking-wider rounded-md transition-all duration-200 cursor-pointer bg-black text-pure-white" title="Vista Tarjetas">
                            <span class="material-symbols-outlined text-[16px]">view_list</span>
                            <span class="hidden sm:inline">Tarjetas</span>
                          </button>
                          <button id="view-table-btn" class="flex items-center gap-1 px-3 py-1.5 text-xs font-medium uppercase tracking-wider rounded-md transition-all duration-200 cursor-pointer bg-pure-white border border-outline-variant/35 text-secondary hover:text-primary" title="Vista Tabla">
                            <span class="material-symbols-outlined text-[16px]">table_rows</span>
                            <span class="hidden sm:inline">Tabla</span>
                          </button>
                        </div>

                        <select id="filter-rooms" class="border border-outline-variant/45 rounded pl-4 pr-10 py-2 text-xs font-medium text-slate-blue bg-white focus:ring-1 focus:ring-primary focus:border-primary outline-none cursor-pointer">
                            <option value="">Todos los ambientes</option>
                            <option value="1">1 Ambiente</option>
                            <option value="2">2 Ambientes</option>
                            <option value="3">3 Ambientes</option>
                            <option value="4">4+ Ambientes</option>
                        </select>
                        <select id="sort-price" class="border border-outline-variant/45 rounded pl-4 pr-10 py-2 text-xs font-medium text-slate-blue bg-white focus:ring-1 focus:ring-primary focus:border-primary outline-none cursor-pointer">
                            <option value="asc">Precio: Menor a Mayor</option>
                            <option value="desc">Precio: Mayor a Menor</option>
                        </select>
                    </div>
                </div>

                <!-- Vista de Tarjetas (Principal) -->
                <div id="units-cards-wrapper" class="w-full">
                    {units.length === 0 ? (
                        <div class="p-8 text-center text-secondary font-[300] bg-pure-white rounded-xl border border-outline-variant/20 shadow-sm mt-4">
                            No hay unidades disponibles en este momento.
                        </div>
                    ) : (
                        <div class="max-h-[500px] overflow-y-auto pr-2 custom-scrollbar mt-4">
                            <div class="space-y-4" id="units-cards-container">
                                {units.map(u => {
                                    const ventaOp = u.operations?.find(op => op.operation_type.toLowerCase() === 'venta');
                                    const ventaPrice = ventaOp?.prices?.[0];
                                    const ventaVal = ventaPrice?.price || 0;
                                    const ventaText = ventaVal > 0 
                                      ? `${ventaPrice.currency || 'USD'} ${new Intl.NumberFormat('es-AR', { maximumFractionDigits: 0 }).format(ventaVal)}` 
                                      : '-';

                                    const alquilerOp = u.operations?.find(op => op.operation_type.toLowerCase() === 'alquiler');
                                    const alquilerPrice = alquilerOp?.prices?.[0];
                                    const alquilerVal = alquilerPrice?.price || 0;
                                    const alquilerText = alquilerVal > 0 
                                      ? `${alquilerPrice.currency || 'USD'} ${new Intl.NumberFormat('es-AR', { maximumFractionDigits: 0 }).format(alquilerVal)}` 
                                      : '-';

                                    const rooms = u.room_amount || 1;
                                    const baths = (u.bathroom_amount || 0) + (u.toilet_amount || 0) || 1;
                                    
                                    const unitPhoto = u.photos && u.photos.length > 0 
                                      ? u.photos[0].image 
                                      : (photosList.length > 0 ? photosList[0] : 'https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?auto=format&fit=crop&w=400&q=80');

                                    const opText = ventaVal > 0 ? 'Venta' : 'Alquiler';
                                    const priceDisplay = ventaVal > 0 ? ventaText : alquilerText;
                                    const sortPriceVal = ventaVal > 0 ? ventaVal : alquilerVal;

                                    const unitTitle = getUnitName(u);
                                    
                                    return (
                                        <div 
                                          class="unit-card border border-outline-variant/30 rounded-2xl bg-pure-white p-4 shadow-sm hover:shadow-md hover:border-primary/40 transition-all duration-300 flex items-center justify-between gap-4 cursor-pointer"
                                          data-id={u.id}
                                          data-price={sortPriceVal}
                                          data-rooms={rooms}
                                        >
                                            <div class="flex items-center gap-4 flex-1 min-w-0">
                                                <!-- Left: Image -->
                                                <div class="w-24 h-16 sm:w-32 sm:h-20 rounded-xl overflow-hidden shrink-0 bg-surface-container shadow-sm border border-outline-variant/10">
                                                    <img 
                                                      class="w-full h-full object-cover transition-transform duration-500 hover:scale-105" 
                                                      src={unitPhoto} 
                                                      alt={unitTitle}
                                                      width="128"
                                                      height="80"
                                                      loading="lazy"
                                                    />
                                                </div>
                                                
                                                <!-- Middle: Details -->
                                                <div class="flex-1 min-w-0 text-left space-y-1">
                                                    <p class="text-[11px] text-secondary/60 uppercase tracking-wider font-semibold font-sans truncate">
                                                        {u.reference_code || `MUV${u.id}`} | {u.type?.name || 'Departamento'}
                                                    </p>
                                                    <h4 class="font-sans font-bold text-sm sm:text-base text-primary truncate leading-snug">
                                                        {unitTitle}
                                                    </h4>
                                                    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-secondary/80 font-sans pt-0.5">
                                                        <div class="flex items-center gap-1">
                                                            <span class="material-symbols-outlined text-[15px] text-secondary/50">meeting_room</span>
                                                            <span>{rooms} {rooms === 1 ? 'ambiente' : 'ambientes'}</span>
                                                        </div>
                                                        <div class="flex items-center gap-1">
                                                            <span class="material-symbols-outlined text-[15px] text-secondary/50">bathtub</span>
                                                            <span>{baths} {baths === 1 ? 'baño' : 'baños'}</span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Right: Separator and Price -->
                                            <div class="flex items-center shrink-0">
                                                <div class="h-12 w-[1px] bg-outline-variant/20 mx-2 sm:mx-4 hidden sm:block"></div>
                                                <div class="flex flex-col items-end justify-center min-w-[100px] sm:min-w-[120px] text-right space-y-1 font-sans">
                                                    <span class="bg-surface-container-low border border-outline-variant/25 text-secondary text-[9px] font-bold uppercase tracking-widest px-2.5 py-0.5 rounded-full select-none">
                                                        {opText}
                                                    </span>
                                                    <span class="text-sm sm:text-base font-bold text-primary font-headline block leading-tight">
                                                        {priceDisplay}
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    );
                                })}
                            </div>
                        </div>
                    )}
                </div>

                <!-- Vista de Tabla (Secundaria) -->
                <div id="units-table-wrapper" class="overflow-auto max-h-[500px] bg-pure-white rounded-xl border border-outline-variant/20 shadow-sm mt-4 hidden custom-scrollbar">
                    <table class="w-full border-collapse text-left">
                        <thead class="sticky top-0 z-10 bg-pure-white shadow-[0_1px_0_0_rgba(0,0,0,0.06)]">
                            <tr class="border-b border-outline-variant/15 text-left bg-surface-container-low/20">
                                <th class="p-6 font-sans text-[15px] font-bold text-primary">Dirección</th>
                                <th class="p-6 font-sans text-[15px] font-bold text-primary">Ambientes</th>
                                <th class="p-6 font-sans text-[15px] font-bold text-primary">Dormitorios</th>
                                <th class="p-6 font-sans text-[15px] font-bold text-primary">Superficie Cubierta</th>
                                <th class="p-6 font-sans text-[15px] font-bold text-primary">Superficie Total</th>
                                <th class="p-6 font-sans text-[15px] font-bold text-primary">Cochera</th>
                                <th class="p-6 font-sans text-[15px] font-bold text-primary">Venta</th>
                                <th class="p-6 font-sans text-[15px] font-bold text-primary">Alquiler</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant/15 font-sans font-[300] text-slate-blue/80" id="units-table-body">
                            {units.length === 0 ? (
                                <tr>
                                    <td colspan="8" class="p-8 text-center text-secondary font-[300]">No hay unidades disponibles en este momento.</td>
                                </tr>
                            ) : (
                                units.map(u => {
                                    const ventaOp = u.operations?.find(op => op.operation_type.toLowerCase() === 'venta');
                                    const ventaPrice = ventaOp?.prices?.[0];
                                    const ventaVal = ventaPrice?.price || 0;
                                    const ventaText = ventaVal > 0 
                                      ? `${ventaPrice.currency || 'USD'} ${new Intl.NumberFormat('es-AR', { maximumFractionDigits: 0 }).format(ventaVal)}` 
                                      : '-';

                                    const alquilerOp = u.operations?.find(op => op.operation_type.toLowerCase() === 'alquiler');
                                    const alquilerPrice = alquilerOp?.prices?.[0];
                                    const alquilerVal = alquilerPrice?.price || 0;
                                    const alquilerText = alquilerVal > 0 
                                      ? `${alquilerPrice.currency || 'USD'} ${new Intl.NumberFormat('es-AR', { maximumFractionDigits: 0 }).format(alquilerVal)}` 
                                      : '-';

                                    const rooms = u.room_amount || 1;
                                    const bedrooms = u.suite_amount || 0;
                                    const coveredSize = u.covered_surface ? `${Math.round(Number(u.covered_surface))} m²` : '-';
                                    const totalSize = u.total_surface ? `${Math.round(Number(u.total_surface))} m²` : '-';
                                    const hasParking = u.parking_lot_amount && u.parking_lot_amount > 0 ? 'Sí' : 'No';

                                    const sortPriceVal = ventaVal > 0 ? ventaVal : alquilerVal;

                                    return (
                                        <tr 
                                          class="unit-row odd:bg-pure-white even:bg-surface-container-low/50 hover:bg-surface-container-high/70 transition-colors duration-200 cursor-pointer"
                                          data-id={u.id}
                                          data-price={sortPriceVal}
                                          data-rooms={rooms}
                                        >
                                            <td class="p-6 text-[15px] font-sans font-[300] text-primary">{getUnitName(u)}{u.location?.name ? `, ${u.location.name}` : ''}</td>
                                            <td class="p-6 text-[15px] font-sans font-[300] text-slate-blue">{rooms}</td>
                                            <td class="p-6 text-[15px] font-sans font-[300] text-slate-blue">{bedrooms}</td>
                                            <td class="p-6 text-[15px] font-sans font-[300] text-slate-blue">{coveredSize}</td>
                                            <td class="p-6 text-[15px] font-sans font-[300] text-slate-blue">{totalSize}</td>
                                            <td class="p-6 text-[15px] font-sans font-[300] text-slate-blue">{hasParking}</td>
                                            <td class="p-6 text-[15px] font-sans font-[300] text-primary">{ventaText}</td>
                                            <td class="p-6 text-[15px] font-sans font-[300] text-primary">{alquilerText}</td>
                                        </tr>
                                    );
                                })
                            )}
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- Información general / Detalles de emprendimiento -->
            <section class="space-y-8 font-sans text-left">
                <h2 class="font-headline text-[20px] font-bold text-primary uppercase tracking-wider border-b border-outline-variant/10 pb-3">Información general</h2>
                
                <div class="bg-[#F8F9FA] border border-[#E5E7EB] rounded-xl p-8 space-y-4">
                    <h3 class="font-sans font-bold text-[#191c1d] text-base border-b border-[#E5E7EB] pb-2">Detalles del Proyecto</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-4 text-sm font-sans font-[300]">
                        <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                            <span class="text-secondary/80">Estado de Obra</span>
                            <span class="text-primary font-medium">{statusText}</span>
                        </div>
                        <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                            <span class="text-secondary/80">Cantidad de Pisos</span>
                            <span class="text-primary font-medium">12</span>
                        </div>
                        <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                            <span class="text-secondary/80">Unidades Totales</span>
                            <span class="text-primary font-medium">{units.length}</span>
                        </div>
                        <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                            <span class="text-secondary/80">Año de Entrega</span>
                            <span class="text-primary font-medium">{deliveryDateText ? deliveryDateText.split(' ').slice(-1)[0] : '2026'}</span>
                        </div>
                        <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                            <span class="text-secondary/80">Área de Amenities</span>
                            <span class="text-primary font-medium">980 m²</span>
                        </div>
                        <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                            <span class="text-secondary/80">Ubicación</span>
                            <span class="text-primary font-medium">{addressText}</span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Characteristics & Amenities -->
            <section class="space-y-6 font-sans text-left">
                <h2 class="font-headline text-[20px] font-bold text-primary uppercase tracking-wider border-b border-outline-variant/10 pb-3">Características</h2>
                
                {finalServicios.length > 0 && (
                    <div class="space-y-3">
                        <h3 class="font-headline text-[14px] font-bold text-primary uppercase tracking-wider">Servicios</h3>
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-2">
                            {finalServicios.map((t) => (
                                <div class="flex items-center gap-2.5 text-secondary text-[15px] font-[300] py-1">
                                    <svg class="w-[18px] h-[18px] text-secondary/60 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                    <span>{t.name}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                )}

                {finalAmenities.length > 0 && (
                    <div class="space-y-3 pt-2">
                        <h3 class="font-headline text-[14px] font-bold text-primary uppercase tracking-wider">Adicionales</h3>
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-2">
                            {finalAmenities.map((t) => (
                                <div class="flex items-center gap-2.5 text-secondary text-[15px] font-[300] py-1">
                                    <svg class="w-[18px] h-[18px] text-secondary/60 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                    <span>{t.name}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                )}
            </section>

            <!-- Contact/Inquiry Lead Section (Centered Full-Width style) -->
            <section class="pt-8 border-t border-outline-variant/10 text-left">
                <div class="max-w-2xl mx-auto">
                    <h2 class="font-headline text-[20px] font-bold text-primary uppercase tracking-wider mb-6 text-center">Consultar por este Emprendimiento</h2>
                    <LeadForm propertyTitle={mainTitle} isDevelopment={true} />
                </div>
            </section>

            <!-- Other Developments Section -->
            {otherDevelopments.length > 0 && (
                <section class="py-12 border-t border-outline-variant/10 select-none">
                    <div class="flex justify-between items-end mb-10">
                        <div class="text-left space-y-1.5 font-sans">
                            <span class="text-secondary font-bold text-[9px] uppercase tracking-widest">Descubrí Más</span>
                            <h3 class="font-headline text-[20px] font-bold text-primary uppercase tracking-wider">Otros Emprendimientos</h3>
                        </div>
                        <a href="/emprendimientos/" class="text-xs font-bold font-sans text-secondary hover:text-primary transition-colors flex items-center gap-1.5 uppercase tracking-widest">
                            <span>Ver todos</span>
                            <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                        </a>
                    </div>

                    <!-- 2 card grid -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        {otherDevelopments.map((dev) => {
                            const status = typeof dev.construction_status === 'string' ? dev.construction_status : 'DESTACADO';
                            const locationName = dev.location ? dev.location.name : 'Buenos Aires';
                            const imageSrc = dev.photos && dev.photos.length > 0 ? dev.photos[0].image : 'https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?auto=format&fit=crop&w=800&q=80';
                            const shortDesc = dev.description ? dev.description.slice(0, 100) + '...' : 'Desarrollo de diseño exclusivo y terminaciones premium.';
                            const isFinished = status.toLowerCase().includes('terminado') || 
                                               status.toLowerCase().includes('estrenar') || 
                                               status.toLowerCase().includes('inmediata');
                            const tagBadge = isFinished ? 'VENTA' : 'PREVENTA';

                            return (
                                <a 
                                  href={`/emprendimientos/${dev.id}/`}
                                  class="group relative block aspect-[16/10] overflow-hidden rounded-xl bg-slate-900 shadow-md hover:shadow-xl transition-all duration-500 cursor-pointer"
                                >
                                  <!-- Background Image with Zoom -->
                                  <img 
                                    class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" 
                                    src={imageSrc} 
                                    alt={`Emprendimiento ${dev.name}`}
                                    width="600"
                                    height="375"
                                    loading="lazy"
                                  />
                                  
                                  <!-- Card Gradient Overlay -->
                                  <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/30 to-black/40 z-10 transition-opacity duration-300 group-hover:opacity-90"></div>

                                  <!-- Top Badges -->
                                  <div class="absolute top-5 left-5 right-5 z-20 flex justify-between items-center pointer-events-none">
                                    <span class="bg-[#7CB342] text-pure-white px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider rounded font-sans shadow-sm">
                                      {status}
                                    </span>
                                    {tagBadge !== 'PREVENTA' && (
                                      <span class="bg-black/60 text-pure-white border border-white/25 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider rounded font-sans shadow-sm">
                                        {tagBadge}
                                      </span>
                                    )}
                                  </div>

                                  <!-- Bottom Overlay Details -->
                                  <div class="absolute bottom-6 left-6 right-6 z-20 flex justify-between items-end text-pure-white font-sans">
                                    <div class="space-y-1.5 max-w-[85%] text-left font-sans">
                                      <h4 class="font-headline-md text-base md:text-lg font-bold leading-tight">
                                        {dev.name}
                                      </h4>
                                      <p class="font-body-md text-xs md:text-sm text-pure-white/80 line-clamp-2 leading-relaxed">
                                        {shortDesc}
                                      </p>
                                    </div>
                                    <div class="w-10 h-10 rounded-full border border-white/30 flex items-center justify-center bg-black/20 backdrop-blur-sm group-hover:bg-black group-hover:border-black group-hover:text-pure-white transition-all duration-300 shrink-0">
                                      <span class="material-symbols-outlined text-[20px] text-pure-white">arrow_outward</span>
                                    </div>
                                  </div>
                                </a>
                            );
                        })}
                    </div>
                </section>
            )}
        </div>

        <!-- WhatsApp Property Meta for Global Button -->
        <div id="whatsapp-page-info" data-title={mainTitle} data-id={id} data-is-development="true" class="hidden"></div>
    </main>

    <script is:inline define:vars={{ id, name: mainTitle }}>
      // Share button micro-interaction
      const shareBtn = document.getElementById('btn-share');
      shareBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        navigator.clipboard.writeText(window.location.href);
        alert('¡Enlace del emprendimiento copiado al portapapeles!');
      });

      // Favorite button micro-interaction
      const favBtn = document.getElementById('btn-favorite');
      if (favBtn) {
        const icon = favBtn.querySelector('.material-symbols-outlined');
        const favKey = `muv_fav_dev_${id}`;
        let isSaved = localStorage.getItem(favKey) === 'true';
        
        const updateFavStyle = () => {
          if (icon) {
            if (isSaved) {
              icon.classList.add('filled-icon');
              favBtn.style.color = '#e056fd';
              favBtn.style.borderColor = '#e056fd';
            } else {
              icon.classList.remove('filled-icon');
              favBtn.style.color = '';
              favBtn.style.borderColor = '';
            }
          }
        };
        
        updateFavStyle();
        
        favBtn.addEventListener('click', (e) => {
          e.preventDefault();
          isSaved = !isSaved;
          localStorage.setItem(favKey, isSaved ? 'true' : 'false');
          updateFavStyle();
        });
      }

      // View Toggle
      const viewCardsBtn = document.getElementById('view-cards-btn');
      const viewTableBtn = document.getElementById('view-table-btn');
      const cardsWrapper = document.getElementById('units-cards-wrapper');
      const tableWrapper = document.getElementById('units-table-wrapper');

      let currentView = 'cards';

      function updateView() {
        if (currentView === 'cards') {
          cardsWrapper?.classList.remove('hidden');
          tableWrapper?.classList.add('hidden');
          
          viewCardsBtn?.classList.remove('bg-pure-white', 'border', 'border-outline-variant/35', 'text-secondary', 'hover:text-primary');
          viewCardsBtn?.classList.add('bg-black', 'text-pure-white');
          
          viewTableBtn?.classList.remove('bg-black', 'text-pure-white');
          viewTableBtn?.classList.add('bg-pure-white', 'border', 'border-outline-variant/35', 'text-secondary', 'hover:text-primary');
        } else {
          tableWrapper?.classList.remove('hidden');
          cardsWrapper?.classList.add('hidden');
          
          viewTableBtn?.classList.remove('bg-pure-white', 'border', 'border-outline-variant/35', 'text-secondary', 'hover:text-primary');
          viewTableBtn?.classList.add('bg-black', 'text-pure-white');
          
          viewCardsBtn?.classList.remove('bg-black', 'text-pure-white');
          viewCardsBtn?.classList.add('bg-pure-white', 'border', 'border-outline-variant/35', 'text-secondary', 'hover:text-primary');
        }
      }

      viewCardsBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        currentView = 'cards';
        updateView();
      });

      viewTableBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        currentView = 'table';
        updateView();
      });

      // Call initially
      updateView();

      // Redirect unit card/row clicks to individual property page
      document.querySelectorAll('.unit-row, .unit-card').forEach(el => {
        el.addEventListener('click', (e) => {
          if (e.target.closest('a')) return;
          const unitId = el.getAttribute('data-id');
          if (unitId) {
            window.location.href = `/property/${unitId}/`;
          }
        });
      });

      // Table and Cards filtering and sorting in sync
      const filterRooms = document.getElementById('filter-rooms');
      const sortPrice = document.getElementById('sort-price');
      const tableBody = document.getElementById('units-table-body');
      const cardsContainer = document.getElementById('units-cards-container');

      function filterAndSortUnits() {
        const roomVal = filterRooms?.value || '';
        const sortVal = sortPrice?.value || 'asc';

        // Filter and sort Table rows
        if (tableBody) {
          const rows = Array.from(tableBody.querySelectorAll('.unit-row'));
          rows.forEach(row => {
            const rooms = row.getAttribute('data-rooms') || '';
            const matchRooms = !roomVal || rooms === roomVal || (roomVal === '4' && parseInt(rooms) >= 4);
            if (matchRooms) {
              row.classList.remove('hidden');
            } else {
              row.classList.add('hidden');
            }
          });

          const sortedRows = rows.sort((a, b) => {
            const priceA = parseFloat(a.getAttribute('data-price') || '0');
            const priceB = parseFloat(b.getAttribute('data-price') || '0');
            return sortVal === 'asc' ? priceA - priceB : priceB - priceA;
          });

          sortedRows.forEach(row => tableBody.appendChild(row));
        }

        // Filter and sort Cards
        if (cardsContainer) {
          const cards = Array.from(cardsContainer.querySelectorAll('.unit-card'));
          cards.forEach(card => {
            const rooms = card.getAttribute('data-rooms') || '';
            const matchRooms = !roomVal || rooms === roomVal || (roomVal === '4' && parseInt(rooms) >= 4);
            if (matchRooms) {
              card.classList.remove('hidden');
            } else {
              card.classList.add('hidden');
            }
          });

          const sortedCards = cards.sort((a, b) => {
            const priceA = parseFloat(a.getAttribute('data-price') || '0');
            const priceB = parseFloat(b.getAttribute('data-price') || '0');
            return sortVal === 'asc' ? priceA - priceB : priceB - priceA;
          });

          sortedCards.forEach(card => cardsContainer.appendChild(card));
        }
      }

      filterRooms?.addEventListener('change', filterAndSortUnits);
      sortPrice?.addEventListener('change', filterAndSortUnits);
    </script>
</MainLayout>

<style is:global>
  .filled-icon {
    font-variation-settings: 'FILL' 1 !important;
  }
  
  /* Custom premium scrollbar styling */
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.15);
    border-radius: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(0, 0, 0, 0.3);
  }
</style>
