  function attachCardListeners() {
    document.querySelectorAll('.property-row-card').forEach((card: any) => {
      let photos: string[] = [];
      try { photos = JSON.parse(card.dataset.photos || '[]'); } catch(e) {}
      let currentIdx = 0;

      const imgElement = card.querySelector('.row-carousel-img') as HTMLImageElement;
      const prevBtn = card.querySelector('.row-btn-prev');
      const nextBtn = card.querySelector('.row-btn-next');
      const zoomBtn = card.querySelector('.row-zoom-btn');

      if (imgElement && photos.length > 0) {
        if (prevBtn) {
          prevBtn.addEventListener('click', (e: Event) => {
            e.preventDefault(); e.stopPropagation();
            currentIdx = (currentIdx - 1 + photos.length) % photos.length;
            imgElement.src = photos[currentIdx];
          });
        }
        if (nextBtn) {
          nextBtn.addEventListener('click', (e: Event) => {
            e.preventDefault(); e.stopPropagation();
            currentIdx = (currentIdx + 1) % photos.length;
            imgElement.src = photos[currentIdx];
          });
        }
      }

      if (zoomBtn) {
        zoomBtn.addEventListener('click', (e: Event) => {
          e.preventDefault(); e.stopPropagation();
          window.location.href = `/property/${card.dataset.id}/`;
        });
      }

      card.addEventListener('click', (e: Event) => {
        const target = e.target as HTMLElement;
        if (target.closest('a') || target.closest('button')) return;

        const propertyId = parseInt(card.dataset.id);
        const lat = parseFloat(card.dataset.lat);
        const lng = parseFloat(card.dataset.lng);

        if (!isNaN(lat) && !isNaN(lng) && map) {
          map.setView([lat, lng], 17);
          const matchedMarker = activeMarkers.find(marker => marker.propertyIds && marker.propertyIds.includes(propertyId));
          if (matchedMarker) {
            matchedMarker.openPopup();
            currentMarkerIndex = activeMarkers.indexOf(matchedMarker);
          }
        }
      });

      card.addEventListener('mouseenter', () => {
        const propertyId = parseInt(card.dataset.id);
        const matchedMarker = activeMarkers.find(marker => marker.propertyIds && marker.propertyIds.includes(propertyId));
        if (matchedMarker && map) {
          matchedMarker.openPopup();
          matchedMarker.getElement()?.classList.add('marker-highlight');
        }
      });

      card.addEventListener('mouseleave', () => {
        const propertyId = parseInt(card.dataset.id);
        const matchedMarker = activeMarkers.find(marker => marker.propertyIds && marker.propertyIds.includes(propertyId));
        matchedMarker?.getElement()?.classList.remove('marker-highlight');
      });
    });
  }

  function navigateMarkers(direction: 'next' | 'prev') {
    if (activeMarkers.length === 0 || !map) return;
    if (direction === 'next') {
      currentMarkerIndex = (currentMarkerIndex + 1) % activeMarkers.length;
    } else {
      currentMarkerIndex = (currentMarkerIndex - 1 + activeMarkers.length) % activeMarkers.length;
    }
    const marker = activeMarkers[currentMarkerIndex];
    map.setView(marker.getLatLng(), 17);
    marker.openPopup();

    const propertyId = marker.propertyIds[0];
    const cardEl = document.querySelector(`.property-row-card[data-id="${propertyId}"]`);
    if (cardEl) {
      cardEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      cardEl.classList.add('bg-refined-gold/10');
      setTimeout(() => cardEl.classList.remove('bg-refined-gold/10'), 1500);
    }
  }

  function initDoubleSlider() {
    const sliderMin = document.getElementById('slider-min') as HTMLInputElement;
    const sliderMax = document.getElementById('slider-max') as HTMLInputElement;
    const track = document.getElementById('slider-track');
    const label = document.getElementById('price-range-label');
    const wrapper = document.querySelector('.slider-wrapper');

    if (!sliderMin || !sliderMax || !track || !label) return;

    function updateSlider(this: any) {
      let minVal = parseInt(sliderMin.value);
      let maxVal = parseInt(sliderMax.value);
      const isRent = filterState.operation === '2';
      const minGap = isRent ? 100 : 50000;

      if (maxVal - minVal < minGap) {
        if (this === sliderMin) {
          sliderMin.value = (maxVal - minGap).toString();
          minVal = maxVal - minGap;
        } else {
          sliderMax.value = (minVal + minGap).toString();
          maxVal = minVal + minGap;
        }
      }

      const minPercent = ((minVal - parseInt(sliderMin.min)) / (parseInt(sliderMin.max) - parseInt(sliderMin.min))) * 100;
      const maxPercent = ((maxVal - parseInt(sliderMax.min)) / (parseInt(sliderMax.max) - parseInt(sliderMax.min))) * 100;

      track.style.left = minPercent + '%';
      track.style.right = (100 - maxPercent) + '%';

      const symbol = filterState.currency === 'ARS' ? '$' : 'USD';
      label.textContent = `${symbol} ${new Intl.NumberFormat('es-AR').format(minVal)} - ${symbol} ${new Intl.NumberFormat('es-AR').format(maxVal)}`;
      filterState.priceMin = minVal;
      filterState.priceMax = maxVal;
    }

    sliderMin.addEventListener('input', updateSlider);
    sliderMax.addEventListener('input', updateSlider);
    sliderMin.addEventListener('change', () => filterAndRender());
    sliderMax.addEventListener('change', () => filterAndRender());

    if (wrapper) {
      wrapper.addEventListener('mousemove', (e: any) => {
        const rect = wrapper.getBoundingClientRect();
        const percent = (e.clientX - rect.left) / rect.width;
        const min = parseFloat(sliderMin.min);
        const max = parseFloat(sliderMin.max);
        const hoverVal = min + percent * (max - min);

        const distMin = Math.abs(hoverVal - parseFloat(sliderMin.value));
        const distMax = Math.abs(hoverVal - parseFloat(sliderMax.value));

        if (distMin < distMax) {
          sliderMin.style.zIndex = '3';
          sliderMax.style.zIndex = '2';
        } else {
          sliderMin.style.zIndex = '2';
          sliderMax.style.zIndex = '3';
        }
      });
    }
    
    updateSlider.call(sliderMin);
  }

  function adjustPriceSliderRange() {
    const sliderMin = document.getElementById('slider-min') as HTMLInputElement;
    const sliderMax = document.getElementById('slider-max') as HTMLInputElement;
    if (!sliderMin || !sliderMax) return;
    
    const isRent = filterState.operation === '2';
    const defaultMin = isRent ? '200' : '50000';
    const defaultMax = isRent ? '5000' : '2500000';
    const sliderStep = isRent ? '100' : '50000';

    sliderMin.min = defaultMin;
    sliderMin.max = defaultMax;
    sliderMin.step = sliderStep;
    sliderMax.min = defaultMin;
    sliderMax.max = defaultMax;
    sliderMax.step = sliderStep;

    sliderMin.value = defaultMin;
    sliderMax.value = defaultMax;

    sliderMin.dispatchEvent(new Event('input'));
  }

  function initLayerSelect() {
    const select = document.getElementById('map-layer-select') as HTMLSelectElement;
    if (!select || !map) return;
    select.addEventListener('change', () => {
      const selected = select.value as keyof typeof layers;
      if (currentTileLayer) map.removeLayer(currentTileLayer);
      currentTileLayer = L.tileLayer(layers[selected], { attribution: layersAttribution[selected] }).addTo(map);
    });
  }

  function initFullscreen() {
    const btn = document.getElementById('btn-fullscreen-map');
    const mapEl = document.getElementById('map');
    if (!btn || !mapEl) return;
    btn.addEventListener('click', () => {
      if (!document.fullscreenElement) {
        mapEl.requestFullscreen().then(() => {
          setTimeout(() => map.invalidateSize(), 200);
        }).catch(err => { console.error(err); });
      } else {
        document.exitFullscreen();
      }
    });
    document.addEventListener('fullscreenchange', () => {
      if (map) setTimeout(() => map.invalidateSize(), 200);
    });
  }

  function initBarriosDropdown() {
    const barrioContainer = document.getElementById('barrio-options-container');
    if (!barrioContainer) return;
    
    const barrios = new Set<string>();
    rawProperties.forEach((p: any) => {
      if (p.location?.name) {
        barrios.add(p.location.name.trim());
      }
    });
    
    const sortedBarrios = Array.from(barrios).sort((a, b) => a.localeCompare(b, 'es'));
    let html = '';
    sortedBarrios.forEach(b => {
      html += `
        <label class="flex items-center gap-2.5 cursor-pointer text-xs font-semibold text-secondary hover:text-primary">
          <input type="checkbox" class="filter-barrio-chk rounded border-outline-variant/50 text-refined-gold focus:ring-refined-gold w-4 h-4" value="${b.toLowerCase()}" data-name="${b}">
          <span>${b}</span>
        </label>
      `;
    });
    barrioContainer.innerHTML = html;
  }

  function initDynamicTags() {
    const tagsContainer = document.getElementById('dynamic-tags-container');
    if (!tagsContainer) return;

    const allTags = new Set<string>();
    rawProperties.forEach((p: any) => {
      if (p.tags) {
        p.tags.forEach((t: any) => {
          if (t.name) allTags.add(t.name.trim());
        });
      }
    });

    const blacklistPattern = /(unidad|disponible|available|unit|water|electricity|gas|pavement|sewage|paved|access|intercom|phone|internet|wifi|cable|lighting)/i;
    const filteredTags = Array.from(allTags).filter(tag => !blacklistPattern.test(tag));
    
    const mappedTags = filteredTags.map(tag => {
      const lowerTag = tag.toLowerCase();
      const translation = tagTranslations[lowerTag] || { label: tag, icon: 'tag' };
      return { raw: tag, lower: lowerTag, label: translation.label, icon: translation.icon };
    }).sort((a, b) => a.label.localeCompare(b, 'es'));

    let html = '';
    mappedTags.forEach(item => {
      html += `
        <button type="button" class="btn-more-toggle flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-outline-variant/50 text-[10px] font-semibold text-secondary bg-pure-white transition-all hover:border-refined-gold" data-key="${item.lower}">
          <span class="material-symbols-outlined text-[14px]">${item.icon}</span>
          <span>${item.label}</span>
        </button>
      `;
    });
    tagsContainer.innerHTML = html;
  }

  function attachDynamicTagListeners() {
    const btnMoreToggles = document.querySelectorAll('.btn-more-toggle');
    btnMoreToggles.forEach((btn: any) => {
      btn.addEventListener('click', () => {
        const key = btn.getAttribute('data-key') || '';
        const idx = filterState.moreToggles.indexOf(key);
        if (idx > -1) {
          filterState.moreToggles.splice(idx, 1);
          btn.classList.remove('bg-[#C5A059]/10', 'border-[#C5A059]', 'text-[#121212]', 'font-bold');
          btn.classList.add('bg-pure-white', 'border-outline-variant/50', 'text-secondary');
        } else {
          filterState.moreToggles.push(key);
          btn.classList.add('bg-[#C5A059]/10', 'border-[#C5A059]', 'text-[#121212]', 'font-bold');
          btn.classList.remove('bg-pure-white', 'border-outline-variant/50', 'text-secondary');
        }
      });
    });
  }

