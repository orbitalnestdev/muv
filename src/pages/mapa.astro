        typeLabel.textContent = chk ? chk.dataset.name : filterState.types[0];
      } else {
        const firstChk = document.querySelector(`.filter-type-chk[value="${filterState.types[0]}"]`) as HTMLInputElement;
        const firstName = firstChk ? firstChk.dataset.name : filterState.types[0];
        typeLabel.textContent = `${firstName} +${filterState.types.length - 1}`;
      }
