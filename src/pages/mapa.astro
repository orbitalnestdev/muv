    tempDiv.innerHTML = html;
    while (tempDiv.firstChild) {
      listContainer.appendChild(tempDiv.firstChild);
    }

    displayedPropertiesCount = end;

    // Attach card listeners
    attachCardListeners();
  }

  // Attach carousel and focus event listeners to horizontal sidebar cards
  function attachCardListeners() {
    const cards = document.querySelectorAll('.property-row-card');

    cards.forEach((card: any) => {
      // 1. Carousel controls inside cards
      let photos: string[] = [];
      try {
        photos = JSON.parse(card.dataset.photos || '[]');
      } catch(e) {}
      let currentIdx = 0;

      const imgElement = card.querySelector('.row-carousel-img') as HTMLImageElement;
      const prevBtn = card.querySelector('.row-btn-prev');
      const nextBtn = card.querySelector('.row-btn-next');
      const zoomBtn = card.querySelector('.row-zoom-btn');

      if (imgElement && photos.length > 0) {
        if (prevBtn) {
          prevBtn.addEventListener('click', (e: Event) => {
            e.preventDefault();
            e.stopPropagation();
            currentIdx = (currentIdx - 1 + photos.length) % photos.length;
            imgElement.src = photos[currentIdx];
          });
        }
        if (nextBtn) {
          nextBtn.addEventListener('click', (e: Event) => {
            e.preventDefault();
            e.stopPropagation();
            currentIdx = (currentIdx + 1) % photos.length;
            imgElement.src = photos[currentIdx];
          });
        }
      }

      if (zoomBtn) {
        zoomBtn.addEventListener('click', (e: Event) => {
          e.preventDefault();
          e.stopPropagation();
          // Opens page details
          const id = card.dataset.id;
          window.location.href = `/propiedades/${id}`;
        });
      }

      // 2. Click card to pan map marker & open popup
      card.addEventListener('click', (e: Event) => {
        // Prevent click if clicking anchors/buttons inside card
        const target = e.target as HTMLElement;
        if (target.closest('a') || target.closest('button')) return;

        const propertyId = parseInt(card.dataset.id);
        const lat = parseFloat(card.dataset.lat);
        const lng = parseFloat(card.dataset.lng);

        if (!isNaN(lat) && !isNaN(lng) && map) {
          map.setView([lat, lng], 16);

          // Find corresponding marker and trigger open popup
          const matchedMarker = activeMarkers.find(marker => marker.propertyId === propertyId);
          if (matchedMarker) {
            matchedMarker.openPopup();
            // Sync index
            currentMarkerIndex = activeMarkers.indexOf(matchedMarker);
          }
        }
      });

      // 3. Hover card to open map marker popup & highlight marker (highly synced interactive UX)
      card.addEventListener('mouseenter', () => {
        const propertyId = parseInt(card.dataset.id);
        const matchedMarker = activeMarkers.find(marker => marker.propertyId === propertyId);
        if (matchedMarker && map) {
          matchedMarker.openPopup();
          const el = matchedMarker.getElement();
          if (el) {
            el.classList.add('marker-highlight');
          }
        }
      });

      card.addEventListener('mouseleave', () => {
        const propertyId = parseInt(card.dataset.id);
        const matchedMarker = activeMarkers.find(marker => marker.propertyId === propertyId);
        if (matchedMarker) {
          const el = matchedMarker.getElement();
          if (el) {
            el.classList.remove('marker-highlight');
          }
        }
      });
    });
  }

  // Navigate through marker overlays
  function navigateMarkers(direction: 'next' | 'prev') {
    if (activeMarkers.length === 0 || !map) return;

    if (direction === 'next') {
      currentMarkerIndex = (currentMarkerIndex + 1) % activeMarkers.length;
    } else {
      currentMarkerIndex = (currentMarkerIndex - 1 + activeMarkers.length) % activeMarkers.length;
    }

    const marker = activeMarkers[currentMarkerIndex];
    map.setView(marker.getLatLng(), 16);
    marker.openPopup();

    // Scroll corresponding card in sidebar into view
    const propertyId = marker.propertyId;
    const cardEl = document.querySelector(`.property-row-card[data-id="${propertyId}"]`);
    if (cardEl) {
      cardEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      // Temporary luxury highlight effect
      cardEl.classList.add('bg-refined-gold/10');
      setTimeout(() => cardEl.classList.remove('bg-refined-gold/10'), 1500);
    }
  }

  // Double Range Slider logic
  function initDoubleSlider() {
    const sliderMin = document.getElementById('slider-min') as HTMLInputElement;
    const sliderMax = document.getElementById('slider-max') as HTMLInputElement;
    const track = document.getElementById('slider-track');
    const label = document.getElementById('price-range-label');
    const wrapper = document.querySelector('.slider-wrapper');

    if (!sliderMin || !sliderMax || !track || !label) return;

    function updateSlider(this: HTMLInputElement) {
      let minVal = parseInt(sliderMin.value);
      let maxVal = parseInt(sliderMax.value);

      // Prevent overlap crossing (maintain gap of at least 50000)
      const minGap = 50000;
      if (maxVal - minVal < minGap) {
        if (this === sliderMin) {
          sliderMin.value = (maxVal - minGap).toString();
          minVal = maxVal - minGap;
        } else {
          sliderMax.value = (minVal + minGap).toString();
          maxVal = minVal + minGap;
        }
      }

      // Calculate percentage positions
      const minPercent = ((minVal - parseInt(sliderMin.min)) / (parseInt(sliderMin.max) - parseInt(sliderMin.min))) * 100;
      const maxPercent = ((maxVal - parseInt(sliderMax.min)) / (parseInt(sliderMax.max) - parseInt(sliderMax.min))) * 100;

      track.style.left = minPercent + '%';
      track.style.right = (100 - maxPercent) + '%';

      // Update text display
      label.textContent = `USD ${new Intl.NumberFormat('es-AR').format(minVal)} - USD ${new Intl.NumberFormat('es-AR').format(maxVal)}`;
    }

    sliderMin.addEventListener('input', updateSlider);
    sliderMax.addEventListener('input', updateSlider);

    // Swap z-indexes dynamically depending on mouse coordinate proximity to thumb handles
    if (wrapper) {
      wrapper.addEventListener('mousemove', (e: any) => {
        const rect = wrapper.getBoundingClientRect();
        const percent = (e.clientX - rect.left) / rect.width;
        const min = parseFloat(sliderMin.min);
        const max = parseFloat(sliderMin.max);
        const hoverVal = min + percent * (max - min);

        const distMin = Math.abs(hoverVal - parseFloat(sliderMin.value));
        const distMax = Math.abs(hoverVal - parseFloat(sliderMax.value));

        if (distMin < distMax) {
          sliderMin.style.zIndex = '3';
          sliderMax.style.zIndex = '2';
        } else {
          sliderMin.style.zIndex = '2';
          sliderMax.style.zIndex = '3';
        }
      });
    }
    
    // Set initial
    updateSlider.call(sliderMin);
  }

  // Map layer switching selector
  function initLayerSelect() {
    const select = document.getElementById('map-layer-select') as HTMLSelectElement;
    if (!select || !map) return;

    select.addEventListener('change', () => {
      const selected = select.value as keyof typeof layers;
      
      if (currentTileLayer) {
        map.removeLayer(currentTileLayer);
      }
      
      currentTileLayer = L.tileLayer(layers[selected], {
        attribution: layersAttribution[selected]
      }).addTo(map);
    });
  }

  // Full screen toggle helper
  function initFullscreen() {
    const btn = document.getElementById('btn-fullscreen-map');
    const mapEl = document.getElementById('map');
    if (!btn || !mapEl) return;

    btn.addEventListener('click', () => {
      if (!document.fullscreenElement) {
        mapEl.requestFullscreen().then(() => {
          setTimeout(() => map.invalidateSize(), 200);
        }).catch(err => {
          console.error("Fullscreen failed", err);
        });
      } else {
        document.exitFullscreen();
      }
    });

    document.addEventListener('fullscreenchange', () => {
      if (map) {
        setTimeout(() => map.invalidateSize(), 200);
      }
    });
  }

  // Debounce helper
  function debounce(func: any, wait: number) {
    let timeout: any;
    return function(...args: any[]) {
      clearTimeout(timeout);
      timeout = setTimeout(() => func.apply(this, args), wait);
    };
  }

  // DOM listeners hooks on page load
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Initialise map
    initMap();

    // 2. Initialise sliders
    initDoubleSlider();

    // 3. Map type switcher
    initLayerSelect();

    // 4. Zoom Fullscreen toggle
    initFullscreen();

    // 5. Connect navigation buttons next/prev markers
    document.getElementById('btn-next-marker')?.addEventListener('click', () => navigateMarkers('next'));
    document.getElementById('btn-prev-marker')?.addEventListener('click', () => navigateMarkers('prev'));

    // 6. Connect query search and clear buttons
    document.getElementById('btn-submit-search')?.addEventListener('click', () => {
      filterAndRender();
    });

    document.getElementById('btn-clear-search')?.addEventListener('click', () => {
      // Clear values
      (document.getElementById('filter-keyword') as HTMLInputElement).value = '';
      (document.getElementById('filter-operation') as HTMLSelectElement).value = '';
      (document.getElementById('filter-barrio') as HTMLSelectElement).value = '';
      (document.getElementById('filter-type') as HTMLSelectElement).value = '';
      (document.getElementById('filter-bedrooms') as HTMLSelectElement).value = '';
      (document.getElementById('filter-rooms') as HTMLSelectElement).value = '';
      (document.getElementById('filter-bathrooms') as HTMLSelectElement).value = '';
      (document.getElementById('filter-garage') as HTMLSelectElement).value = '';
      (document.getElementById('filter-currency') as HTMLSelectElement).value = '';
      
      const sliderMin = document.getElementById('slider-min') as HTMLInputElement;
      const sliderMax = document.getElementById('slider-max') as HTMLInputElement;
      if (sliderMin && sliderMax) {
        sliderMin.value = sliderMin.min;
        sliderMax.value = sliderMax.max;
        // trigger update slider track position
        sliderMin.dispatchEvent(new Event('input'));
      }

      filterAndRender();
    });

    // Auto trigger filtering on filters selection change (optimizing UX)
    const selectFilters = document.querySelectorAll('select');
    selectFilters.forEach(select => {
      select.addEventListener('change', () => filterAndRender());
    });

    // Debounced real-time filter search on keyword text box type input
    const keywordInput = document.getElementById('filter-keyword');
    if (keywordInput) {
      keywordInput.addEventListener('input', debounce(filterAndRender, 250));
    }

    // Infinite Scroll detection hook on window scroll
    window.addEventListener('scroll', () => {
      if ((window.innerHeight + window.scrollY) >= (document.documentElement.scrollHeight - 200)) {
        loadNextBatch();
      }
    });

    // Mobile toggle view button click handler
    const toggleBtn = document.getElementById('btn-mobile-view-toggle');
    const mainContainer = document.getElementById('map-page-main');
    const toggleIcon = document.getElementById('toggle-view-icon');
    const toggleText = document.getElementById('toggle-view-text');
    
    if (toggleBtn && mainContainer && toggleIcon && toggleText) {
      toggleBtn.addEventListener('click', () => {
        if (mainContainer.classList.contains('mobile-list-active')) {
          mainContainer.classList.remove('mobile-list-active');
          mainContainer.classList.add('mobile-map-active');
          toggleIcon.textContent = 'list';
          toggleText.textContent = 'Ver Lista';
          if (map) {
            setTimeout(() => map.invalidateSize(), 150);
          }
        } else {
          mainContainer.classList.remove('mobile-map-active');
          mainContainer.classList.add('mobile-list-active');
          toggleIcon.textContent = 'map';
          toggleText.textContent = 'Ver Mapa';
        }
      });
    }

    // Keep map sizes always synchronized and resized properly
    window.addEventListener('resize', () => {
      if (map) {
        map.invalidateSize();
      }
    });
  });
</script>
