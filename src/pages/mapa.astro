    const bedsLabel = document.getElementById('pill-label-bedrooms');
    if (bedsLabel) {
      bedsLabel.textContent = filterState.bedrooms ? `${filterState.bedrooms} Dorm.` : 'Dormitorios';
    }

    const bathsLabel = document.getElementById('pill-label-bathrooms');
    if (bathsLabel) {
      bathsLabel.textContent = filterState.bathrooms ? `${filterState.bathrooms} Baños` : 'Baños';
    }

    const garageLabel = document.getElementById('pill-label-garage');
    if (garageLabel) {
      if (!filterState.garage) {
        garageLabel.textContent = 'Cochera';
      } else if (filterState.garage === '0') {
        garageLabel.textContent = 'Sin Cochera';
      } else if (filterState.garage === '1') {
        garageLabel.textContent = '1 Cochera';
      } else {
        garageLabel.textContent = '2+ Cocheras';
      }
    }

    const surfaceLabel = document.getElementById('pill-label-surface');
    if (surfaceLabel) {
      if (filterState.surfaceMin === null && filterState.surfaceMax === null) {
        surfaceLabel.textContent = 'Superficie / Más';
      } else if (filterState.surfaceMin !== null && filterState.surfaceMax !== null) {
        surfaceLabel.textContent = `${filterState.surfaceMin}-${filterState.surfaceMax} m²`;
      } else if (filterState.surfaceMin !== null) {
        surfaceLabel.textContent = `> ${filterState.surfaceMin} m²`;
      } else {
        surfaceLabel.textContent = `< ${filterState.surfaceMax} m²`;
