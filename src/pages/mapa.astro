---
import MainLayout from '../layouts/MainLayout.astro';
import { getProperties } from '../lib/tokko';

// Fetch all properties to initialize on the server side, excluding development units
const { properties } = await getProperties();
---

<MainLayout title="Mapa de Propiedades | MUV Propiedades" isDarkHero={false}>
  <!-- Leaflet CSS and JS (Safe for SSR since initialized on the client, avoids Google Maps API Key billing errors) -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

  <main id="map-page-main" class="min-h-screen pt-[72px] bg-surface flex flex-col lg:flex-row mobile-list-active">
    
    <!-- Left Column: Map -->
    <section id="map-section" class="w-full lg:w-1/2 lg:sticky lg:top-[72px] lg:h-[calc(100vh-72px)] h-[35vh] relative shrink-0">
      <!-- Map Loader Overlay -->
      <div id="map-loader" class="absolute inset-0 bg-pure-white z-[2000] flex flex-col items-center justify-center transition-opacity duration-500">
        <div class="w-10 h-10 border-2 border-refined-gold border-t-transparent rounded-full animate-spin"></div>
        <p class="mt-4 font-sans text-xs font-bold uppercase tracking-widest text-primary">Cargando mapa interactivo...</p>
      </div>
      <div id="map" class="w-full h-full"></div>

      <!-- Map Floating Overlays -->
      <!-- Top Row Controls -->
      <div class="absolute top-4 right-4 z-[1000] flex items-center gap-2 select-none pointer-events-auto">
        <!-- Map Type Select -->
        <div class="relative bg-[#121212]/85 border border-white/20 text-pure-white rounded pl-2.5 pr-8 py-1.5 flex items-center gap-1.5 text-xs font-semibold cursor-pointer shadow-md">
          <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
          </svg>
          <select id="map-layer-select" class="bg-transparent outline-none cursor-pointer text-pure-white font-bold uppercase tracking-wider text-[10px] appearance-none !bg-none border-0 p-0 focus:ring-0">
            <option value="calle" class="text-primary bg-pure-white font-bold">Calle</option>
            <option value="satelite" class="text-primary bg-pure-white font-bold">Satélite</option>
            <option value="terreno" class="text-primary bg-pure-white font-bold">Terreno</option>
          </select>
          <span class="material-symbols-outlined text-[14px] text-white/80 absolute right-2 pointer-events-none">expand_more</span>
        </div>

        <!-- Navigation Buttons -->
        <button id="btn-prev-marker" class="bg-[#121212]/85 border border-white/20 text-pure-white text-[10px] font-bold uppercase tracking-wider px-3 py-2 rounded flex items-center gap-1 hover:bg-[#C5A059] transition-all shadow-md active:scale-95">
          <span class="material-symbols-outlined text-[14px]">chevron_left</span>
          Anterior
        </button>
        <button id="btn-next-marker" class="bg-[#121212]/85 border border-white/20 text-pure-white text-[10px] font-bold uppercase tracking-wider px-3 py-2 rounded flex items-center gap-1 hover:bg-[#C5A059] transition-all shadow-md active:scale-95">
          Siguiente
          <span class="material-symbols-outlined text-[14px]">chevron_right</span>
        </button>
      </div>

      <!-- Bottom Row Info -->
      <div id="map-listings-counter" class="absolute bottom-4 left-4 z-[1000] bg-[#121212]/85 text-pure-white text-[9px] font-bold uppercase tracking-wider px-3.5 py-2 rounded shadow-md border border-white/10 select-none pointer-events-none">
        Mostrando 0 de 0 propiedades
      </div>

      <!-- Fullscreen Toggle Button -->
      <button id="btn-fullscreen-map" class="absolute bottom-4 right-4 z-[1000] bg-[#121212]/85 border border-white/10 text-pure-white text-[9.5px] font-bold uppercase tracking-widest px-4 py-2.5 rounded shadow-md flex items-center gap-1.5 hover:bg-[#C5A059] transition-all pointer-events-auto active:scale-95">
        <span class="material-symbols-outlined text-[14px]">fullscreen</span>
        Pantalla Completa
      </button>
    </section>

    <!-- Right Column: Sidebar Filters & Horizontal Properties List -->
    <section id="list-section" class="w-full lg:w-1/2 flex flex-col bg-surface border-t lg:border-t-0 lg:border-l border-outline-variant/30 shrink-0">
      
      <!-- Top Filters Container with horizontal pills -->
      <div class="bg-pure-white border-b border-outline-variant/30 px-5 py-4 shrink-0 z-20 shadow-sm relative select-none">
        
        <!-- Row 0: Title and Layout Switcher -->
        <div class="flex items-center justify-between mb-4 pb-2 border-b border-outline-variant/15">
          <h1 id="map-page-title" class="font-sans text-xs md:text-sm font-bold text-primary tracking-wider uppercase">
            Mapa de Propiedades
          </h1>
          <div class="flex items-center gap-1 bg-surface-container-low border border-outline-variant/30 rounded-lg p-0.5 select-none">
              <a 
                href="/buscar/" 
                id="btn-map-layout-grid" 
                class="w-8 h-8 rounded-md flex items-center justify-center transition-all text-secondary hover:text-primary" 
                aria-label="Vista cuadrícula"
              >
                  <span class="material-symbols-outlined text-[18px]">grid_view</span>
              </a>
              <a 
                href="/buscar/" 
                id="btn-map-layout-list" 
                class="w-8 h-8 rounded-md flex items-center justify-center transition-all text-secondary hover:text-primary" 
                aria-label="Vista lista"
              >
                  <span class="material-symbols-outlined text-[18px]">format_list_bulleted</span>
              </a>
              <button 
                type="button" 
                class="w-8 h-8 rounded-md flex items-center justify-center transition-all bg-primary text-pure-white cursor-default" 
                aria-label="Vista mapa"
              >
                  <span class="material-symbols-outlined text-[18px]">map</span>
              </button>
          </div>
        </div>

        <!-- Row 1: Keyword Search Bar with Ajax -->
        <div class="relative flex items-center mb-4">
          <span class="material-symbols-outlined text-secondary/50 absolute left-4 pointer-events-none">search</span>
          <input 
            type="text" 
            id="filter-keyword" 
            placeholder="Buscar por dirección, título o descripción..." 
            class="w-full pl-11 pr-10 py-2.5 text-sm rounded-xl border border-outline-variant/40 focus:border-refined-gold focus:outline-none bg-surface/30 font-body-md transition-all duration-300" 
          />
          <button 
            type="button" 
            id="btn-clear-keyword" 
            class="absolute right-4 text-secondary/40 hover:text-secondary hidden"
            aria-label="Limpiar búsqueda"
          >
            <span class="material-symbols-outlined text-[18px]">close</span>
          </button>
        </div>

        <!-- Row 2: Filter Pills Row -->
        <div class="flex flex-wrap items-center gap-2" id="filter-pills-row">
          
          <!-- Pill: Operación -->
          <div class="relative filter-pill-wrapper">
            <button type="button" class="filter-pill flex items-center gap-1.5 px-4 py-2 rounded-full border border-outline-variant/50 text-xs font-semibold text-secondary bg-pure-white hover:border-refined-gold transition-all duration-200" data-dropdown="dropdown-operation">
              <span id="pill-label-operation">Operación</span>
              <span class="material-symbols-outlined text-[16px] text-refined-gold">expand_more</span>
            </button>
            <div id="dropdown-operation" class="filter-dropdown absolute top-full left-0 mt-2 w-48 bg-pure-white border border-outline-variant/30 rounded-lg shadow-lg z-50 hidden p-2 space-y-0.5">
              <button type="button" class="btn-select-op w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="">Cualquiera</button>
              <button type="button" class="btn-select-op w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="1">Venta</button>
              <button type="button" class="btn-select-op w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="2">Alquiler</button>
            </div>
          </div>

          <!-- Pill: Barrio (Promoted to main next to Propiedad) -->
          <div class="relative filter-pill-wrapper">
            <button type="button" class="filter-pill flex items-center gap-1.5 px-4 py-2 rounded-full border border-outline-variant/50 text-xs font-semibold text-secondary bg-pure-white hover:border-refined-gold transition-all duration-200" data-dropdown="dropdown-barrio">
              <span id="pill-label-barrio">Barrio</span>
              <span class="material-symbols-outlined text-[16px] text-refined-gold">expand_more</span>
            </button>
            <div id="dropdown-barrio" class="filter-dropdown absolute top-full left-0 mt-2 w-64 bg-pure-white border border-outline-variant/30 rounded-lg shadow-lg z-50 hidden p-3 space-y-3">
              <div class="max-h-60 overflow-y-auto space-y-2 scrollbar-thin" id="barrio-options-container">
                <!-- Dynamically populated checkboxes -->
              </div>
              <div class="border-t border-outline-variant/20 pt-2 flex justify-between items-center">
                <button type="button" class="btn-clear-barrio text-[10px] font-bold text-secondary hover:text-primary transition-colors">Limpiar</button>
                <button type="button" class="btn-apply-barrio bg-primary text-pure-white text-[10px] font-bold uppercase tracking-wider px-3 py-1.5 rounded-lg transition-all hover:bg-refined-gold active:scale-95">Aplicar</button>
              </div>
            </div>
          </div>

          <!-- Pill: Propiedad -->
          <div class="relative filter-pill-wrapper">
            <button type="button" class="filter-pill flex items-center gap-1.5 px-4 py-2 rounded-full border border-outline-variant/50 text-xs font-semibold text-secondary bg-pure-white hover:border-refined-gold transition-all duration-200" data-dropdown="dropdown-type">
              <span id="pill-label-type">Propiedad</span>
              <span class="material-symbols-outlined text-[16px] text-refined-gold">expand_more</span>
            </button>
            <div id="dropdown-type" class="filter-dropdown absolute top-full left-0 mt-2 w-56 bg-pure-white border border-outline-variant/30 rounded-lg shadow-lg z-50 hidden p-3 space-y-3">
              <div class="space-y-2">
                <label class="flex items-center gap-2.5 cursor-pointer text-xs font-semibold text-secondary hover:text-primary">
                  <input type="checkbox" class="filter-type-chk rounded border-outline-variant/50 text-refined-gold focus:ring-refined-gold w-4 h-4" data-name="Departamento" value="2">
                  <span>Departamento</span>
                </label>
                <label class="flex items-center gap-2.5 cursor-pointer text-xs font-semibold text-secondary hover:text-primary">
                  <input type="checkbox" class="filter-type-chk rounded border-outline-variant/50 text-refined-gold focus:ring-refined-gold w-4 h-4" data-name="Casa" value="3">
                  <span>Casa</span>
                </label>
                <label class="flex items-center gap-2.5 cursor-pointer text-xs font-semibold text-secondary hover:text-primary">
                  <input type="checkbox" class="filter-type-chk rounded border-outline-variant/50 text-refined-gold focus:ring-refined-gold w-4 h-4" data-name="PH" value="4">
                  <span>PH</span>
                </label>
                <label class="flex items-center gap-2.5 cursor-pointer text-xs font-semibold text-secondary hover:text-primary">
                  <input type="checkbox" class="filter-type-chk rounded border-outline-variant/50 text-refined-gold focus:ring-refined-gold w-4 h-4" data-name="Local" value="7">
                  <span>Local</span>
                </label>
                <label class="flex items-center gap-2.5 cursor-pointer text-xs font-semibold text-secondary hover:text-primary">
                  <input type="checkbox" class="filter-type-chk rounded border-outline-variant/50 text-refined-gold focus:ring-refined-gold w-4 h-4" data-name="Oficina" value="8">
                  <span>Oficina</span>
                </label>
                <label class="flex items-center gap-2.5 cursor-pointer text-xs font-semibold text-secondary hover:text-primary">
                  <input type="checkbox" class="filter-type-chk rounded border-outline-variant/50 text-refined-gold focus:ring-refined-gold w-4 h-4" data-name="Terreno" value="10">
                  <span>Terreno</span>
                </label>
              </div>
              <div class="border-t border-outline-variant/20 pt-2 flex justify-between items-center">
                <button type="button" class="btn-clear-type text-[10px] font-bold text-secondary hover:text-primary transition-colors">Limpiar</button>
                <button type="button" class="btn-apply-type bg-primary text-pure-white text-[10px] font-bold uppercase tracking-wider px-3 py-1.5 rounded-lg transition-all hover:bg-refined-gold active:scale-95">Aplicar</button>
              </div>
            </div>
          </div>

          <!-- Pill: Presupuesto (Precio) -->
          <div class="relative filter-pill-wrapper">
            <button type="button" class="filter-pill flex items-center gap-1.5 px-4 py-2 rounded-full border border-outline-variant/50 text-xs font-semibold text-secondary bg-pure-white hover:border-refined-gold transition-all duration-200" data-dropdown="dropdown-price">
              <span id="pill-label-price">Presupuesto</span>
              <span class="material-symbols-outlined text-[16px] text-refined-gold">expand_more</span>
            </button>
            <div id="dropdown-price" class="filter-dropdown absolute top-full left-0 mt-2 w-72 bg-pure-white border border-outline-variant/30 rounded-lg shadow-lg z-50 hidden p-4 space-y-4">
              <!-- Currency Selector buttons -->
              <div class="space-y-1.5">
                <label class="text-[9px] font-bold text-[#747878] uppercase tracking-widest block">Moneda</label>
                <div class="grid grid-cols-2 gap-2">
                  <button type="button" class="btn-currency-toggle py-1.5 px-3 border rounded-lg text-xs font-semibold text-center transition-all bg-primary text-pure-white border-primary" data-val="USD">USD</button>
                  <button type="button" class="btn-currency-toggle py-1.5 px-3 border rounded-lg text-xs font-semibold text-center transition-all bg-pure-white text-secondary border-outline-variant/50 hover:border-refined-gold" data-val="ARS">ARS</button>
                </div>
              </div>
              <!-- Price Slider range label -->
              <div class="space-y-1.5">
                <div class="text-[9px] font-bold text-[#747878] uppercase tracking-widest flex justify-between">
                  <span>Rango:</span>
                  <span id="price-range-label" class="text-primary font-bold">USD 200 - USD 2.500.000</span>
                </div>
                
                <!-- Double Range Slider track -->
                <div class="relative w-full h-6 flex items-center slider-wrapper pt-1">
                  <div class="absolute w-full h-[4px] bg-[#e2e8f0] rounded"></div>
                  <div id="slider-track" class="absolute h-[4px] bg-[#C5A880] rounded" style="left: 0%; right: 0%;"></div>
                  
                  <input 
                    type="range" 
                    id="slider-min" 
                    min="200" 
                    max="2500000" 
                    step="500" 
                    value="200" 
                    class="absolute w-full pointer-events-auto appearance-none bg-transparent h-2 outline-none cursor-pointer" 
                    style="z-index: 2;"
                  />
                  <input 
                    type="range" 
                    id="slider-max" 
                    min="200" 
                    max="2500000" 
                    step="500" 
                    value="2500000" 
                    class="absolute w-full pointer-events-auto appearance-none bg-transparent h-2 outline-none cursor-pointer" 
                    style="z-index: 2;"
                  />
                </div>
              </div>
              <div class="border-t border-outline-variant/20 pt-2 flex justify-end">
                <button type="button" class="btn-apply-price bg-primary text-pure-white text-[10px] font-bold uppercase tracking-wider px-3 py-1.5 rounded-lg transition-all hover:bg-refined-gold active:scale-95">Aplicar</button>
              </div>
            </div>
          </div>

          <!-- Pill: Ambientes -->
          <div class="relative filter-pill-wrapper">
            <button type="button" class="filter-pill flex items-center gap-1.5 px-4 py-2 rounded-full border border-outline-variant/50 text-xs font-semibold text-secondary bg-pure-white hover:border-refined-gold transition-all duration-200" data-dropdown="dropdown-rooms">
              <span id="pill-label-rooms">Ambientes</span>
              <span class="material-symbols-outlined text-[16px] text-refined-gold">expand_more</span>
            </button>
            <div id="dropdown-rooms" class="filter-dropdown absolute top-full left-0 mt-2 w-48 bg-pure-white border border-outline-variant/30 rounded-lg shadow-lg z-50 hidden p-2 space-y-0.5">
              <button type="button" class="btn-select-rooms w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="">Cualquiera</button>
              <button type="button" class="btn-select-rooms w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="1">1 Ambiente</button>
              <button type="button" class="btn-select-rooms w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="2">2 Ambientes</button>
              <button type="button" class="btn-select-rooms w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="3">3 Ambientes</button>
              <button type="button" class="btn-select-rooms w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="4">4+ Ambientes</button>
            </div>
          </div>

          <!-- Pill: Dormitorios -->
          <div class="relative filter-pill-wrapper">
            <button type="button" class="filter-pill flex items-center gap-1.5 px-4 py-2 rounded-full border border-outline-variant/50 text-xs font-semibold text-secondary bg-pure-white hover:border-refined-gold transition-all duration-200" data-dropdown="dropdown-bedrooms">
              <span id="pill-label-bedrooms">Dormitorios</span>
              <span class="material-symbols-outlined text-[16px] text-refined-gold">expand_more</span>
            </button>
            <div id="dropdown-bedrooms" class="filter-dropdown absolute top-full left-0 mt-2 w-48 bg-pure-white border border-outline-variant/30 rounded-lg shadow-lg z-50 hidden p-2 space-y-0.5">
              <button type="button" class="btn-select-bedrooms w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="">Cualquiera</button>
              <button type="button" class="btn-select-bedrooms w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="1">1 Dormitorio</button>
              <button type="button" class="btn-select-bedrooms w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="2">2 Dormitorios</button>
              <button type="button" class="btn-select-bedrooms w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="3">3 Dormitorios</button>
              <button type="button" class="btn-select-bedrooms w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="4">4+ Dormitorios</button>
            </div>
          </div>

          <!-- Pill: Baños -->
          <div class="relative filter-pill-wrapper">
            <button type="button" class="filter-pill flex items-center gap-1.5 px-4 py-2 rounded-full border border-outline-variant/50 text-xs font-semibold text-secondary bg-pure-white hover:border-refined-gold transition-all duration-200" data-dropdown="dropdown-bathrooms">
              <span id="pill-label-bathrooms">Baños</span>
              <span class="material-symbols-outlined text-[16px] text-refined-gold">expand_more</span>
            </button>
            <div id="dropdown-bathrooms" class="filter-dropdown absolute top-full left-0 mt-2 w-48 bg-pure-white border border-outline-variant/30 rounded-lg shadow-lg z-50 hidden p-2 space-y-0.5">
              <button type="button" class="btn-select-bathrooms w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="">Cualquiera</button>
              <button type="button" class="btn-select-bathrooms w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="1">1 Baño</button>
              <button type="button" class="btn-select-bathrooms w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="2">2 Baños</button>
              <button type="button" class="btn-select-bathrooms w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="3">3+ Baños</button>
            </div>
          </div>

          <!-- Pill: Cochera -->
          <div class="relative filter-pill-wrapper">
            <button type="button" class="filter-pill flex items-center gap-1.5 px-4 py-2 rounded-full border border-outline-variant/50 text-xs font-semibold text-secondary bg-pure-white hover:border-refined-gold transition-all duration-200" data-dropdown="dropdown-garage">
              <span id="pill-label-garage">Cochera</span>
              <span class="material-symbols-outlined text-[16px] text-refined-gold">expand_more</span>
            </button>
            <div id="dropdown-garage" class="filter-dropdown absolute top-full left-0 mt-2 w-48 bg-pure-white border border-outline-variant/30 rounded-lg shadow-lg z-50 hidden p-2 space-y-0.5">
              <button type="button" class="btn-select-garage w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="">Cualquiera</button>
              <button type="button" class="btn-select-garage w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="0">Sin Cochera</button>
              <button type="button" class="btn-select-garage w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="1">1 Cochera</button>
              <button type="button" class="btn-select-garage w-full text-left px-3.5 py-2 text-xs font-semibold rounded hover:bg-surface transition-colors" data-val="2">2+ Cocheras</button>
            </div>
          </div>

          <!-- Pill: Más filtros (with dynamic amenities and age/surface) -->
          <div class="relative filter-pill-wrapper">
            <button type="button" id="btn-more-filters" class="filter-pill flex items-center gap-1.5 px-4 py-2 rounded-full border border-outline-variant/50 text-xs font-semibold text-secondary bg-pure-white hover:border-refined-gold transition-all duration-200" data-dropdown="dropdown-more">
              <span id="pill-label-surface">Superficie / Más</span>
              <span class="material-symbols-outlined text-[16px] text-refined-gold">tune</span>
            </button>
            <div id="dropdown-more" class="filter-dropdown absolute top-full right-0 mt-2 w-[340px] sm:w-[420px] bg-pure-white border border-outline-variant/30 rounded-lg shadow-lg z-50 hidden p-4 space-y-4 max-h-[70vh] overflow-y-auto scrollbar-thin">
              
              <!-- Superficie -->
              <div class="space-y-2">
                <label class="text-[9px] font-bold text-[#747878] uppercase tracking-widest block">Superficie (m²)</label>
                <div class="grid grid-cols-2 gap-2">
                  <input type="number" id="filter-surface-min" placeholder="Mínimo" class="w-full px-3 py-1.5 text-xs rounded border border-outline-variant/40 focus:border-refined-gold focus:outline-none font-semibold bg-surface/30" />
                  <input type="number" id="filter-surface-max" placeholder="Máximo" class="w-full px-3 py-1.5 text-xs rounded border border-outline-variant/40 focus:border-refined-gold focus:outline-none font-semibold bg-surface/30" />
                </div>
              </div>

              <!-- Antigüedad -->
              <div class="space-y-2">
                <label class="text-[9px] font-bold text-[#747878] uppercase tracking-widest block">Antigüedad</label>
                <div class="flex flex-wrap gap-1.5">
                  <button type="button" class="btn-more-toggle px-3 py-1.5 rounded-full border border-outline-variant/50 text-[10px] font-semibold text-secondary bg-pure-white transition-all hover:border-refined-gold" data-key="a-estrenar">A estrenar</button>
                  <button type="button" class="btn-more-toggle px-3 py-1.5 rounded-full border border-outline-variant/50 text-[10px] font-semibold text-secondary bg-pure-white transition-all hover:border-refined-gold" data-key="hasta-5-anos">Hasta 5 años</button>
                  <button type="button" class="btn-more-toggle px-3 py-1.5 rounded-full border border-outline-variant/50 text-[10px] font-semibold text-secondary bg-pure-white transition-all hover:border-refined-gold" data-key="hasta-10-anos">Hasta 10 años</button>
                  <button type="button" class="btn-more-toggle px-3 py-1.5 rounded-full border border-outline-variant/50 text-[10px] font-semibold text-secondary bg-pure-white transition-all hover:border-refined-gold" data-key="hasta-20-anos">Hasta 20 años</button>
                  <button type="button" class="btn-more-toggle px-3 py-1.5 rounded-full border border-outline-variant/50 text-[10px] font-semibold text-secondary bg-pure-white transition-all hover:border-refined-gold" data-key="mas-de-20-anos">Más de 20 años</button>
                </div>
              </div>

              <!-- Características (DYNAMICAL checklists loaded from active Tokko list) -->
              <div class="space-y-2 border-t border-outline-variant/15 pt-3">
                <label class="text-[9px] font-bold text-[#747878] uppercase tracking-widest block">Características / Amenities</label>
                <div class="grid grid-cols-2 gap-x-3 gap-y-2 max-h-48 overflow-y-auto pr-1 scrollbar-thin" id="dynamic-tags-container">
                  <!-- Injected via Client-side JS -->
                </div>
              </div>

              <div class="border-t border-outline-variant/20 pt-3 flex justify-between items-center">
                <button type="button" id="btn-clear-more" class="text-xs font-bold uppercase tracking-wider text-secondary hover:text-primary transition-colors">Limpiar</button>
                <button type="button" id="btn-apply-more" class="bg-primary text-pure-white text-xs font-bold uppercase tracking-widest px-5 py-2 rounded-xl transition-all hover:bg-refined-gold active:scale-95">Aplicar</button>
              </div>

            </div>
          </div>

          <!-- General reset filters button -->
          <button 
            id="btn-clear-search" 
            class="hidden text-xs font-bold uppercase tracking-widest text-[#9c27b0] hover:text-primary px-3 py-2 transition-all"
          >
            Limpiar Filtros
          </button>

        </div>
      </div>

      <!-- Properties Cards Container (Single Flow Area) -->
      <div 
        id="properties-list" 
        class="p-5 space-y-4 bg-surface-container-lowest"
      >
        <!-- Horizontal cards injected here via Client JS -->
      </div>
    </section>

    <!-- Mobile Toggle Button (Floating at bottom center) -->
    <div class="lg:hidden fixed bottom-6 left-1/2 -translate-x-1/2 z-[2000] select-none">
        <button 
          id="btn-mobile-view-toggle" 
          class="bg-primary text-pure-white px-6 py-3 rounded-full text-xs font-bold uppercase tracking-widest shadow-xl flex items-center gap-2 border border-white/20 active:scale-95 transition-all"
        >
            <span class="material-symbols-outlined text-[18px]" id="toggle-view-icon">map</span>
            <span id="toggle-view-text">Ver Mapa</span>
        </button>
    </div>

  </main>
  
  <!-- Data attributes cache passing server array to client context -->
  <div id="map-page-container" class="hidden" data-properties={JSON.stringify(properties)}></div>
</MainLayout>

