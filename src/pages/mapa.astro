        } else if (spec.icon === 'bed') {
          iconSvg = `<svg class="w-[15px] h-[15px] text-[#191c1d]/90 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v6" /><path d="M3 10V6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v4" /><path d="M12 4v6" /><path d="M5 14h14" /></svg>`;
        } else if (spec.icon === 'bath') {
          iconSvg = `<svg class="w-[15px] h-[15px] text-[#191c1d]/90 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20v-9a4 4 0 0 1 4-4h7" /><path d="M14 7h3l1 3H13z" fill="currentColor" fill-opacity="0.15" /><path d="M14 12v2M15.5 12v3M17 12v2" /></svg>`;
        } else if (spec.icon === 'car') {
          iconSvg = `<svg class="w-[15px] h-[15px] text-[#191c1d]/90 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M6 14 L8 9h8l2 5" /><rect x="4" y="14" width="16" height="5" rx="1" /><circle cx="7" cy="16.5" r="0.75" fill="currentColor" /><circle cx="17" cy="16.5" r="0.75" fill="currentColor" /><path d="M6 19v2M18 19v2" /></svg>`;
        } else if (spec.icon === 'ruler') {
          iconSvg = `<svg class="w-[15px] h-[15px] text-[#191c1d]/90 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M5 5v14h14z" /><path d="M8 8v8h8z" /><path d="M8 19v-1M11 19v-1M14 19v-1M17 19v-1" /></svg>`;
        }

        const isLast = index === specs.length - 1;
        const paddingClass = index === 0 ? 'pr-3.5' : isLast ? 'pl-3.5' : 'px-3.5';
        const borderClass = isLast ? '' : 'border-r border-outline-variant/25';
        return `
          <div class="${paddingClass} ${borderClass} flex flex-col items-start shrink-0">
            <div class="flex items-center gap-1.5 font-bold text-[14px] text-primary">
              <span>${spec.value}</span>
              ${iconSvg}
            </div>
            <span class="text-[9.5px] text-[#888888] font-medium mt-0.5 block leading-none">${spec.label}</span>
          </div>
        `;
      }).join('');

      html += `
        <div class="property-row-card flex flex-col sm:flex-row bg-pure-white rounded-lg border border-outline-variant/30 overflow-hidden hover:shadow-md transition-all duration-300 relative group h-auto sm:h-[180px]" data-id="${p.id}" data-photos='${JSON.stringify(imageList)}' data-lat="${p.geo_lat || ''}" data-lng="${p.geo_long || ''}">
          <div class="relative w-full sm:w-[240px] h-[160px] sm:h-full overflow-hidden shrink-0 bg-gray-100 select-none">
            <div class="absolute top-3.5 left-3.5 z-10 select-none pointer-events-none opacity-40">
              <div class="text-[12px] font-bold text-pure-white uppercase tracking-[0.2em] leading-none">MUV</div>
              <div class="text-[6px] font-bold text-pure-white uppercase tracking-[0.25em] leading-none mt-1">Propiedades</div>
            </div>
            ${imageList.length > 1 ? `
              <button class="row-carousel-btn row-btn-prev absolute left-2 top-1/2 -translate-y-1/2 z-10 w-8 h-8 flex items-center justify-center text-white/75 hover:text-white hover:scale-110 transition-all opacity-0 group-hover:opacity-100" aria-label="Anterior">
                <span class="material-symbols-outlined text-[28px] font-light">chevron_left</span>
              </button>
              <button class="row-carousel-btn row-btn-next absolute right-2 top-1/2 -translate-y-1/2 z-10 w-8 h-8 flex items-center justify-center text-white/75 hover:text-white hover:scale-110 transition-all opacity-0 group-hover:opacity-100" aria-label="Siguiente">
                <span class="material-symbols-outlined text-[28px] font-light">chevron_right</span>
              </button>
            ` : ''}
            <div class="absolute bottom-2.5 right-2.5 z-10 flex items-center gap-1.5">
              <button class="row-zoom-btn w-7 h-7 bg-[#121212]/60 hover:bg-[#C5A880] border border-white/10 rounded flex items-center justify-center text-white transition-all opacity-0 group-hover:opacity-100 active:scale-95 pointer-events-auto" aria-label="Zoom">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
                </svg>
              </button>
              <button class="row-save-btn w-7 h-7 bg-[#121212]/60 hover:bg-[#C5A880] border border-white/10 rounded flex items-center justify-center text-white transition-all opacity-0 group-hover:opacity-100 active:scale-95 pointer-events-auto" aria-label="Guardar">
                <span class="material-symbols-outlined text-[16px]">add_circle</span>
              </button>
            </div>
            <a href="/property/${p.id}/" class="block w-full h-full">
              <img src="${imageList[0]}" class="row-carousel-img w-full h-full object-cover group-hover:scale-103 transition-transform duration-500" loading="lazy" alt="${p.publication_title}" />
            </a>
          </div>
          <div class="flex flex-col justify-between p-4 flex-grow text-left relative min-w-0 font-sans">
            <div class="flex justify-between items-center w-full">
              <div class="flex gap-1.5 select-none items-center">
                <span class="bg-[#4A4A4A] text-pure-white px-2.5 py-1 text-[8.5px] font-bold tracking-wider uppercase rounded-md leading-none">${opTypeLabel}</span>
                <span class="bg-[#4A4A4A] text-pure-white px-2.5 py-1 text-[8.5px] font-bold tracking-wider uppercase rounded-md leading-none">DISPONIBLE</span>
