---
import MainLayout from '../layouts/MainLayout.astro';
import { getDevelopments } from '../lib/tokko';

// Fetch developments on the server side
const { developments, total } = await getDevelopments();

// Extract unique locations for the filter
const locations = Array.from(new Set(developments.map(dev => dev.location?.name).filter(Boolean)));
---

<MainLayout title="Emprendimientos | MUV Propiedades" isDarkHero={false}>
    <!-- Hero Section -->
    <header class="relative h-[65vh] w-full flex items-end overflow-hidden pt-20">
        <img class="absolute inset-0 w-full h-full object-cover" src="https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?auto=format&fit=crop&w=1600&q=80" alt="Emprendimientos Signature Series MUV" width="1600" height="900" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>
        <div class="relative w-full max-w-container-max mx-auto px-margin-desktop pb-16">
            <div class="max-w-2xl animate-fade-up">
                <span class="inline-block bg-refined-gold text-pure-white px-3 py-1 font-label-sm text-label-sm uppercase tracking-widest mb-4">Signature Series</span>
                <h1 class="font-display-lg text-display-lg-mobile md:text-display-lg text-pure-white mb-4 leading-none font-semibold">Desarrollos de Vanguardia</h1>
                <p class="font-body-lg text-body-lg text-pure-white/95 max-w-lg mb-6">Emprendimientos exclusivos en las mejores ubicaciones. Diseño y precisión para inversores exigentes.</p>
                <a class="bg-pure-white text-primary px-8 py-4 inline-block font-label-lg text-label-lg hover:bg-refined-gold hover:text-pure-white transition-all font-semibold" href="#projects">
                    Ver Proyectos
                </a>
            </div>
        </div>
    </header>

    <!-- Filters Section -->
    <section class="sticky top-[80px] z-40 bg-surface/95 backdrop-blur-nav border-b border-outline-variant/30 py-6">
        <div class="max-w-container-max mx-auto px-margin-desktop">
            <div class="flex flex-wrap items-center justify-between gap-6">
                <div class="flex items-center gap-8">
                    <div class="flex flex-col gap-1">
                        <label for="filter-location" class="font-label-sm text-label-sm text-slate-blue uppercase font-semibold">Ubicación</label>
                        <select id="filter-location" class="bg-transparent border-none p-0 pr-8 font-headline-md text-[18px] text-primary focus:ring-0 cursor-pointer appearance-none outline-none font-bold">
                            <option value="">Todas las Zonas</option>
                            {locations.map(loc => (
                                <option value={loc}>{loc}</option>
                            ))}
                        </select>
                    </div>
                    <div class="h-10 w-[1px] bg-outline-variant/50"></div>
                    <div class="flex flex-col gap-1">
                        <label for="filter-status" class="font-label-sm text-label-sm text-slate-blue uppercase font-semibold">Estado de Obra</label>
                        <select id="filter-status" class="bg-transparent border-none p-0 pr-8 font-headline-md text-[18px] text-primary focus:ring-0 cursor-pointer appearance-none outline-none font-bold">
                            <option value="">Todos los Estados</option>
                            <option value="En Construcción">En Construcción</option>
                            <option value="Lanzamiento">Lanzamiento</option>
                            <option value="Terminado">Terminado</option>
                        </select>
                    </div>
                </div>
                <div class="text-secondary font-label-sm font-semibold" id="results-counter">
                    {total} {total === 1 ? 'resultado' : 'resultados'}
                </div>
            </div>
        </div>
    </section>

    <!-- Development Grid -->
    <main class="max-w-container-max mx-auto px-margin-desktop py-16" id="projects">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter" id="developments-grid">
            {developments.map((dev) => {
                const status = dev.construction_status || 'Premium';
                const locationName = dev.location ? dev.location.name : 'Buenos Aires';
                const imageSrc = dev.photos && dev.photos.length > 0 ? dev.photos[0].image : 'https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?auto=format&fit=crop&w=800&q=80';
                const shortDesc = dev.description ? dev.description.slice(0, 100) + '...' : 'Desarrollo de diseño exclusivo y terminaciones premium.';
                
                return (
                    <a 
                      href={`/emprendimientos/${dev.id}`} 
                      class="development-card group cursor-pointer block animate-fade-up bg-pure-white border border-outline-variant/30 rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-all duration-300"
                      data-location={locationName}
                      data-status={status}
                    >
                        <div class="relative aspect-[3/2] overflow-hidden">
                            <img 
                              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" 
                              src={imageSrc} 
                              loading="lazy" 
                              alt={`Emprendimiento ${dev.name}`}
                              width="800"
                              height="533"
                            />
                            <div class="absolute top-4 left-4">
                                <span class="bg-primary text-pure-white px-3 py-1 font-label-sm text-[11px] uppercase tracking-wider rounded">{status}</span>
                            </div>
                        </div>
                        <div class="p-6">
                            <div class="flex justify-between items-start mb-2">
                                <h3 class="font-headline-md text-[20px] text-primary font-bold truncate w-3/4">{dev.name}</h3>
                                <span class="text-refined-gold font-label-sm text-label-sm uppercase font-semibold">MUV</span>
                            </div>
                            <div class="flex items-center gap-2 text-slate-blue mb-4">
                                <span class="material-symbols-outlined text-[18px]">location_on</span>
                                <span class="font-body-md text-body-md">{locationName}</span>
                            </div>
                            <p class="font-body-md text-secondary text-sm mb-4 leading-relaxed line-clamp-2">{shortDesc}</p>
                            <div class="flex gap-4 border-t border-outline-variant/30 pt-4 text-secondary">
                                <div class="flex items-center gap-1.5 font-label-sm text-[11px] uppercase tracking-wider">
                                    <span class="material-symbols-outlined text-refined-gold text-[18px]">info</span>
                                    <span>Ver Unidades Disponibles</span>
                                </div>
                            </div>
                        </div>
                    </a>
                );
            })}
        </div>
    </main>

    <!-- Strategic Neighborhoods -->
    <section class="bg-off-white py-24 border-t border-outline-variant/30">
        <div class="max-w-container-max mx-auto px-margin-desktop">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-gutter items-center">
                <div class="space-y-6">
                    <span class="text-refined-gold font-label-lg uppercase tracking-[0.25em] text-xs font-semibold block">Ubicaciones Clave</span>
                    <h2 class="font-headline-lg text-headline-lg text-primary mb-6">Barrios Estratégicos</h2>
                    <p class="font-body-lg text-body-lg text-slate-blue mb-10 leading-relaxed">
                        Seleccionamos los mejores emplazamientos urbanos que garanticen revalorización del capital, accesibilidad, y un estilo de vida de primer nivel.
                    </p>
                    <div class="space-y-6">
                        <div class="p-6 bg-pure-white border-l-4 border-refined-gold shadow-sm hover:translate-x-2 transition-all duration-300 rounded-r">
                            <h4 class="font-headline-md text-headline-md mb-1 font-bold">Recoleta</h4>
                            <p class="font-body-md text-body-md text-on-surface-variant">El epicentro de la elegancia tradicional porteña, con sus avenidas arboladas y estilo francés.</p>
                        </div>
                        <div class="p-6 bg-pure-white hover:translate-x-2 transition-all duration-300 border-l-4 border-transparent hover:border-refined-gold rounded shadow-sm">
                            <h4 class="font-headline-md text-headline-md mb-1 font-bold">Palermo Chico</h4>
                            <p class="font-body-md text-body-md text-on-surface-variant">Exclusividad residencial rodeada de embajadas, museos y pulmones verdes.</p>
                        </div>
                    </div>
                </div>
                <div class="relative h-[500px] bg-surface-container rounded-lg overflow-hidden group shadow-md border border-outline-variant/30">
                    <iframe 
                        class="w-full h-full border-0 grayscale hover:grayscale-0 transition-all duration-700" 
                        src="https://maps.google.com/maps?q=Recoleta,%20Buenos%20Aires&t=&z=14&ie=UTF8&iwloc=&output=embed" 
                        allowfullscreen 
                        loading="lazy"
                        title="Mapa de ubicaciones de emprendimientos MUV">
                    </iframe>
                    <div class="absolute bottom-4 left-4 bg-white/90 backdrop-blur px-4 py-2 rounded shadow-sm border border-outline-variant/30 pointer-events-none">
                        <p class="font-label-sm text-label-sm text-primary font-medium">Buenos Aires, Argentina</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</MainLayout>

<script>
    // In-memory filter logic
    const selectLocation = document.getElementById('filter-location') as HTMLSelectElement | null;
    const selectStatus = document.getElementById('filter-status') as HTMLSelectElement | null;
    const cards = document.querySelectorAll('.development-card') as NodeListOf<HTMLAnchorElement>;
    const counter = document.getElementById('results-counter');

    function applyFilters() {
        const locationVal = selectLocation?.value || '';
        const statusVal = selectStatus?.value || '';
        let visibleCount = 0;

        cards.forEach(card => {
            const loc = card.getAttribute('data-location') || '';
            const status = card.getAttribute('data-status') || '';

            const locMatches = !locationVal || loc === locationVal;
            const statusMatches = !statusVal || status === statusVal;

            if (locMatches && statusMatches) {
                card.classList.remove('hidden');
                visibleCount++;
            } else {
                card.classList.add('hidden');
            }
        });

        if (counter) {
            counter.innerText = `${visibleCount} ${visibleCount === 1 ? 'resultado' : 'resultados'}`;
        }
    }

    selectLocation?.addEventListener('change', applyFilters);
    selectStatus?.addEventListener('change', applyFilters);
</script>
