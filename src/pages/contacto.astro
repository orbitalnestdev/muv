---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout 
  title="Contacto | MUV Propiedades" 
  description="Contactá con MUV Propiedades. Dejanos tu consulta sobre venta, alquiler o tasación de inmuebles y proyectos premium en las mejores zonas de Buenos Aires."
  isDarkHero={false}
>
  <main class="bg-pure-white">
    <!-- Hero Section: Contact Header with Watermark & Social Icons -->
    <section class="relative bg-black h-[250px] pt-20 overflow-hidden flex items-center">
      <!-- Watermark M logo -->
      <div class="absolute right-0 top-20 h-[calc(100%-5rem)] w-1/2 opacity-20 pointer-events-none select-none">
        <img 
          src="/assets/iso_muv.png" 
          alt="Watermark" 
          class="absolute bottom-0 right-6 md:right-16 h-full w-auto object-contain brightness-0 invert"
        />
      </div>
      
      <div class="relative z-10 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto w-full text-left space-y-4">
        <h1 class="font-display-lg text-3xl md:text-4xl text-pure-white leading-tight font-medium tracking-tight">
          Contacto
        </h1>
        
        <!-- Social Media Icons under title -->
        <div class="flex items-center gap-3">
          <!-- Facebook icon (outlined white) -->
          <a href="https://facebook.com/muvpropiedades" target="_blank" class="text-pure-white/80 hover:text-pure-white transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z"/>
            </svg>
          </a>
          <!-- Instagram icon (outlined white) -->
          <a href="https://instagram.com/muvpropiedades" target="_blank" class="text-pure-white/80 hover:text-pure-white transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Info Cards Row -->
    <section class="py-12 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Card 1: Llamanos al -->
        <div class="bg-pure-white p-6 border border-outline-variant/30 rounded-2xl shadow-md flex items-center gap-4 text-left">
          <div class="w-12 h-12 rounded-full bg-surface-container flex items-center justify-center text-primary shrink-0">
            <!-- Telephone SVG -->
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.387a20.373 20.373 0 0 1-7.147-7.147c-.155-.441.011-.928.387-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25z" />
            </svg>
          </div>
          <div class="min-w-0">
            <span class="text-[10px] text-secondary font-bold uppercase tracking-widest block leading-none mb-1">Llamanos al</span>
            <a href="tel:+541148054192" class="text-sm font-semibold text-primary hover:text-slate-blue transition-colors block truncate">(011) 4805-4192</a>
          </div>
        </div>

        <!-- Card 2: WhatsApp -->
        <div class="bg-pure-white p-6 border border-outline-variant/30 rounded-2xl shadow-md flex items-center gap-4 text-left">
          <div class="w-12 h-12 rounded-full bg-surface-container flex items-center justify-center text-primary shrink-0">
            <!-- WhatsApp SVG -->
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 0 0 1.333 4.993L2 22l5.13-1.347a9.92 9.92 0 0 0 4.878 1.28h.005c5.502 0 9.985-4.478 9.99-9.988 0-2.67-1.039-5.18-2.93-7.073C17.18 3.002 14.675 2 12.012 2zm5.72 13.918c-.313.88-1.534 1.576-2.124 1.666-.52.078-1.026.294-3.328-.623-2.946-1.173-4.834-4.108-4.981-4.303-.147-.196-1.196-1.585-1.196-3.023 0-1.439.752-2.144 1.021-2.438.27-.294.59-.367.785-.367.197 0 .393.002.564.01.18.008.423-.07.662.502.245.587.834 2.03.908 2.177.073.147.123.318.024.514-.098.196-.147.318-.294.49-.147.172-.31.383-.442.514-.147.147-.3.307-.129.6.172.294.765 1.258 1.642 2.039.882.784 1.626 1.025 1.872 1.147.245.123.392.1.539-.074.147-.172.637-.734.81-1.003.17-.27.342-.22.563-.123.22.098 1.4.66 1.643.784.246.123.409.183.47.288.06.104.06.602-.253 1.482z"/>
            </svg>
          </div>
          <div class="min-w-0">
            <span class="text-[10px] text-secondary font-bold uppercase tracking-widest block leading-none mb-1">WhatsApp</span>
            <a href="https://wa.me/5491122862000" target="_blank" class="text-sm font-semibold text-primary hover:text-slate-blue transition-colors block truncate">(+54 9) 11 2286-2000</a>
          </div>
        </div>

        <!-- Card 3: Ubicación -->
        <div class="bg-pure-white p-6 border border-outline-variant/30 rounded-2xl shadow-md flex items-center gap-4 text-left">
          <div class="w-12 h-12 rounded-full bg-surface-container flex items-center justify-center text-primary shrink-0">
            <!-- Location SVG -->
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0z" />
            </svg>
          </div>
          <div class="min-w-0">
            <span class="text-[10px] text-secondary font-bold uppercase tracking-widest block leading-none mb-1">Ubicación</span>
            <span class="text-xs font-semibold text-primary block leading-snug">Jerónimo Salguero 2686 - Ciudad Buenos Aires</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Invitation Text & Contact Form Section -->
    <section class="py-6 px-margin-mobile md:px-margin-desktop max-w-[1130px] mx-auto space-y-8 text-center">
      <p class="text-xs md:text-sm text-secondary leading-relaxed">
        Lo invitamos a dejarnos sus datos y nos contactaremos con usted a la brevedad.
      </p>

      <!-- Rounded form exactly as references -->
      <form class="space-y-4 text-left">
        <!-- Input: Nombre -->
        <div>
          <input 
            type="text" 
            id="name"
            name="name"
            placeholder="Nombre" 
            required
            class="w-full px-6 py-3 border border-outline-variant/40 rounded-full focus:outline-none focus:border-primary text-sm bg-transparent transition-all duration-300"
          />
        </div>

        <!-- Input: Email -->
        <div>
          <input 
            type="email" 
            id="email"
            name="email"
            placeholder="Email" 
            required
            class="w-full px-6 py-3 border border-outline-variant/40 rounded-full focus:outline-none focus:border-primary text-sm bg-transparent transition-all duration-300"
          />
        </div>

        <!-- Input: Teléfono with Argentina Flag prefix -->
        <div class="relative flex items-center border border-outline-variant/40 rounded-full px-5 py-2.5 focus-within:border-primary transition-all duration-300 bg-transparent">
          <div class="flex items-center gap-1.5 pr-3.5 border-r border-outline-variant/30 text-sm select-none shrink-0">
            <span class="text-base leading-none">🇦🇷</span>
            <span class="text-xs font-semibold text-secondary leading-none">+54</span>
          </div>
          <input 
            type="tel" 
            id="phone" 
            name="phone"
            placeholder="Teléfono" 
            required
            class="w-full bg-transparent border-0 outline-none focus:ring-0 text-sm pl-3.5 p-0" 
          />
        </div>

        <!-- Input: Mensaje -->
        <div>
          <textarea 
            id="message"
            name="message"
            placeholder="Mensaje" 
            rows="5"
            required
            class="w-full px-6 py-4 border border-outline-variant/40 rounded-3xl focus:outline-none focus:border-primary text-sm bg-transparent resize-none transition-all duration-300"
          ></textarea>
        </div>

        <!-- Submit Button -->
        <div class="pt-2">
          <button 
            type="submit" 
            class="bg-black text-pure-white hover:bg-black/90 px-10 py-3 rounded-full text-xs font-bold uppercase tracking-wider transition-all duration-300 active:scale-95"
          >
            Enviar
          </button>
        </div>
      </form>
    </section>

    <!-- Map Section -->
    <section class="py-8 px-margin-mobile md:px-margin-desktop max-w-[1130px] mx-auto">
      <div class="w-full h-[300px] border border-outline-variant/30 rounded-lg overflow-hidden relative shadow-sm">
        <!-- Interactive Google Map embed centered at Jerónimo Salguero 2686, Palermo, CABA -->
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3284.6644265814545!2d-58.406963424260274!3d-34.58735397296068!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bcca9dcd8e6db9%3A0xe7a5078516086745!2sJer%C3%B3nimo%20Salguero%202686%2C%20C1425%20CABA!5e0!3m2!1ses-419!2sar!4v1700000000000!5m2!1ses-419!2sar" 
          class="w-full h-full border-0 grayscale opacity-90" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación MUV Propiedades"
        ></iframe>
      </div>
    </section>
  </main>
</MainLayout>
