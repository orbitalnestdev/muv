---
import MainLayout from '../../layouts/MainLayout.astro';
import SearchFilters from '../../components/SearchFilters.astro';
import PropertyGrid from '../../components/PropertyGrid.astro';
import { getProperties } from '../../lib/tokko';

const { slug } = Astro.params;

const barrioMap: Record<string, string> = {
  'belgrano': 'Belgrano',
  'palermo': 'Palermo',
  'palermo-hollywood': 'Palermo Hollywood',
  'palermo-soho': 'Palermo Soho',
  'palermo-chico': 'Palermo Chico',
  'palermo-nuevo': 'Palermo Nuevo',
  'recoleta': 'Recoleta',
  'puerto-madero': 'Puerto Madero',
  'villa-urquiza': 'Villa Urquiza',
  'colegiales': 'Colegiales',
  'nunez': 'Nuñez',
  'villa-crespo': 'Villa Crespo',
  'flores': 'Flores',
  'san-telmo': 'San Telmo',
  'botanico': 'Botanico',
  'once': 'Once',
  'microcentro': 'Microcentro'
};

const locationName = barrioMap[slug || ''] || '';

if (!locationName) {
  return Astro.redirect('/search-results/');
}

// Fetch all properties to compute neighborhood counts
const { properties: allProperties } = await getProperties();
const normalizeString = (str: string) => str.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();

// Extract query parameters from URL
const url = Astro.url;
const q = url.searchParams.get('q') || '';
const operationId = url.searchParams.get('operation_id') || '';
const propertyTypeId = url.searchParams.get('property_type_id') || '';
const priceMin = url.searchParams.get('price_min') || '';
const priceMax = url.searchParams.get('price_max') || '';
const currency = url.searchParams.get('currency') || 'USD';
const rooms = url.searchParams.get('rooms') || '';
const bedrooms = url.searchParams.get('bedrooms') || '';
const bathrooms = url.searchParams.get('bathrooms') || '';
const garage = url.searchParams.get('garage') || '';
const surfaceMin = url.searchParams.get('surface_min') || '';
const surfaceMax = url.searchParams.get('surface_max') || '';
const amenities = url.searchParams.getAll('amenities') || [];
const currentPage = Number(url.searchParams.get('page') || '1');

// Matcher function to filter properties against all active criteria EXCEPT neighborhood
interface Property {
  id: number;
  reference_code: string;
  publication_title: string;
  description: string;
  address: string;
  bathroom_amount: number;
  room_amount: number;
  suite_amount: number;
  surface: string;
  total_surface: string;
  covered_surface: string;
  parking_lot_amount: number;
  is_starred_on_web: boolean;
  type: { id: number; name: string };
  development?: { id: number; name: string };
  operations: Array<{
    operation_type: string;
    operation_id: number;
    prices: Array<{ currency: string; price: number }>;
  }>;
  location: { id: number; name: string; full_location: string };
  photos: Array<{ image: string; thumb: string }>;
  tags: Array<{ name: string; type?: number; id?: number }>;
  geo_lat?: string;
  geo_long?: string;
}

const matchesFiltersExceptNeighborhood = (p: Property, overrides: { operation_id?: string, property_type_id?: string } = {}) => {
  const activeOpId = overrides.operation_id !== undefined ? overrides.operation_id : operationId;
  const activePropTypeId = overrides.property_type_id !== undefined ? overrides.property_type_id : propertyTypeId;

  // 1. Search Query
  if (q) {
    const queryNorm = normalizeString(q);
    const inTitle = p.publication_title && normalizeString(p.publication_title).includes(queryNorm);
    const inAddress = p.address && normalizeString(p.address).includes(queryNorm);
    const inDesc = p.description && normalizeString(p.description).includes(queryNorm);
    const inLoc = p.location?.name && normalizeString(p.location.name).includes(queryNorm);
    if (!inTitle && !inAddress && !inDesc && !inLoc) return false;
  }
  
  // 2. Operation
  if (activeOpId && !p.operations?.some(op => op.operation_id.toString() === activeOpId)) {
    return false;
  }
  
  // 3. Property Type
  if (activePropTypeId && p.type?.id?.toString() !== activePropTypeId) {
    return false;
  }
  
  // 4. Price & Currency
  const opId = activeOpId ? Number(activeOpId) : null;
  const currencyFilter = currency ? currency.toUpperCase() : '';
  
  if (priceMin) {
    const pMin = Number(priceMin);
    const hasPriceMin = p.operations?.some(op => 
      (!opId || op.operation_id === opId) && op.prices?.some(pr => 
        (!currencyFilter || pr.currency === currencyFilter) && pr.price >= pMin
      )
    );
    if (!hasPriceMin) return false;
  }
  
  if (priceMax) {
    const pMax = Number(priceMax);
    const hasPriceMax = p.operations?.some(op => 
      (!opId || op.operation_id === opId) && op.prices?.some(pr => 
        (!currencyFilter || pr.currency === currencyFilter) && pr.price <= pMax
      )
    );
    if (!hasPriceMax) return false;
  }
  
  if (currency && !p.operations?.some(op => (!opId || op.operation_id === opId) && op.prices?.some(pr => pr.currency === currencyFilter))) {
    return false;
  }
  
  // 5. Rooms / Ambientes
  if (rooms) {
    const rAmt = Number(rooms);
    if (rAmt === 4) {
      if (p.room_amount < 4) return false;
    } else {
      if (p.room_amount !== rAmt) return false;
    }
  }
  
  // 6. Bedrooms
  if (bedrooms) {
    const bAmt = Number(bedrooms);
    if (bAmt === 4) {
      if (p.suite_amount < 4) return false;
    } else {
      if (p.suite_amount !== bAmt) return false;
    }
  }
  
  // 7. Bathrooms
  if (bathrooms) {
    const bathAmt = Number(bathrooms);
    if (bathAmt === 4) {
      if (p.bathroom_amount < 4) return false;
    } else {
      if (p.bathroom_amount !== bathAmt) return false;
    }
  }
  
  // 8. Garage
  if (garage) {
    const garAmt = Number(garage);
    if (garAmt === 4) {
      if (p.parking_lot_amount < 4) return false;
    } else {
      if (p.parking_lot_amount !== garAmt) return false;
    }
  }
  
  // 9. Surface
  if (surfaceMin && Number(p.covered_surface || p.surface || 0) < Number(surfaceMin)) {
    return false;
  }
  if (surfaceMax && Number(p.covered_surface || p.surface || 0) > Number(surfaceMax)) {
    return false;
  }
  
  // 10. Amenities
  if (Array.isArray(amenities) && amenities.length > 0) {
    const hasAllAms = amenities.every(amName => 
      p.tags?.some(tag => normalizeString(tag.name) === normalizeString(amName))
    );
    if (!hasAllAms) return false;
  }
  
  return true;
};

// Count helper for neighborhood list (preserves active operation and property type filters)
const getBarrioCount = (barrioName: string) => {
  return allProperties.filter(p => {
    const matchesBarrio = p.location?.name && normalizeString(p.location.name).includes(normalizeString(barrioName));
    if (!matchesBarrio) return false;
    return matchesFiltersExceptNeighborhood(p);
  }).length;
};

// Count helper for operation and property type buttons (local to the current neighborhood)
const getLocalFilterCount = (overrides: { operation_id?: string, property_type_id?: string }) => {
  return allProperties.filter(p => {
    const matchesBarrio = p.location?.name && normalizeString(p.location.name).includes(normalizeString(locationName));
    if (!matchesBarrio) return false;
    return matchesFiltersExceptNeighborhood(p, overrides);
  }).length;
};

// Count of properties matching active operation and property type in ALL neighborhoods
const globalMatchingCount = allProperties.filter(p => matchesFiltersExceptNeighborhood(p)).length;

const neighborhoodList = [
  { slug: '', name: 'Todos los Barrios', count: globalMatchingCount },
  { slug: 'belgrano', name: 'Belgrano', count: getBarrioCount('Belgrano') },
  { slug: 'colegiales', name: 'Colegiales', count: getBarrioCount('Colegiales') },
  { slug: 'flores', name: 'Flores', count: getBarrioCount('Flores') },
  { slug: 'microcentro', name: 'Microcentro', count: getBarrioCount('Microcentro') },
  { slug: 'nunez', name: 'Núñez', count: getBarrioCount('Nuñez') || getBarrioCount('Núñez') },
  { slug: 'once', name: 'Once', count: getBarrioCount('Once') },
  { slug: 'palermo', name: 'Palermo', count: getBarrioCount('Palermo') },
  { slug: 'palermo-hollywood', name: 'Palermo Hollywood', count: getBarrioCount('Palermo Hollywood') },
  { slug: 'palermo-soho', name: 'Palermo Soho', count: getBarrioCount('Palermo Soho') },
  { slug: 'palermo-chico', name: 'Palermo Chico', count: getBarrioCount('Palermo Chico') },
  { slug: 'palermo-nuevo', name: 'Palermo Nuevo', count: getBarrioCount('Palermo Nuevo') },
  { slug: 'puerto-madero', name: 'Puerto Madero', count: getBarrioCount('Puerto Madero') },
  { slug: 'recoleta', name: 'Recoleta', count: getBarrioCount('Recoleta') },
  { slug: 'san-telmo', name: 'San Telmo', count: getBarrioCount('San Telmo') },
  { slug: 'villa-crespo', name: 'Villa Crespo', count: getBarrioCount('Villa Crespo') },
  { slug: 'villa-urquiza', name: 'Villa Urquiza', count: getBarrioCount('Villa Urquiza') }
];

const barrioImages: Record<string, string> = {
  'belgrano': 'https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_BELGRANO.webp',
  'palermo': 'https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_PALERMO.webp',
  'palermo-hollywood': 'https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_PALERMO.webp',
  'palermo-soho': 'https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_PALERMO.webp',
  'palermo-chico': 'https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_PALERMO.webp',
  'palermo-nuevo': 'https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_PALERMO.webp',
  'recoleta': 'https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_RECOLETA.webp',
  'puerto-madero': 'https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_PUERTO-MADERO.webp',
  'villa-urquiza': 'https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_VILLA-URQUIZA.webp',
  'colegiales': 'https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_COLEGIALES.webp',
  'nunez': 'https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_NUNEZ-1.webp',
  'villa-crespo': 'https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_PALERMO.webp',
  'flores': 'https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_BELGRANO.webp',
  'san-telmo': 'https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_RECOLETA.webp',
  'once': 'https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_RECOLETA.webp',
  'microcentro': 'https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_PUERTO-MADERO.webp'
};
const heroBg = barrioImages[slug || ''] || 'https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_BELGRANO.webp';

// Fetch properties in this neighborhood (force locationName filter)
const { properties, total } = await getProperties({
  q,
  location: locationName,
  operation_id: operationId,
  property_type_id: propertyTypeId,
  price_min: priceMin,
  price_max: priceMax,
  currency,
  rooms,
  bedrooms,
  bathrooms,
  garage,
  surface_min: surfaceMin,
  surface_max: surfaceMax,
  amenities
});

// Calculate pagination
const limit = 6; // items per page
const startIndex = (currentPage - 1) * limit;
const endIndex = startIndex + limit;
const paginatedProperties = properties.slice(startIndex, endIndex);
const totalPages = Math.ceil(properties.length / limit) || 1;

// Active chips labels helper
interface ActiveChip {
  key: string;
  value?: string;
  label: string;
}
const activeChips: ActiveChip[] = [];
if (q) activeChips.push({ key: 'q', label: `Búsqueda: "${q}"` });
if (operationId === '1') activeChips.push({ key: 'operation_id', label: 'Venta' });
if (operationId === '2') activeChips.push({ key: 'operation_id', label: 'Alquiler' });
if (propertyTypeId === '2') activeChips.push({ key: 'property_type_id', label: 'Departamento' });
if (propertyTypeId === '3') activeChips.push({ key: 'property_type_id', label: 'Casa' });
if (propertyTypeId === '4') activeChips.push({ key: 'property_type_id', label: 'PH' });
if (propertyTypeId === '7') activeChips.push({ key: 'property_type_id', label: 'Local' });

const isRent = operationId === '2';
const defaultMinPrice = isRent ? '200' : '50000';
const defaultMaxPrice = isRent ? '5000' : '2000000';
const priceSymbol = currency === 'ARS' ? '$' : 'USD';

if (priceMin && priceMin !== defaultMinPrice) activeChips.push({ key: 'price_min', label: `Desde ${priceSymbol} ${new Intl.NumberFormat('es-AR').format(Number(priceMin))}` });
if (priceMax && priceMax !== defaultMaxPrice) activeChips.push({ key: 'price_max', label: `Hasta ${priceSymbol} ${new Intl.NumberFormat('es-AR').format(Number(priceMax))}` });
if (url.searchParams.has('currency')) activeChips.push({ key: 'currency', label: `Moneda: ${currency}` });
if (rooms) activeChips.push({ key: 'rooms', label: `${rooms} Ambientes` });
if (bedrooms) activeChips.push({ key: 'bedrooms', label: `${bedrooms} Dormitorios` });
if (bathrooms) activeChips.push({ key: 'bathrooms', label: `${bathrooms} Baños` });
if (garage) activeChips.push({ key: 'garage', label: `${garage} Cocheras` });
if (surfaceMin) activeChips.push({ key: 'surface_min', label: `Sup. Mín: ${surfaceMin} m²` });
if (surfaceMax) activeChips.push({ key: 'surface_max', label: `Sup. Máx: ${surfaceMax} m²` });

if (Array.isArray(amenities)) {
  amenities.forEach(am => {
    activeChips.push({ key: 'amenities', value: am, label: am });
  });
}

// Helper to generate URLs for sidebar filtering and neighborhood slug switching
function getFilterUrl(params: Record<string, string | null>, targetSlug: string | undefined = undefined) {
  const newUrl = new URL(url);
  
  if (targetSlug !== undefined) {
    if (targetSlug) {
      newUrl.pathname = `/city/${targetSlug}/`;
    } else {
      newUrl.pathname = '/search-results/';
    }
  }
  
  Object.entries(params).forEach(([key, val]) => {
    if (val === null || val === '') {
      newUrl.searchParams.delete(key);
    } else {
      newUrl.searchParams.set(key, val);
    }
  });
  newUrl.searchParams.set('page', '1');
  return newUrl.pathname + newUrl.search;
}

// Local Counts for operation segmented control and property type badges
const localTotalCount = getLocalFilterCount({ operation_id: '' });
const ventaCount = getLocalFilterCount({ operation_id: '1' });
const alquilerCount = getLocalFilterCount({ operation_id: '2' });

const propTypeTotalCount = getLocalFilterCount({ property_type_id: '' });
const deptoCount = getLocalFilterCount({ property_type_id: '2' });
const casaCount = getLocalFilterCount({ property_type_id: '3' });
const phCount = getLocalFilterCount({ property_type_id: '4' });
const localCount = getLocalFilterCount({ property_type_id: '7' });
---

<MainLayout 
  title={`Propiedades en ${locationName} | MUV Propiedades`} 
  description={`Propiedades exclusivas en venta y alquiler en ${locationName}, Buenos Aires. Ingresá para descubrir departamentos y oficinas premium con MUV Propiedades.`} 
  isDarkHero={true}
>
    <!-- Neighborhood Banner Hero -->
    <section class="relative h-[45vh] flex items-center justify-center overflow-hidden">
        <!-- Static background image with Ken Burns animation -->
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-black/55 z-10"></div>
            <img 
              alt={`Propiedades en ${locationName}`} 
              class="w-full h-full object-cover origin-center animate-ken-burns" 
              src={heroBg} 
            />
        </div>
        <!-- Centered Text -->
        <div class="relative z-20 px-margin-mobile md:px-margin-desktop text-center text-pure-white space-y-3">
            <h1 class="font-sans text-[36px] md:text-[54px] font-[300] tracking-tight text-white leading-tight">
                Propiedades en {locationName}
            </h1>
            <div class="w-16 h-[3px] bg-white mx-auto mt-2"></div>
        </div>
    </section>

    <!-- Content Section -->
    <main class="py-16 bg-surface select-none">
        <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
            <!-- Main Split Layout -->
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter items-start">
                
                <!-- Desktop Sidebar Filters -->
                <aside class="hidden lg:block lg:col-span-3 bg-pure-white p-6 border border-outline-variant/30 rounded-lg shadow-sm sticky top-28">
                    <div class="space-y-8 font-sans">
                        <!-- Section 1: Explorar Barrios -->
                        <div class="space-y-4 text-left">
                            <h3 class="font-sans text-[11px] font-[500] text-secondary/80 uppercase tracking-widest border-b border-outline-variant/10 pb-2.5">Explorar Barrios</h3>
                            <nav class="space-y-1.5 flex flex-col">
                                {neighborhoodList.map((item) => {
                                    const isActive = item.slug === slug;
                                    const isDisabled = item.count === 0 && !isActive;
                                    return (
                                        <a 
                                          href={isDisabled ? '#' : getFilterUrl({}, item.slug || '')} 
                                          class={`flex justify-between items-center px-4 py-3 rounded-xl text-sm font-[300] tracking-wide transition-all duration-300 cursor-pointer ${
                                            isActive 
                                              ? 'bg-primary text-pure-white shadow-md hover:opacity-90 font-[500]' 
                                              : isDisabled 
                                                ? 'text-secondary/35 opacity-40 cursor-not-allowed pointer-events-none bg-surface-container-low/20 border border-dashed border-outline-variant/15'
                                                : 'text-secondary hover:bg-surface-container-low hover:text-primary hover:translate-x-1.5'
                                          }`}
                                        >
                                            <span class="flex items-center gap-2">
                                                <span class={`w-1.5 h-1.5 rounded-full transition-all duration-300 ${
                                                    isActive 
                                                      ? 'bg-pure-white scale-125 animate-pulse' 
                                                      : isDisabled
                                                        ? 'bg-secondary/20'
                                                        : 'bg-secondary/45 group-hover:bg-primary'
                                                }`}></span>
                                                {item.name}
                                            </span>
                                            <span class={`text-[11px] px-2.5 py-0.5 rounded-full transition-colors duration-300 ${
                                                isActive 
                                                  ? 'bg-pure-white/25 text-pure-white font-[500]' 
                                                  : isDisabled
                                                    ? 'bg-transparent text-secondary/30'
                                                    : 'bg-surface-container-low text-secondary/70 font-[300]'
                                            }`}>
                                                {item.count}
                                            </span>
                                        </a>
                                    );
                                })}
                            </nav>
                        </div>

                        <!-- Section 2: Tipo de Operación -->
                        <div class="space-y-4 text-left">
                            <h3 class="font-sans text-[11px] font-[500] text-secondary/80 uppercase tracking-widest border-b border-outline-variant/10 pb-2.5">Operación</h3>
                            <div class="grid grid-cols-3 bg-surface-container-low/40 p-1 rounded-xl border border-outline-variant/15 select-none">
                                <a 
                                  href={getFilterUrl({ operation_id: null })} 
                                  class={`px-2 py-2.5 rounded-lg text-[10px] md:text-xs font-[400] text-center uppercase tracking-wider transition-all duration-300 cursor-pointer flex flex-col items-center justify-center ${
                                    !operationId 
                                      ? 'bg-primary text-pure-white shadow-sm font-[500]' 
                                      : 'text-secondary hover:text-primary hover:scale-[1.03]'
                                  }`}
                                >
                                    <span>Todos</span>
                                    <span class={`text-[9px] opacity-75 font-[300] transition-colors ${!operationId ? 'text-white/80' : 'text-secondary/60'}`}>({localTotalCount})</span>
                                </a>
                                <a 
                                  href={ventaCount === 0 && operationId !== '1' ? '#' : getFilterUrl({ operation_id: '1' })} 
                                  class={`px-2 py-2.5 rounded-lg text-[10px] md:text-xs font-[400] text-center uppercase tracking-wider transition-all duration-300 cursor-pointer flex flex-col items-center justify-center ${
                                    operationId === '1' 
                                      ? 'bg-primary text-pure-white shadow-sm font-[500]' 
                                      : ventaCount === 0
                                        ? 'text-secondary/30 opacity-40 cursor-not-allowed pointer-events-none'
                                        : 'text-secondary hover:text-primary hover:scale-[1.03]'
                                  }`}
                                >
                                    <span>Venta</span>
                                    <span class={`text-[9px] opacity-75 font-[300] transition-colors ${operationId === '1' ? 'text-white/80' : 'text-secondary/60'}`}>({ventaCount})</span>
                                </a>
                                <a 
                                  href={alquilerCount === 0 && operationId !== '2' ? '#' : getFilterUrl({ operation_id: '2' })} 
                                  class={`px-2 py-2.5 rounded-lg text-[10px] md:text-xs font-[400] text-center uppercase tracking-wider transition-all duration-300 cursor-pointer flex flex-col items-center justify-center ${
                                    operationId === '2' 
                                      ? 'bg-primary text-pure-white shadow-sm font-[500]' 
                                      : alquilerCount === 0
                                        ? 'text-secondary/30 opacity-40 cursor-not-allowed pointer-events-none'
                                        : 'text-secondary hover:text-primary hover:scale-[1.03]'
                                  }`}
                                >
                                    <span>Alquiler</span>
                                    <span class={`text-[9px] opacity-75 font-[300] transition-colors ${operationId === '2' ? 'text-white/80' : 'text-secondary/60'}`}>({alquilerCount})</span>
                                </a>
                            </div>
                        </div>

                        <!-- Section 3: Tipo de Propiedad -->
                        <div class="space-y-4 text-left">
                            <h3 class="font-sans text-[11px] font-[500] text-secondary/80 uppercase tracking-widest border-b border-outline-variant/10 pb-2.5">Tipo de Propiedad</h3>
                            <div class="flex flex-col gap-1.5 select-none">
                                <a 
                                  href={getFilterUrl({ property_type_id: null })} 
                                  class={`flex items-center justify-between px-4 py-2 rounded-lg text-[11px] font-[400] uppercase tracking-wider transition-all duration-300 cursor-pointer border ${
                                    !propertyTypeId 
                                      ? 'bg-primary border-primary text-pure-white shadow-sm font-[500]' 
                                      : 'bg-pure-white border-outline-variant/25 text-secondary hover:text-primary hover:border-primary/45 hover:translate-x-1'
                                  }`}
                                >
                                    <span>Todos</span>
                                    <div class="flex items-center gap-1.5">
                                        <span class={`text-[10px] px-2 py-0.5 rounded-full ${!propertyTypeId ? 'bg-pure-white/20 text-pure-white font-[500]' : 'bg-surface-container-low text-secondary/70 font-[300]'}`}>{propTypeTotalCount}</span>
                                        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                                    </div>
                                </a>
                                <a 
                                  href={deptoCount === 0 && propertyTypeId !== '2' ? '#' : getFilterUrl({ property_type_id: '2' })} 
                                  class={`flex items-center justify-between px-4 py-2 rounded-lg text-[11px] font-[400] uppercase tracking-wider transition-all duration-300 cursor-pointer border ${
                                    propertyTypeId === '2' 
                                      ? 'bg-primary border-primary text-pure-white shadow-sm font-[500]' 
                                      : deptoCount === 0
                                        ? 'bg-pure-white/20 border-outline-variant/10 text-secondary/30 opacity-40 cursor-not-allowed pointer-events-none'
                                        : 'bg-pure-white border-outline-variant/25 text-secondary hover:text-primary hover:border-primary/45 hover:translate-x-1'
                                  }`}
                                >
                                    <span>Departamento</span>
                                    <div class="flex items-center gap-1.5">
