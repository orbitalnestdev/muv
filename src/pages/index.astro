---
import MainLayout from '../layouts/MainLayout.astro';
import PropertyCard from '../components/PropertyCard.astro';
import { getProperties, getDevelopments } from '../lib/tokko';

// Fetch properties for the featured carousel (starred, max 12 items)
const { properties } = await getProperties();
let starredProperties = properties.filter(p => p.is_starred_on_web).slice(0, 12);
if (starredProperties.length === 0) {
  starredProperties = properties.slice(0, 12);
}

// Fetch developments
const { developments } = await getDevelopments();

// Clean and format developments for homepage carousel matching design requirements
const homeDevelopments = developments.map(d => {
  const devId = Number(d.id);
  
  const configMap: Record<number, { name: string; badges: string[]; showDestacado: boolean; subtitle: string }> = {
    52973: {
      name: "DOME Green Soho",
      badges: ["UNIDAD"],
      showDestacado: true,
      subtitle: "EDIFICIO"
    },
    60364: {
      name: "Cerviño Palermo Boulevard – Palermo Chico",
      badges: ["EMPRENDIMIENTO", "UNIDAD"],
      showDestacado: true,
      subtitle: "EDIFICIO"
    },
    61196: {
      name: "DOME Suites & Residence – Palermo Hollywood",
      badges: ["EMPRENDIMIENTO", "UNIDAD"],
      showDestacado: true,
      subtitle: "EDIFICIO"
    },
    66963: {
      name: "Paz Boulevard – Nuñez",
      badges: ["EMPRENDIMIENTO", "UNIDAD"],
      showDestacado: true,
      subtitle: "EDIFICIO"
    },
    63094: {
      name: "Edificio Gregoria – Colegiales",
      badges: ["EMPRENDIMIENTO", "UNIDAD"],
      showDestacado: false,
      subtitle: "EDIFICIO"
    },
    67299: {
      name: "DOME Torre Arcos – Belgrano",
      badges: ["EMPRENDIMIENTO", "UNIDAD"],
      showDestacado: false,
      subtitle: "EDIFICIO"
    },
    68692: {
      name: "DOME Cabello Residence",
      badges: ["EMPRENDIMIENTO", "UNIDAD"],
      showDestacado: false,
      subtitle: "EDIFICIO"
    },
    69416: {
      name: "DOME Torre Beruti – Palermo",
      badges: ["EMPRENDIMIENTO", "UNIDAD"],
      showDestacado: false,
      subtitle: "EDIFICIO"
    },
    70464: {
      name: "Folium Jufré – Villa Crespo",
      badges: ["EMPRENDIMIENTO", "UNIDAD"],
      showDestacado: false,
      subtitle: "EDIFICIO"
    },
    88523: {
      name: "ViraLoft – Villa Crespo",
      badges: ["EMPRENDIMIENTO", "UNIDAD"],
      showDestacado: false,
      subtitle: "EDIFICIO"
    },
    53879: {
      name: "Cabildo Boulevard 2502",
      badges: ["EMPRENDIMIENTO", "UNIDAD"],
      showDestacado: false,
      subtitle: "EDIFICIO"
    }
  };

  const config = configMap[devId] || {
    name: d.name,
    badges: ["EMPRENDIMIENTO", "UNIDAD"],
    showDestacado: false,
    subtitle: "EDIFICIO"
  };

  return {
    ...d,
    displayName: config.name,
    badges: config.badges,
    showDestacado: config.showDestacado,
    subtitle: config.subtitle
  };
});

// Sort developments to ensure specific ones appear first as in design reference
const orderedDevelopments = [...homeDevelopments].sort((a, b) => {
  const order = [52973, 60364, 61196, 66963]; // Target order of IDs
  const idxA = order.indexOf(Number(a.id));
  const idxB = order.indexOf(Number(b.id));
  
  if (idxA !== -1 && idxB !== -1) return idxA - idxB;
  if (idxA !== -1) return -1;
  if (idxB !== -1) return 1;
  return 0;
});

// Dynamic unique neighborhoods extraction for the hero search form dropdown
const selectBarrios = Array.from(new Set(properties.map(p => p.location?.name?.trim()).filter(Boolean))).sort((a, b) => a.localeCompare(b, 'es'));

// Neighborhood properties counts helper (query catalog counts or fallback to mockup counts)
const normalizeString = (str: string) => str.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();
const getCount = (name: string) => properties.filter(p => p.location?.name && normalizeString(p.location.name).includes(normalizeString(name))).length;

const countRecoleta = getCount('Recoleta') || 13;
const countBelgrano = getCount('Belgrano') || 118;
const countPalermo = getCount('Palermo') || 186;
const countPuertoMadero = getCount('Puerto Madero') || 1;
const countVillaUrquiza = getCount('Villa Urquiza') || 5;
const countColegiales = getCount('Colegiales') || 7;
const countNunez = getCount('Núñez') || 82;

const formatCount = (count: number) => `${count} ${count === 1 ? 'Propiedad' : 'Propiedades'}`;
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "RealEstateAgent",
  "name": "MUV Propiedades",
  "url": "https://muvpropiedades.com",
  "logo": "https://muvpropiedades.com/assets/iso_muv.png",
  "image": "https://muvpropiedades.com/assets/hero2.png",
  "description": "Especialistas en propiedades premium y emprendimientos exclusivos en las mejores zonas de Buenos Aires.",
  "telephone": "+541148054192",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Jerónimo Salguero 2686",
    "addressLocality": "Ciudad Autónoma de Buenos Aires",
    "postalCode": "C1425",
    "addressCountry": "AR"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+541148054192",
    "contactType": "sales",
    "areaServed": "AR",
    "availableLanguage": ["Spanish", "English"]
  },
  "sameAs": [
    "https://www.facebook.com/muvprop",
    "https://www.instagram.com/muvprop"
  ]
};
---

<MainLayout 
  title="MUV Propiedades | Real Estate Premium" 
  description="MUV Propiedades es una inmobiliaria boutique especializada en venta, alquiler y tasación de propiedades exclusivas y emprendimientos premium en Buenos Aires."
  isDarkHero={true}
>
    <!-- Inject Organization Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} slot="head" />
    <link rel="preload" as="image" href="/assets/hero2.webp" slot="head" />
    <main id="home-main" class="w-full">
        <!-- Hero Section -->
    <section class="relative min-h-[90vh] md:h-[85vh] flex items-center justify-center overflow-hidden pt-28 pb-16 md:py-0">
        <!-- Static background image from assets -->
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-black/45 hero-overlay z-10"></div>
            <img 
              alt="MUV Propiedades Hero Background" 
              class="w-full h-full object-cover object-top origin-top animate-ken-burns" 
              src="/assets/hero2.webp" 
            />
        </div>
               <!-- Hero Text and Quick Search -->
        <div class="relative z-20 w-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto text-center text-pure-white space-y-8 animate-fade-up">
            <div class="space-y-3">
                <h1 class="font-sans text-[48px] md:text-[68px] font-[300] tracking-normal text-white lowercase leading-none mb-1">
                    muv propiedades
                </h1>
                <p class="font-sans text-sm md:text-lg font-[300] text-white/95 max-w-5xl mx-auto">
                    Encontrá tu propiedad ideal en los mejores barrios de la ciudad de Buenos Aires.
                </p>
            </div>
            
            <!-- Tabbed Segmented Search Widget (Upgraded to match mockup reference) -->
            <div class="space-y-0 w-full max-w-5xl mx-auto font-sans">
                <!-- Centered Tabs Selector -->
                <div class="flex gap-1 justify-center -mb-[1px] relative z-10 px-4">
                    <button 
                      type="button" 
                      class="tab-btn px-6 py-2.5 rounded-t-xl font-sans text-xs font-bold uppercase tracking-wider transition-all duration-300 bg-pure-white text-primary border-t border-x border-outline-variant/30"
                      data-value="1"
                    >
                        Venta
                    </button>
                    <button 
                      type="button" 
                      class="tab-btn px-6 py-2.5 rounded-t-xl font-sans text-xs font-bold uppercase tracking-wider transition-all duration-300 bg-black/45 text-pure-white hover:bg-black/60 border-t border-x border-transparent"
                      data-value="2"
                    >
                        Alquiler
                    </button>
                    <button 
                      type="button" 
                      class="tab-btn px-6 py-2.5 rounded-t-xl font-sans text-xs font-bold uppercase tracking-wider transition-all duration-300 bg-black/45 text-pure-white hover:bg-black/60 border-t border-x border-transparent"
                      data-value="emprendimientos"
                    >
                        Emprendimientos
                    </button>
                </div>

                <!-- Search Container -->
                <form 
                  id="hero-search-form" 
                  action="/search-results/" 
                  method="GET" 
                  class="w-full bg-pure-white shadow-2xl rounded-3xl md:rounded-full p-2 md:pl-6 md:pr-3 md:py-2.5 border border-outline-variant/25 text-left relative z-25 flex flex-col md:flex-row items-center gap-2"
                >
                    <!-- Hidden inputs for active tab -->
                    <input type="hidden" name="operation_id" id="search-operation-id" value="1" />

                    <div class="flex-1 w-full grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-outline-variant/20">
                        <!-- Segment 1: Tipo de propiedad -->
                        <div id="segment-prop-type" class="px-6 py-2 flex flex-col items-start justify-center group relative hover:bg-slate-50 transition-colors duration-300 md:rounded-l-full">
                            <span class="text-[#747878] font-sans font-[600] text-[9.5px] uppercase tracking-widest block mb-0.5">Tipo</span>
                            <div class="relative w-full flex items-center">
                                <select 
                                  name="property_type_id" 
                                  id="search-prop-type" 
                                  aria-label="Tipo de propiedad"
                                  class="w-full bg-transparent border-0 text-[#191c1d] text-sm font-[600] focus:ring-0 focus:outline-none py-0.5 appearance-none cursor-pointer pr-6 font-sans !bg-none"
                                >
                                    <option value="">Tipo de propiedad</option>
                                    <option value="2">Departamento</option>
                                    <option value="3">Casa</option>
                                    <option value="13">PH</option>
                                    <option value="7">Local</option>
                                </select>
                                <span class="material-symbols-outlined text-[16px] text-[#747878] absolute right-0 pointer-events-none transition-transform group-hover:scale-110 duration-300">unfold_more</span>
                            </div>
                        </div>

                        <!-- Segment 2: Todos los barrios -->
                        <div class="px-6 py-2 flex flex-col items-start justify-center group relative hover:bg-slate-50 transition-colors duration-300">
                            <span class="text-[#747878] font-sans font-[600] text-[9.5px] uppercase tracking-widest block mb-0.5">Barrio</span>
                            <div class="relative w-full flex items-center">
                                <select 
                                  name="location" 
                                  id="search-location" 
                                  aria-label="Barrio"
                                  class="w-full bg-transparent border-0 text-[#191c1d] text-sm font-[600] focus:ring-0 focus:outline-none py-0.5 appearance-none cursor-pointer pr-6 font-sans !bg-none"
                                >
                                    <option value="">Todos los barrios</option>
                                    {selectBarrios.map(barrio => (
                                        <option value={barrio}>{barrio}</option>
                                    ))}
                                </select>
                                <span class="material-symbols-outlined text-[16px] text-[#747878] absolute right-0 pointer-events-none transition-transform group-hover:scale-110 duration-300">unfold_more</span>
                            </div>
                        </div>

                        <!-- Segment 3: Palabra Clave / Búsqueda -->
                        <div class="px-6 py-2 flex flex-col items-start justify-center hover:bg-slate-50 transition-colors duration-300 md:rounded-r-full">
                            <span class="text-[#747878] font-sans font-[600] text-[9.5px] uppercase tracking-widest block mb-0.5">Búsqueda</span>
                            <input 
                              type="text" 
                              id="search-keyword" 
                              name="q"
                              placeholder="¿Qué estás buscando?" 
                              class="w-full bg-transparent border-0 text-[#191c1d] text-sm font-[600] placeholder:text-[#858383]/60 focus:ring-0 focus:outline-none py-0.5 font-sans"
                            />
                        </div>
                    </div>

                    <!-- Segment 4: Buscar button -->
                    <div class="w-full md:w-auto p-0.5 flex-shrink-0">
                        <button 
                          type="submit" 
                          class="w-full md:w-auto bg-primary text-pure-white hover:bg-black/90 hover:text-pure-white px-8 py-3.5 rounded-full transition-all duration-300 font-sans text-xs font-bold uppercase tracking-wider text-center shadow-md hover:scale-[1.02] active:scale-[0.98] flex items-center justify-center gap-2"
                        >
                            <span class="material-symbols-outlined text-[16px]">search</span>
                            <span>Buscar</span>
                        </button>
                    </div>
                </form>

                <!-- Advanced Filters Toggle & Reset -->
                <div class="flex justify-between items-center mt-4 px-6 select-none relative z-20">
                    <button 
                      type="button" 
                      id="btn-toggle-filters" 
                      class="flex items-center gap-2 text-pure-white/85 font-semibold hover:text-pure-white transition-colors text-xs font-sans focus:outline-none cursor-pointer bg-[#121212]/35 hover:bg-[#121212]/55 backdrop-blur-md px-4 py-2 rounded-full border border-white/10"
                    >
                        <span class="material-symbols-outlined text-[18px]">tune</span>
                        <span>Filtros Avanzados</span>
                    </button>
                    <button 
                      type="button" 
                      id="btn-reset-filters" 
                      class="text-error hover:text-error/85 font-semibold transition-colors text-xs font-sans focus:outline-none hidden cursor-pointer bg-[#121212]/35 hover:bg-[#121212]/55 backdrop-blur-md px-4 py-2 rounded-full border border-white/10"
                    >
                        Limpiar Filtros
                    </button>
                </div>

                <!-- Advanced Filters Panel (Collapsible slide-down) -->
                <div 
                  id="advanced-filters-panel" 
                  class="max-h-0 overflow-hidden transition-all duration-300 ease-in-out text-left mt-3 relative z-20"
                  style="max-height: 0px;"
                >
                    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-4 p-5 bg-pure-white shadow-2xl rounded-2xl border border-outline-variant/20 font-sans">
                        <!-- Precio Min -->
                        <div class="flex flex-col space-y-1">
                            <label class="text-[#747878] font-bold text-[9px] uppercase tracking-wider">Precio Mínimo</label>
                            <input 
                              type="number" 
                              name="price_min" 
                              id="filter-price-min" 
                              placeholder="Sin mínimo" 
                              class="border border-outline-variant/35 bg-pure-white rounded-lg p-2 focus:ring-1 focus:ring-primary focus:border-primary outline-none text-xs text-primary placeholder:text-outline/40 font-semibold"
                            />
                        </div>
                        <!-- Precio Max -->
                        <div class="flex flex-col space-y-1">
                            <label class="text-[#747878] font-bold text-[9px] uppercase tracking-wider">Precio Máximo</label>
                            <input 
                              type="number" 
                              name="price_max" 
                              id="filter-price-max" 
                              placeholder="Sin máximo" 
                              class="border border-outline-variant/35 bg-pure-white rounded-lg p-2 focus:ring-1 focus:ring-primary focus:border-primary outline-none text-xs text-primary placeholder:text-outline/40 font-semibold"
                            />
                        </div>
                        <!-- Moneda -->
                        <div class="flex flex-col space-y-1">
                            <label class="text-[#747878] font-bold text-[9px] uppercase tracking-wider">Moneda</label>
                            <select 
                              name="currency" 
                              id="filter-currency" 
                              aria-label="Moneda"
                              class="border border-outline-variant/35 bg-pure-white rounded-lg p-2 focus:ring-1 focus:ring-primary focus:border-primary outline-none text-xs text-primary cursor-pointer font-bold"
                            >
                                <option value="USD">USD</option>
                                <option value="ARS">ARS</option>
                            </select>
                        </div>
                        <!-- Ambientes -->
                        <div class="flex flex-col space-y-1">
                            <label class="text-[#747878] font-bold text-[9px] uppercase tracking-wider">Ambientes</label>
                            <select 
                              name="rooms" 
                              id="filter-rooms" 
                              aria-label="Ambientes"
                              class="border border-outline-variant/35 bg-pure-white rounded-lg p-2 focus:ring-1 focus:ring-primary focus:border-primary outline-none text-xs text-primary cursor-pointer font-bold"
                            >
                                <option value="">Cualquiera</option>
                                <option value="1">1 Ambiente</option>
                                <option value="2">2 Ambientes</option>
                                <option value="3">3 Ambientes</option>
                                <option value="4">4+ Ambientes</option>
                            </select>
                        </div>
                        <!-- Dormitorios -->
                        <div class="flex flex-col space-y-1">
                            <label class="text-[#747878] font-bold text-[9px] uppercase tracking-wider">Dormitorios</label>
                            <select 
                              name="bedrooms" 
                              id="filter-bedrooms" 
                              aria-label="Dormitorios"
                              class="border border-outline-variant/35 bg-pure-white rounded-lg p-2 focus:ring-1 focus:ring-primary focus:border-primary outline-none text-xs text-primary cursor-pointer font-bold"
                            >
                                <option value="">Cualquiera</option>
                                <option value="1">1 Dormitorio</option>
                                <option value="2">2 Dormitorios</option>
                                <option value="3">3 Dormitorios</option>
                                <option value="4">4+ Dormitorios</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Scroll indicator -->
        <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center pointer-events-none select-none opacity-80 animate-fade-in delay-700">
            <span class="text-[10px] font-sans font-[300] tracking-[0.2em] uppercase text-white/50 mb-2">Scroll</span>
            <div class="w-5 h-9 border border-white/30 rounded-full flex justify-center py-1.5">
                <div class="w-1.5 h-1.5 bg-primary rounded-full animate-scroll-wheel"></div>
            </div>
        </div>
    </section>

    <!-- Destacados Horizontal Carousel Section -->
    <section class="py-24 bg-surface relative overflow-hidden reveal">
        <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto flex justify-between items-end mb-12">
            <div class="space-y-3">
                <h2 class="font-sans font-[300] md:text-[35px] text-2xl text-primary leading-none">Propiedades Destacadas</h2>
            </div>
            <!-- Carousel Control Arrows -->
            <div class="flex gap-4">
                <button 
                  id="carousel-prev" 
                  class="w-11 h-11 rounded-full border border-outline-variant/60 text-primary flex items-center justify-center hover:bg-primary hover:text-pure-white transition-all active:scale-95 shadow-sm"
                  aria-label="Anterior destacado"
                >
                    <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                </button>
                <button 
                  id="carousel-next" 
                  class="w-11 h-11 rounded-full border border-outline-variant/60 text-primary flex items-center justify-center hover:bg-primary hover:text-pure-white transition-all active:scale-95 shadow-sm"
                  aria-label="Siguiente destacado"
                >
                    <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                </button>
            </div>
        </div>

        <!-- Horizontal Scroll Container -->
        <div class="w-full overflow-x-auto scroll-smooth scrollbar-hide px-margin-mobile md:px-margin-desktop flex gap-8 pb-8 snap-x snap-mandatory" id="property-carousel-container">
            {starredProperties.map((prop) => (
                <div class="min-w-[280px] md:min-w-[380px] max-w-[400px] snap-start snap-always flex-shrink-0">
                    <PropertyCard property={prop} />
                </div>
            ))}
        </div>
    </section>

    <!-- Residenciales Neighborhood Bento Grid Section -->
    <section class="py-24 bg-surface-container-low/30 relative overflow-hidden reveal">
        <!-- Large Monogram Watermark Image on the bottom-right background (Matches reference screenshot) -->
        <div class="absolute right-0 bottom-0 pointer-events-none select-none z-0 w-[70%] max-w-[600px] opacity-[0.06] block">
            <img src="/assets/iso_muv.png" alt="MUV Propiedades Logotipo Monograma de Marca" class="w-full h-auto brightness-0" />
        </div>

        <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto relative z-10">
            <div class="grid grid-cols-2 md:grid-cols-3 gap-6 items-stretch">
                <!-- Cell 1: Heading Description Block -->
                <div class="col-span-2 md:col-span-1 flex flex-col justify-center gap-4 py-6 text-left pr-4">
                    <h2 class="font-sans font-[300] md:text-[35px] text-2xl text-primary leading-tight">Residenciales</h2>
                    <div class="w-12 h-[3px] bg-[#121212]"></div>
                    <p class="font-body-md text-secondary leading-relaxed text-sm">
                        Encontrá tu propiedad ideal en los mejores barrios de la ciudad de Buenos Aires.
                    </p>
                </div>

                <!-- Cell 2: Belgrano (Tall, spans 2 rows on desktop) -->
                <a href="/city/belgrano/" class="group relative overflow-hidden rounded-lg cursor-pointer col-span-2 md:col-span-1 md:row-span-2 min-h-[300px] md:h-auto flex flex-col justify-between p-6 shadow-sm">
                    <img class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 -z-10" src="https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_BELGRANO.webp" alt="Propiedades exclusivas en venta y alquiler en barrio Belgrano, CABA" loading="lazy" decoding="async" />
                    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/85 -z-10"></div>
                    
                    <div class="text-left text-pure-white">
                        <span class="text-[11px] font-sans text-white/80 block mb-1 font-semibold tracking-wider">{formatCount(countBelgrano)}</span>
                        <h3 class="font-headline-md text-xl font-bold leading-none">Belgrano</h3>
                    </div>
                    <div class="flex justify-between items-center text-pure-white pt-4">
                        <span class="text-[10px] tracking-widest font-bold font-sans">VER PROPIEDADES</span>
                        <div class="w-8 h-8 rounded-full border border-white/30 flex items-center justify-center group-hover:bg-black group-hover:border-black group-hover:text-pure-white transition-all">
                             <span class="material-symbols-outlined text-[16px] text-white">arrow_forward</span>
                        </div>
                    </div>
                </a>

                <!-- Cell 3: Palermo -->
                <a href="/city/palermo/" class="group relative overflow-hidden rounded-lg cursor-pointer h-[240px] flex flex-col justify-between p-6 shadow-sm">
                    <img class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 -z-10" src="https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_PALERMO.webp" alt="Casas y departamentos en Palermo, Buenos Aires" loading="lazy" decoding="async" />
                    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/85 -z-10"></div>
                    
                    <div class="text-left text-pure-white">
                        <span class="text-[11px] font-sans text-white/80 block mb-1 font-semibold tracking-wider">{formatCount(countPalermo)}</span>
                        <h3 class="font-headline-md text-xl font-bold leading-none">Palermo</h3>
                    </div>
                    <div class="flex justify-between items-center text-pure-white pt-4">
                        <span class="text-[10px] tracking-widest font-bold font-sans">VER PROPIEDADES</span>
                        <div class="w-8 h-8 rounded-full border border-white/30 flex items-center justify-center group-hover:bg-black group-hover:border-black group-hover:text-pure-white transition-all">
                            <span class="material-symbols-outlined text-[16px] text-white">arrow_forward</span>
                        </div>
                    </div>
                </a>

                <!-- Cell 4: Recoleta -->
                <a href="/city/recoleta/" class="group relative overflow-hidden rounded-lg cursor-pointer h-[240px] flex flex-col justify-between p-6 shadow-sm">
