---
import MainLayout from '../layouts/MainLayout.astro';
import PropertyCard from '../components/PropertyCard.astro';
import { getProperties } from '../lib/tokko';

// Fetch properties for the featured carousel (starred, max 12 items)
const { properties } = await getProperties();
let starredProperties = properties.filter(p => p.is_starred_on_web).slice(0, 12);
if (starredProperties.length === 0) {
  starredProperties = properties.slice(0, 12);
}

// Neighborhood properties counts helper (query catalog counts or fallback to mockup counts)
const getCount = (name: string) => properties.filter(p => p.location?.name?.toLowerCase().includes(name.toLowerCase())).length;

const countRecoleta = getCount('Recoleta') || 13;
const countBelgrano = getCount('Belgrano') || 118;
const countPalermo = getCount('Palermo') || 186;
const countPuertoMadero = getCount('Puerto Madero') || 1;
const countVillaUrquiza = getCount('Villa Urquiza') || 5;
const countColegiales = getCount('Colegiales') || 7;
const countNunez = getCount('Núñez') || 82;

const formatCount = (count: number) => `${count} ${count === 1 ? 'Propiedad' : 'Propiedades'}`;
---

<MainLayout title="MUV Propiedades | Real Estate Premium" isDarkHero={true}>
    <!-- Hero Section -->
    <section class="relative h-[85vh] md:h-screen flex items-center justify-center overflow-hidden">
        <!-- Static background image from assets -->
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-black/45 hero-overlay z-10"></div>
            <img 
              alt="MUV Propiedades Hero Background" 
              class="w-full h-full object-cover animate-ken-burns" 
              src="/assets/hero.webp" 
            />
        </div>
        
        <!-- Hero Text and Quick Search -->
        <div class="relative z-20 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto text-center text-pure-white space-y-8 animate-fade-up">
            <div class="space-y-4">
                <span class="text-refined-gold font-label-lg uppercase tracking-[0.25em] text-xs">Exclusividad & Confianza</span>
                <h1 class="font-display-lg text-4xl md:text-6xl text-pure-white leading-tight font-semibold tracking-tight">
                    Encontrá tu próximo hogar
                </h1>
            </div>
            
            <!-- Tabbed Segmented Search Widget (Upgraded to match mockup reference) -->
            <div class="space-y-0 max-w-5xl mx-auto font-sans">
                <!-- Left-Aligned Tabs Selector -->
                <div class="flex gap-1 justify-center md:justify-start -mb-[1px] relative z-10 px-4">
                    <button 
                      type="button" 
                      class="tab-btn px-6 py-2.5 rounded-t-xl font-headline text-xs font-bold uppercase tracking-wider transition-all duration-300 bg-pure-white text-primary border-t border-x border-outline-variant/30"
                      data-value="1"
                    >
                        Comprar
                    </button>
                    <button 
                      type="button" 
                      class="tab-btn px-6 py-2.5 rounded-t-xl font-headline text-xs font-bold uppercase tracking-wider transition-all duration-300 bg-black/45 text-pure-white hover:bg-black/60 border-t border-x border-transparent"
                      data-value="2"
                    >
                        Alquilar
                    </button>
                </div>

                <!-- Search Container -->
                <form 
                  id="hero-search-form" 
                  action="/buscar/" 
                  method="GET" 
                  class="bg-pure-white shadow-2xl rounded-2xl rounded-tl-none p-4 md:px-6 md:py-4 border border-outline-variant/25 text-left relative z-25"
                >
                    <!-- Hidden inputs for active tab -->
                    <input type="hidden" name="operation_id" id="search-operation-id" value="1" />

                    <div class="flex flex-col md:flex-row items-center gap-3">
                        <div class="flex-1 w-full grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-outline-variant/30">
                            <!-- Segment 1: Tipo de propiedad -->
                            <div id="segment-prop-type" class="px-6 py-3.5 flex flex-col items-start text-left justify-center group relative hover:bg-slate-50 transition-colors duration-300">
                                <span class="text-[#747878] font-label-sm uppercase tracking-widest text-[9.5px] font-bold block mb-1">Tipo</span>
                                <div class="relative w-full flex items-center">
                                    <select 
                                      name="property_type_id" 
                                      id="search-prop-type" 
                                      aria-label="Tipo de propiedad"
                                      class="w-full bg-transparent border-0 text-[#191c1d] text-sm font-bold focus:ring-0 focus:outline-none py-1 appearance-none cursor-pointer pr-6 font-sans !bg-none"
                                    >
                                        <option value="">Cualquier tipo</option>
                                        <option value="2">Departamento</option>
                                        <option value="3">Casa</option>
                                        <option value="4">PH</option>
                                        <option value="7">Local</option>
                                    </select>
                                    <span class="material-symbols-outlined text-[18px] text-refined-gold absolute right-0 pointer-events-none transition-transform group-hover:scale-110 duration-300">unfold_more</span>
                                </div>
                            </div>

                            <!-- Segment 2: Todos los barrios -->
                            <div class="px-6 py-3.5 flex flex-col items-start text-left justify-center group relative hover:bg-slate-50 transition-colors duration-300">
                                <span class="text-[#747878] font-label-sm uppercase tracking-widest text-[9.5px] font-bold block mb-1">Barrio</span>
                                <div class="relative w-full flex items-center">
                                    <select 
                                      name="location" 
                                      id="search-location" 
                                      aria-label="Barrio"
                                      class="w-full bg-transparent border-0 text-[#191c1d] text-sm font-bold focus:ring-0 focus:outline-none py-1 appearance-none cursor-pointer pr-6 font-sans !bg-none"
                                    >
                                        <option value="">Todos los barrios</option>
                                        <option value="Belgrano">Belgrano</option>
                                        <option value="Palermo">Palermo</option>
                                        <option value="Recoleta">Recoleta</option>
                                        <option value="Colegiales">Colegiales</option>
                                        <option value="Núñez">Núñez</option>
                                        <option value="Puerto Madero">Puerto Madero</option>
                                        <option value="Villa Urquiza">Villa Urquiza</option>
                                    </select>
                                    <span class="material-symbols-outlined text-[18px] text-refined-gold absolute right-0 pointer-events-none transition-transform group-hover:scale-110 duration-300">unfold_more</span>
                                </div>
                            </div>

                            <!-- Segment 3: Palabra Clave -->
                            <div class="px-6 py-3.5 flex flex-col items-start text-left justify-center hover:bg-slate-50 transition-colors duration-300">
                                <span class="text-[#747878] font-label-sm uppercase tracking-widest text-[9.5px] font-bold block mb-1">Palabra clave</span>
                                <input 
                                  type="text" 
                                  id="search-keyword" 
                                  name="q"
                                  placeholder="Ej: balcón, cochera..." 
                                  class="w-full bg-transparent border-0 text-[#191c1d] text-sm font-bold placeholder:text-[#858383]/60 focus:ring-0 focus:outline-none py-1 font-sans"
                                />
                            </div>
                        </div>

                        <!-- Segment 4: Buscar button -->
                        <div class="w-full md:w-auto p-1 flex-shrink-0">
                            <button 
                              type="submit" 
                              class="w-full md:w-auto bg-primary text-pure-white hover:bg-refined-gold hover:text-primary px-10 py-4 rounded-xl transition-all duration-300 font-headline text-xs font-bold uppercase tracking-wider text-center shadow-md hover:scale-[1.02] active:scale-[0.98] flex items-center justify-center gap-2"
                            >
                                <span class="material-symbols-outlined text-[18px]">search</span>
                                <span>Buscar</span>
                            </button>
                        </div>
                    </div>

                    <!-- Advanced Filters Toggle & Reset -->
                    <div class="flex justify-between items-center mt-3 px-4 pt-3 border-t border-outline-variant/15 select-none">
                        <button 
                          type="button" 
                          id="btn-toggle-filters" 
                          class="flex items-center gap-2 text-secondary font-semibold hover:text-primary transition-colors text-xs font-sans focus:outline-none cursor-pointer"
                        >
                            <span class="material-symbols-outlined text-[18px]">tune</span>
                            <span>Filtros Avanzados</span>
                        </button>
                        <button 
                          type="button" 
                          id="btn-reset-filters" 
                          class="text-error hover:text-error/80 font-semibold transition-colors text-xs font-sans focus:outline-none hidden cursor-pointer"
                        >
                            Limpiar Filtros
                        </button>
                    </div>

                    <!-- Advanced Filters Panel (Collapsible slide-down) -->
                    <div 
                      id="advanced-filters-panel" 
                      class="max-h-0 overflow-hidden transition-all duration-300 ease-in-out text-left"
                      style="max-height: 0px;"
                    >
                        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 p-5 mt-3 border-t border-outline-variant/15 bg-[#F8F9FA]/60 rounded-xl font-sans">
                            <!-- Precio Min -->
                            <div class="flex flex-col space-y-1">
                                <label class="text-[#747878] font-bold text-[9px] uppercase tracking-wider">Precio Mínimo (USD)</label>
                                <input 
                                  type="number" 
                                  name="price_min" 
                                  id="filter-price-min" 
                                  placeholder="Sin mínimo" 
                                  class="border border-outline-variant/35 bg-pure-white rounded-lg p-2 focus:ring-1 focus:ring-refined-gold focus:border-refined-gold outline-none text-xs text-primary placeholder:text-outline/40"
                                />
                            </div>
                            <!-- Precio Max -->
                            <div class="flex flex-col space-y-1">
                                <label class="text-[#747878] font-bold text-[9px] uppercase tracking-wider">Precio Máximo (USD)</label>
                                <input 
                                  type="number" 
                                  name="price_max" 
                                  id="filter-price-max" 
                                  placeholder="Sin máximo" 
                                  class="border border-outline-variant/35 bg-pure-white rounded-lg p-2 focus:ring-1 focus:ring-refined-gold focus:border-refined-gold outline-none text-xs text-primary placeholder:text-outline/40"
                                />
                            </div>
                            <!-- Ambientes -->
                            <div class="flex flex-col space-y-1">
                                <label class="text-[#747878] font-bold text-[9px] uppercase tracking-wider">Ambientes</label>
                                <select 
                                  name="rooms" 
                                  id="filter-rooms" 
                                  aria-label="Ambientes"
                                  class="border border-outline-variant/35 bg-pure-white rounded-lg p-2 focus:ring-1 focus:ring-refined-gold focus:border-refined-gold outline-none text-xs text-primary cursor-pointer"
                                >
                                    <option value="">Cualquiera</option>
                                    <option value="1">1 Ambiente</option>
                                    <option value="2">2 Ambientes</option>
                                    <option value="3">3 Ambientes</option>
                                    <option value="4">4+ Ambientes</option>
                                </select>
                            </div>
                            <!-- Dormitorios -->
                            <div class="flex flex-col space-y-1">
                                <label class="text-[#747878] font-bold text-[9px] uppercase tracking-wider">Dormitorios</label>
                                <select 
                                  name="bedrooms" 
                                  id="filter-bedrooms" 
                                  aria-label="Dormitorios"
                                  class="border border-outline-variant/35 bg-pure-white rounded-lg p-2 focus:ring-1 focus:ring-refined-gold focus:border-refined-gold outline-none text-xs text-primary cursor-pointer"
                                >
                                    <option value="">Cualquiera</option>
                                    <option value="1">1 Dormitorio</option>
                                    <option value="2">2 Dormitorios</option>
                                    <option value="3">3 Dormitorios</option>
                                    <option value="4">4+ Dormitorios</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </section>

    <!-- Destacados Horizontal Carousel Section -->
    <section class="py-24 bg-surface relative overflow-hidden">
        <div class="px-margin-desktop max-w-container-max mx-auto flex justify-between items-end mb-12">
            <div class="space-y-3">
                <h2 class="font-headline-xl text-headline-xl text-primary leading-none">Propiedades Destacadas</h2>
            </div>
            <!-- Carousel Control Arrows -->
            <div class="flex gap-4">
                <button 
                  id="carousel-prev" 
                  class="w-11 h-11 rounded-full border border-outline-variant/60 text-primary flex items-center justify-center hover:bg-primary hover:text-pure-white transition-all active:scale-95 shadow-sm"
                  aria-label="Anterior destacado"
                >
                    <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                </button>
                <button 
                  id="carousel-next" 
                  class="w-11 h-11 rounded-full border border-outline-variant/60 text-primary flex items-center justify-center hover:bg-primary hover:text-pure-white transition-all active:scale-95 shadow-sm"
                  aria-label="Siguiente destacado"
                >
                    <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                </button>
            </div>
        </div>

        <!-- Horizontal Scroll Container -->
        <div class="w-full overflow-x-auto scroll-smooth scrollbar-hide px-margin-desktop flex gap-8 pb-8 snap-x snap-mandatory" id="property-carousel-container">
            {starredProperties.map((prop) => (
                <div class="min-w-[280px] md:min-w-[380px] max-w-[400px] snap-start snap-always flex-shrink-0">
                    <PropertyCard property={prop} />
                </div>
            ))}
        </div>
    </section>

    <!-- Residenciales Neighborhood Bento Grid Section -->
    <section class="py-24 bg-surface-container-low/30 relative overflow-hidden">
        <!-- Large Monogram Watermark Image on the bottom-right background (Matches reference screenshot) -->
        <div class="absolute right-0 bottom-0 pointer-events-none select-none z-0 w-[70%] max-w-[600px] opacity-[0.06] block">
            <img src="/assets/iso_muv.png" alt="M Monogram Watermark" class="w-full h-auto brightness-0" />
        </div>

        <div class="px-margin-desktop max-w-container-max mx-auto relative z-10">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">
                <!-- Cell 1: Heading Description Block -->
                <div class="flex flex-col justify-center gap-4 py-6 text-left pr-4">
                    <h2 class="font-headline-xl text-[36px] text-primary font-bold leading-tight">Residenciales</h2>
                    <div class="w-12 h-[3px] bg-refined-gold"></div>
                    <p class="font-body-md text-secondary leading-relaxed text-sm">
                        Encontrá tu propiedad ideal en los mejores barrios de la ciudad de Buenos Aires.
                    </p>
                </div>

                <!-- Cell 2: Belgrano (Tall, spans 2 rows on desktop) -->
                <a href="/buscar/?q=Belgrano" class="group relative overflow-hidden rounded-lg cursor-pointer md:row-span-2 min-h-[350px] md:h-auto flex flex-col justify-between p-6 shadow-sm">
                    <img class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 -z-10" src="https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_BELGRANO.webp" alt="Belgrano" loading="lazy" decoding="async" />
                    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/85 -z-10"></div>
                    
                    <div class="text-left text-pure-white">
                        <span class="text-[11px] font-sans text-white/80 block mb-1 font-semibold tracking-wider">{formatCount(countBelgrano)}</span>
                        <h3 class="font-headline-md text-xl font-bold leading-none">Belgrano</h3>
                    </div>
                    <div class="flex justify-between items-center text-pure-white pt-4">
                        <span class="text-[10px] tracking-widest font-bold font-sans">VER PROPIEDADES</span>
                        <div class="w-8 h-8 rounded-full border border-white/30 flex items-center justify-center group-hover:bg-refined-gold group-hover:border-refined-gold group-hover:text-primary transition-all">
                            <span class="material-symbols-outlined text-[16px] text-white">arrow_forward</span>
                        </div>
                    </div>
                </a>

                <!-- Cell 3: Palermo -->
                <a href="/buscar/?q=Palermo" class="group relative overflow-hidden rounded-lg cursor-pointer h-[240px] flex flex-col justify-between p-6 shadow-sm">
                    <img class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 -z-10" src="https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_PALERMO.webp" alt="Palermo" loading="lazy" decoding="async" />
                    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/85 -z-10"></div>
                    
                    <div class="text-left text-pure-white">
                        <span class="text-[11px] font-sans text-white/80 block mb-1 font-semibold tracking-wider">{formatCount(countPalermo)}</span>
                        <h3 class="font-headline-md text-xl font-bold leading-none">Palermo</h3>
                    </div>
                    <div class="flex justify-between items-center text-pure-white pt-4">
                        <span class="text-[10px] tracking-widest font-bold font-sans">VER PROPIEDADES</span>
                        <div class="w-8 h-8 rounded-full border border-white/30 flex items-center justify-center group-hover:bg-refined-gold group-hover:border-refined-gold group-hover:text-primary transition-all">
                            <span class="material-symbols-outlined text-[16px] text-white">arrow_forward</span>
                        </div>
                    </div>
                </a>

                <!-- Cell 4: Recoleta -->
                <a href="/buscar/?q=Recoleta" class="group relative overflow-hidden rounded-lg cursor-pointer h-[240px] flex flex-col justify-between p-6 shadow-sm">
                    <img class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 -z-10" src="https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_RECOLETA.webp" alt="Recoleta" loading="lazy" decoding="async" />
                    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/85 -z-10"></div>
                    
                    <div class="text-left text-pure-white">
                        <span class="text-[11px] font-sans text-white/80 block mb-1 font-semibold tracking-wider">{formatCount(countRecoleta)}</span>
                        <h3 class="font-headline-md text-xl font-bold leading-none">Recoleta</h3>
                    </div>
                    <div class="flex justify-between items-center text-pure-white pt-4">
                        <span class="text-[10px] tracking-widest font-bold font-sans">VER PROPIEDADES</span>
                        <div class="w-8 h-8 rounded-full border border-white/30 flex items-center justify-center group-hover:bg-refined-gold group-hover:border-refined-gold group-hover:text-primary transition-all">
                            <span class="material-symbols-outlined text-[16px] text-white">arrow_forward</span>
                        </div>
                    </div>
                </a>

                <!-- Cell 5: Puerto Madero -->
                <a href="/buscar/?q=Puerto%20Madero" class="group relative overflow-hidden rounded-lg cursor-pointer h-[240px] flex flex-col justify-between p-6 shadow-sm">
                    <img class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 -z-10" src="https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_PUERTO-MADERO.webp" alt="Puerto Madero" loading="lazy" decoding="async" />
                    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/85 -z-10"></div>
                    
                    <div class="text-left text-pure-white">
                        <span class="text-[11px] font-sans text-white/80 block mb-1 font-semibold tracking-wider">{formatCount(countPuertoMadero)}</span>
                        <h3 class="font-headline-md text-xl font-bold leading-none">Puerto Madero</h3>
                    </div>
                    <div class="flex justify-between items-center text-pure-white pt-4">
                        <span class="text-[10px] tracking-widest font-bold font-sans">VER PROPIEDADES</span>
                        <div class="w-8 h-8 rounded-full border border-white/30 flex items-center justify-center group-hover:bg-refined-gold group-hover:border-refined-gold group-hover:text-primary transition-all">
                            <span class="material-symbols-outlined text-[16px] text-white">arrow_forward</span>
                        </div>
                    </div>
                </a>

                <!-- Cell 6: Villa Urquiza -->
                <a href="/buscar/?q=Villa%20Urquiza" class="group relative overflow-hidden rounded-lg cursor-pointer h-[240px] flex flex-col justify-between p-6 shadow-sm">
                    <img class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 -z-10" src="https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_VILLA-URQUIZA.webp" alt="Villa Urquiza" loading="lazy" decoding="async" />
                    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/85 -z-10"></div>
                    
                    <div class="text-left text-pure-white">
                        <span class="text-[11px] font-sans text-white/80 block mb-1 font-semibold tracking-wider">{formatCount(countVillaUrquiza)}</span>
                        <h3 class="font-headline-md text-xl font-bold leading-none">Villa Urquiza</h3>
                    </div>
                    <div class="flex justify-between items-center text-pure-white pt-4">
                        <span class="text-[10px] tracking-widest font-bold font-sans">VER PROPIEDADES</span>
                        <div class="w-8 h-8 rounded-full border border-white/30 flex items-center justify-center group-hover:bg-refined-gold group-hover:border-refined-gold group-hover:text-primary transition-all">
                            <span class="material-symbols-outlined text-[16px] text-white">arrow_forward</span>
                        </div>
                    </div>
                </a>

                <!-- Cell 7: Colegiales -->
                <a href="/buscar/?q=Colegiales" class="group relative overflow-hidden rounded-lg cursor-pointer h-[240px] flex flex-col justify-between p-6 shadow-sm">
                    <img class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 -z-10" src="https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_COLEGIALES.webp" alt="Colegiales" loading="lazy" decoding="async" />
                    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/85 -z-10"></div>
                    
                    <div class="text-left text-pure-white">
                        <span class="text-[11px] font-sans text-white/80 block mb-1 font-semibold tracking-wider">{formatCount(countColegiales)}</span>
                        <h3 class="font-headline-md text-xl font-bold leading-none">Colegiales</h3>
                    </div>
                    <div class="flex justify-between items-center text-pure-white pt-4">
                        <span class="text-[10px] tracking-widest font-bold font-sans">VER PROPIEDADES</span>
                        <div class="w-8 h-8 rounded-full border border-white/30 flex items-center justify-center group-hover:bg-refined-gold group-hover:border-refined-gold group-hover:text-primary transition-all">
                            <span class="material-symbols-outlined text-[16px] text-white">arrow_forward</span>
                        </div>
                    </div>
                </a>

                <!-- Cell 8: Núñez -->
                <a href="/buscar/?q=Núñez" class="group relative overflow-hidden rounded-lg cursor-pointer h-[240px] flex flex-col justify-between p-6 shadow-sm">
                    <img class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 -z-10" src="https://muvpropiedades.com/wp-content/uploads/2025/12/MUV-WEB_NUNEZ-1.webp" alt="Núñez" loading="lazy" decoding="async" />
                    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/85 -z-10"></div>
                    
                    <div class="text-left text-pure-white">
                        <span class="text-[11px] font-sans text-white/80 block mb-1 font-semibold tracking-wider">{formatCount(countNunez)}</span>
                        <h3 class="font-headline-md text-xl font-bold leading-none">Núñez</h3>
                    </div>
                    <div class="flex justify-between items-center text-pure-white pt-4">
                        <span class="text-[10px] tracking-widest font-bold font-sans">VER PROPIEDADES</span>
                        <div class="w-8 h-8 rounded-full border border-white/30 flex items-center justify-center group-hover:bg-refined-gold group-hover:border-refined-gold group-hover:text-primary transition-all">
                            <span class="material-symbols-outlined text-[16px] text-white">arrow_forward</span>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </section>

    <!-- About Section ("Quienes somos") -->
    <section class="py-24 bg-surface-container-lowest overflow-hidden">
        <div class="px-margin-desktop max-w-container-max mx-auto flex flex-col lg:flex-row items-center gap-20">
            <!-- Team Image Container with Custom Interaction -->
