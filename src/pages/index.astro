<script>
  // Carousel logic with Autoplay (Boutique Auto-play feature)
  const container = document.getElementById('property-carousel-container');
  const prevBtn = document.getElementById('carousel-prev');
  const nextBtn = document.getElementById('carousel-next');

  if (container) {
    const getCardWidth = () => container.querySelector('.property-card')?.clientWidth || 380;
    const gap = 32;

    const scrollNext = () => {
      const cardWidth = getCardWidth();
      const maxScroll = container.scrollWidth - container.clientWidth;
      if (container.scrollLeft >= maxScroll - 10) {
        container.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        container.scrollBy({ left: cardWidth + gap, behavior: 'smooth' });
      }
    };

    const scrollPrev = () => {
      const cardWidth = getCardWidth();
      if (container.scrollLeft <= 10) {
        container.scrollTo({ left: container.scrollWidth, behavior: 'smooth' });
      } else {
        container.scrollBy({ left: -(cardWidth + gap), behavior: 'smooth' });
      }
    };

    prevBtn?.addEventListener('click', () => {
      scrollPrev();
      resetInterval();
    });

    nextBtn?.addEventListener('click', () => {
      scrollNext();
      resetInterval();
    });

    // Auto-play interval (every 4.5 seconds for elegant smooth speed)
    let intervalId = setInterval(scrollNext, 4500);

    function resetInterval() {
      clearInterval(intervalId);
      intervalId = setInterval(scrollNext, 4500);
    }

    // Pause autoplay on mouse enter / resume on mouse leave
    container.addEventListener('mouseenter', () => clearInterval(intervalId));
    container.addEventListener('mouseleave', () => {
      clearInterval(intervalId);
      intervalId = setInterval(scrollNext, 4500);
    });

    // Touch support for mobile touch pause and resume
    container.addEventListener('touchstart', () => clearInterval(intervalId), { passive: true });
    container.addEventListener('touchend', () => {
      clearInterval(intervalId);
      intervalId = setInterval(scrollNext, 4500);
    }, { passive: true });
  }

  // Hero Search Widget Tabs logic
  const tabBtns = document.querySelectorAll('.tab-btn');
  const opInput = document.getElementById('search-operation-id') as HTMLInputElement | null;
  const searchForm = document.getElementById('hero-search-form') as HTMLFormElement | null;
  const propTypeSelect = document.getElementById('search-prop-type') as HTMLSelectElement | null;
  const segmentPropType = document.getElementById('segment-prop-type');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      // Toggle active states
      tabBtns.forEach(b => {
        b.classList.remove('bg-pure-white', 'text-primary', 'border-outline-variant/30');
        b.classList.add('bg-black/45', 'text-pure-white', 'hover:bg-black/60', 'border-transparent');
      });
      btn.classList.add('bg-pure-white', 'text-primary', 'border-outline-variant/30');
      btn.classList.remove('bg-black/45', 'text-pure-white', 'hover:bg-black/60', 'border-transparent');
      
      const value = btn.getAttribute('data-value');
      if (value === 'emprendimientos') {
        if (opInput) opInput.disabled = true;
        if (searchForm) searchForm.action = '/emprendimientos/';
        if (propTypeSelect) propTypeSelect.disabled = true;
        if (segmentPropType) segmentPropType.classList.add('opacity-40', 'pointer-events-none');
      } else {
        if (opInput) {
          opInput.disabled = false;
          opInput.value = value || '1';
        }
        if (searchForm) searchForm.action = '/buscar/';
        if (propTypeSelect) propTypeSelect.disabled = false;
        if (segmentPropType) segmentPropType.classList.remove('opacity-40', 'pointer-events-none');
      }
    });
  });

  // Advanced Filters toggle
  const toggleBtn = document.getElementById('btn-toggle-filters');
  const resetBtn = document.getElementById('btn-reset-filters');
  const panel = document.getElementById('advanced-filters-panel');

  if (toggleBtn && panel) {
    toggleBtn.addEventListener('click', () => {
      if (panel.style.maxHeight && panel.style.maxHeight !== '0px') {
        panel.style.maxHeight = '0px';
      } else {
        panel.style.maxHeight = panel.scrollHeight + 'px';
      }
    });
  }

  // Reset inputs functionality
  if (resetBtn && panel) {
    const inputs = panel.querySelectorAll('input, select');
    const checkInputs = () => {
      let active = false;
      inputs.forEach((input: any) => {
        if (input.value) active = true;
      });
      if (active) {
        resetBtn.classList.remove('hidden');
      } else {
        resetBtn.classList.add('hidden');
      }
    };

    inputs.forEach((input: any) => {
      input.addEventListener('input', checkInputs);
      input.addEventListener('change', checkInputs);
    });

    resetBtn.addEventListener('click', () => {
      inputs.forEach((input: any) => {
        input.value = '';
      });
      resetBtn.classList.add('hidden');
      // Adjust panel height if open
      if (panel.style.maxHeight && panel.style.maxHeight !== '0px') {
        panel.style.maxHeight = panel.scrollHeight + 'px';
      }
    });
  }

  // Price min/max swap validation on form submit
  const priceMinInput = document.getElementById('filter-price-min') as HTMLInputElement | null;
  const priceMaxInput = document.getElementById('filter-price-max') as HTMLInputElement | null;
  if (searchForm && priceMinInput && priceMaxInput) {
    searchForm.addEventListener('submit', () => {
      const minVal = parseFloat(priceMinInput.value);
      const maxVal = parseFloat(priceMaxInput.value);
      if (!isNaN(minVal) && !isNaN(maxVal) && minVal > maxVal) {
        priceMinInput.value = maxVal.toString();
        priceMaxInput.value = minVal.toString();
      }
    });
  }

  // Newsletter form inline feedback
  const newsletterForm = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const newsletterFeedback = document.getElementById('newsletter-feedback');
  if (newsletterForm && newsletterFeedback) {
    newsletterForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const emailInput = document.getElementById('newsletter-email') as HTMLInputElement | null;
      if (!emailInput || !emailInput.value) return;
      
      newsletterFeedback.textContent = '¡Gracias por suscribirte! Recibirás nuestras novedades pronto.';
      newsletterFeedback.className = 'text-xs transition-all duration-300 opacity-100 max-h-12 mt-2 text-refined-gold font-medium';
      
      emailInput.value = '';
      
      setTimeout(() => {
        newsletterFeedback.className = 'text-xs transition-all duration-300 opacity-0 max-h-0 overflow-hidden text-center';
      }, 5000);
    });
  }
</script>
