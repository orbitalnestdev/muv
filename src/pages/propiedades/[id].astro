---
import MainLayout from '../../layouts/MainLayout.astro';
import Gallery from '../../components/Gallery.astro';
import LeadForm from '../../components/LeadForm.astro';
import PropertyCard from '../../components/PropertyCard.astro';
import { getPropertyById, getProperties } from '../../lib/tokko';

const { id } = Astro.params;

// Fetch property data at request-time (SSR)
const property = await getPropertyById(Number(id));

// Handle missing property state
if (!property) {
  return Astro.redirect('/buscar');
}

const {
  publication_title,
  address,
  description,
  bathroom_amount,
  room_amount,
  suite_amount, // bedrooms
  total_surface,
  covered_surface,
  surface,
  parking_lot_amount,
  is_starred_on_web,
  operations,
  location,
  photos = [],
  tags = [],
  expenses,
  toilet_amount,
  age,
  orientation
} = property;

// Format Price
const op = operations?.[0];
const price = op?.prices?.[0];
const priceText = price 
  ? `${price.currency} ${new Intl.NumberFormat('es-AR', { maximumFractionDigits: 0 }).format(price.price)}` 
  : 'Consultar';

// Format Expensas Text (mockup layout: "+ USD 45.000 Expensas")
const expensesText = expenses && Number(expenses) > 0 
  ? `+ USD ${new Intl.NumberFormat('es-AR', { maximumFractionDigits: 0 }).format(expenses)} Expensas` 
  : '';

// Format Badges
let badgeText = 'VENTA';
let badgeClass = 'bg-[#C5A880]';

if (is_starred_on_web) {
  badgeText = 'DESTACADO';
  badgeClass = 'bg-[#C5A059]';
} else if (op) {
  const opType = op.operation_type.toUpperCase();
  if (opType.includes('ALQ') || opType.includes('RENT')) {
    badgeText = 'ALQUILER';
    badgeClass = 'bg-black';
  } else if (opType.includes('TEMP')) {
    badgeText = 'TEMPORARIO';
    badgeClass = 'bg-black';
  }
}

// Format Specs
const beds = suite_amount || 0;
const baths = (bathroom_amount || 0) + (toilet_amount || 0);
const rooms = room_amount || 0;
const garage = parking_lot_amount || 0;
const totalSurface = total_surface || covered_surface || surface || '0';

const photosList = photos.length > 0 ? photos.map(p => p.image) : [];

// Categorize tags/amenities into Services and Amenities lists
const serviceKeywords = ['agua', 'luz', 'gas', 'cloaca', 'internet', 'electricidad', 'pavimento', 'desague', 'telefono', 'cable', 'corriente', 'servicio'];
const serviciosTags = tags.filter(tag => 
  serviceKeywords.some(keyword => tag.name.toLowerCase().includes(keyword))
);
const amenitiesTags = tags.filter(tag => 
  !serviceKeywords.some(keyword => tag.name.toLowerCase().includes(keyword))
);

// Fallbacks if lists are empty (mockup list content matching screenshot)
const defaultServices = [
  { name: 'Agua Corriente' },
  { name: 'Cloaca' },
  { name: 'Gas Natural' },
  { name: 'Internet' },
  { name: 'Electricidad' },
  { name: 'Pavimento' }
];
const defaultAmenities = [
  { name: 'Piscina' },
  { name: 'Gimnasio' },
  { name: 'SUM' },
  { name: 'Parrilla' },
  { name: 'Seguridad 24hs' },
  { name: 'Solarium' }
];

// Fetch 3 similar properties for the bottom section
const { properties: allProps } = await getProperties();
const similarProperties = allProps
  .filter(p => p.id !== Number(id))
  .slice(0, 3);

// JSON-LD structured data for Real Estate Listings SEO
const schemaJsonLd = {
  "@context": "https://schema.org",
  "@type": "RealEstateListing",
  "name": publication_title,
  "description": description,
  "datePosted": new Date().toISOString(),
  "offers": {
    "@type": "Offer",
    "price": price?.price || "0",
    "priceCurrency": price?.currency || "USD",
    "availability": "https://schema.org/InStock"
  },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": address,
    "addressLocality": location?.name || "Buenos Aires",
    "addressCountry": "AR"
  }
};
---

<MainLayout 
  title={`${publication_title} | MUV Propiedades`} 
  description={`${publication_title} - ${priceText}. ${description.substring(0, 150)}...`}
  isDarkHero={false}
>
    <!-- Inject Schema JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaJsonLd)} slot="head" />

    <main class="pt-24 min-h-[70vh] bg-surface select-none">
        
        <!-- Breadcrumbs (Matches mockup style exactly) -->
        <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-6">
            <nav class="flex items-center space-x-2 text-label-sm font-label-sm text-secondary text-left select-none font-sans">
                <a class="hover:text-primary transition-colors font-semibold" href="/">Inicio</a>
                <span class="text-secondary/60 text-xs font-bold font-sans">&gt;</span>
                <a class="hover:text-primary transition-colors font-semibold" href="/buscar">Residenciales</a>
                <span class="text-secondary/60 text-xs font-bold font-sans">&gt;</span>
                <span class="text-on-surface truncate font-semibold">{address || publication_title}</span>
            </nav>
        </div>

        <!-- High-Quality Image Gallery Grid (Mockup 3-photo grid inside Gallery component) -->
        <section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-12 select-none">
            <Gallery photos={photosList} title={publication_title} />
        </section>

        <!-- Content Grid Details -->
        <section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop grid grid-cols-1 lg:grid-cols-12 gap-gutter pb-24 text-left">
            
            <!-- Left Main Column details -->
            <div class="lg:col-span-8 space-y-10">
                
                <!-- Title Header info -->
                <div class="space-y-3 font-sans">
                    <div class="flex flex-wrap items-center gap-2 select-none">
                        <span class="bg-[#C5A059]/10 text-[#C5A059] border border-[#C5A059]/20 px-3 py-1 text-[9px] font-bold tracking-widest uppercase rounded-sm">
                            NUEVO INGRESO
                        </span>
                        <span class="bg-[#F3F4F5] text-[#545F72] px-3 py-1 text-[9px] font-bold tracking-widest uppercase rounded-sm border border-outline-variant/10">
                            {badgeText}
                        </span>
                    </div>
                    
                    <h1 class="font-headline text-2xl md:text-3xl text-primary font-bold leading-tight tracking-tight">
                        {publication_title}
                    </h1>
                    
                    <p class="text-secondary flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider">
                        <span class="material-symbols-outlined text-refined-gold text-[16px]">location_on</span>
                        <span>{address} {location?.name ? `, ${location.name}` : ''}</span>
                    </p>
                    
                    <div class="flex items-baseline gap-3 pt-2">
                        <span class="font-headline text-2xl font-bold text-primary">{priceText}</span>
                        {expensesText && (
                            <span class="text-xs font-semibold text-secondary/80 tracking-wide font-sans">{expensesText}</span>
                        )}
                    </div>
                </div>

                <!-- Specs Row Grid (Outlined custom SVGs matching reference exactly) -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-y-8 gap-x-4 py-8 border-y border-outline-variant/35 text-center select-none font-sans">
                    <!-- Item 1: Sup. Total -->
                    <div class="flex flex-col items-center">
                        <svg class="w-6 h-6 text-refined-gold mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M5 5v14h14z" />
                          <path d="M8 8v8h8z" />
                          <path d="M8 19v-1M11 19v-1M14 19v-1M17 19v-1" />
                        </svg>
                        <span class="text-secondary font-bold text-[9px] uppercase tracking-widest">Sup. Total</span>
                        <span class="text-sm font-semibold text-primary mt-1">{totalSurface} m²</span>
                    </div>

                    <!-- Item 2: Sup. Cubierta -->
                    <div class="flex flex-col items-center">
                        <svg class="w-6 h-6 text-refined-gold mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M5 5v14h14z" />
                          <path d="M8 8v8h8z" />
                          <path d="M8 19v-1M11 19v-1M14 19v-1M17 19v-1" />
                        </svg>
                        <span class="text-secondary font-bold text-[9px] uppercase tracking-widest">Sup. Cubierta</span>
                        <span class="text-sm font-semibold text-primary mt-1">{covered_surface || totalSurface} m²</span>
                    </div>

                    <!-- Item 3: Dormitorios -->
                    <div class="flex flex-col items-center">
                        <svg class="w-6 h-6 text-refined-gold mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M3 18v-6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v6" />
                          <path d="M3 10V6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v4" />
                          <path d="M12 4v6" />
                          <path d="M5 14h14" />
                        </svg>
                        <span class="text-secondary font-bold text-[9px] uppercase tracking-widest">Dormitorios</span>
                        <span class="text-sm font-semibold text-primary mt-1">{beds || 0}</span>
                    </div>

                    <!-- Item 4: Baños -->
                    <div class="flex flex-col items-center">
                        <svg class="w-6 h-6 text-refined-gold mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M4 20v-9a4 4 0 0 1 4-4h7" />
                          <path d="M14 7h3l1 3H13z" fill="currentColor" fill-opacity="0.15" />
                          <path d="M14 12v2M15.5 12v3M17 12v2" />
                        </svg>
                        <span class="text-secondary font-bold text-[9px] uppercase tracking-widest">Baños</span>
                        <span class="text-sm font-semibold text-primary mt-1">{baths || 0}</span>
                    </div>

                    <!-- Item 5: Cocheras -->
                    <div class="flex flex-col items-center">
                        <svg class="w-6 h-6 text-refined-gold mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M6 14 L8 9h8l2 5" />
                          <rect x="4" y="14" width="16" height="5" rx="1" />
                          <circle cx="7" cy="16.5" r="0.75" fill="currentColor" />
                          <circle cx="17" cy="16.5" r="0.75" fill="currentColor" />
                          <path d="M6 19v2M18 19v2" />
                        </svg>
                        <span class="text-secondary font-bold text-[9px] uppercase tracking-widest">Cocheras</span>
                        <span class="text-sm font-semibold text-primary mt-1">{garage || 0}</span>
                    </div>

                    <!-- Item 7: Antigüedad -->
                    <div class="flex flex-col items-center">
                        <svg class="w-6 h-6 text-refined-gold mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="12" cy="12" r="9" />
                          <path d="M12 7v5l3 2" />
                        </svg>
                        <span class="text-secondary font-bold text-[9px] uppercase tracking-widest">Antigüedad</span>
                        <span class="text-sm font-semibold text-primary mt-1">{age && Number(age) > 0 ? `${age} años` : 'A estrenar'}</span>
                    </div>

                    <!-- Item 8: Orientación -->
                    <div class="flex flex-col items-center">
                        <svg class="w-6 h-6 text-refined-gold mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="12" cy="12" r="9" />
                          <path d="M16.2 7.8L13.4 13.4L7.8 16.2L10.6 10.6z" />
                          <circle cx="12" cy="12" r="1" fill="currentColor" />
                        </svg>
                        <span class="text-secondary font-bold text-[9px] uppercase tracking-widest">Orientación</span>
                        <span class="text-sm font-semibold text-primary mt-1">{orientation || 'Norte'}</span>
                    </div>
                </div>

                <!-- Property Description -->
                <div class="space-y-4 font-sans text-left">
                    <h3 class="font-headline text-[18px] font-bold text-primary uppercase tracking-widest border-b border-outline-variant/10 pb-3">Descripción</h3>
                    <p class="font-body text-sm text-[#545F72] leading-relaxed whitespace-pre-line">
                        {description}
                    </p>
                </div>

                <!-- Characteristics & Amenities Grid -->
                <div class="space-y-6 pt-4 font-sans text-left">
                    <h3 class="font-headline text-[18px] font-bold text-primary uppercase tracking-widest border-b border-outline-variant/10 pb-3">Características & Amenities</h3>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">
                        <!-- Servicios -->
                        <div class="space-y-4">
                            <h4 class="text-[#747878] font-bold text-[10px] uppercase tracking-widest">Servicios</h4>
                            <div class="grid grid-cols-1 gap-2.5">
                                {(serviciosTags.length > 0 ? serviciosTags : defaultServices).map((s) => (
                                    <div class="flex items-center gap-2 text-secondary text-sm font-semibold">
                                        <span class="text-refined-gold font-bold">✓</span>
                                        <span>{s.name}</span>
                                    </div>
                                ))}
                            </div>
                        </div>

                        <!-- Amenities -->
                        <div class="space-y-4">
                            <h4 class="text-[#747878] font-bold text-[10px] uppercase tracking-widest">Amenities</h4>
                            <div class="grid grid-cols-1 gap-2.5">
                                {(amenitiesTags.length > 0 ? amenitiesTags : defaultAmenities).map((a) => (
                                    <div class="flex items-center gap-2 text-secondary text-sm font-semibold">
                                        <span class="text-refined-gold font-bold">✓</span>
                                        <span>{a.name}</span>
                                    </div>
                                ))}
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Ubicación Map section -->
                <div class="space-y-6 pt-4 font-sans text-left select-none">
                    <h3 class="font-headline text-[18px] font-bold text-primary uppercase tracking-widest border-b border-outline-variant/10 pb-3">Ubicación</h3>
                    
                    <div class="relative w-full h-[320px] rounded-lg overflow-hidden border border-outline-variant/35 bg-surface-container shadow-sm flex items-center justify-center">
                        <iframe 
                          class="w-full h-full border-0 brightness-[0.98] contrast-[1.02]" 
                          src={`https://maps.google.com/maps?q=${encodeURIComponent(address || location?.name || 'Buenos Aires')}&t=&z=14&ie=UTF8&iwloc=&output=embed`} 
                          loading="lazy" 
                          allowfullscreen
                        ></iframe>
                        <!-- Address float label -->
                        <div class="absolute bottom-4 left-4 bg-pure-white px-4 py-2 border border-outline-variant/40 rounded shadow-md text-xs font-semibold text-primary uppercase tracking-wider font-sans">
                            {address || location?.name || 'Buenos Aires, Argentina'}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sticky Right Inquiry Column -->
            <div class="lg:col-span-4 lg:sticky lg:top-28 pt-8 lg:pt-0">
                <LeadForm propertyId={Number(id)} propertyTitle={publication_title} />
            </div>
        </section>

        <!-- Similar Properties Section matching mockup -->
        {similarProperties.length > 0 && (
            <section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-20 border-t border-outline-variant/10 select-none">
                <div class="flex justify-between items-end mb-10">
                    <div class="text-left space-y-1.5 font-sans">
                        <span class="text-refined-gold font-bold text-[9px] uppercase tracking-widest">Descubrí Más</span>
                        <h2 class="font-headline text-[24px] font-bold text-primary">Propiedades Similares</h2>
                    </div>
                    <a href="/buscar" class="text-xs font-bold font-sans text-secondary hover:text-primary transition-colors flex items-center gap-1.5 uppercase tracking-widest">
                        <span>Ver todas</span>
                        <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                    </a>
                </div>

                <!-- 3 card grid -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    {similarProperties.map((prop) => (
                        <PropertyCard property={prop} />
                    ))}
                </div>
            </section>
        )}
    </main>
</MainLayout>
