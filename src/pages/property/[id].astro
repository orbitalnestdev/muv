---
import MainLayout from '../../layouts/MainLayout.astro';
import Gallery from '../../components/Gallery.astro';
import LeadForm from '../../components/LeadForm.astro';
import PropertyCard from '../../components/PropertyCard.astro';
import { getPropertyById, getProperties } from '../../lib/tokko';

const { id } = Astro.params;

// Fetch property data at request-time (SSR)
const property = await getPropertyById(Number(id));

// Handle missing property state
if (!property) {
  return Astro.redirect('/search-results/');
}

const {
  publication_title,
  address,
  description,
  bathroom_amount,
  room_amount,
  suite_amount, // bedrooms
  total_surface,
  covered_surface,
  surface,
  parking_lot_amount,
  is_starred_on_web,
  operations,
  location,
  photos = [],
  tags = [],
  expenses,
  toilet_amount,
  age,
  orientation,
  expenses_currency,
  transaction_requirements,
  geo_lat,
  geo_long,
  development
} = property;

const tagTranslations: Record<string, string> = {
  // Services
  'water': 'Agua Corriente',
  'sewer': 'Cloaca',
  'gas': 'Gas Natural',
  'electricity': 'Electricidad',
  'internet': 'Internet',
  'cable tv': 'Cable',
  'phone line': 'Línea Telefónica',
  'pavement': 'Pavimento',
  'security': 'Seguridad',
  'security 24hs': 'Seguridad 24hs',
  '24 hour security': 'Seguridad 24hs',
  'access control': 'Control de Acceso',
  
  // Amenities / Spaces / Characteristics
  'pool': 'Piscina',
  'swimming pool': 'Piscina',
  'outdoor swiming pool': 'Piscina',
  'gym': 'Gimnasio',
  'gymnasium': 'Gimnasio',
  'barbecue': 'Parrilla',
  'grill': 'Parrilla',
  'barbecue area': 'Parrilla',
  'communal bbq area': 'Parrilla',
  'individual grill in the apartment': 'Parrilla Individual',
  'quincho': 'Quincho',
  'sum': 'SUM',
  'balcony': 'Balcón',
  'professional use': 'Apto Profesional',
  'apto profesional': 'Apto Profesional',
  'work able': 'Apto Profesional',
  'solarium': 'Solarium',
  'solarium area': 'Solarium',
  'laundry': 'Laundry',
  'laundry room': 'Laundry',
  'playground': 'Juegos Infantiles',
  'green space': 'Espacio Verde',
  'green areas': 'Áreas Verdes',
  'terrace': 'Terraza',
  'parking': 'Cochera',
  'garage': 'Cochera',
  'cocheras': 'Cocheras',
  'air conditioning': 'Aire Acondicionado',
  'air conditioner': 'Aire Acondicionado',
  'individual air conditioner': 'Aire Acondicionado',
  'heating': 'Calefacción',
  'central heating': 'Calefacción Central',
  'elevator': 'Ascensor',
  'sauna': 'Sauna',
  'jacuzzi': 'Jacuzzi',
  'spa': 'Spa',
  'storage': 'Baulera',
  'locker room': 'Vestuario',
  'disabled access': 'Acceso Discapacitados',
  'kitchen': 'Cocina',
  'cocina': 'Cocina',
  'office': 'Oficina',
  'basement': 'Sótano',
  'toilet': 'Toilette',
  'toilette': 'Toilette',
  'playroom': 'Playroom',
  'play room': 'Playroom',
  'game room': 'Sala de Juegos',
  'living room': 'Living',
  'dining room': 'Comedor',
  'suite': 'Dormitorio en Suite',
  'dressing room': 'Vestidor',
  'desk': 'Escritorio',
  'patio': 'Patio',
  'garden': 'Jardín',
  'yard': 'Patio/Jardín',
  'attic': 'Altillo',
  'service quarters': 'Dependencia de Servicio',
  'hall': 'Hall',
  'gallery': 'Galería',
  'backyard': 'Jardín Trasero',
  'view': 'Vista',
  'river view': 'Vista al Río',
  'luminous': 'Luminoso',
  'category': 'Categoría',
  'pets allowed': 'Acepta Mascotas',
  'professional use / commercial': 'Apto Profesional / Comercial'
};

const translateTag = (name: string): string => {
  if (!name) return '';
  const key = name.trim().toLowerCase();
  return tagTranslations[key] || name;
};

// Check if coordinates exist and are valid (not '0' or empty)
const hasCoords = geo_lat && geo_long && String(geo_lat).trim() !== '0' && String(geo_long).trim() !== '0' && String(geo_lat).trim() !== '' && String(geo_long).trim() !== '';

// Google Maps API Key for official Street View Embed
const googleMapsApiKey = import.meta.env.GOOGLE_MAPS_API_KEY || '';


// Format Price
const op = operations?.[0];
const price = op?.prices?.[0];
const priceText = price 
  ? `${price.currency} ${new Intl.NumberFormat('es-AR', { maximumFractionDigits: 0 }).format(price.price)}` 
  : 'Consultar';

// Format Expensas Text
const expCurrency = expenses_currency || 'ARS';
const expensesText = expenses && Number(expenses) > 0 
  ? `+ ${expCurrency === 'ARS' ? '$' : expCurrency} ${new Intl.NumberFormat('es-AR', { maximumFractionDigits: 0 }).format(expenses)} Expensas` 
  : '';

// Format Badges
let badgeText = 'VENTA';
let badgeClass = 'bg-[#C5A880]';

if (is_starred_on_web) {
  badgeText = 'DESTACADO';
  badgeClass = 'bg-[#C5A059]';
} else if (op) {
  const opType = op.operation_type.toUpperCase();
  if (opType.includes('ALQ') || opType.includes('RENT')) {
    badgeText = 'ALQUILER';
    badgeClass = 'bg-black';
  } else if (opType.includes('TEMP')) {
    badgeText = 'TEMPORARIO';
    badgeClass = 'bg-black';
  }
}

// Format Specs
const beds = suite_amount || 0;
const baths = (bathroom_amount || 0) + (toilet_amount || 0);
const rooms = room_amount || 0;
const garage = parking_lot_amount || 0;
const totalSurface = total_surface || covered_surface || surface || '0';

const photosList = photos.length > 0 ? photos.map(p => p.image) : [];

// Categorize tags/amenities into Services, Spaces (Ambientes), and Amenities lists
const serviceKeywords = ['agua', 'luz', 'gas', 'cloaca', 'internet', 'electricidad', 'pavimento', 'desague', 'telefono', 'cable', 'corriente', 'servicio', 'wifi', 'teléfono'];
const ambienteKeywords = [
  'cocina', 'oficina', 'sótano', 'toilette', 'balcón', 'balcon', 'comedor', 'dormitorio', 'suite', 'lavadero', 'laundry', 'terraza', 'vestidor', 'living', 'playroom', 'dependencia', 'hall', 'galería', 'galeria', 'escritorio', 'patio', 'jardín', 'jardin', 'altillo', 'sotano', 'baño', 'baños', 'toilette', 'kitchen', 'basement', 'yard'
];

const serviciosTags = tags.filter(tag => 
  tag.type === 1 || serviceKeywords.some(keyword => tag.name.toLowerCase().includes(keyword))
);

// Prevent duplicate counting
const remainingTags = tags.filter(tag => !serviciosTags.some(s => s.name === tag.name));

const ambientesTags = remainingTags.filter(tag =>
  tag.type === 2 || ambienteKeywords.some(keyword => tag.name.toLowerCase().includes(keyword))
);

const amenitiesTags = remainingTags.filter(tag => 
  !ambientesTags.some(a => a.name === tag.name)
);

// Fallbacks if lists are empty (mockup list content matching screenshot)
const defaultServices = [
  { name: 'Agua Corriente' },
  { name: 'Cloaca' },
  { name: 'Gas Natural' },
  { name: 'Internet' },
  { name: 'Electricidad' },
  { name: 'Pavimento' }
];
const defaultAmbientes = [
  { name: 'Cocina' },
  { name: 'Living' },
  { name: 'Comedor' },
  { name: 'Balcón' },
  { name: 'Toilette' }
];
const defaultAmenities = [
  { name: 'Piscina' },
  { name: 'Gimnasio' },
  { name: 'SUM' },
  { name: 'Parrilla' },
  { name: 'Seguridad 24hs' },
  { name: 'Solarium' }
];

const finalServicios = tags.length > 0 ? serviciosTags : defaultServices;
const finalAmbientes = tags.length > 0 ? ambientesTags : defaultAmbientes;
const finalAmenities = tags.length > 0 ? amenitiesTags : defaultAmenities;

// Fetch 2 similar properties for the bottom section (matches mockup 2 cards layout)
const { properties: allProps } = await getProperties();
const similarProperties = allProps
  .filter(p => p.id !== Number(id))
  .slice(0, 2);

// JSON-LD structured data for Real Estate Listings SEO
const schemaJsonLd = {
  "@context": "https://schema.org",
  "@type": "RealEstateListing",
  "name": publication_title,
  "description": description,
  "datePosted": new Date().toISOString(),
  "offers": {
    "@type": "Offer",
    "price": price?.price || "0",
    "priceCurrency": price?.currency || "USD",
    "availability": "https://schema.org/InStock"
  },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": address,
    "addressLocality": location?.name || "Buenos Aires",
    "addressCountry": "AR"
  }
};

// Helper function to format surface
function formatSurface(value: string | number | null | undefined): string {
  if (!value) return '-';
  const num = typeof value === 'string' ? parseFloat(value) : value;
  if (isNaN(num) || num <= 0) return '-';
  return `${Math.round(num)} m²`;
}

// Helper function to check if value exists and is valid
function hasVal(val: any): boolean {
  if (val === null || val === undefined) return false;
  const str = String(val).trim().toLowerCase();
  return (
    str !== '' && 
    str !== '-' && 
    str !== '---' && 
    str !== 'no especificado' && 
    str !== 'consultar' && 
    str !== 'no' && 
    str !== '0'
  );
}

// Compute technical specs details
const hasAC = tags.some(t => t.name.toLowerCase().includes('aire') || t.name.toLowerCase().includes('split')) || description.toLowerCase().includes('aire acondicionado') || description.toLowerCase().includes('split') ? 'Sí' : 'No';
const hasAguaCaliente = tags.some(t => t.name.toLowerCase().includes('agua caliente') || t.name.toLowerCase().includes('caldera') || t.name.toLowerCase().includes('termotanque')) || description.toLowerCase().includes('agua caliente') || description.toLowerCase().includes('termotanque') ? 'Sí' : 'No';
const hasBaulera = tags.some(t => t.name.toLowerCase().includes('baulera')) || description.toLowerCase().includes('baulera') ? 'Sí' : 'No';
const isAptoComercial = tags.some(t => t.name.toLowerCase().includes('comercial') || t.name.toLowerCase().includes('apto profesional')) || description.toLowerCase().includes('apto comercial') || description.toLowerCase().includes('apto profesional') ? 'Sí' : 'No';
const isLuminoso = tags.some(t => t.name.toLowerCase().includes('luminoso') || t.name.toLowerCase().includes('vista')) || description.toLowerCase().includes('luminoso') || description.toLowerCase().includes('vista abierta') ? 'Sí' : 'No';
const hasAscensor = tags.some(t => t.name.toLowerCase().includes('ascensor') || t.name.toLowerCase().includes('elevador')) || description.toLowerCase().includes('ascensor') ? 'Sí' : 'No';

const expensesFormatted = expenses && Number(expenses) > 0 
  ? `${expCurrency === 'ARS' ? '$' : expCurrency} ${new Intl.NumberFormat('es-AR', { maximumFractionDigits: 0 }).format(expenses)}` 
  : 'Sin Expensas';
---

<MainLayout 
  title={`${publication_title} | MUV Propiedades`} 
  description={`${publication_title} - ${priceText}. ${description.substring(0, 150)}...`}
  isDarkHero={false}
>
    <!-- Inject Schema JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaJsonLd)} slot="head" />

    <main class="pt-24 min-h-[70vh] bg-surface select-none pb-24">
        
        <!-- Breadcrumbs & Share/Fav Bar -->
        <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
            <div class="flex justify-between items-center py-3 border-b border-outline-variant/15 mb-4">
                <nav class="flex items-center text-[12px] text-secondary text-left font-sans font-[300] tracking-wide select-none">
                    <a href="javascript:history.back()" class="hover:text-primary transition-colors flex items-center mr-4 border-r border-outline-variant/30 pr-4">
                        <span class="material-symbols-outlined text-[16px] mr-1">chevron_left</span>
                        Volver
                    </a>
                    <a class="hover:text-primary transition-colors flex items-center" href="/">
                        <span class="material-symbols-outlined text-[16px] mr-1">home</span>
                        Home
                    </a>
                    <span class="text-secondary/40 mx-2">&gt;</span>
                    <a class="hover:text-primary transition-colors" href="/search-results/">{property.type?.name || 'Propiedad'}</a>
                    <span class="text-secondary/40 mx-2">&gt;</span>
                    <span class="text-primary truncate max-w-[180px] sm:max-w-[360px] md:max-w-[500px]">{location?.name || address || publication_title}</span>
                </nav>
                <div class="flex gap-2">
                    <button id="btn-share" class="w-10 h-10 border border-outline-variant/35 rounded-full flex items-center justify-center text-primary hover:bg-primary hover:text-pure-white hover:border-primary transition-all duration-300 shadow-sm bg-pure-white cursor-pointer" title="Compartir propiedad">
                        <span class="material-symbols-outlined text-[20px]">share</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Title, Address & Price Header -->
        <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-5">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4 text-left font-sans">
                <div class="space-y-2.5">
                    <h1 class="font-sans font-[400] md:text-[30px] text-2xl text-primary leading-tight tracking-tight">
                        {address || publication_title}
                    </h1>
                    
                    <p class="font-sans font-[300] text-[15px] leading-[25px] text-[#636363] flex items-center gap-1.5">
                        <span class="material-symbols-outlined text-[#636363] text-[16px]">location_on</span>
                        <span>{location?.full_location ? location.full_location.split('|').map(x => x.trim()).reverse().join(' | ') : (location?.name ? `${location.name} | Capital Federal | Argentina` : address)}</span>
                    </p>
                    
                    <div class="flex flex-wrap items-center gap-2 pt-1 select-none font-sans">
                        <span class="bg-[#595959] text-[#e4e8ea] px-3 py-1.5 text-[10px] font-bold tracking-widest uppercase rounded-md shadow-sm">
                            {badgeText}
                        </span>
                        <span class="bg-[#595959] text-[#e4e8ea] px-3 py-1.5 text-[10px] font-bold tracking-widest uppercase rounded-md shadow-sm">
                            DISPONIBLE
                        </span>
                        {is_starred_on_web && (
                            <span class="bg-[#595959] text-[#e4e8ea] px-3 py-1.5 text-[10px] font-bold tracking-widest uppercase rounded-md shadow-sm">
                                DESTACADO
                            </span>
                        )}
                    </div>
                </div>
                
                <div class="text-left md:text-right shrink-0 pt-2 md:pt-0">
                    <span class="font-headline text-3xl md:text-4xl font-bold text-primary block leading-none">{priceText}</span>
                    {expensesText && (
                        <span class="text-xs font-semibold text-secondary/80 tracking-wide font-sans mt-2 block">{expensesText}</span>
                    )}
                </div>
            </div>
        </div>

        <!-- High-Quality Image Gallery Grid (Mockup 3-photo grid inside Gallery component) -->
        <section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-6 select-none">
            <Gallery photos={photosList} title={publication_title} />
        </section>

        <!-- Horizontal Specs Bar (Mockup Style - Flex Wrap Layout to prevent overlap and hide 0 values) -->
        <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-12">
            <div class="bg-pure-white border border-outline-variant/30 rounded-xl shadow-sm flex flex-wrap justify-center items-center gap-x-6 md:gap-x-12 gap-y-4 py-6 px-4 select-none font-sans font-[300]">
                <!-- Item 1: Tipo de Propiedad -->
                <div class="flex flex-col items-center justify-center min-w-[100px]">
                    <span class="material-symbols-outlined text-primary text-[24px] mb-1 select-none pointer-events-none">apartment</span>
                    <span class="text-sm text-primary mt-1 whitespace-nowrap">{property.type?.name || 'Departamento'}</span>
                </div>
                
                <!-- Item 2: Ambientes -->
                {rooms > 0 && (
                  <>
                    <div class="h-8 w-[1px] bg-outline-variant/30 hidden sm:block"></div>
                    <div class="flex flex-col items-center justify-center min-w-[100px]">
                        <span class="material-symbols-outlined text-primary text-[24px] mb-1 select-none pointer-events-none">meeting_room</span>
                        <span class="text-sm text-primary mt-1 whitespace-nowrap">{rooms} {rooms === 1 ? 'ambiente' : 'ambientes'}</span>
                    </div>
                  </>
                )}
                
                <!-- Item 3: Dormitorios -->
                {beds > 0 && (
                  <>
                    <div class="h-8 w-[1px] bg-outline-variant/30 hidden sm:block"></div>
                    <div class="flex flex-col items-center justify-center min-w-[100px]">
                        <span class="material-symbols-outlined text-primary text-[24px] mb-1 select-none pointer-events-none">bed</span>
                        <span class="text-sm text-primary mt-1 whitespace-nowrap">{beds} {beds === 1 ? 'dormitorio' : 'dormitorios'}</span>
                    </div>
                  </>
                )}
                
                <!-- Item 4: Baños -->
                {baths > 0 && (
                  <>
                    <div class="h-8 w-[1px] bg-outline-variant/30 hidden sm:block"></div>
                    <div class="flex flex-col items-center justify-center min-w-[100px]">
                        <span class="material-symbols-outlined text-primary text-[24px] mb-1 select-none pointer-events-none">bathtub</span>
                        <span class="text-sm text-primary mt-1 whitespace-nowrap">{baths} {baths === 1 ? 'baño' : 'baños'}</span>
                    </div>
                  </>
                )}
                
                <!-- Item 5: Superficie Total -->
                {Number(totalSurface) > 0 && (
                  <>
                    <div class="h-8 w-[1px] bg-outline-variant/30 hidden sm:block"></div>
                    <div class="flex flex-col items-center justify-center min-w-[100px]">
                        <span class="material-symbols-outlined text-primary text-[24px] mb-1 select-none pointer-events-none">square_foot</span>
                        <span class="text-sm text-primary mt-1 whitespace-nowrap">{formatSurface(totalSurface)} Sup. Total</span>
                    </div>
                  </>
                )}
            </div>
        </div>

        <!-- Full-Width Stacked Sections -->
        <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop space-y-16">
            
            <!-- Description -->
            <section class="space-y-4 font-sans text-left">
                <h2 class="font-headline text-[20px] font-bold text-primary uppercase tracking-wider border-b border-outline-variant/10 pb-3">Propiedad</h2>
                <p class="font-body text-[15px] text-[#545F72] leading-relaxed whitespace-pre-line">
                    {description}
                </p>
            </section>

            <!-- Ubicación -->
            <section class="space-y-6 font-sans text-left">
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-outline-variant/10 pb-3 gap-3">
                    <h2 class="font-headline text-[20px] font-bold text-primary uppercase tracking-wider">Ubicación</h2>
                    <div class="flex flex-wrap gap-2 w-full sm:w-auto">
                        <a 
                          href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address || location?.name || 'Buenos Aires')}`} 
                          target="_blank" 
                          rel="noopener noreferrer" 
                          class="bg-black text-pure-white hover:bg-neutral-800 transition-colors px-6 py-2.5 rounded-full text-xs font-medium uppercase tracking-widest flex items-center justify-center gap-2 cursor-pointer flex-1 sm:flex-initial"
                        >
                            <span class="material-symbols-outlined text-[16px]">map</span>
                            <span>Abrir en Google Maps</span>
                        </a>
                        {hasCoords && (
                            <a 
                              href={`https://www.google.com/maps/@?api=1&map_action=pano&viewpoint=${geo_lat},${geo_long}`} 
                              target="_blank" 
                              rel="noopener noreferrer" 
                              class="border border-black text-black hover:bg-black hover:text-white transition-colors px-6 py-2.5 rounded-full text-xs font-medium uppercase tracking-widest flex items-center justify-center gap-2 cursor-pointer flex-1 sm:flex-initial"
                            >
                                <span class="material-symbols-outlined text-[16px]">streetview</span>
                                <span>Ver Street View</span>
                            </a>
                        )}
                    </div>
                </div>



                {hasCoords && (
                    <div class="flex gap-2 mt-4 select-none">
                        <button 
                          id="tab-map"
                          class="px-4 py-2 text-xs font-medium uppercase tracking-wider rounded-lg border-2 border-primary bg-primary text-pure-white transition-all duration-300 cursor-pointer shadow-sm active:scale-[0.98]"
                        >
                            Mapa
                        </button>
                        <button 
                          id="tab-streetview"
                          class="px-4 py-2 text-xs font-medium uppercase tracking-wider rounded-lg border border-outline-variant/30 text-secondary bg-pure-white hover:text-primary hover:bg-surface-container transition-all duration-300 cursor-pointer shadow-sm active:scale-[0.98]"
                        >
                            Street View
                        </button>
                    </div>
                )}

                <div class="relative w-full h-[400px] rounded-xl overflow-hidden border border-outline-variant/35 bg-surface-container shadow-sm mt-4">
                    <!-- Mapa View Wrapper -->
                    <div id="map-view" class="w-full h-full transition-all duration-300">
                        <iframe 
                          class="w-full h-full border-0 brightness-[0.98] contrast-[1.02]" 
                          src={`https://maps.google.com/maps?q=${encodeURIComponent(address || location?.name || 'Buenos Aires')}&t=&z=14&ie=UTF8&iwloc=&output=embed`} 
                          loading="lazy" 
                          allowfullscreen
                        ></iframe>
                    </div>

                    <!-- Street View Wrapper -->
                    {hasCoords && (
                        <div id="streetview-view" class="w-full h-full hidden transition-all duration-300">
                            {googleMapsApiKey ? (
                                <iframe 
                                  class="w-full h-full border-0" 
                                  src={`https://www.google.com/maps/embed/v1/streetview?key=${googleMapsApiKey}&location=${geo_lat},${geo_long}`} 
                                  loading="lazy" 
                                  allowfullscreen
                                ></iframe>
                            ) : (
                                <div class="w-full h-full bg-[#1C1B1B] text-pure-white flex flex-col items-center justify-center p-8 text-center select-none">
                                    <span class="material-symbols-outlined text-[48px] text-white/60 mb-4">streetview</span>
                                    <h4 class="font-sans font-semibold text-lg text-[#FFFFFF] mb-2">Vista de calle 360° disponible</h4>
                                    <p class="text-xs text-[#E1E3E4]/80 max-w-sm mb-6 leading-relaxed">
                                        Explora la zona de la propiedad de forma interactiva en Google Maps.
                                    </p>
                                    <a 
                                      href={`https://www.google.com/maps/@?api=1&map_action=pano&viewpoint=${geo_lat},${geo_long}`} 
                                      target="_blank" 
                                      rel="noopener noreferrer" 
                                      class="bg-pure-white text-[#1C1B1B] hover:bg-pure-white/90 font-sans font-medium px-8 py-3.5 rounded-full text-xs uppercase tracking-widest flex items-center gap-2 cursor-pointer shadow-md transition-all active:scale-[0.98]"
                                    >
                                        <span class="material-symbols-outlined text-[16px]">open_in_new</span>
                                        <span>Abrir Street View</span>
                                    </a>
                                </div>
                            )}
                        </div>
                    )}
                </div>
            </section>

            <!-- Información general (Technical specs box - Premium neutral style) -->
            <section class="space-y-8 font-sans text-left">
                <h2 class="font-headline text-[20px] font-bold text-primary uppercase tracking-wider border-b border-outline-variant/10 pb-3">Información general</h2>
                
                
                <!-- Sub-sección: Información general -->
                <div class="bg-[#F8F9FA] border border-[#E5E7EB] rounded-xl p-8 space-y-4">
                    <h3 class="font-sans font-bold text-[#191c1d] text-base border-b border-[#E5E7EB] pb-2">Detalles de la propiedad</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-4 text-sm font-sans font-[300]">
                        <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                            <span class="text-secondary/80">Código de Propiedad</span>
                            <span class="text-primary font-medium">{property.reference_code || property.id || id}</span>
                        </div>
                        {hasVal(room_amount) && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Ambientes</span>
                                <span class="text-primary font-medium">{room_amount}</span>
                            </div>
                        )}
                        {hasVal(beds) && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Dormitorios</span>
                                <span class="text-primary font-medium">{beds}</span>
                            </div>
                        )}
                        {hasVal(property.suite_amount) && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Dormitorios en suite</span>
                                <span class="text-primary font-medium">{property.suite_amount}</span>
                            </div>
                        )}
                        {hasVal(bathroom_amount) && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Baños</span>
                                <span class="text-primary font-medium">{bathroom_amount}</span>
                            </div>
                        )}
                        {hasVal(toilet_amount) && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Toilettes</span>
                                <span class="text-primary font-medium">{toilet_amount}</span>
                            </div>
                        )}
                        {hasVal(garage) && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Cocheras</span>
                                <span class="text-primary font-medium">{garage}</span>
                            </div>
                        )}
                        {hasVal(property.covered_parking_lot) && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Cocheras cubiertas</span>
                                <span class="text-primary font-medium">{property.covered_parking_lot}</span>
                            </div>
                        )}
                        {hasVal(hasAscensor) && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Ascensores</span>
                                <span class="text-primary font-medium">{hasAscensor}</span>
                            </div>
                        )}
                        {hasVal(property.disposition) && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Disposición</span>
                                <span class="text-primary font-medium">{property.disposition}</span>
                            </div>
                        )}
                        {hasVal(orientation) && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Orientación</span>
                                <span class="text-primary font-medium">{orientation}</span>
                            </div>
                        )}
                        {(hasVal(age) || age === 0 || age === '0') && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Antigüedad</span>
                                <span class="text-primary font-medium">{Number(age) > 0 ? `${age} años` : 'A estrenar'}</span>
                            </div>
                        )}
                        {hasVal(property.property_condition) && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Condición</span>
                                <span class="text-primary font-medium">{property.property_condition}</span>
                            </div>
                        )}
                        {hasVal(property.floors_amount) && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Pisos en el edificio</span>
                                <span class="text-primary font-medium">{property.floors_amount}</span>
                            </div>
                        )}
                        {hasVal(property.appartments_per_floor) && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Departamentos por piso</span>
                                <span class="text-primary font-medium">{property.appartments_per_floor}</span>
                            </div>
                        )}
                        {hasVal(hasAC) && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Aire Acondicionado</span>
                                <span class="text-primary font-medium">{hasAC}</span>
                            </div>
                        )}
                        {hasVal(hasAguaCaliente) && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Agua Caliente</span>
                                <span class="text-primary font-medium">{hasAguaCaliente}</span>
                            </div>
                        )}
                        {hasVal(hasBaulera) && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Baulera</span>
                                <span class="text-primary font-medium">{hasBaulera}</span>
                            </div>
                        )}
                        {hasVal(isAptoComercial) && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Apto Profesional / Comercial</span>
                                <span class="text-primary font-medium">{isAptoComercial}</span>
                            </div>
                        )}
                        {hasVal(isLuminoso) && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Luminoso</span>
                                <span class="text-primary font-medium">{isLuminoso}</span>
                            </div>
                        )}
                    </div>
                </div>

                <!-- Sub-sección: Superficies y medidas -->
                <div class="bg-[#F8F9FA] border border-[#E5E7EB] rounded-xl p-8 space-y-4">
                    <h3 class="font-sans font-bold text-[#191c1d] text-base border-b border-[#E5E7EB] pb-2">Superficies y medidas</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-4 text-sm font-sans font-[300]">
                        {hasVal(totalSurface) && Number(totalSurface) > 0 && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Total construido</span>
                                <span class="text-primary font-medium">{formatSurface(totalSurface)}</span>
                            </div>
                        )}
                        {hasVal(covered_surface) && Number(covered_surface) > 0 && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Superficie cubierta</span>
                                <span class="text-primary font-medium">{formatSurface(covered_surface)}</span>
                            </div>
                        )}
                        {hasVal(property.semiroofed_surface) && Number(property.semiroofed_surface) > 0 && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Superficie semicubierta</span>
                                <span class="text-primary font-medium">{formatSurface(property.semiroofed_surface)}</span>
                            </div>
                        )}
                        {hasVal(property.unroofed_surface) && Number(property.unroofed_surface) > 0 && (
                            <div class="flex justify-between border-b border-[#E5E7EB] pb-2">
                                <span class="text-secondary/80">Superficie descubierta</span>
                                <span class="text-primary font-medium">{formatSurface(property.unroofed_surface)}</span>
                            </div>
                        )}
                    </div>
                </div>
            </section>

            <!-- Characteristics & Amenities -->
            <section class="space-y-6 font-sans text-left">
                <h2 class="font-headline text-[20px] font-bold text-primary uppercase tracking-wider border-b border-outline-variant/10 pb-3">Características</h2>
                
                {finalAmbientes.length > 0 && (
                    <div class="space-y-3">
                        <h3 class="font-headline text-[14px] font-bold text-primary uppercase tracking-wider">Ambientes</h3>
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-2">
                            {finalAmbientes.map((t) => (
                                <div class="flex items-center gap-2.5 text-secondary text-[15px] font-[300] py-1">
                                    <svg class="w-[18px] h-[18px] text-secondary/60 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                    <span>{translateTag(t.name)}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                )}

                {finalServicios.length > 0 && (
                    <div class="space-y-3 pt-2">
                        <h3 class="font-headline text-[14px] font-bold text-primary uppercase tracking-wider">Servicios</h3>
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-2">
                            {finalServicios.map((t) => (
                                <div class="flex items-center gap-2.5 text-secondary text-[15px] font-[300] py-1">
                                    <svg class="w-[18px] h-[18px] text-secondary/60 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                    <span>{translateTag(t.name)}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                )}

                {finalAmenities.length > 0 && (
                    <div class="space-y-3 pt-2">
                        <h3 class="font-headline text-[14px] font-bold text-primary uppercase tracking-wider">Adicionales</h3>
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-2">
                            {finalAmenities.map((t) => (
                                <div class="flex items-center gap-2.5 text-secondary text-[15px] font-[300] py-1">
                                    <svg class="w-[18px] h-[18px] text-secondary/60 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                    <span>{translateTag(t.name)}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                )}
            </section>

            <!-- Contact/Inquiry Lead Section (Centered Full-Width style) -->
            <section class="pt-8 border-t border-outline-variant/10 text-left">
                <div class="max-w-2xl mx-auto">
                    <h2 class="font-headline text-[20px] font-bold text-primary uppercase tracking-wider mb-6 text-center">Consultar por esta Propiedad</h2>
                    <LeadForm propertyId={Number(id)} propertyTitle={publication_title} isDevelopment={!!development} />
                </div>
            </section>

            <!-- Similar Properties Section (Mockup 2-column cards layout) -->
            {similarProperties.length > 0 && (
                <section class="py-12 border-t border-outline-variant/10 select-none">
                    <div class="flex justify-between items-end mb-10">
                        <div class="text-left space-y-1.5 font-sans">
                            <span class="text-secondary font-bold text-[9px] uppercase tracking-widest">Descubrí Más</span>
                            <h3 class="font-headline text-[20px] font-bold text-primary uppercase tracking-wider">Propiedades Similares</h3>
                        </div>
                        <a href="/search-results/" class="text-xs font-bold font-sans text-secondary hover:text-primary transition-colors flex items-center gap-1.5 uppercase tracking-widest">
                            <span>Ver todas</span>
                            <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                        </a>
                    </div>

                    <!-- 2 card grid -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        {similarProperties.map((prop) => (
                            <PropertyCard property={prop} />
                        ))}
                    </div>
                </section>
            )}
        </div>

        <!-- WhatsApp Property Meta for Global Button -->
        <div id="whatsapp-page-info" data-title={publication_title} data-id={id} data-is-development={development ? "true" : "false"} class="hidden"></div>
        
        <!-- Floating Inquiry Button -->
        <button 
          id="btn-floating-inquiry" 
          class="fixed bottom-6 right-6 z-50 bg-[#25D366] text-pure-white px-5 py-3 rounded-full shadow-2xl hover:bg-[#20ba5a] hover:scale-105 active:scale-95 transition-all flex items-center gap-2 cursor-pointer border border-white/10 select-none font-sans"
          aria-label="Consultar por WhatsApp"
        >
            <!-- WhatsApp SVG Icon -->
            <svg class="w-5 h-5 fill-current text-pure-white" viewBox="0 0 24 24">
                <path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 001.333 4.982L2 22l5.233-1.371a9.994 9.994 0 004.78 1.218h.004c5.502 0 9.981-4.479 9.982-9.985A9.97 9.97 0 0012.012 2zm5.72 14.158c-.249.704-1.444 1.353-1.996 1.412-.5.053-1.15.084-3.355-.785-2.82-1.11-4.636-3.977-4.777-4.163-.14-.186-1.139-1.517-1.139-2.89 0-1.373.72-2.048 1.002-2.33.282-.282.61-.353.812-.353h.582c.186 0 .436-.07.68.517.25.597.854 2.083.928 2.235.074.152.124.33.023.533-.1.203-.152.33-.3.504-.15.172-.315.386-.45.517-.15.148-.306.31-.132.61.173.3.77 1.27 1.657 2.059.81.71 1.488.93 1.698 1.037.21.107.33.09.454-.052.124-.144.53-.618.67-.83.14-.21.282-.178.477-.107.195.07 1.24.585 1.455.693.215.108.358.162.41.25.05.09.05.518-.2.1.222zm0 0"/>
            </svg>
            <span class="text-xs font-semibold uppercase tracking-wider">Consultar</span>
        </button>

    </main>

    <script is:inline>
      // Micro-interactions for sharing and liking
      const shareBtn = document.getElementById('btn-share');
      if (shareBtn) {
        shareBtn.addEventListener('click', (e) => {
          e.preventDefault();
          navigator.clipboard.writeText(window.location.href);
          alert('¡Enlace de la propiedad copiado al portapapeles!');
        });
      }

      const favBtn = document.getElementById('btn-favorite');
      if (favBtn) {
        const propertyId = favBtn.dataset.id || '';
        const icon = favBtn.querySelector('.material-symbols-outlined');
        const favKey = 'muv_fav_' + propertyId;
        let isSaved = localStorage.getItem(favKey) === 'true';
        
        const updateFavStyle = () => {
          if (icon) {
            if (isSaved) {
              icon.classList.add('filled-icon');
              favBtn.style.color = '#e056fd';
              favBtn.style.borderColor = '#e056fd';
            } else {
              icon.classList.remove('filled-icon');
              favBtn.style.color = '';
              favBtn.style.borderColor = '';
            }
          }
        };
        
        updateFavStyle();
        
        favBtn.addEventListener('click', (e) => {
          e.preventDefault();
          isSaved = !isSaved;
          localStorage.setItem(favKey, isSaved ? 'true' : 'false');
          updateFavStyle();
        });
      }

      // Tab switcher for Map / Street View
      const tabMap = document.getElementById('tab-map');
      const tabStreetView = document.getElementById('tab-streetview');
      const mapView = document.getElementById('map-view');
      const streetViewView = document.getElementById('streetview-view');

      if (tabMap && tabStreetView && mapView && streetViewView) {
        tabMap.addEventListener('click', (e) => {
          e.preventDefault();
          
          // Switch active class to tabMap
          tabMap.classList.remove('border-outline-variant/30', 'text-secondary', 'bg-pure-white', 'hover:bg-surface-container');
          tabMap.classList.add('border-primary', 'bg-primary', 'text-pure-white', 'border-2');
          
          // Switch inactive class to tabStreetView
          tabStreetView.classList.remove('border-primary', 'bg-primary', 'text-pure-white', 'border-2');
          tabStreetView.classList.add('border', 'border-outline-variant/30', 'text-secondary', 'bg-pure-white', 'hover:text-primary', 'hover:bg-surface-container');
          
          // Toggle views
          mapView.classList.remove('hidden');
          mapView.classList.add('animate-fade-in');
          streetViewView.classList.add('hidden');
          streetViewView.classList.remove('animate-fade-in');
        });

        tabStreetView.addEventListener('click', (e) => {
          e.preventDefault();
          
          // Switch active class to tabStreetView
          tabStreetView.classList.remove('border-outline-variant/30', 'text-secondary', 'bg-pure-white', 'hover:bg-surface-container');
          tabStreetView.classList.add('border-primary', 'bg-primary', 'text-pure-white', 'border-2');
          
          // Switch inactive class to tabMap
          tabMap.classList.remove('border-primary', 'bg-primary', 'text-pure-white', 'border-2');
          tabMap.classList.add('border', 'border-outline-variant/30', 'text-secondary', 'bg-pure-white', 'hover:text-primary', 'hover:bg-surface-container');
          
          // Toggle views
          streetViewView.classList.remove('hidden');
          streetViewView.classList.add('animate-fade-in');
          mapView.classList.add('hidden');
          mapView.classList.remove('animate-fade-in');
        });
      }

      // Floating inquiry button click behavior (intelligent WhatsApp dialog trigger)
      const floatBtn = document.getElementById('btn-floating-inquiry');
      if (floatBtn) {
        floatBtn.addEventListener('click', (e) => {
          e.preventDefault();
          const dialog = document.getElementById('whatsapp-dialog');
          const nameInput = document.getElementById('whatsapp-user-name');
          if (dialog) {
            dialog.showModal();
            setTimeout(() => {
              if (nameInput) nameInput.focus();
            }, 100);
          }
        });
      }
    </script>

</MainLayout>

<style is:global>
  .filled-icon {
    font-variation-settings: 'FILL' 1 !important;
  }
  #btn-global-whatsapp {
    display: none !important;
  }
</style>
